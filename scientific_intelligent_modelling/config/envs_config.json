{
  "env_list": {
    "sim_base": {
      "python_version": "3.10",
      "conda_packages": [
        "pip"
      ],
      "pip_packages": [
        "gplearn",
        "pysr",
        "pyoperon"
      ],
      "channels": [
        "conda-forge"
      ],
      "comments": "测试环境，目前可以运行gplearn, pysr, pyoperon",
      "post_install_commands": [
        "pip install -e ."
      ]
    },
    "sim": {
      "python_version": "3.10",
      "conda_packages": [
        "pip",
        "scikit-learn"
      ],
      "pip_packages": [],
      "comments": "这是工具箱的基环境，里面不装任何的依赖包"
    },
    "sim_e2esr": {
      "python_version": "3.7",
      "conda_packages": [
        "pip"
      ],
      "channels": [
        "conda-forge",
        "defaults"
      ],
      "pip_packages": [
        "numpy==1.21.5",
        "scipy==1.7.3",
        "scikit-learn==1.0.2",
        "pandas==1.3.5",
        "sympy==1.10.1",
        "torch==1.11.0",
        "torchaudio==0.11.0",
        "torchvision==0.12.0",
        "functorch==0.1.0",
        "tqdm==4.64.0",
        "pyyaml==6.0",
        "requests==2.27.1"
      ],
      "post_install_commands": [
        "pip install -e .",
        "wget https://dl.fbaipublicfiles.com/symbolicregression/model1.pt -O ./scientific_intelligent_modelling/algorithms/e2esr_wrapper/model.pt"
      ],
      "comments": "e2e-symbolic-regression环境"
    },
    "sim_llm": {
      "python_version": "3.10",
      "conda_packages": [
        "pip",
        "sympy==1.13.1"
      ],
      "post_install_commands": [
        "pip install -e .",
        "pip install -r ./scientific_intelligent_modelling/algorithms/llmsr_wrapper/llmsr/requirements.txt"
      ]
    },
    "sim_dso": {
      "python_version": "3.7",
      "conda_packages": [
        "pip"
      ],
      "channels": [
        "conda-forge"
      ],
      "pip_packages": [
        "numpy==1.19.0",
        "protobuf==3.20.3",
        "tensorflow==1.14.0",
        "tensorflow-estimator==1.14.0",
        "numba==0.53.1",
        "llvmlite==0.36.0",
        "sympy==1.10.1",
        "pandas==1.3.5",
        "scikit-learn==1.0.2",
        "click",
        "deap",
        "pathos",
        "seaborn",
        "progress",
        "commentjson",
        "prettytable",
        "pyyaml",
        "cython"
      ],
      "post_install_commands": [
        "pip install -e ."
      ],
      "comments": "DSO 回归环境；依赖本地源码路径导入，不强制编译 cyfunc 扩展"
    },
    "sim_tpsr": {
      "python_version": "3.9",
      "conda_packages": [
        "pip",
        "pytorch",
        "numpy",
        "scikit-learn",
        "matplotlib",
        "pandas",
        "sympy"
      ],
      "channels": [
        "conda-forge",
        "pytorch"
      ],
      "pip_packages": [
        "timeout-decorator",
        "numexpr",
        "sympytorch",
        "gym==0.26.2",
        "gym-notices==0.0.8",
        "tqdm==4.64.0",
        "click==8.1.8",
        "pytorch-lightning"
      ],
      "comments": "TPSR (Transformer-based Planning for Symbolic Regression)环境",
      "post_install_commands": [
        "pip install -e .",
        "pip install -e ./scientific_intelligent_modelling/algorithms/tpsr_wrapper/tpsr/nesymres/src"
        ,
        "python -c \"from pathlib import Path; import urllib.request; p=Path('scientific_intelligent_modelling/algorithms/e2esr_wrapper/model.pt'); p.parent.mkdir(parents=True, exist_ok=True); p.exists() or urllib.request.urlretrieve('https://dl.fbaipublicfiles.com/symbolicregression/model1.pt', str(p))\""
      ]
    },
    "sim_qLattice": {
      "python_version": "3.10",
      "conda_packages": [
        "pip"
      ],
      "channels": [
        "conda-forge"
      ],
      "pip_packages": [
        "numpy",
        "pandas",
        "scikit-learn",
        "sympy",
        "feyn"
      ],
      "post_install_commands": [
        "pip install -e ."
      ],
      "comments": "Feyn/Qlattice 符号建模环境"
    },
    "sim_iMCTS": {
      "python_version": "3.10",
      "conda_packages": [
        "pip"
      ],
      "channels": [
        "conda-forge"
      ],
      "pip_packages": [
        "numba==0.61.2",
        "numpy==2.2.0",
        "pandas==2.3.0",
        "PyYAML==6.0.1",
        "scikit_learn==1.2.2",
        "nlopt==2.9.1",
        "sortedcontainers==2.4.0",
        "sympy==1.12",
        "tqdm==4.65.0"
      ],
      "post_install_commands": [
        "pip install -e .",
        "pip install -e ./scientific_intelligent_modelling/algorithms/iMCTS_wrapper/MCTS-4-SR"
      ],
      "comments": "iMCTS (MCTS-4-SR) 符号回归环境"
    }
  }
}
