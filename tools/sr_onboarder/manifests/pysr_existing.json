{
  "tool_name": "pysr",
  "display_name": "PySR",
  "wrapper_class_name": "PySRRegressor",
  "integration_mode": "python_api",
  "source_mode": "pip_editable",
  "vendor_repo_relpath": "scientific_intelligent_modelling/algorithms/pysr_wrapper",
  "entrypoint": {
    "module": "pysr",
    "object_name": "PySRRegressor"
  },
  "env": {
    "name": "sim_base",
    "python_version": "3.10",
    "conda_packages": [
      "pip"
    ],
    "pip_packages": [
      "gplearn",
      "pysr",
      "pyoperon"
    ],
    "channels": [
      "conda-forge"
    ],
    "post_install_commands": [
      "pip install -e ."
    ],
    "comments": "测试环境，目前可以运行gplearn, pysr, pyoperon"
  },
  "adapter": {
    "x_shape": "samples_first",
    "supports_predict": true,
    "serialization_mode": "base_pickle",
    "meta_params": [
      "exp_name",
      "exp_path",
      "problem_name",
      "seed"
    ],
    "constructor_param_allowlist": [],
    "fit_param_allowlist": [],
    "equation_notes": "当前 PySR 包装器已自行实现表达式提取，这里主要作为 manifest 结构示例"
  },
  "smoke_test": {
    "problem_name": "ci_pysr",
    "predict_rows": 4,
    "default_params": {
      "niterations": 3,
      "population_size": 50,
      "progress": false,
      "verbosity": 0
    }
  }
}
