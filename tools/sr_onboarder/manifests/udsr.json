{
  "tool_name": "udsr",
  "display_name": "uDSR",
  "wrapper_class_name": "UDSRRegressor",
  "integration_mode": "python_api",
  "source_mode": "vendored",
  "vendor_repo_relpath": "scientific_intelligent_modelling/algorithms/dso_wrapper/dso",
  "entrypoint": {
    "module": "dso",
    "object_name": "DeepSymbolicOptimizer"
  },
  "env": {
    "name": "sim_dso",
    "python_version": "3.7",
    "conda_packages": [
      "pip"
    ],
    "pip_packages": [
      "numpy==1.19.0",
      "protobuf==3.20.3",
      "tensorflow==1.14.0",
      "tensorflow-estimator==1.14.0",
      "numba==0.53.1",
      "llvmlite==0.36.0",
      "sympy==1.10.1",
      "pandas==1.3.5",
      "scikit-learn==1.0.2",
      "click",
      "deap",
      "pathos",
      "seaborn",
      "progress",
      "commentjson",
      "prettytable",
      "pyyaml",
      "cython"
    ],
    "channels": [
      "conda-forge"
    ],
    "post_install_commands": [
      "pip install -e ."
    ],
    "comments": "DSO/uDSR 回归环境；依赖本地源码路径导入，不强制编译 cyfunc 扩展"
  },
  "adapter": {
    "x_shape": "samples_first",
    "supports_predict": true,
    "serialization_mode": "base_pickle",
    "meta_params": [
      "exp_name",
      "exp_path",
      "problem_name",
      "seed",
      "n_features",
      "feature_names",
      "target_name"
    ],
    "constructor_param_allowlist": [],
    "fit_param_allowlist": [],
    "equation_notes": "基于 DSO DeepSymbolicOptimizer；启用 poly token 与 GP-meld，导出 sympy 表达式。"
  },
  "smoke_test": {
    "problem_name": "ci_udsr_check",
    "predict_rows": 4,
    "default_params": {
      "training": {
        "n_samples": 20,
        "batch_size": 1,
        "n_cores_batch": 1
      }
    }
  }
}
