{
  "tool_name": "example_sr",
  "display_name": "ExampleSR",
  "wrapper_class_name": "ExampleSRRegressor",
  "integration_mode": "python_api",
  "source_mode": "submodule",
  "vendor_repo_relpath": "scientific_intelligent_modelling/algorithms/example_sr_wrapper/example_sr",
  "entrypoint": {
    "module": "example_sr.api",
    "object_name": "SymbolicRegressor"
  },
  "env": {
    "name": "sim_example_sr",
    "python_version": "3.10",
    "conda_packages": [
      "pip"
    ],
    "pip_packages": [],
    "channels": [
      "conda-forge"
    ],
    "post_install_commands": [
      "pip install -e ."
    ],
    "comments": "示例环境，请按真实仓库依赖补齐"
  },
  "adapter": {
    "x_shape": "samples_first",
    "supports_predict": true,
    "serialization_mode": "base_pickle",
    "meta_params": [
      "exp_name",
      "exp_path",
      "problem_name",
      "seed"
    ],
    "constructor_param_allowlist": [],
    "fit_param_allowlist": [],
    "equation_notes": "将这里替换为真实的最优方程和候选方程提取逻辑"
  },
  "smoke_test": {
    "problem_name": "ci_example_sr",
    "predict_rows": 4,
    "default_params": {
      "random_state": 0
    }
  }
}
