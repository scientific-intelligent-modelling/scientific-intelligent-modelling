import numpy as np

from scientific_intelligent_modelling.srkit.regressor import SymbolicRegressor


TOOL_NAME = ${tool_name_literal}
PROBLEM_NAME = ${problem_name_literal}
SUPPORTS_PREDICT = ${supports_predict_literal}
PREDICT_ROWS = ${predict_rows_literal}
DEFAULT_PARAMS = ${default_params_literal}


def assert_ok(condition: bool, message: str):
    if not condition:
        raise AssertionError(message)


def build_toy_data():
    rng = np.random.RandomState(7)
    X = rng.rand(32, 2)
    y = 1.75 * X[:, 0] - 0.5 * X[:, 1] + 0.1
    return X, y


def build_regressor():
    return SymbolicRegressor(
        TOOL_NAME,
        problem_name=PROBLEM_NAME,
        **DEFAULT_PARAMS,
    )


def run():
    X, y = build_toy_data()
    reg = build_regressor()
    reg.fit(X, y)

    equation = reg.get_optimal_equation()
    equations = reg.get_total_equations()

    assert_ok(isinstance(equation, str) and len(equation) > 0, f"{TOOL_NAME} 最优方程为空")
    assert_ok(isinstance(equations, list) and len(equations) > 0, f"{TOOL_NAME} 方程列表为空")

    if SUPPORTS_PREDICT:
        pred = reg.predict(X[:PREDICT_ROWS])
        assert_ok(pred.shape == (PREDICT_ROWS,), f"{TOOL_NAME} 预测形状异常: {pred.shape}")

    print(f"[check_{TOOL_NAME}] OK")
    print("equation_head:", equation[:160])
    print("equations:", len(equations))


if __name__ == "__main__":
    run()
