from __future__ import annotations

import json
import importlib
import sys
from pathlib import Path
from typing import Any, Dict, List

import numpy as np

from ..base_wrapper import BaseWrapper


class ${wrapper_class_name}(BaseWrapper):
    """${display_name} 的统一接入脚手架。"""

    _TOOL_NAME = ${tool_name_literal}
    _DISPLAY_NAME = ${display_name_literal}
    _INTEGRATION_MODE = ${integration_mode_literal}
    _SOURCE_MODE = ${source_mode_literal}
    _VENDOR_REPO_RELATIVE = ${vendor_repo_relpath_literal}
    _ENTRY_MODULE = ${entry_module_literal}
    _ENTRY_OBJECT = ${entry_object_literal}
    _X_SHAPE = ${x_shape_literal}
    _SUPPORTS_PREDICT = ${supports_predict_literal}
    _SERIALIZATION_MODE = ${serialization_mode_literal}
    _META_PARAMS = ${meta_params_literal}
    _CONSTRUCTOR_ALLOWLIST = ${constructor_allowlist_literal}
    _FIT_ALLOWLIST = ${fit_allowlist_literal}
    _EQUATION_NOTES = ${equation_notes_literal}

    def __init__(self, **kwargs):
        self.raw_params = dict(kwargs or {})
        self.params = self._normalize_params(self.raw_params)
        self.model = None
        self._best_equation = None
        self._all_equations: List[str] = []

    @classmethod
    def _repo_root(cls) -> Path:
        return Path(__file__).resolve().parents[3]

    @classmethod
    def _vendor_repo_path(cls) -> Path:
        return cls._repo_root() / cls._VENDOR_REPO_RELATIVE

    @classmethod
    def _ensure_vendor_repo_on_path(cls) -> Path:
        vendor_path = cls._vendor_repo_path()
        vendor_path_str = str(vendor_path)
        if vendor_path.exists() and vendor_path_str not in sys.path:
            sys.path.insert(0, vendor_path_str)
        return vendor_path

    @classmethod
    def _normalize_params(cls, raw_params: Dict[str, Any]) -> Dict[str, Any]:
        params = dict(raw_params or {})
        for key in cls._META_PARAMS:
            params.pop(key, None)

        allowlisted = set(cls._CONSTRUCTOR_ALLOWLIST) | set(cls._FIT_ALLOWLIST)
        if allowlisted:
            unknown = sorted(set(params) - allowlisted)
            if unknown:
                allowed_text = ", ".join(sorted(allowlisted))
                raise ValueError(
                    f"{cls._TOOL_NAME} 参数不受支持: {', '.join(unknown)}。"
                    f"当前允许的参数有: {allowed_text}"
                )
        return params

    def _split_params(self) -> tuple[Dict[str, Any], Dict[str, Any]]:
        constructor_params = dict(self.params)
        fit_params: Dict[str, Any] = {}
        for key in list(constructor_params.keys()):
            if key in self._FIT_ALLOWLIST:
                fit_params[key] = constructor_params.pop(key)
        return constructor_params, fit_params

    def _prepare_X(self, X):
        arr = np.asarray(X)
        if arr.ndim != 2:
            raise ValueError(f"{self._TOOL_NAME} 需要二维 X，当前形状为 {arr.shape}")
        if self._X_SHAPE == "features_first":
            return arr.T
        return arr

    def _prepare_y(self, y):
        arr = np.asarray(y).reshape(-1)
        return arr

    def _load_vendor_entry(self):
        if self._INTEGRATION_MODE != "python_api":
            raise NotImplementedError(
                f"{self._TOOL_NAME} 当前 manifest 声明为 CLI 模式，请在生成后补充 CLI 适配逻辑"
            )

        self._ensure_vendor_repo_on_path()
        module = importlib.import_module(self._ENTRY_MODULE)
        return getattr(module, self._ENTRY_OBJECT)

    def _refresh_equations_from_model(self):
        if self.model is None:
            return

        best_candidates = (
            "get_optimal_equation",
            "get_equation",
            "get_model_string",
            "symbolic_model",
            "best_",
            "program_",
        )
        for attr_name in best_candidates:
            if not hasattr(self.model, attr_name):
                continue
            value = getattr(self.model, attr_name)
            try:
                value = value() if callable(value) else value
            except TypeError:
                value = value
            if value is None:
                continue
            text = str(value).strip()
            if text:
                self._best_equation = text
                break

        all_candidates = (
            "get_total_equations",
            "get_all_equations",
            "hall_of_fame_",
            "models_",
        )
        for attr_name in all_candidates:
            if not hasattr(self.model, attr_name):
                continue
            value = getattr(self.model, attr_name)
            try:
                value = value() if callable(value) else value
            except TypeError:
                value = value
            if value is None:
                continue
            if isinstance(value, (list, tuple)):
                self._all_equations = [str(item) for item in value if str(item).strip()]
                break

        if not self._all_equations and self._best_equation:
            self._all_equations = [self._best_equation]

    def fit(self, X, y):
        X_prepared = self._prepare_X(X)
        y_prepared = self._prepare_y(y)
        constructor_params, fit_params = self._split_params()

        if self._INTEGRATION_MODE == "cli":
            raise NotImplementedError(
                f"{self._TOOL_NAME} 的 CLI 适配尚未补完，请在生成的 wrapper.py 中实现命令行桥接"
            )

        entry = self._load_vendor_entry()
        self.model = entry(**constructor_params)

        # 默认按 sklearn 风格适配。若外部仓库签名不同，请在这里手工调整。
        if fit_params:
            self.model.fit(X_prepared, y_prepared, **fit_params)
        else:
            self.model.fit(X_prepared, y_prepared)

        # 若通用提取不够，请根据 _EQUATION_NOTES 改写此方法。
        self._refresh_equations_from_model()
        return self

    def predict(self, X):
        if not self._SUPPORTS_PREDICT:
            raise NotImplementedError(f"{self._TOOL_NAME} manifest 声明为不支持 predict")
        if self.model is None:
            raise ValueError("模型尚未训练，请先调用 fit")
        if not hasattr(self.model, "predict"):
            raise NotImplementedError(
                f"{self._TOOL_NAME} 底层对象没有 predict，请在包装器中实现自定义预测逻辑"
            )

        X_prepared = self._prepare_X(X)
        prediction = self.model.predict(X_prepared)
        return np.asarray(prediction).reshape(-1)

    def get_optimal_equation(self):
        return self._best_equation or ""

    def get_total_equations(self):
        return list(self._all_equations)

    def serialize(self):
        if self._SERIALIZATION_MODE == "base_pickle":
            return super().serialize()

        payload = {
            "params": self.params,
            "best_equation": self._best_equation,
            "all_equations": self._all_equations,
        }
        return json.dumps(payload, ensure_ascii=False)

    @classmethod
    def deserialize(cls, payload):
        if cls._SERIALIZATION_MODE == "base_pickle":
            return BaseWrapper.deserialize(payload)

        data = json.loads(payload)
        inst = cls(**data.get("params", {}))
        inst._best_equation = data.get("best_equation")
        inst._all_equations = list(data.get("all_equations") or [])
        inst.model = None
        return inst
