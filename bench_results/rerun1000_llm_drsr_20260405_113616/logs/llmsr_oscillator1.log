def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version extends equation_v1 by adding:
    - Higher order mixed nonlinear terms (x0^3 * x1, x0 * x1^3)
    - Quadratic velocity-position coupling terms
    - Smooth nonlinear damping via tanh functions on velocity and position
    - Retains all previous polynomial terms for flexibility

    Parameters:
        x0 (np.ndarray): Position at time t.
        x1 (np.ndarray): Velocity at time t.
        params (np.ndarray): Array of 12 coefficients.

    Returns:
        np.ndarray: Calculated acceleration at time t.
    """
    
    # Base polynomial and cross terms (params[0] to params[9])
    base = (
        params[0]  # constant offset
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 ** 2
        + params[4] * x0 * x1
        + params[5] * x1 ** 2
        + params[6] * x0 ** 3
        + params[7] * x1 ** 3
        + params[8] * (x0 ** 2) * x1
        + params[9] * x0 * (x1 ** 2)
    )
    
    # Higher order mixed nonlinear terms using remaining parameters (params[10], params[11])
    higher_order_terms = (
        params[10] * (x0 ** 3) * x1 
        + params[11] * x0 * (x1 ** 3)
    )
    
    # Smooth nonlinear damping/saturation effects using tanh on velocity and position,
    # representing friction-like or saturation behavior in a smooth manner.
    
    # Here we use fixed coefficients (-1) for tanh terms to represent generic damping,
    # but these could be made trainable if param count allowed.
    
