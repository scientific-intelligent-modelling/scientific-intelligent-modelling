          + p11* |x0|*x0         # nonlinear restoring force with sign preservation

    Note:
      The last two terms introduce physically meaningful nonlinear damping and restoring forces,
      which often appear in real oscillators beyond polynomial expansions.
    """
    
    abs_x0 = np.abs(x0)
    abs_x1 = np.abs(x1)

    return (
        params[0]
