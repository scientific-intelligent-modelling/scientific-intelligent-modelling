def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version adds higher order nonlinear terms and possible coupling terms 
    to better capture complex nonlinear oscillator dynamics.

    Model form:
        y = params[0] 
            + params[1]*x0                 # linear stiffness term
            + params[2]*x0**3              # cubic nonlinearity
            + params[3]*x1                 # damping term (velocity)
            + params[4]*x0**2              # quadratic position term
            + params[5]*x1**2              # quadratic velocity term
            + params[6]*x0*x1              # cross term between position and velocity
            + params[7]*x0**4              # quartic position nonlinearity
            + params[8]*x1**3              # cubic velocity nonlinearity
            + params[9]*(x0**2)*x1         # mixed nonlinear term
            + params[10]*x0*(x1**2)        # another mixed nonlinear term
            + params[11]*np.sign(x1)       # friction-like or dry friction effect

        Plus additional terms (if desired, can be included by extending param vector):
            + params[12] * x0**5           # quintic position nonlinearity (if param available)
            + params[13] * x1**4           # quartic velocity nonlinearity (if param available)
    
    Parameters:
    - x0: Position at time t (np.ndarray)
    - x1: Velocity at time t (np.ndarray)
    - params: array of parameters (length >= 12)

    Returns:
    - y: Acceleration computed from the model.
    """
    
    y = (params[0]
         + params[1] * x0
         + params[2] * x0**3
         + params[3] * x1
         + params[4] * x0**2
         + params[5] * x1**2
         + params[6] * x0 * x1
         + params[7] * x0**4
         + params[8] * x1**3
         + params[9] * (x0**2) * x1
         + params[10] * x0 * (x1**2)
         + params[11] * np.sign(x1))
    
    if len(params) > 12:
        y += np.where(len(params) > 12, 
                      sum(params[i]*(x0 ** (i-7)) for i in range(12, len(params))), 0)

    return y
