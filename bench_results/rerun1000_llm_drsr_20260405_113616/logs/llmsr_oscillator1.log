def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further refines the nonlinear harmonic oscillator acceleration model by including
    additional nonlinear terms involving mixed powers and absolute values to better capture
    asymmetric restoring forces and complex damping effects.

    Parameters:
    - x0 (np.ndarray): Position at time t.
    - x1 (np.ndarray): Velocity at time t.
    - params (np.ndarray): array of length 12 containing coefficients for each term.

    Returns:
    - y (np.ndarray): computed acceleration values.

    Equation form:
        y = p0 
          + p1 * x0                      # linear restoring force
          + p2 * x1                      # linear damping
          + p3 * x0**2                   # quadratic nonlinearity in position
          + p4 * x1**2                   # quadratic nonlinearity in velocity
          + p5 * x0**3                   # cubic nonlinearity in position
          + p6 * x1**3                   # cubic nonlinearity in velocity
          + p7 * x0 * x1                 # coupling term linear*linear
          + p8 * x0**2 * x1              # higher order coupling term 1
          + p9 * x0 * x1**2              # higher order coupling term 2
          + p10* |x1|*x1                 # nonlinear damping ~ velocity magnitude times velocity (friction-like)
          + p11* sign(x0)*x0**2          # asymmetric nonlinear restoring force with sign preservation

    Notes:
      - Retains all terms from v1 for physical interpretability.
      - Suitable for fitting complex oscillator dynamics with asymmetry and nonlinear damping.
    """
    
    abs_x1 = np.abs(x1)
    
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * (x0 ** 2)
        + params[4] * (x1 ** 2)
        + params[5] * (x0 ** 3)
        + params[6] * (x1 ** 3)
        + params[7] * (x0 * x1)
        + params[8] * (x0 ** 2) * x1
        + params[9] * x0 * (x1 ** 2)
        + params[10]* abs_x1*x1       # nonlinear damping term ~ |v|*v 
        + params[11]* np.sign(x0) * (x0 ** 2)   # asymmetric nonlinear restoring force with sign preservation 
    )
