    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation_v1 with physically motivated structure:
    Acceleration = constant + linear & nonlinear restoring forces + linear & nonlinear damping + cross terms.

    Parameters:
    - params (np.ndarray): array of 12 parameters
    
    Returns:
    - y (np.ndarray): acceleration values
    """
    # Unpack parameters for clarity
    c0 = params[0]   # constant offset
    k1 = params[1]   # linear stiffness coefficient (restoring force)
    k3 = params[2]   # cubic stiffness coefficient
    d1 = params[3]   # linear damping coefficient
    d3 = params[4]   # cubic damping coefficient
    
    p5 = params[5]
    p6 = params[6]
    p7 = params[7]
    p8 = params[8]
    p9 = params[9]
    
    h4_pos = params[10]  # higher order position term (x0^4)
    h4_vel = params[11]  # higher order velocity term (x1^4)

    return (
        c0
        - k1 * x0               # linear restoring force (-k*x)
        - k3 * (x0 ** 3)       # cubic nonlinearity in restoring force (-alpha*x^3)
        - d1 * x1              # linear damping (-c*v)
        - d3 * (x1 ** 3)       # nonlinear damping (-beta*v^3)
        + p5 * (x0 ** 2)       # additional quadratic position term (+...)
        + p6 * (x1 ** 2)       # additional quadratic velocity term (+...)
        + p7 * (x0 * x1)       # cross term (+...)
        + p8 * (x0 ** 2 * x1)  # higher order cross term (+...)
        + p9 * (x0 * x1 ** 2)  # higher order cross term (+...)
        + h4_pos * (x0 ** 4)   # optional higher order position term
        + h4_vel * (x1 ** 4)   # optional higher order velocity term
    )
