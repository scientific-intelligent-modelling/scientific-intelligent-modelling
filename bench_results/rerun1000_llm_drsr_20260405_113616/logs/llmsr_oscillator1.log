def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration as a polynomial function of position (x0) and velocity (x1),
    including nonlinear terms up to quartic order, multiple cross terms,
    plus nonlinear damping via |v|*v and dry friction via sign(v).

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Coefficients for each term; length should be >=14

    Returns:
    - np.ndarray: Calculated acceleration
    """
    
    return (
        params[0]                         # constant term
        + params[1] * x0                 # linear position stiffness (-k*x)
