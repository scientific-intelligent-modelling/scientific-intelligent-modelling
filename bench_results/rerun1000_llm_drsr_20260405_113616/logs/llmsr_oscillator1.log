def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version extends equation_v1 by adding:
    - Higher order mixed nonlinear terms (e.g., x0^3 * x1, x0 * x1^3)
    - Nonlinear damping modeled via smooth saturation functions (tanh)
    - Possible quadratic velocity-position coupling terms
    - Retains all previous terms for flexibility

    Parameters:
        x0 (np.ndarray): Position at time t.
        x1 (np.ndarray): Velocity at time t.
        params (np.ndarray): Array of 12 coefficients.

    Returns:
        np.ndarray: Calculated acceleration at time t.
    """
    
    # Base polynomial and cross terms from v1
    base = (
        params[0]  # constant offset
        + params[1] * x0
        + params[2] * x1
        + params[3] * (x0 ** 2)
        + params[4] * (x0 * x1)
        + params[5] * (x1 ** 2)
        + params[6] * (x0 ** 3)
        + params[7] * (x1 ** 3)
        + params[8] * ((x0 ** 2) * x1)
        + params[9] * (x0 * (x1 ** 2))
    )
    
    # Add higher order mixed nonlinear terms using remaining parameters if any
    # Since we have only 12 parameters total, we use the last two for nonlinear damping/saturation
    
    # Nonlinear damping / friction-like smooth saturation effects modeled by tanh functions:
    nonlinear_friction_pos = params[10] * np.tanh(x0)
    nonlinear_friction_vel = params[11] * np.tanh(x1)

    return base + nonlinear_friction_pos + nonlinear_friction_vel
