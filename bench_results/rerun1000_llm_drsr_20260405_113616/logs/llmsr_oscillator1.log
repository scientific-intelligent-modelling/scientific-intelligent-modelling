def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Calculates acceleration as a nonlinear function of position (x0) and velocity (x1),
    including polynomial terms up to 5th power in position and 3rd power in velocity,
    as well as cross terms combining powers of position and velocity.

    Physically motivated structure:
    - params[0]: constant forcing term (could be zero)
    - params[1]: linear restoring force coefficient (-k)
    - params[2]: linear damping coefficient (-c)
    - params[3], [5], [8], [9]: nonlinear stiffness coefficients for quadratic, cubic, quartic, quintic terms
    - params[4], [6]: nonlinear damping coefficients for quadratic and cubic velocity terms
    - params[7], [10], [11]: mixed nonlinear interaction terms between position and velocity

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Array of 12 parameters

    Returns:
        np.ndarray: Acceleration at time t
    """
    
    # Linear restoring force and damping
    linear_part = params[1] * x0 + params[2] * x1
    
    # Nonlinear stiffness terms in position only
    nonlinear_stiffness = (
        params[3] * (x0 ** 2) +
        params[5] * (x0 ** 3) +
        params[8] * (x0 ** 4) +
        params[9] * (x0 ** 5)
    )
    
    # Nonlinear damping terms in velocity only
    nonlinear_damping = (
        params[4] * (x1 ** 2) +
        params[6] * (x1 ** 3)
    )
    
    # Mixed interaction terms between position and velocity
    mixed_terms = (
        params[7] * x0 * x1 +
        params[10] * ((x0 ** 2) * x1) +
        params[11] * (x0 * (x1 ** 2))
    )
    
    # Constant forcing term or offset
    constant_term = params[0]
    
    return constant_term + linear_part + nonlinear_stiffness + nonlinear_damping + mixed_terms
