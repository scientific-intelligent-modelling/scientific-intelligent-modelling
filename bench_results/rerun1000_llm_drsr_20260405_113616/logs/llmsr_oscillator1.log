def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation including physically meaningful nonlinearities:
    - Linear and cubic stiffness in position (x0)
    - Linear and quadratic/cubic damping in velocity (x1)
    - Cross interaction terms between position and velocity
    
    Parameters:
    - params (np.ndarray): array of length 12 coefficients
    
    Returns:
    - y (np.ndarray): acceleration values
    """
    
    # Unpack parameters for clarity
    c0 = params[0]   # constant offset (usually near zero)
    
    k1 = params[1]   # linear stiffness coefficient on position
    k3 = params[2]   # cubic stiffness coefficient on position
    
    d1 = params[3]   # linear damping coefficient on velocity
    d2 = params[4]   # quadratic damping coefficient on |velocity|*velocity
    
    cxy = params[5]  # cross term coefficient: position * velocity
    
    k2 = params[6]   # quadratic stiffness term on position squared
    
    d3 = params[7]   # cubic damping term on velocity cubed
    
    cxxv = params[8] # cross term: (position squared)*velocity
    cxvv = params[9] # cross term: position*(velocity squared)
    
    k4 = params[10]  # quartic stiffness term on position^4
    
    d4 = params[11]  # quartic damping term on velocity^4

    
    y = (
        c0 
        + k1 * x0 
        + k2 * (x0 ** 2) 
        + k3 * (x0 ** 3) 
        + k4 * (x0 ** 4)
        + d1 * x1 
        + d2 * np.abs(x1) * x1     # quadratic damping-like nonlinearity
