def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Models acceleration in a nonlinear harmonic oscillator as:
    y = params[0] 
        + params[1]*x0 
        + params[2]*x1 
        + params[3]*x0**3 
        + params[4]*x1**3

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    return (
        params[0]  # constant offset term, could be zero physically
        + params[1] * x0  # linear stiffness term (-k*x)
        + params[2] * x1  # linear damping term (-c*v)
        + params[3] * x0**3  # cubic stiffness nonlinearity
        + params[4] * x1**3  # possible nonlinear damping or other effects
    )
