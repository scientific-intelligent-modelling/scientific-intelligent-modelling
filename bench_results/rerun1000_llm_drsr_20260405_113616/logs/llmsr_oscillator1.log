        # Higher order velocity nonlinearity e.g. quartic velocity term v^4
        y += params[idx] * (x1 ** 4)
        idx += 1

        if len(params) > idx:
            # Mixed fractional power cross-term between position and velocity,
            # e.g., |x|^{3/2}*v or x*|v|^{3/2}
            y += params[idx] * np.sign(x0)*np.abs(x0)**(3/2)*x1  
            idx += 1

            if len(params) > idx:
                y += params[idx] * x0*np.sign(x1)*np.abs(x1)**(3/2)
                idx += 1

                if len(params) > idx:
                    # Another high order mixed polynomial term e.g. x^3*v^2 
                    y += params[idx]*(x0**3)*(x1**2)
                    idx += 1

                    if len(params)>idx:
                        # Another high order mixed polynomial term e.g. x^4*v 
                        y += params[idx]*(x0**4)*x1

    return y
