        + params[9] * (np.power(x0, 4) * x1)  # cross term: quartic position times velocity
        + params[10] * (x0 * np.power(x1, 2))  # cross term: linear position times quadratic velocity
        + params[11] * np.power(x1,4)   # quartic velocity term (strong nonlinear damping)
    )
