def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration y as a nonlinear function of position (x0) and velocity (x1),
    including polynomial terms up to cubic order with physically interpretable grouping,
    capturing nonlinear restoring forces, nonlinear damping effects,
    coupling between position and velocity, and higher-order mixed terms.

    Parameters:
    - x0 (np.ndarray): Position at time t.
    - x1 (np.ndarray): Velocity at time t.
    - params (np.ndarray): array of length 12 containing coefficients for each term.

    Returns:
    - y (np.ndarray): computed acceleration values.

    Equation form:
        y = p0                          # constant offset / external forcing
          + p1 * x0                     # linear restoring force (Hooke's law)
          + p3 * x0**2                  # quadratic stiffness nonlinearity
          + p5 * x0**3                  # cubic stiffness nonlinearity (Duffing)
          + p2 * x1                     # linear damping
          + p4 * x1**2                  # quadratic damping nonlinearity
          + p6 * x1**3                  # cubic damping nonlinearity
          + p7 * x0 * x1                # bilinear coupling between position & velocity
          + p8 * x0**2 * x1             # higher order coupling term 1
          + p9 * x0 * x1**2             # higher order coupling term 2
          + p10* x0**3 * x1             # higher order mixed nonlinear term 3
          + p11* x0 * x1**3             # higher order mixed nonlinear term 4

    This form captures key physics of a nonlinear oscillator with complex damping/stiffness behavior.
    """
    
    restoring_force = (
        params[1]  * x0 
        + params[3]  * (x0 ** 2) 
        + params[5]  * (x0 ** 3)
    )
    
    damping_force = (
        params[2]  * x1 
        + params[4]  * (x1 ** 2) 
        + params[6]  * (x1 ** 3)
    )
    
    coupling_terms = (
        params[7]   * (x0     * x1) 
        + params[8]   * (x0 ** 2)   * x1 
        + params[9]   * x0         * (x1 ** 2) 
        + params[10]  * (x0 ** 3)   * x1 
        + params[11]  * x0         *(x1 ** 3)
    )
    
    y = (
        params[0]           # constant offset / external forcing
        + restoring_force   
        + damping_force     
        + coupling_terms    
    )
    
    return y
