def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version models the acceleration of a nonlinear harmonic oscillator as a function of position (x0)
    and velocity (x1), including physically meaningful terms:

    - Linear restoring force proportional to position (Hooke's law): params[1] * x0
      Typically negative coefficient for restoring force.
    - Linear damping proportional to velocity: params[2] * x1
      Typically negative coefficient for damping.
    - Nonlinear stiffness terms: quadratic and cubic powers of position (x0**2, x0**3)
      Capture nonlinear restoring forces.
    - Nonlinear damping terms: quadratic and cubic powers of velocity (x1**2, x1**3)
      Capture nonlinear damping effects.
    - Cross terms between position and velocity (x0*x1) to capture coupling effects.
    - Higher order cross terms like (x0^2 * x1), (x0 * x1^2).
    - Absolute value terms for friction-like or non-smooth effects.
    - Trigonometric term sin(x0) to model pendulum-like restoring force.

    Parameters:
        x0 (np.ndarray): Position at time t.
        x1 (np.ndarray): Velocity at time t.
        params (np.ndarray): Array of 12 coefficients.

    Returns:
        np.ndarray: Calculated acceleration at time t.
    """
    
    return (
        params[0]  # constant offset term
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 ** 2
        + params[4] * x0 * x1
        + params[5] * x1 ** 2
        + params[6] * x0 ** 3
        + params[7] * x1 ** 3
        + params[8] * (x0 ** 2) * x1
        + params[9] * x0 * (x1 ** 2)
        + params[10] * np.abs(x0)
        + params[11] * np.sin(x0)   # add sine term instead of abs(x1) for richer nonlinearity
    )
