def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration as a polynomial function of position and velocity,
    including linear, quadratic, cubic and cross terms,
    plus nonlinear friction and velocity-dependent damping saturation.

    Physically motivated terms:
    - Constant offset term
    - Linear restoring force proportional to position (x0)
    - Linear damping proportional to velocity (x1)
    - Quadratic and cubic stiffness nonlinearities in position
    - Quadratic and cubic damping nonlinearities in velocity
    - Cross-terms coupling position and velocity up to cubic order
    - Sine term for geometric or periodic forcing effects
    - Smooth dry friction approximation via tanh(sign-like) term
    - Velocity-dependent exponential decay damping saturation

    Parameters:
        x0 (np.ndarray): Position at time t.
        x1 (np.ndarray): Velocity at time t.
        params (np.ndarray): Trainable coefficients used by the equation skeleton.
                             Expected length at least 13.

    Returns:
        np.ndarray: Acceleration values computed from the model.
    """
    
    p = params
    
    # Smooth approximation of sign(x1) using tanh with scaling factor 5 for sharpness 
    tanh_friction = np.tanh(5 * x1)
    
    # Velocity dependent exponential decay term modeling drag saturation effect 
    exp_damping = x1 * np.exp(-np.abs(x1))
    
    return (
        p[0]                      # constant offset term
        + p[1] * x0               # linear stiffness (-k*x)
        + p[2] * x1               # linear damping (-c*v)
        + p[3] * (x0 ** 2)        # quadratic stiffness nonlinearity
        + p[4] * (x1 ** 2)        # quadratic damping nonlinearity
        + p[5] * (x0 ** 3)        # cubic stiffness nonlinearity (-k3*x^3)
        + p[6] * (x1 ** 3)        # cubic damping nonlinearity
        + p[7] * (x0 * x1)        # cross term linear in both variables
        + p[8] * ((x0 ** 2) * x1) # mixed nonlinear term: quadratic position times velocity
        + p[9] * (x0 * (x1 ** 2)) # mixed nonlinear term: position times quadratic velocity 
        + p[10] * np.sin(x0)      # geometric/periodic nonlinearity or forcing effect 
        + p[11] * tanh_friction   # smooth dry friction approx via tanh(sign-like)
        + p[12] * exp_damping     # velocity-dependent exponential decay damping saturation
       )
