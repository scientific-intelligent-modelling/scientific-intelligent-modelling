    - x0 (np.ndarray): position at time t
    - x1 (np.ndarray): velocity at time t
    - params (np.ndarray): array of 12 parameters

    Returns:
    - y (np.ndarray): acceleration values
    """
    
    c0 = params[0]   # constant offset
    
    k1 = params[1]   # linear stiffness coefficient (-k*x)
    k3 = params[2]   # cubic stiffness coefficient (-alpha*x^3)
    
    d1 = params[3]   # linear damping coefficient (-c*v)
    d3 = params[4]   # cubic damping coefficient (-beta*v^3)
    
    p5 = params[5]   # quadratic position term (+x^2)
    p6 = params[6]   # quadratic velocity term (+v^2)
    
