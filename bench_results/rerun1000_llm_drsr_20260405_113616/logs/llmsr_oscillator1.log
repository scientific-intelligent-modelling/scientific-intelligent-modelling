        + cross2 * ((x0 ** 2) * x1) 
        + cross3 * (x0 * (x1 ** 2)) 
        + h5 * (x0 ** 5)
    )
    
    # Add a smooth nonlinear function of velocity to capture subtle effects,
    # e.g., exponential decay or sinusoidal modulation.
    
    smooth_nonlinear_velocity_term = h_vel_nl * np.exp(-np.abs(x1))
    
