        + params[9] * (x0 * (x1 ** 2))  # another higher order coupling term
        
        + params[10] * np.sign(x1) * abs_x1**(3/2)   # fractional power damping-like term 
        + params[11] * np.sign(x0) * abs_x0**(7/2)   # fractional power restoring-like term 
        
        # Additional terms beyond v1 for richer dynamics:
        
        + params[12] * np.sign(x1) * abs_x1**(5/2)   # higher order fractional damping
        + params[13] * np.sign(x0) * abs_x0**(9/2)   # higher order fractional restoring
        
        + params[14] * ((x0 ** 3) * x1)               # cubic position times velocity coupling
        + params[15] * (x0 * (x1 ** 3))               # position times cubic velocity coupling
        
        + params[16] * ((x0 ** 4))                     # quartic restoring force term
        
        + params[17] * ((x1 ** 4))                     # quartic velocity/damping related term
        
        + params[18]                                    # reserved for constant offset or bias if needed
    )
