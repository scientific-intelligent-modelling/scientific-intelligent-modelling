def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved version of the oscillator acceleration model.

    Models acceleration as a combination of:
    - constant offset
    - linear and nonlinear damping terms (velocity powers)
    - linear restoring force
    - odd-powered nonlinear restoring forces (cubic, quintic)
    - cross-terms between position and velocity (various powers)
    
    Parameters:
    - params (np.ndarray): array with at least 12 elements.
    
    Equation form:
        y = p0 
            + p1 * v 
            + p2 * x 
            + p3 * x**3 
            + p4 * x**5 
            + p5 * v**2 
            + p6 * x**2 * v
            + p7 * v**3
            + p8 * x * v**2
            + p9 * x**4
            + p10 * x**3 * v
            + p11 * x * v

    where:
        x = position (x0)
        v = velocity (x1)
        y = acceleration

    """
    return (
        params[0]  # constant offset
        + params[1] * x1  # linear damping term (velocity)
        + params[2] * x0  # linear restoring force (position)
        + params[3] * np.power(x0, 3)  # cubic nonlinearity in restoring force
        + params[4] * np.power(x0, 5)  # quintic nonlinearity in restoring force
        + params[5] * np.power(x1, 2)  # quadratic velocity term (nonlinear damping)
