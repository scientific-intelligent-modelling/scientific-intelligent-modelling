def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version models acceleration in a nonlinear harmonic oscillator including:
    - Linear and nonlinear restoring forces (position terms)
    - Linear and nonlinear damping/friction effects (velocity terms)
    - Cross terms between position and velocity
    - Explicit sign-based friction-like effects replacing absolute value terms

    Parameters:
        x0 (np.ndarray): Position at time t.
        x1 (np.ndarray): Velocity at time t.
        params (np.ndarray): Array of 12 coefficients.

    Returns:
        np.ndarray: Calculated acceleration at time t.
    """
    
    c0 = params[0]   # constant offset
    c1 = params[1]   # linear position term (restoring force)
    c2 = params[2]   # linear velocity term (damping)
    c3 = params[3]   # quadratic position term
    c4 = params[4]   # position * velocity cross term
    c5 = params[5]   # quadratic velocity term
    c6 = params[6]   # cubic position term
    c7 = params[7]   # cubic velocity term
    c8 = params[8]   # quadratic position * velocity term
    c9 = params[9]   # position * quadratic velocity term
    
    # Replace absolute value terms with sign functions for friction-like effects:
    c10 = params[10]  # coefficient for sign(position) friction-like effect
    c11 = params[11]  # coefficient for sign(velocity) friction-like effect

    return (
        c0 
        + c1 * x0 
        + c2 * x1 
        + c3 * x0 ** 2 
        + c4 * x0 * x1 
        + c5 * x1 ** 2 
        + c6 * x0 ** 3 
        + c7 * x1 ** 3 
        + c8 * (x0 ** 2) * x1 
        + c9 * x0 * (x1 ** 2) 
        
        + c10 * np.sign(x0)     # friction-like force depending on direction of position displacement
        + c11 * np.sign(x1)     # friction-like force depending on direction of velocity
        
        )
