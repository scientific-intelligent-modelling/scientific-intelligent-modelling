def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Includes:
    - Constant term
    - Linear terms in position (x0) and velocity (x1)
    - Quadratic, cubic nonlinearities in both x0 and x1
    - Quartic and quintic nonlinearities in position (x0)
    - Mixed interaction terms between powers of x0 and x1 up to cubic order
    - Additional higher-order mixed terms for richer dynamics

    Physical meaning:
    Models acceleration of a nonlinear harmonic oscillator with damping,
    nonlinear stiffness, and velocity-dependent nonlinear effects.
    
    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Coefficients for each term
    
    Returns:
        np.ndarray: Acceleration at time t
    """
    
    # Ensure params has enough length; if not, pad with zeros
    p = np.zeros(16)
    p[:len(params)] = params
    
    return (
        p[0]  # constant term
        
        + p[1] * x0  # linear restoring force (-k*x)
        + p[2] * x1  # linear damping (-c*v)
        
        + p[3] * (x0 ** 2)  # quadratic nonlinearity in position
        + p[4] * (x1 ** 2)  # quadratic nonlinearity in velocity
        
        + p[5] * (x0 ** 3)  # cubic nonlinearity in position
        + p[6] * (x1 ** 3)  # cubic nonlinearity in velocity
        
        + p[7] * (x0 * x1)          # mixed linear interaction term
        + p[8] * ((x0 ** 2) * x1)   # mixed quadratic-linear interaction term
        + p[9] * (x0 * (x1 ** 2))   # mixed linear-quadratic interaction term
        
        + p[10] * (x0 ** 4)         # quartic nonlinearity in position
        + p[11] * (x0 ** 5)         # quintic nonlinearity in position
        
        + p[12] * ((x0 **3 )* x1)   # cubic-linear mixed interaction term
        + p[13] * (x0*(x1**3 ))     # linear-cubic mixed interaction term
        
        + p[14] * ((x0**2)*(x1**2))   # quadratic-quadratic mixed interaction term
        
        + p[15] * ((x0**4)* x1)       # quartic-linear mixed interaction term
    )
