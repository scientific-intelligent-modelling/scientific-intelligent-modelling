def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Adds additional nonlinear interaction terms and periodic nonlinearities:
    - sinusoidal restoring force term (params[12] * sin(x))
    - velocity-position mixed higher order terms
    - cross polynomial terms for richer dynamics

    Parameters:
        params: array-like with at least 13 elements

    Returns:
        y: acceleration values as numpy array
    """
    
    # Base polynomial and interaction terms from v1
    y = (
        params[0]
        + params[1]  * x1
        + params[2]  * x0
        + params[3]  * np.power(x0, 3)
        + params[4]  * np.power(x0, 5)
        + params[5]  * np.power(x1, 2)
        + params[6]  * x1       * x0
        + params[7]  * x1       * np.power(x0, 3)
        + params[8]  * np.power(x1, 2)   * np.power(x0, 3)
        + params[9]  * np.power(x1, 3)
        + params[10] * np.power(x0, 2)
        + params[11] * np.power(x1, 3)   * np.power(x0,5)
    )
    
    # Additional nonlinear terms for v2
    
    # To avoid index error if fewer than expected parameters are passed,
    # we can check length or assume user passes enough parameters.
    
    if len(params) > 12:
        y += (
            params[12] * np.sin(x0)               # periodic restoring force term (like pendulum)
            + (params[13] if len(params) >13 else 0) * x1**4             # quartic velocity damping
            + (params[14] if len(params) >14 else 0) * x0**7             # higher order position nonlinearity
            + (params[15] if len(params) >15 else 0) * x1**2 * x0**2     # quadratic coupling term
            + (params[16] if len(params) >16 else 0) * x1**5             # quintic velocity damping term
            + (params[17] if len(params) >17 else 0) * x1*np.cos(x0)**2   # mixed trig-polynomial coupling 
        )
    
    return y
