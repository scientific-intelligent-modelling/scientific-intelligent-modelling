def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This function models acceleration y = f(x0, x1) in a nonlinear harmonic oscillator,
    incorporating linear and nonlinear restoring forces, damping terms,
    and cross-coupling terms between position and velocity.

    Parameters:
    - x0: Position at time t (np.ndarray)
    - x1: Velocity at time t (np.ndarray)
    - params: Trainable coefficients (length >= 12)

    Returns:
    - y: Acceleration at time t (np.ndarray)
    
    Equation structure:
        y = 
          + constant term
          + linear restoring force ~ x0
          + cubic restoring force ~ x0^3
          + quintic restoring force ~ x0^5
          + linear damping ~ x1
          + quadratic & cubic velocity terms ~ x1^2, x1^3
          + coupling terms between position and velocity ~ x0*x1, x0^2*x1, x0*x1^2
          + fractional power damping-like term ~ sign(x1)*|x1|^(3/2)
          + fractional power restoring-like term ~ sign(x0)*|x0|^(7/2)

        Additional improvements:
        - Added a mixed fractional power term involving both position and velocity to capture subtle nonlinear interactions.
        - Included a squared position term to allow for asymmetric potential shapes.

    """
    
    # Extract parameters for clarity (assuming params length >= 12)
    c0 = params[0]   # constant offset (usually zero)
    
    k1 = params[1]   # linear restoring force coefficient (-k * x)
    k3 = params[2]   # cubic restoring force coefficient
    k5 = params[3]   # quintic restoring force coefficient
    
    c_lin = params[4]  # linear damping coefficient (-c * v)
    
    c_quad = params[5]  # quadratic velocity term (nonlinear damping or forcing)
    c_cub = params[6]   # cubic velocity term
    
    c_xv = params[7]     # coupling between position and velocity (x*v)
    c_x2v = params[8]     # higher order coupling (x^2 * v)
    c_xv2 = params[9]     # higher order coupling (x * v^2)

    c_frac_v = params[10]  # fractional power damping-like term sign(v)*|v|^{3/2}
    
    c_frac_x = params[11]  # fractional power restoring-like term sign(x)*|x|^{7/2}

    
    return (
        c0
        + k1 * x0
        + k3 * np.power(x0, 3)
        + k5 * np.power(x0, 5)
        + c_lin * x1
        + c_quad * np.power(x1, 2)
        + c_cub * np.power(x1, 3)
        + c_xv * (x0 * x1)
        + c_x2v * ((x0 ** 2) * x1)
        + c_xv2 * (x0 * (x1 ** 2))
        + c_frac_v * np.sign(x1) * np.abs(x1) ** (3 / 2)
        + c_frac_x * np.sign(x0) * np.abs(x0) ** (7 / 2)
        
       # Additional optional terms can be added here if needed,
       # but we keep it within MAX_NPARAMS=12 as per original design.
       
       )
