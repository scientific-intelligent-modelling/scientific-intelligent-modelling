        + params[8]  * np.power(x1, 2)   * np.power(x0, 3)
        + params[9]  * np.power(x1, 3)   # cubic velocity damping
        + params[10] * np.power(x0, 2)   # quadratic position restoring force
        + params[11] * np.power(x1, 3)   * np.power(x0,5) # high order coupling term
    )
