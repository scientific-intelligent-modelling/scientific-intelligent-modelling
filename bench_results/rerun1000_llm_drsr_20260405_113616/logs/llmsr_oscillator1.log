    """

    # Unpack parameters for clarity
    c0 = params[0]   # constant term
    c1 = params[1]   # linear position term (-k*x)
    c2 = params[2]   # linear velocity term (damping)
    
    c3 = params[3]   # quadratic position term
    c4 = params[4]   # quadratic velocity term
    
