def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration y as a nonlinear oscillator with polynomial and transcendental terms,
    capturing restoring force, damping, and nonlinear stiffness effects.

    Equation form:
        y = p0 
            + p1*x0 
            + p2*x1 
            + p3*x0**2 
            + p4*x1**2 
            + p5*x0*x1 
            + p6*x0**3 
            + p7*x1**3 
            + p8*(x0**2)*x1 
            + p9*(x1**2)*x0
            + p10*sin(x0)
            + p11*exp(-abs(x1)) * sign(x1)

    Notes:
    - The last term models velocity-dependent damping with exponential decay and directionality.
    - This form allows flexible fitting of nonlinear oscillator dynamics including asymmetric damping.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    # sign function to preserve velocity direction in damping term
    sign_x1 = np.sign(x1)
    
    return (
        params[0] +
        params[1] * x0 +
        params[2] * x1 +
        params[3] * x0**2 +
        params[4] * x1**2 +
        params[5] * x0 * x1 +
        params[6] * x0**3 +
        params[7] * x1**3 +
        params[8] * (x0**2) * x1 +
        params[9] * (x1**2) * x0 +
        params[10] * np.sin(x0) +
        params[11] * np.exp(-np.abs(x1)) * sign_x1
    )
