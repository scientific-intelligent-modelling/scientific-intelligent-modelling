def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculates acceleration as a nonlinear function of position (x0) and velocity (x1),
    including polynomial terms up to 5th power in position and 4th power in velocity,
    plus cross terms involving products of powers of position and velocity.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients (length >= 14)

    Returns:
    - y (np.ndarray): Acceleration at time t
    """

    # Unpack parameters for clarity; allow for optional higher order cross terms if present
    c0 = params[0]   # constant term
    c1 = params[1]   # linear position term (-k*x)
    c2 = params[2]   # linear velocity term (damping)
    
    c3 = params[3]   # quadratic position term
    c4 = params[4]   # quadratic velocity term
    
    c5 = params[5]   # cubic position term (-alpha*x^3)
    c6 = params[6]   # cubic velocity term
    
    c7 = params[7]   # quartic position term
    c8 = params[8]   # quartic velocity term
    
    c9  = params[9]  # quintic position term (-beta*x^5)
    
    c10 = params[10] # cross-term: x * v^2
    c11 = params[11] # cross-term: x^2 * v

    # Optional higher order mixed terms if provided
    c12 = params[12] if len(params) > 12 else 0.0  # x^3 * v
    c13 = params[13] if len(params) > 13 else 0.0  # x * v^3

    
    y = (
        c0 +
        c1 * x0 +
        c2 * x1 +
        c3 * np.power(x0, 2) +
        c4 * np.power(x1, 2) +
        c5 * np.power(x0, 3) +
        c6 * np.power(x1, 3) +
        c7 * np.power(x0, 4) +
        c8 * np.power(x1, 4) +
        c9 * np.power(x0, 5) +
        c10 * x0 * np.power(x1, 2) +
        c11 * np.power(x0, 2) * x1 +
        c12 * np.power(x0,3)*x1 + 
        c13 * x0*np.power(x1,3)
       )
    
    return y
