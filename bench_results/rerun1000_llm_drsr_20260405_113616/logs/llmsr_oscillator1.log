def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculates acceleration for a nonlinear harmonic oscillator as a function of position (x0)
    and velocity (x1), including polynomial nonlinearities and cross terms.

    The model includes:
    - Constant term (bias)
    - Linear restoring force term proportional to position (like Hooke's law)
    - Linear damping term proportional to velocity
    - Nonlinear stiffness terms up to quintic power in position
    - Nonlinear damping terms up to cubic power in velocity
    - Cross interaction terms between position and velocity

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Array of coefficients with length 12

    Returns:
        y (np.ndarray): Acceleration at time t
    """

    return (
        params[0]                      # constant offset / bias acceleration
        + params[1] * x0              # linear restoring force (-k*x)
        + params[2] * x1              # linear damping (-c*v)
        + params[3] * (x0 ** 2)       # quadratic stiffness nonlinearity
        + params[4] * (x1 ** 2)       # quadratic damping nonlinearity
        + params[5] * (x0 ** 3)       # cubic stiffness nonlinearity
        + params[6] * (x1 ** 3)       # cubic damping nonlinearity
        + params[7] * (x0 * x1)       # cross linear interaction term
        + params[8] * (x0 ** 4)       # quartic stiffness nonlinearity
        + params[9] * ((x0 ** 2) * x1)# cross term: quadratic position × linear velocity 
        + params[10] * (x0 * (x1 ** 2))# cross term: linear position × quadratic velocity 
        + params[11] * (x0 ** 5)      # quintic stiffness nonlinearity for strong nonlinearities/stiffening effect
    )
