def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0` incorporating nonlinear and damping terms.

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected to have at least 6 parameters:
        params[0]: constant offset term
        params[1]: linear stiffness coefficient (-k1)
        params[2]: damping coefficient (-c)
        params[3]: cubic stiffness coefficient (-k2)
        params[4]: optional quadratic position term coefficient
        params[5]: optional quadratic velocity term coefficient

    Returns:
    - y (np.ndarray): acceleration values computed from inputs.
    """
    # Unpack parameters for clarity
    c0 = params[0]
    k1 = params[1]
    c = params[2]
    k2 = params[3]
    
    # Optional higher order terms if desired
    q_pos = params[4] if len(params) > 4 else 0.0  # quadratic in position
    q_vel = params[5] if len(params) > 5 else 0.0  # quadratic in velocity

    return (
        c0 
        + k1 * x0 
        + k2 * (x0 ** 3)
        + c * x1 
        + q_pos * (x0 ** 2)
        + q_vel * (x1 ** 2)
    )
