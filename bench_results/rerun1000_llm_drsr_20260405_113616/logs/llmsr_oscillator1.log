def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Includes:
    - All polynomial terms up to cubic order in position and velocity,
    - Cross terms between position and velocity,
    - Nonlinear damping term proportional to |velocity| * velocity.
    """
    poly_terms = (
        params[0]  # constant
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0**3
        + params[6] * x1**3
        + params[7] * x0 * x1
        + params[8] * (x0**2) * x1
        + params[9] * x0 * (x1**2)
        + params[10] * (x0**3) * x1
        # Instead of last cross term from v1 use nonlinear damping:
    )
    
    # Nonlinear damping term: |v|*v = abs(x1)*x1 weighted by param 11
    nonlinear_damping = params[11] * np.abs(x1) * x1
    
    return poly_terms + nonlinear_damping
