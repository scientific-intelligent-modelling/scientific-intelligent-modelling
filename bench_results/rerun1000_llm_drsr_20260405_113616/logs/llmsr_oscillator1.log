    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Physically motivated nonlinear oscillator acceleration model.

    Background:
    Calculate acceleration in a nonlinear harmonic oscillator given position (x0) and velocity (x1).

    Variables:
    - Independents: x0 (position), x1 (velocity)
    - Dependent: y (acceleration)

    Parameters:
        params (np.ndarray): array of length 12 coefficients

    Returns:
        np.ndarray: acceleration values for each input pair (x0, x1)
    
    Model structure includes:
      - Constant offset
      - Linear stiffness term (-omega^2 * x0)
      - Cubic and quartic stiffness nonlinearities
      - Linear, quadratic, cubic damping terms
      - Cross terms coupling position and velocity powers
      - Higher order polynomial terms for flexibility
      - Smooth nonlinear functions to capture complex dynamics
    """

    # Unpack parameters for clarity (optional)
    c0 = params[0]   # constant term
    k1 = params[1]   # linear stiffness coefficient (~-omega^2)
    k3 = params[2]   # cubic stiffness coefficient (-alpha)
    k4 = params[3]   # quartic stiffness coefficient

    d1 = params[4]   # linear damping coefficient (-beta)
    d2 = params[5]   # quadratic damping coefficient
    d3 = params[6]   # cubic damping coefficient

    cross1 = params[7]  # cross term x0 * x1
    cross2 = params[8]  # cross term x0^2 * x1
    cross3 = params[9]  # cross term x0 * x1^2

    h5 = params[10]     # higher order position nonlinearity (x0^5)
    
    h_vel_nl = params[11]  # higher order velocity nonlinearity or smooth function coeff

    
    acc_poly_terms = (
        c0 
        + k1 * x0 
        + k3 * (x0 ** 3) 
        + k4 * (x0 ** 4) 
        + d1 * x1 
        + d2 * (x1 ** 2) 
        + d3 * (x1 ** 3) 
