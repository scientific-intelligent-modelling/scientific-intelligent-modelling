def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further extends the model of acceleration in a nonlinear harmonic oscillator by including:
    - Sign functions to explicitly model friction-like or dry-friction effects
    - Retains key polynomial and absolute value terms for nonlinear stiffness and damping

    Parameters:
        x0 (np.ndarray): Position at time t.
        x1 (np.ndarray): Velocity at time t.
        params (np.ndarray): Array of 12 coefficients.

    Returns:
        np.ndarray: Calculated acceleration at time t.
    """
    
    c0 = params[0]   # constant offset
    c1 = params[1]   # linear position term (restoring force)
    c2 = params[2]   # linear velocity term (damping)
    c3 = params[3]   # quadratic position term
    c4 = params[4]   # position * velocity cross term
    c5 = params[5]   # quadratic velocity term
    c6 = params[6]   # cubic position term
    c7 = params[7]   # cubic velocity term
    
    # Replace previous cross terms with sign-based friction terms for better physical modeling
    c8 = params[8]   # coefficient for sign(position) term - models asymmetric restoring force/friction
    c9 = params[9]   # coefficient for sign(velocity) term - models dry friction/damping
    
    c10 = params[10]  # absolute value of position (friction-like)
    c11 = params[11]  # absolute value of velocity (friction-like)

    return (
        c0 
        + c1 * x0 
        + c2 * x1 
        + c3 * x0 ** 2 
        + c4 * x0 * x1 
        + c5 * x1 ** 2 
        + c6 * x0 ** 3 
        + c7 * x1 ** 3 
        
        + c8 * np.sign(x0)      # explicit asymmetric restoring/friction force based on position sign
        + c9 * np.sign(x1)      # explicit dry friction/damping based on velocity sign
        
        + c10 * np.abs(x0)      # smooth friction-like effect from abs(position)
        + c11 * np.abs(x1)      # smooth friction-like effect from abs(velocity)
        
        )
