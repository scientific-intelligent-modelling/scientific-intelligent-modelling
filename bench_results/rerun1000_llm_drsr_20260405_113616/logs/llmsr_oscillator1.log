def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculate acceleration for a nonlinear harmonic oscillator given position (x0) and velocity (x1).

    This model includes:
    - Constant term (bias)
    - Linear restoring force term proportional to position (Hooke's law)
    - Linear damping term proportional to velocity
    - Cubic nonlinearity in position (Duffing oscillator type nonlinearity)
    - Quadratic and cubic nonlinearities in velocity and mixed terms to capture complex damping or forcing effects
    - Absolute value terms to allow for possible non-smooth/friction-like effects

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Array of 12 coefficients corresponding to each term

    Returns:
        np.ndarray: Calculated acceleration y = d²x/dt²
    """
    
    return (
        params[0]                    # constant offset / bias
        + params[1] * x0            # linear restoring force ~ -k*x0
        + params[2] * x1            # linear damping ~ -c*x1
        + params[3] * (x0 ** 2)     # quadratic position nonlinearity
        + params[4] * (x1 ** 2)     # quadratic velocity nonlinearity
        + params[5] * (x0 * x1)     # interaction between position and velocity
        + params[6] * (x0 ** 3)     # cubic restoring force nonlinearity (Duffing)
        + params[7] * (x1 ** 3)     # cubic velocity nonlinearity 
        + params[8] * ((x0 ** 2) * x1)   # mixed higher order term 
        + params[9] * (x0 * (x1 ** 2))   # another mixed higher order term 
        + params[10] * np.abs(x0)          # absolute value of position for friction-like or piecewise effects
        + params[11] * np.abs(x1)          # absolute value of velocity for friction-like or piecewise effects
    )
