        y = p0                      # constant offset term
          + p1 * x0                 # linear restoring force
          + p2 * x1                 # linear damping force
          + p3 * x0**2              # quadratic restoring force term
          + p4 * x1**2              # quadratic damping term
          + p5 * x0**3              # cubic restoring force nonlinearity
          + p6 * x1**3              # cubic damping nonlinearity
          + p7 * (x0 * x1)          # bilinear coupling term
