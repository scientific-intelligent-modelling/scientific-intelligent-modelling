    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Physically motivated nonlinear oscillator acceleration model.

    Parameters:
    - x0 (np.ndarray): position at time t
    - x1 (np.ndarray): velocity at time t
    - params (np.ndarray): array of 12 coefficients

    Returns:
    - np.ndarray: acceleration values for each input pair (x0, x1)
    
    Model structure includes:
      - Constant offset
      - Linear & nonlinear restoring forces (-k1*x0, -k3*x0^3, -k4*x0^4)
      - Linear & nonlinear damping (-d1*x1, -d2*x1^2, -d3*x1^3)
      - Cross terms coupling position and velocity powers
      - Higher order polynomial terms for flexibility
      - Smooth nonlinear functions to capture complex dynamics 
        (e.g., exp(-|x1|), tanh(x0), sin(x1))
    """

    # Unpack parameters for clarity
    c0 = params[0]   # constant offset
    
    k1 = params[1]   # linear stiffness coefficient (~omega^2)
    k3 = params[2]   # cubic stiffness coefficient 
    k4 = params[3]   # quartic stiffness coefficient
    
    d1 = params[4]   # linear damping coefficient 
    d2 = params[5]   # quadratic damping coefficient 
    d3 = params[6]   # cubic damping coefficient 
    
    cross1 = params[7]  # cross term x0 * x1 
    cross2 = params[8]  # cross term x0^2 * x1 
    cross3 = params[9]  # cross term x0 * x1^2 
    
    h_pos = params[10]  # higher order position nonlinearity (e.g., x0^5 or tanh(x0))
    
    h_vel_smooth = params[11]  # smooth nonlinear velocity function coeff

    
    acc_poly_terms = (
        c0
        - k1 * x0                 # linear restoring force (-k*x)
        - k3 * (x0 ** 3)          # cubic nonlinearity in restoring force (-alpha*x^3)
        - k4 * (x0 ** 4)          # quartic nonlinearity in restoring force
        
        - d1 * x1                 # linear damping (-c*v)
        - d2 * (x1 ** 2)          # quadratic damping term (-...)
        - d3 * (x1 ** 3)          # cubic damping term (-beta*v^3)

        + cross1 * (x0 * x1)           # cross term coupling position and velocity (+/-)
        + cross2 * ((x0 ** 2) * x1)     #
        + cross3 * (x0 * (x1 ** 2))     #

        + h_pos * np.tanh(x0)           # smooth higher order position nonlinearity
        
        + h_vel_smooth * np.exp(-np.abs(x1))   # smooth nonlinear velocity effect to capture subtle dynamics
    )
    
    return acc_poly_terms
