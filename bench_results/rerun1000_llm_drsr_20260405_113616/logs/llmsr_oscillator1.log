def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved version of `equation_v1` to better capture nonlinear harmonic oscillator dynamics.

    Physical reasoning:
    - The acceleration in a nonlinear oscillator typically depends on position and velocity,
      including linear restoring force (-k*x0), nonlinear restoring forces (e.g., cubic stiffness),
      and damping terms (linear and possibly nonlinear in velocity).
    - Typical model form:
        y = a0 
            + a1*x0                 # linear stiffness term
            + a2*x1                 # linear damping term
            + a3*x0**2              # quadratic stiffness nonlinearity
            + a4*x0*x1              # coupling between position and velocity (nonlinear damping)
            + a5*x1**2              # quadratic velocity term (nonlinear damping)
            + a6*x0**3              # cubic stiffness nonlinearity
            + a7*x1**3              # cubic velocity term (higher order damping)
            + a8*(x0**2)*x1         # mixed nonlinear terms
            + a9*x0*(x1**2)         # mixed nonlinear terms
            + a10*np.abs(x0)        # possible non-smooth effects or friction-like terms
            + a11*np.abs(x1)        # possible non-smooth effects or friction-like terms

    Parameters:
    - params (np.ndarray): Array of 12 coefficients corresponding to each term.

    Returns:
    - np.ndarray: Calculated acceleration.
    """
    return (
        params[0]  # constant offset, often zero in physical oscillators but kept for flexibility
        + params[1] * x0
        + params[2] * x1
        + params[3] * (x0 ** 2)
        + params[4] * x0 * x1
        + params[5] * (x1 ** 2)
        + params[6] * (x0 ** 3)
        + params[7] * (x1 ** 3)
        + params[8] * (x0 ** 2) * x1
        + params[9] * x0 * (x1 ** 2)
        + params[10] * np.abs(x0)
        + params[11] * np.abs(x1)
    )
