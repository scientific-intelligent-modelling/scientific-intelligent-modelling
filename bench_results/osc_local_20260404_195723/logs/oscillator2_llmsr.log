def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Calculates acceleration y given time (x0), position (x1), and velocity (x2)
    for a nonlinear harmonic oscillator with cubic nonlinearity and damping.
    
    Parameters:
    - params: array-like with at least 12 elements representing coefficients.
    
    Returns:
    - y: acceleration values as numpy array.
    """
    # Unpack parameters for clarity
    c0 = params[0]   # constant term
    c_t = params[1]  # linear in time
    c_x = params[2]  # linear in position (restoring force)
    c_v = params[3]  # linear in velocity (damping)
    
    # Optional quadratic terms if needed
    c_x3 = params[9] # cubic term in position
    
    y = (
        c0 +
        c_t * x0 +
        c_x * x1 +
        c_v * x2 +
        c_x3 * np.power(x1, 3)
    )
    
    return y
