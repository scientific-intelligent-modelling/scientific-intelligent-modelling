    - params (np.ndarray): array of 12 parameters controlling each term.

        params[0]: constant offset
        params[1]: linear in time coefficient
        params[2]: linear stiffness coefficient k (>0)
        params[3]: linear damping coefficient c (>0)
        params[4]: cubic stiffness coefficient alpha (>0)
        params[5]: quadratic velocity damping coefficient
        params[6]: quadratic position stiffness coefficient
        params[7]: cross term between position and velocity (nonlinear damping)
        params[8]: quadratic time effect
        params[9]: mixed time-position cubic effect
        params[10]: mixed time-velocity quadratic effect
        params[11]: amplitude of sinusoidal forcing

    Note:
    We use a fixed frequency omega for the sinusoidal forcing.
    """

    # Physically consistent positive coefficients for restoring/damping terms:
    k = abs(params[2])      # linear stiffness > 0
    c = abs(params[3])      # linear damping > 0
    alpha = abs(params[4])  # cubic stiffness > 0

    # Unpack other parameters for clarity:
    c0 = params[0]          # constant offset term
    c_time = params[1]      # linear in time term
    
    c_quad_vel = params[5]  # quadratic velocity damping (sign flexible)
    
    k_quad_pos = params[6]  # quadratic position stiffness (sign flexible)
    
    cross_pos_vel = params[7]   # cross term pos*vel
    
    c_time_sq = params[8]       # quadratic in time
    
    mixed_time_pos_cubic = params[9]
    
    mixed_time_vel_quad = params[10]
    
    amp_sin_forcing = params[11]   # amplitude of sinusoidal forcing
    
    omega = 2.0 * np.pi * 1.0       # fixed frequency, e.g., 1 Hz angular frequency
    
    y = (
          c0 
        + c_time * x0 
        - k * x1               # linear restoring force (-k*x)
        - c * x2               # linear damping (-c*v)
        - alpha * (x1 ** 3)     # cubic nonlinear restoring force (-alpha*x^3)
        
        - c_quad_vel * (x2 ** 2)   # nonlinear velocity squared damping/forcing
        
