def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved version of the nonlinear harmonic oscillator acceleration model.

    Physical reasoning and improvements over v1:
    - Retains constant offset.
    - Linear stiffness and damping terms with enforced positivity where physically required.
    - Cubic stiffness (Duffing nonlinearity).
    - Quadratic velocity damping term (v * |v|) to capture nonlinear dissipation.
    - Quadratic stiffness term (x1^2) to capture asymmetry or additional nonlinear restoring forces.
    - Cross coupling between position and velocity.
    - Time-dependent parametric excitation terms (linear and quadratic in time).
    - Mixed nonlinear time-position cubic term for richer dynamics.
    - Sinusoidal external forcing with amplitude and frequency parameters.
    - Higher order mixed nonlinear interaction term (sign depends on quadratic stiffness sign).

    Parameters indexing:
        params[0]  = c0                # constant offset / bias force
        params[1]  = c_time_lin         # linear in time effect
        params[2]  = k_lin              # linear stiffness coefficient (>0)
        params[3]  = c_damp             # linear damping coefficient (>0)
        params[4]  = k_cubic            # cubic stiffness coefficient (+/-)
        params[5]  = c_quad_vel         # quadratic velocity damping coefficient (usually negative)
        params[6]  = k_quad_pos         # quadratic stiffness coefficient (+/-)
        params[7]  = cross_pos_vel      # cross coupling between position and velocity
        params[8]  = c_time_sq          # quadratic in time effect / parametric excitation
        params[9]  = mixed_time_pos_cub # mixed time-position cubic nonlinearity
        params[10] = amp_forcing         # amplitude of sinusoidal forcing (>=0)
        params[11] = omega_forcing       # angular frequency of sinusoidal forcing (>=0)

    Returns:
      y : acceleration at given inputs.
    """

    c0               = params[0]
    c_time_lin       = params[1]

    k_lin            = abs(params[2])   # ensure positive restoring force coefficient
    c_damp           = abs(params[3])   # ensure positive damping

    k_cubic          = params[4]

    c_quad_vel       = params[5]

    k_quad_pos       = params[6]

    cross_pos_vel    = params[7]

    c_time_sq        = params[8]

    mixed_time_pos_cub= params[9]

    amp_forcing      = abs(params[10])

    omega_forcing     = abs(params[11])

    
    y = (
          c0 
          + c_time_lin * x0 
