          + params[10]*np.sin(2*x0)         # second harmonic sine forcing term
          + params[11]*np.cos(2*x0)         # second harmonic cosine forcing term

    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x2
        + params[4] * (x1 ** 3)
