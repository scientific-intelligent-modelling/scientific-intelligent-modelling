            - p4 * x1**3                   # cubic restoring force (-alpha*x^3)
            - p5 * x2                      # linear damping (-c*v)
            - p6 * x2**3                   # cubic damping
            + p7 * x1**2                   # quadratic position term (anharmonicity/asymmetry)
            + p8 * x2**2                   # quadratic velocity term (nonlinear damping effect)
            + p9 * x1*x2                   # coupling between position and velocity
