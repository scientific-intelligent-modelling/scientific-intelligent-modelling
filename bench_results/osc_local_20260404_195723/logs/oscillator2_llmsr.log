def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version extends the nonlinear harmonic oscillator acceleration model by including:
    - quartic nonlinearities in position (x1^4) for stronger anharmonic restoring forces
    - mixed cubic terms involving position and velocity (x1^2 * x2, x1 * x2^2)
    - higher order time-modulated forcing terms (sin(2*x0)*x1, cos(2*x0)*x2)
    - cubic time term (x0^3) to capture more complex slow modulation or drift effects

    Parameters:
        x0 (np.ndarray): time
        x1 (np.ndarray): position at time t
        x2 (np.ndarray): velocity at time t
        params (np.ndarray): array of up to 12 trainable coefficients

    Returns:
        y (np.ndarray): predicted acceleration
    """
    
    # Ensure params has length MAX_NPARAMS = 12 with zeros if fewer provided
    p = np.zeros(MAX_NPARAMS)
    n = min(len(params), MAX_NPARAMS)
    p[:n] = params[:n]
    
    y = (
        p[0]  # constant term
        
        + p[1] * x1  # linear restoring force (-k*x)
        
        + p[2] * (x1 ** 3)  # cubic stiffness nonlinearity
        
        + p[3] * x2  # linear damping (-c*v)
        
        + p[4] * (x2 ** 3)  # cubic damping nonlinearity
        
        + p[5] * (x1 ** 4)  # quartic stiffness nonlinearity
        
        + p[6] * (x1 ** 2) * x2   # mixed cubic term
        
        + p[7] * x1 * (x2 ** 2)   # mixed cubic term
        
        + p[8] * np.sin(2*x0) * x1   # higher harmonic forcing on position
        
        + p[9] * np.cos(2*x0) * x2   # higher harmonic forcing on velocity
        
        + p[10] * (x0 ** 3)   # cubic time modulation term
        
        + p[11] * np.sin(x0)   # fundamental sinusoidal forcing term
    )
    
    return y
