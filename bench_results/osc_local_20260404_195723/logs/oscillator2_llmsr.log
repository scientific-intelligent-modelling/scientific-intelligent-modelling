def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved version of the oscillator acceleration model.

    Model acceleration as:
        y = p0 
            + p1*t 
            + p2*x 
            + p3*x^3 
            + p4*v 
            + p5*v^3
            + p6*x*v
            + p7*x^2*v
            + p8*x*v^2
            + p9*x^2
            + p10*v^2
            + p11*t*x
            + p12*t*v          # new time-velocity interaction term (if params has 13 elements)
    
    where:
    - t = time (x0)
    - x = position (x1)
    - v = velocity (x2)

    Note:
        If params has only 12 elements, ignore the last term.
    
    Parameters:
        params: array-like with at least 12 elements.
    """
    
    # Base terms from equation_v1
    y = (
        params[0]
        + params[1] * x0
        + params[11] * x0 * x1   # time-position interaction term
        + params[2] * x1
        + params[3] * (x1 ** 3)
        + params[4] * x2
        + params[5] * (x2 ** 3)
        + params[6] * (x1 * x2)
        + params[7] * (x1 ** 2) * x2
        + params[8] * x1 * (x2 ** 2)
        + params[9] * (x1 ** 2)
        + params[10] * (x2 ** 2)
    )
    
    # Add an optional time-velocity interaction if available in parameters array length >12.
    if len(params) > 12:
        y += params[12] * x0 * x2
    
    return y
