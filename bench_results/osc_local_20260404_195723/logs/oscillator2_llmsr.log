    y += -abs(params[5]) * x2**2      # typically damping-like so negative
    
    # Quadratic position nonlinearity; can represent asymmetric potential well effects
    y += params[6] * x1**2
    
    # Cross-term between position and velocity; can represent coupling effects or parametric damping/driving
    y += params[7] * x1 * x2
    
    # Time squared effect / modulation; models slow changes in forcing or system parameters over time squared
    y += params[8] * x0**2
    
    # Mixed time-position cubic effect; models modulation of nonlinear stiffness by time-dependent factors
    y += params[9] * x0 * x1**3
    
    # Mixed time-velocity quadratic effect; modulation of quadratic velocity damping by time-dependent factors
    y += -abs(params[10]) * x0 * x2**2
