def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved equation for acceleration in nonlinear harmonic oscillator.

    Variables:
    - x0: time t
    - x1: position at time t
    - x2: velocity at time t

    Parameters:
    - params: array of 12 parameters controlling each term.

    Model structure:
        y = acceleration =
            constant offset +
            linear time effect +
            linear stiffness * position +
            linear damping * velocity +
            cubic stiffness * position^3 +
            quadratic velocity damping * velocity^2 +
            quadratic stiffness * position^2 +
            cross term between position and velocity +
            quadratic time effect +
            mixed time-position cubic term +
            sinusoidal forcing term (amplitude * sin(freq * t)) +
            higher order mixed term (position squared times velocity)
    """

    c0 = params[0]   # constant offset
    c_time = params[1]  # linear in time
    k_lin = params[2]   # linear stiffness coefficient (position)
    c_damp = params[3]  # linear damping coefficient (velocity)

    k_cubic = params[4]  # cubic stiffness coefficient (position^3)

    c_quad_vel = params[5]  # quadratic velocity damping

    k_quad_pos = params[6]  # quadratic stiffness

    cross_pos_vel = params[7]  # cross product pos*vel

    c_time_sq = params[8]   # quadratic in time

    mixed_time_pos_cubic = params[9]

    amp_forcing = params[10]   # amplitude of sinusoidal forcing

    omega_forcing = params[11]  # angular frequency of sinusoidal forcing

    
    y = (
          c0 
        + c_time * x0 
        - abs(k_lin) * x1       # restoring force negative proportional to displacement
        - abs(c_damp) * x2      # damping force opposes velocity
        
        - abs(k_cubic) * x1**3  # nonlinear restoring force
        
        - abs(c_quad_vel) * x2**2   # nonlinear damping
        
        - abs(k_quad_pos) * x1**2   # additional nonlinear stiffness
        
        + cross_pos_vel * x1 * x2
        
        + c_time_sq * x0**2
        
        + mixed_time_pos_cubic * x0 * (x1**3)
        
        + amp_forcing * np.sin(omega_forcing * x0)
        
        + ((x1 ** 2) * x2)       # higher order mixed term scaled by sign of param
          * np.sign(params[11]) if omega_forcing != 0 else ((x1 ** 2) * x2)
       )
    
    return y
