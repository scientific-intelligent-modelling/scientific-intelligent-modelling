    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` focusing on physical interpretability:
    - Linear stiffness (-k * x1)
    - Nonlinear stiffness (-alpha * x1^3)
    - Linear damping (-c * x2)
    - Quadratic damping (d * x2 * |x2|)
    - Cross coupling between position and velocity
    - Optional time-dependent forcing or parametric terms
    
    Parameters:
        params[0]: constant offset
        params[1]: coefficient for time (x0)
        params[2]: linear stiffness coefficient (should be negative for restoring force)
        params[3]: linear damping coefficient (should be negative for dissipation)
        params[4]: cubic stiffness coefficient
        params[5]: quadratic velocity damping coefficient
        params[6]: quadratic position term coefficient
        params[7]: cross term coefficient between position and velocity
        params[8]: time squared effect coefficient
        params[9]: mixed time-position cubic term coefficient
        params[10]: mixed time-quadratic velocity term coefficient
        params[11]: higher order mixed term coefficient
        
    Returns:
        y: acceleration array corresponding to input arrays.
    """
    
    # Constant + linear terms including time effect
    y = (
          params[0] 
          + params[1]*x0 
          + params[2]*x1  # linear stiffness; expect negative value for restoring force 
          + params[3]*x2  # linear damping; expect negative value for dissipation 
         )
    
    # Nonlinear cubic stiffness term (-alpha * x^3)
    y += params[4] * x1**3
    
    # Quadratic velocity damping term (e.g., d * v |v|)
    y += params[5] * x2 * np.abs(x2)
    
    # Quadratic position nonlinearity
    y += params[6] * x1**2
    
    # Cross coupling between position and velocity
    y += params[7] * x1 * x2
    
    # Time squared effect (parametric excitation possibility)
    y += params[8] * x0**2
    
    # Mixed time-position cubic nonlinearity
    y += params[9] * x0 * x1**3
    
    # Mixed time-quadratic velocity effect
    y += params[10] * x0 * (x2**2)
    
    # Higher order mixed nonlinearities e.g., squared position times velocity 
    y += params[11] * (x1**2) * x2

    
    return y
