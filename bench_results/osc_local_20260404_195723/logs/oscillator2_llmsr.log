    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved version of the nonlinear harmonic oscillator acceleration model.

    Models acceleration y as a function of time (x0), position (x1), and velocity (x2) with nonlinear stiffness,
    damping, coupling terms, and time-dependent effects:

        y = params[0] 
            + params[1]*x0 
            + params[11]*(x0**2)
            + params[2]*x1 
            + params[4]*(x1**3) 
            + params[7]*(x1**5)
            + params[3]*x2 
            + params[6]*(x2**3) 
            + params[10]*(x2**5)
            + params[5]*(x1*x2) 
            + params[8]*((x1**2)*x2) 
            + params[9]*(x1*(x2**2))

    Where:
        - x0: time array
        - x1: position array
        - x2: velocity array
        - y: acceleration array

    Parameters:
        - params (np.ndarray): Array of parameters with length >= 12

    Returns:
        - y (np.ndarray): Calculated acceleration values
    """
    
    # Unpack parameters for clarity (optional)
    c0 = params[0]      # constant offset
    c_t = params[1]     # linear time dependence
    c_t2 = params[11]   # quadratic time dependence
    
    k_lin = params[2]   # linear stiffness coefficient (-ω²)
    k_cub = params[4]   # cubic stiffness nonlinearity (-α)
    k_qui = params[7]   # quintic stiffness nonlinearity
    
    b_lin = params[3]   # linear damping coefficient (-β)
    
    b_cub_vel = params[6]  # cubic velocity nonlinearity damping term
    b_qui_vel = params[10] # quintic velocity nonlinearity damping term
    
    c_pos_vel_1 = params[5]  # coupling term x1*x2
    c_pos_vel_2 = params[8]  # coupling term (x1^2)*x2
    c_pos_vel_3 = params[9]  # coupling term x1*(x2^2)

    return (
        c0
        + c_t * x0
        + c_t2 * (x0 ** 2)
        + k_lin * x1
        + k_cub * (x1 ** 3)
        + k_qui * (x1 ** 5)
        + b_lin * x2
        + b_cub_vel * (x2 ** 3)
        + b_qui_vel * (x2 ** 5)
        + c_pos_vel_1 * (x1 * x2)
        + c_pos_vel_2 * ((x1 ** 2) * x2)
        + c_pos_vel_3 * (x1 * (x2 ** 2))
    )
