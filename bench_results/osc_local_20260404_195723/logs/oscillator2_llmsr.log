def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved version of equation modeling acceleration in a nonlinear harmonic oscillator.

    Parameters:
    - x0: time array
    - x1: position array at time t
    - x2: velocity array at time t
    - params: array of 12 parameters with physical meaning:
        params[0]: constant offset acceleration (e.g. bias)
        params[1]: linear time-dependent forcing amplitude
        params[2]: linear stiffness coefficient (restoring force magnitude)
        params[3]: linear viscous damping coefficient (positive)
        params[4]: cubic stiffness coefficient (nonlinear restoring force)
        params[5]: quadratic velocity damping coefficient (nonlinear damping)
        params[6]: quadratic position nonlinearity coefficient
        params[7]: cross term coefficient between position and velocity
        params[8]: quadratic time effect coefficient (parametric forcing)
        params[9]: mixed time-position cubic term coefficient
        params[10]: mixed time-velocity quadratic term coefficient
        params[11]: higher order mixed nonlinear interaction term

    Returns:
    - y: acceleration array modeled by the nonlinear oscillator equation.
    """

    # Linear restoring force always opposes displacement (-k*x)
    restoring_force = -abs(params[2]) * x1

    # Linear viscous damping always opposes velocity (-c*v)
    linear_damping = -abs(params[3]) * x2

    # Nonlinear cubic stiffness term (+ or - depending on param sign)
    cubic_stiffness = params[4] * x1**3

    # Quadratic velocity dependent damping-like term; often models drag ~ v|v|
    # Use sign(x2)*x2^2 = |x2|*x2 to preserve direction opposing motion if param positive.
    quad_velocity_damping = -np.sign(x2) * abs(params[5]) * x2**2

    # Quadratic position nonlinearity (can stiffen or soften spring)
    quad_position = params[6] * x1**2

    # Cross-term between position and velocity; can model coupling effects
    cross_pos_vel = params[7] * x1 * x2

    # Time squared effect / parametric forcing modulation
    time_quad_effect = params[8] * x0**2

    # Mixed time-position cubic effect; e.g. modulation of nonlinear stiffness by time
    mixed_time_pos_cubic = params[9] * x0 * x1**3

    # Mixed time-velocity quadratic effect; e.g. modulation of nonlinear damping by time
    mixed_time_vel_quad = params[10] * x0 * x2**2

    
    # Higher order mixed nonlinear interaction term e.g. pos^2*vel 
    higher_order_mixed = params[11] * (x1**2) * x2


    
    y = (
          params[0]
        + params[1]*x0                 # linear forcing in time 
        + restoring_force              # linear restoring force (-k*x)
        + linear_damping              # linear viscous damping (-c*v)
        + cubic_stiffness             # cubic stiffness nonlinearity 
        + quad_velocity_damping       # quadratic velocity dependent damping (~v|v|)
        + quad_position               # quadratic position nonlinearity 
        + cross_pos_vel               # cross-term pos*vel coupling 
        + time_quad_effect            # parametric forcing via t^2 
        + mixed_time_pos_cubic         # modulated cubic stiffness by t*x^3 
        + mixed_time_vel_quad          # modulated quadratic vel^2 by t 
        + higher_order_mixed           # higher order nonlinear interaction pos^2*vel 
     )

    
    return y
