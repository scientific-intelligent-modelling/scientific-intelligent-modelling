def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further enriches the nonlinear harmonic oscillator acceleration model by including:
    - constant offset
    - linear and nonlinear restoring force terms (position-dependent)
    - linear and nonlinear damping terms (velocity-dependent)
    - time-dependent forcing terms (sinusoidal in time)
    - interaction terms between position, velocity, and time
    - higher order nonlinearities including mixed polynomial and trigonometric terms
    - cross-terms to capture coupling effects between variables

    Parameters:
    - x0: time
    - x1: position at time t
    - x2: velocity at time t
    - params (np.ndarray): array of 12 trainable coefficients

    Returns:
    - y (np.ndarray): predicted acceleration
    """
    
    return (
        params[0]  # constant term (bias)
        + params[1] * x1  # linear restoring force ~ position
        + params[2] * (x1 ** 3)  # cubic nonlinearity in restoring force
        + params[3] * x2  # linear damping ~ velocity
        + params[4] * (x2 ** 3)  # cubic nonlinear damping term
        + params[5] * np.sin(x0)  # sinusoidal forcing term with time
        + params[6] * np.cos(x0)  # another sinusoidal forcing term with time 
        + params[7] * x0 * x1  # parametric excitation coupling time and position 
        + params[8] * (x1 ** 2)  # quadratic position term for restoring force flexibility 
        + params[9] * (x2 ** 2)  # quadratic velocity term for damping flexibility 
        + params[10] * x1 * x2   # interaction between position and velocity 
        + params[11] * np.sin(x1) * np.cos(x2)   # mixed nonlinear trigonometric interaction of position & velocity 
    )
