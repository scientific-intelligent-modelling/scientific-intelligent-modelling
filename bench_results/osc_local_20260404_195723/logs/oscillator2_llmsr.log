        + params[9] * x0  # linear time dependence to capture slow drift or parametric effects
        + params[10] * (x0 ** 2)  # quadratic time dependence for flexibility
        + params[11] * np.sin(2 * x0)  # second harmonic forcing component for richer dynamics
    )
