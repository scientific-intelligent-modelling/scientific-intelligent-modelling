def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration as a nonlinear function of time (x0), position (x1), and velocity (x2).
    Includes constant, linear, quadratic, cubic and cross-product terms,
    plus higher-order mixed nonlinearities relevant for nonlinear oscillators.
    
    Parameters:
    - x0: time
    - x1: position at time t
    - x2: velocity at time t
    - params: array of 12 parameters controlling each term's coefficient
    
    Returns:
    - y: acceleration at time t
    """
    
    # Constant + linear terms
    y = params[0] + params[1]*x0 + params[2]*x1 + params[3]*x2
    
    # Nonlinear stiffness cubic term in position
    y += params[4] * x1**3
    
    # Quadratic velocity damping term (nonlinear damping)
    y += params[5] * x2**2
    
    # Quadratic position term (nonlinear stiffness)
    y += params[6] * x1**2
    
    # Cross term between position and velocity (damping or coupling)
    y += params[7] * x1 * x2
    
    # Time squared effect (could model parametric excitation)
    y += params[8] * x0**2
    
    # Mixed time-position cubic term (modulated stiffness)
    y += params[9] * x0 * x1**3
    
    # Mixed time-velocity quadratic term (modulated damping)
    y += params[10] * x0 * x2**2
    
    # Higher order mixed term e.g. position squared times velocity
    y += params[11] * (x1**2) * x2

    
    return y
