def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version adds more nonlinear interaction terms and higher harmonics to better capture
    complex dynamics of a nonlinear harmonic oscillator with damping, forcing, and anharmonicity.

    Model structure:
    y = params[0] 
        + params[1]*x0                      # linear time term
        + params[2]*x1                      # linear position term (restoring force)
        + params[3]*x1**3                   # cubic nonlinearity in position (Duffing-type)
        + params[4]*x2                      # linear velocity term (damping)
        + params[5]*x0*x1                  # interaction between time and position
        + params[6]*x0*x2                  # interaction between time and velocity
        + params[7]*x1**2                  # quadratic position term (nonlinear stiffness)
        + params[8]*x2**2                  # quadratic velocity term (nonlinear damping)
        + params[9]*np.sin(x0)             # sinusoidal forcing term (time-dependent external force)
        + params[10]*np.cos(2*x0)          # second harmonic cosine forcing term
        + params[11]*(x1**2)*x2            # mixed nonlinear interaction: quadratic position * velocity
        + params[12]*(x1**4)                # quartic nonlinearity in position for stronger anharmonicity
        + params[13]*(x2**3)                # cubic velocity term for complex damping effects

        + (params[14] if len(params)>14 else 0.0)* x1 * x2          # cross product of position and velocity
        + (params[15] if len(params)>15 else 0.0)* np.sin(3*x0)      # third harmonic forcing term
        + (params[16] if len(params)>16 else 0.0)* x1**5            # quintic nonlinearity in position
        + (params[17] if len(params)>17 else 0.0)* x2**4            # quartic velocity nonlinearity for advanced damping effects

    Parameters:
    - x0: time array
    - x1: position array at time t
    - x2: velocity array at time t
    - params: array of parameters; expected length >= 18 for full model

    Returns:
    - y: acceleration array at given t,x,v
    """
    
    p = lambda i: params[i] if i < len(params) else 0.0
    
    return (
