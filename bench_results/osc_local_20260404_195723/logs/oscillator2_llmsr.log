def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Model acceleration as a nonlinear oscillator with:
    - constant term
    - linear time dependence
    - linear and cubic restoring forces (position terms)
    - linear, cubic velocity damping terms
    - quadratic velocity-position coupling
    - cubic velocity-position coupling
    - quadratic position-velocity damping term
    - quadratic position squared term (nonlinear stiffness)
    
    Equation form:

        y = p0 
            + p1*t 
            + p2*x 
            + p3*x^3 
            + p4*v 
            + p5*v^3 
            + p6*(v^2 * x) 
            + p7*(v * x^3) 
            + p8*(v^2 * x^2) 
            + p9*(x^2)

    where:
        t = time (x0)
        x = position (x1)
        v = velocity (x2)

    Parameters:
        params: array-like with at least 10 elements.

    Returns:
        y : acceleration at time t
    """
    
    return (
        params[0]
