    v = x2
    
    return (
          params[0]                # constant offset
        + params[1] * x            # linear position term (-ω² *x)
        + params[2] * (x ** 3)     # cubic nonlinearity in position
        + params[3] * v            # linear velocity term (damping)
        + params[4] * (v ** 3)     # cubic nonlinearity in velocity
        + params[5] * (x * v)      # interaction between position and velocity
        + params[6] * t            # linear time dependence
