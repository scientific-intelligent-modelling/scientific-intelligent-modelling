def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Calculates acceleration y of a nonlinear harmonic oscillator given:
    - x0: time t
    - x1: position at time t
    - x2: velocity at time t

    Parameters:
    params[0]: constant forcing / offset
    params[1]: linear parametric excitation coefficient (time-dependent forcing)
    params[2]: linear stiffness coefficient magnitude (k > 0)
    params[3]: linear damping coefficient magnitude (c > 0)
    params[4]: cubic stiffness coefficient magnitude (alpha > 0)
    params[5]: quadratic velocity damping coefficient (nonlinear damping)
    params[6]: quadratic position stiffness coefficient
    params[7]: cross term between position and velocity (nonlinear damping or coupling)
    params[8]: quadratic time effect (time-dependent forcing)
    params[9]: mixed time-position cubic effect
    params[10]: mixed time-velocity quadratic effect
    params[11]: higher order mixed term ((x1^2)*x2)

    Returns:
        y: acceleration at given inputs.
    
    Physical model notes:
        The restoring forces are negative in acceleration,
        so their coefficients are enforced positive and multiplied by -1.
        Damping terms similarly reduce acceleration.
        Other nonlinear terms can have positive or negative signs as learned.
    
    """
    
    # Enforce positive magnitudes for physically negative contributions
    k = abs(params[2])       # linear stiffness magnitude (>0)
    c = abs(params[3])       # linear damping magnitude (>0)
    alpha = abs(params[4])   # cubic stiffness magnitude (>0)

    y = (
        params[0]                              # constant forcing / offset
        
        + params[1] * x0                      # parametric excitation (time-dependent forcing)
        
        - k * x1                             # linear restoring force (-k*x1)
        
        - c * x2                             # linear damping (-c*x2)
        
        - alpha * (x1 ** 3)                  # cubic nonlinear restoring force (-alpha*x1^3)
        
        + params[5] * (x2 ** 2)              # nonlinear velocity squared term
        
        + params[6] * (x1 ** 2)              # quadratic position stiffness term
        
        + params[7] * (x1 * x2)              # cross term between position and velocity
        
        + params[8] * (x0 ** 2)              # quadratic time effect
        
        + params[9] * (x0 * (x1 ** 3))      # mixed time-position cubic effect
        
        + params[10] * (x0 * (x2 ** 2))     # mixed time-velocity quadratic effect
        
        + params[11] * ((x1 ** 2) * x2)     # higher order mixed term
     )
    
    return y
