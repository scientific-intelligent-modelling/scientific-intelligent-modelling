def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculate acceleration for nonlinear harmonic oscillator:
    y = params[0] + params[1]*x0 + params[2]*x1 + params[3]*x1**3 + params[4]*x2
    where:
    - params[0]: constant offset
    - params[1]: coefficient for time (optional)
    - params[2]: linear stiffness term (-ω²)
    - params[3]: nonlinear stiffness term (-α)
    - params[4]: damping coefficient (-β)
    
    Returns acceleration y.
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * (x1 ** 3)
        + params[4] * x2
    )
