            params[0]  = constant offset term
            params[1]  = linear coefficient for time (forcing)
            params[2]  = linear coefficient for position (restoring force)
            params[3]  = linear coefficient for velocity (damping)
            params[4]  = quadratic coefficient for position^2 (stiffness nonlinearity)
            params[5]  = quadratic coefficient for velocity^2 (nonlinear damping)
            params[6]  = cross term coefficient for position*velocity
            params[7]  = cubic coefficient for velocity^3 (nonlinear damping)
            params[8]  = cross term coefficient for position^2 * velocity
