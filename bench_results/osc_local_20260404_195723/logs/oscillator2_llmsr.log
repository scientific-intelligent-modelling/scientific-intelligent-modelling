        + params[10] * (x ** 2)    # quadratic position term for additional flexibility
        + params[11] * (v ** 2)    # quadratic velocity term for additional flexibility
        + params[12] * ((x ** 2) * v)   # nonlinear damping dependent on position squared times velocity
    )
