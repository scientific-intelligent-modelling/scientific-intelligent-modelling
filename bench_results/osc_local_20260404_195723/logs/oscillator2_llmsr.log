    using a nonlinear harmonic oscillator model with cubic nonlinearity in position.
    
    Parameters:
    - params: array-like coefficients [p0,...]
    
    Returns:
    - y: acceleration values
    """
    # Unpack parameters safely with default 0 if not enough params provided
    p = np.zeros(MAX_NPARAMS)
    n = min(len(params), MAX_NPARAMS)
    p[:n] = params[:n]
    
    # Construct equation
    y = (
        p[0]               # constant term
        + p[1] * x0        # linear in time
        + p[2] * x1        # linear in position
        + p[3] * x2        # linear in velocity (damping)
        + p[4] * x1**3     # cubic nonlinearity in position
        # Optionally add more terms if desired:
        # + p[5] * x2**2   # quadratic velocity term (less common)
        # + p[6] * x1*x2   # cross term between position and velocity
    )
    
    return y
