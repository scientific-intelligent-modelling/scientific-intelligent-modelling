def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration y as a physically meaningful nonlinear oscillator acceleration,
    including:
      - constant offset (baseline forcing)
      - linear and quadratic time-dependent forcing/drift
      - linear restoring force (-ω² * x)
      - linear damping (proportional to velocity)
      - cubic stiffness nonlinearity (x^3)
      - quadratic and cubic velocity nonlinearities (v^2 and v^3)
      - interaction terms between position and velocity
      - time-dependent interaction terms with position and velocity
      - quadratic position term for additional flexibility

    The general form is:

        y = p0 
            + p1 * t 
            + p7 * t^2
            + p2 * x 
            + p11 * x^2
            + p4 * x^3 
            + p3 * v 
            + p5 * v^2 
            + p10 * v^3
            + p6 * (x * v) 
            + p8 * (t * x) 
            + p9 * (t * v)

    Parameters:
    - params: array-like of length at least 12

    Variables:
    - x0: time t
    - x1: position x(t)
    - x2: velocity v(t)

    Returns:
    - y: acceleration a(t)
    """

    t = x0
    x = x1
    v = x2

    return (
        params[0]               # constant offset baseline forcing term
        + params[1] * t         # linear time-dependent forcing/drift term
        + params[7] * (t ** 2)  # quadratic time effect / forcing modulation over time squared
        
        + params[2] * x         # linear restoring force (-ω²*x)
        + params[11] * (x ** 2) # quadratic position term for potential energy shape flexibility
        + params[4] * (x ** 3)  # cubic stiffness nonlinearity in position
        
        + params[3] * v         # linear damping term (~velocity)
        + params[5] * (v ** 2)  # quadratic velocity nonlinearity for richer dynamics/damping effects
        + params[10] * (v ** 3) # cubic velocity nonlinearity for complex damping/nonlinear effects
        
        + params[6] * (x * v)   # interaction between position and velocity
        
        + params[8] * (t * x)   # interaction between time and position
        + params[9] * (t * v)   # interaction between time and velocity
    )
