def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further extends the nonlinear oscillator model by including:
    - cubic and quartic nonlinear stiffness terms in position,
    - nonlinear damping terms involving velocity and position,
    - cross terms between velocity squared and position cubed,
    - time-dependent nonlinear terms to capture possible parametric excitation effects.

    Model:
        y = params[0] 
            + params[1]*x0 
            + params[2]*x1 
            + params[3]*x2 
            + params[4]*x1**3
            + params[5]*x1*x2
            + params[6]*x2**3
            + params[7]*(x1**2)
            + params[8]*(x2**2)
            + params[9]*(x1**2)*x2
            + params[10]*x1*(x2**2)
            + params[11]*x0*(x1**3)

    Extended with:
        + params[12]*(x1**4)
        + params[13]*(x1**5)
        + params[14]*(x1*x2**2)
        + params[15]*(x0*x1*x2)

    Note: Since MAX_NPARAMS=12 in original code, you may need to increase it to 16 for this version.

    Parameters:
        - x0: time array (independent variable)
        - x1: position array at time t
        - x2: velocity array at time t
        - params: array of parameters with length >= 16

    Returns:
        - y: acceleration array modeled by the equation above.
    """
    
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x2
        + params[4] * (x1 ** 3)
        + params[5] * (x1 * x2)
        + params[6] * (x2 ** 3)
        + params[7] * (x1 ** 2)
        + params[8] * (x2 ** 2)
        + params[9] * ((x1 ** 2) * x2)
        + params[10] * (x1 * (x2 ** 2))
        + params[11] * (x0 * (x1 ** 3))
        
        # extended terms below:
        
        # quartic stiffness term in position
        + (params[12] if len(params) > 12 else 0) * (x1 ** 4)  
        
         # quintic stiffness term in position for stronger nonlinearity capture
         # safe fallback if param missing 
         # Note: if len(params)<=13, this term is zero.
         # Adjust MAX_NPARAMS accordingly if used.
         
         # higher order nonlinear stiffness term in position^5
         +(params[13] if len(params) > 13 else 0) * (x1 ** 5)

         # nonlinear damping-like term coupling velocity squared and position linearly 
         +(params[14] if len(params) >14 else 0) *( x1*( x2**2))

         # time-dependent cross term between time, position and velocity capturing parametric effects 
         +(params [15 ] if len(params)>15 else 0)* ( x0* x1* x2 )
         
     )
