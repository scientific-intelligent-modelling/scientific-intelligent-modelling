def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version models acceleration in a nonlinear harmonic oscillator considering:
    - constant offset
    - linear and quadratic time dependence
    - linear, quadratic, cubic terms in position (restoring force)
    - linear, quadratic, cubic terms in velocity (damping)
    - interaction terms between position and velocity (including higher order)
    - sinusoidal forcing and exponential decay forcing in time
    - mixed nonlinear interaction terms involving position and velocity

    Parameters:
        x0 (np.ndarray): time variable
        x1 (np.ndarray): position at time t
        x2 (np.ndarray): velocity at time t
        params (np.ndarray): array of length 12 coefficients

    Returns:
        y (np.ndarray): predicted acceleration at each input point
    """
    
    return (
        params[0]  # constant term
        + params[1] * x0  # linear time term
        + params[2] * x1  # linear position term (-ω²x)
        + params[3] * (x1 ** 3)  # cubic restoring force (-αx³)
        + params[4] * x2  # linear velocity term (-βv)
        + params[5] * (x2 ** 3)  # cubic nonlinear damping 
        + params[6] * (x1 ** 2)  # quadratic position nonlinearity 
        + params[7] * (x2 ** 2)  # quadratic velocity nonlinearity 
        + params[8] * (x1 * x2)  # interaction between position and velocity 
        + params[9] * np.sin(x0)  # sinusoidal external forcing 
        + params[10] * np.exp(-np.abs(x0))  # decaying forcing or modulation effect 
        + params[11] * (x1 ** 3 * x2)  # higher order nonlinear interaction term
    )
