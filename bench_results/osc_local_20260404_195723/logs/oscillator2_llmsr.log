    y += params[7] * x1 * x2
    
    # Time squared effect / modulation
    y += params[8] * x0**2
    
    # Mixed time-position cubic effect
    y += params[9] * x0 * x1**3
    
    # Mixed time-velocity quadratic effect
    y += params[10] * x0 * x2**2
    
    # Higher order mixed nonlinear interaction term e.g. pos^2*vel 
    y += params[11] * (x1**2) * x2

    
    return y
