def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    This version models the acceleration of a nonlinear harmonic oscillator as a combination of:
    - constant offset
    - linear and nonlinear restoring force terms (position-dependent)
    - linear and nonlinear damping terms (velocity-dependent)
    - time-dependent forcing via sinusoids
    - interaction terms between position, velocity, and time
    - additional nonlinear trigonometric and polynomial interaction terms to capture complex dynamics

    Parameters:
    - x0: time
    - x1: position at time t
    - x2: velocity at time t
    - params: array of 12 trainable coefficients

    Returns:
    - y: predicted acceleration
    """
    
    return (
        params[0]  # constant term (bias)
        + params[1] * x1  # linear restoring force ~ position (Hooke's law)
        + params[2] * (x1 ** 3)  # cubic stiffness nonlinearity in restoring force
        + params[3] * x2  # linear damping ~ velocity
        + params[4] * (x2 ** 3)  # cubic nonlinear damping term
        + params[5] * np.sin(x0)  # sinusoidal forcing term depending on time
        + params[6] * np.cos(x0)  # another sinusoidal forcing term depending on time
        + params[7] * x0 * x1  # parametric excitation coupling time and position
        + params[8] * (x1 ** 2)  # quadratic position term for additional restoring force flexibility 
        + params[9] * (x2 ** 2)  # quadratic velocity term for nonlinear damping flexibility 
        + params[10] * np.sin(x1) * x2   # combined nonlinear restoring force modulated by velocity 
        + params[11] * np.cos(x2) * x1   # combined nonlinear damping modulated by position 
    )
