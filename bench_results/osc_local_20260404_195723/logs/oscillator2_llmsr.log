def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculates acceleration of a nonlinear harmonic oscillator given time (x0),
    position (x1), and velocity (x2).

    Parameters:
        params[0]: constant offset
        params[1]: linear time coefficient
        params[2]: linear stiffness coefficient (restoring force)
        params[3]: linear damping coefficient
        params[4]: cubic stiffness coefficient (nonlinear restoring force)
        params[5]: quadratic velocity damping coefficient
        params[6]: quadratic position term coefficient
        params[7]: cross term coefficient between position and velocity
        params[8]: time squared effect coefficient (parametric excitation)
        params[9]: mixed time-position cubic term coefficient
        params[10]: sinusoidal forcing frequency parameter (omega)
        params[11]: sinusoidal forcing amplitude parameter

    Returns:
        y: acceleration array corresponding to input arrays.
    """

    c0 = params[0]            # constant offset
    c_time = params[1]         # linear in time term
    k_lin = params[2]          # linear stiffness coefficient (>0)
    c_damp = params[3]         # linear damping coefficient (>0)
    
    k_cubic = params[4]         # cubic stiffness coefficient (>0)
    
    c_quad_vel = params[5]      # quadratic velocity damping
    
    k_quad_pos = params[6]      # quadratic stiffness
    
    cross_pos_vel = params[7]   # cross product of pos*vel
    
    c_time_sq = params[8]       # quadratic in time
    
    mixed_time_pos_cubic = params[9]
    
    omega_forcing = abs(params[10])  # frequency of external forcing, ensure positive
    
    amp_forcing = params[11]          # amplitude of external forcing

    y = (
          c0 
        + c_time * x0 
        - k_lin * x1             # restoring force (-k*x)
        - c_damp * x2            # damping force (-c*v)

        - k_cubic * x1**3         # nonlinear restoring force (-alpha*x^3)

        - c_quad_vel * x2 * np.abs(x2)  # nonlinear damping proportional to v|v|

        - k_quad_pos * x1**2      # additional nonlinear stiffness

        + cross_pos_vel * x1 * x2

        + c_time_sq * x0**2

        + mixed_time_pos_cubic * x0 * (x1**3)

       )

    # Add sinusoidal external forcing term: amp_forcing*sin(omega*t)
    y += amp_forcing * np.sin(omega_forcing * x0)

    return y
