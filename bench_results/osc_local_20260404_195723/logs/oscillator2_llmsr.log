def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator as a function of time (x0),
    position (x1), and velocity (x2).

    The model includes:
    - Constant term
    - Linear terms in time, position, velocity
    - Cubic nonlinearity in position (typical Duffing oscillator term)
    - Quadratic and linear terms in velocity to capture damping/nonlinear damping
    - Cross term between position and velocity to capture coupling effects
    - Optional time-dependent forcing term

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of parameters with length at least 9

            params[0]: constant offset
            params[1]: coefficient for time (forcing frequency or trend)
            params[2]: linear stiffness coefficient (-k)
            params[3]: linear damping coefficient (-c)
            params[4]: cubic stiffness coefficient (-alpha)
            params[5]: quadratic velocity coefficient (nonlinear damping)
            params[6]: cross term coefficient between position and velocity
            params[7]: optional sinusoidal forcing amplitude multiplier for sin(omega * t)
            params[8]: angular frequency omega for sinusoidal forcing

    Returns:
        y: acceleration at time t as numpy array
    """

    # Unpack parameters for clarity
    c0 = params[0]
    c_time = params[1]
    c_pos = params[2]
    c_vel = params[3]
    c_pos3 = params[4]
    c_vel2 = params[5]
    c_pos_vel = params[6]

    # Optional sinusoidal forcing if parameters provided; else zero forcing.
    if len(params) > 8:
        forcing_ampl = params[7]
        omega = params[8]
        forcing_term = forcing_ampl * np.sin(omega * x0)
    else:
        forcing_term = 0.0

    
    return (
        c0 
        + c_time * x0 
        + c_pos * x1 
        + c_vel * x2 
        + c_pos3 * x1**3 
        + c_vel2 * x2**2 
        + c_pos_vel * x1 * x2 
        + forcing_term
     )
