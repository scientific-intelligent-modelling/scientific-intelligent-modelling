def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Calculate acceleration for nonlinear harmonic oscillator including higher order nonlinear,
    cross terms and mixed time-velocity terms to capture more complex dynamics:

    y = p0 + p1*t + p2*x + p3*v + p4*x^3 + p5*v^2 + p6*x^2 + p7*x*v + p8*v^3 +
        p9*x^2*v + p10*x*v^2 + p11*t*x +
        p12*t*v  (if params has 13 elements)

    Parameters:
    - params[0]: constant offset
    - params[1]: coefficient for time t
    - params[2]: coefficient for position x
    - params[3]: coefficient for velocity v
    - params[4]: coefficient for cubic term in position (x^3)
    - params[5]: coefficient for quadratic term in velocity (v^2)
    - params[6]: coefficient for quadratic term in position (x^2)
    - params[7]: coefficient for cross term (x * v)
    - params[8]: coefficient for cubic term in velocity (v^3)
    - params[9]: coefficient for cross term (x^2 * v)
    - params[10]: coefficient for cross term (x * v^2)
    - params[11]: coefficient for cross term (t * x)
    - params[12]: coefficient for cross term (t * v)

    Returns:
        Acceleration array.
    """
    
    # If fewer than 13 parameters are provided, treat missing ones as zero
    n_params = len(params)
    
    y = (
        params[0] +
        params[1] * x0 +
        params[2] * x1 +
        params[3] * x2 +
        params[4] * (x1 ** 3) +
        params[5] * (x2 ** 2) +
        params[6] * (x1 ** 2) +
        params[7] * (x1 * x2) +
        params[8] * (x2 ** 3) +
        params[9] * (x1 ** 2) * x2 +
        params[10] * x1 * (x2 ** 2) +
        params[11] * x0 * x1
    )
    
    if n_params > 12:
        y += params[12] * x0 * x2
    
    return y
