def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration y as a physically meaningful nonlinear oscillator acceleration,
    including:
      - constant offset and time-dependent forcing (linear + quadratic in time)
      - linear restoring force (proportional to position)
      - cubic stiffness nonlinearity (position^3)
      - linear and nonlinear damping terms (velocity, velocity^2, velocity^3)
      - interaction terms between position & velocity and time & state variables
      - adds cross nonlinearities involving position squared times velocity and velocity squared times position

    Parameters:
    - x0: time t
    - x1: position x(t)
    - x2: velocity v(t)
    - params: array of length 12 containing coefficients for each term

    Returns:
    - y: acceleration a(t)
    """
    
    t = x0
    x = x1
    v = x2
    
    # Constant offset + time-dependent forcing terms
    constant_offset = params[0]
    linear_time_forcing = params[1] * t
    quadratic_time_forcing = params[2] * t**2
    
    # Restoring forces (linear + cubic stiffness nonlinearity)
    linear_restoring_force = params[3] * x       # typically negative for restoring force
    cubic_stiffness_nonlinearity = params[4] * x**3
    
    # Damping terms (linear + nonlinear in velocity)
    linear_damping = params[5] * v
    quadratic_velocity_damping = params[6] * v**2
    cubic_velocity_damping = params[7] * v**3
    
    # Interaction terms between position & velocity and time & state variables
    pos_vel_interaction = params[8] * x * v
    time_pos_interaction = params[9] * t * x
    time_vel_interaction = params[10] * t * v
    
    # Additional nonlinear cross terms to capture more complex dynamics:
    
    # Position squared times velocity term (x^2*v), capturing asymmetric nonlinear damping or forcing effects 
    pos_squared_vel_interaction = 0.0 if len(params) < 13 else params[11] * (x**2) * v
    
  
    return (
        constant_offset 
        + linear_time_forcing 
        + quadratic_time_forcing 
        + linear_restoring_force 
        + cubic_stiffness_nonlinearity 
        + linear_damping 
        + quadratic_velocity_damping 
        + cubic_velocity_damping 
        + pos_vel_interaction 
        + time_pos_interaction 
        + time_vel_interaction 
        + pos_squared_vel_interaction  # added new nonlinear interaction term here
     )
