    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator as a function of time (x0),
    position (x1), and velocity (x2).

    The model includes:
    - Constant offset
    - Polynomial terms in time (up to cubic)
    - Linear, quadratic, cubic, quartic nonlinearities in position and velocity
    - Cross terms between position & velocity and time & position/velocity
    - Sinusoidal forcing with sine and cosine components

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of parameters with length at least 18

            params[0]: constant offset
            params[1]: linear time coefficient
            params[2]: quadratic time coefficient (time^2)
            params[3]: cubic time coefficient (time^3)
            params[4]: linear stiffness coefficient (-k)
            params[5]: linear damping coefficient (-c)
            params[6]: quadratic stiffness coefficient (-k2)
            params[7]: cubic stiffness coefficient (-alpha)
            params[8]: quartic stiffness coefficient (-beta)
            params[9]: quadratic velocity damping coefficient
            params[10]: cubic velocity damping coefficient
            params[11]: quartic velocity damping coefficient
            params[12]: cross term between position and velocity (x1*x2)
            params[13]: cross term between time and position (x0*x1)
            params[14]: cross term between time and velocity (x0*x2)
            params[15]: sinusoidal forcing amplitude multiplier for sin(omega * t)
            params[16]: sinusoidal forcing amplitude multiplier for cos(omega * t)
            params[17]: angular frequency omega for sinusoidal forcing

    Returns:
        y: acceleration at time t as numpy array.
    """

    c0 = params[0]
    c_t = params[1]
    c_t2 = params[2]
    c_t3 = params[3]

    c_pos = params[4]
    c_vel = params[5]

    c_pos2 = params[6]
    c_pos3 = params[7]
    c_pos4 = params[8]

    c_vel2 = params[9]
    c_vel3 = params[10]
    c_vel4 = params[11]

    c_pos_vel = params[12]

    c_t_pos = params[13]
    c_t_vel = params[14]

    
    if len(params) > 17:
        forcing_sin_amp = params[15]
        forcing_cos_amp = params[16]
        omega = abs(params[17])  # frequency should be positive or zero
        
        forcing_term = (
              forcing_sin_amp * np.sin(omega * x0) 
            + forcing_cos_amp * np.cos(omega * x0)
        )
        
    else:
        forcing_term = 0.0


    
    y = (
          c0 
          + c_t * x0 
          + c_t2 * x0**2 
          + c_t3 * x0**3 

          + c_pos * x1 
          + c_vel * x2 

          + c_pos2 * x1**2 
          + c_pos3 * x1**3 
          + c_pos4 * x1**4 

          + c_vel2 * x2**2 
          + c_vel3 * x2**3 
          + c_vel4 * x2**4 

          + c_pos_vel * x1 * x2 

          + c_t_pos * x0 * x1 
          + c_t_vel * x0 * x2 

          + forcing_term
      )

    
    return y
