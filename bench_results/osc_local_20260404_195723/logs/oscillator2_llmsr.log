def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation_v1 including physically meaningful nonlinear oscillator dynamics:
    - Linear restoring force (-k * x1)
    - Cubic nonlinear stiffness (-k3 * x1^3)
    - Linear damping (-c * x2)
    - Quadratic and cubic damping
    - Time-dependent forcing modeled as sinusoidal function
    - Cross terms between variables
    
    Parameters:
        params: array of 12 parameters controlling each term.
    
    Returns:
        Acceleration y as numpy array.
    """
    
    # Unpack parameters for clarity
    c0 = params[0]   # constant offset / bias acceleration
    k_t = params[1]  # linear time coefficient
    k_x = params[2]  # linear position coefficient (restoring force)
    c_v = params[3]  # linear velocity coefficient (damping)
    
    k_x3 = params[4]  # cubic stiffness coefficient
    c_v2 = params[5]  # quadratic velocity damping coefficient
    k_x2 = params[6]  # quadratic position nonlinearity
    
    c_xv = params[7]  # cross term between position and velocity
    
    k_t2 = params[8]   # quadratic time effect
    
    k_t_x3 = params[9]   # mixed time-position cubic
    
    k_t_v2 = params[10]  # mixed time-velocity squared
    
    c_x2v = params[11]   # higher order mixed term: position squared times velocity

    
    y = (
        c0 
        + k_t * x0 
        + (-k_x) * x1             # restoring force usually negative sign
        + (-c_v) * x2             # damping usually negative sign
        
        + (-k_x3) * x1**3         # nonlinear stiffness
        
        + c_v2 * x2**2            # quadratic damping
        
        + k_x2 * x1**2            # quadratic nonlinearity in stiffness
        
        + c_xv * x1 * x2          # cross term
        
        + k_t2 * x0**2            # quadratic time effect
        
        + k_t_x3 * x0 * x1**3     # mixed time-position cubic
        
        + k_t_v2 * x0 * x2**2     # mixed time-velocity squared
        
        + c_x2v * (x1**2) * x2     # higher order mixed term
       
       )
    
    return y
