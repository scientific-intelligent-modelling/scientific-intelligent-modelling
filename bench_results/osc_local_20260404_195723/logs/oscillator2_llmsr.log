def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved equation for acceleration in nonlinear harmonic oscillator.

    Variables:
    - x0: time t
    - x1: position at time t
    - x2: velocity at time t

    Parameters:
    - params: array of 12 parameters controlling each term.

    Model structure:
        y = acceleration =
            constant offset +
            linear time effect +
            linear stiffness * position +
            linear damping * velocity +
            cubic stiffness * position^3 +
            quadratic velocity damping * velocity*|velocity| +
            quadratic stiffness * position^2 +
            cross term between position and velocity +
            quadratic time effect +
            mixed time-position cubic term +
            sinusoidal forcing term (amplitude * sin(freq * t)) +
            higher order mixed nonlinear interaction (position squared times velocity)
    """

    c0 = params[0]   # constant offset / forcing
    c_time = params[1]  # linear in time forcing or parametric effect

    k_lin = abs(params[2])   # linear stiffness coefficient (positive)
    c_damp = abs(params[3])  # linear damping coefficient (positive)

    k_cubic = params[4]      # cubic stiffness coefficient (can be positive or negative)

    c_quad_vel = params[5]   # quadratic velocity damping coefficient (usually negative)

    k_quad_pos = params[6]   # quadratic stiffness coefficient

    cross_pos_vel = params[7]  # cross coupling between position and velocity

    c_time_sq = params[8]     # quadratic in time effect / parametric excitation

    mixed_time_pos_cubic = params[9]  # mixed time-position cubic nonlinearity

    amp_forcing = params[10]     # amplitude of sinusoidal forcing

    omega_forcing = params[11]   # angular frequency of sinusoidal forcing


    y = (
          c0 
        + c_time * x0 
        - k_lin * x1           # restoring force (-k*x)
        - c_damp * x2          # damping force (-c*v)
        
        + k_cubic * x1**3      # cubic stiffness
        
        + c_quad_vel * x2 * np.abs(x2)  # quadratic velocity damping v|v|
        
        + k_quad_pos * x1**2   # quadratic position nonlinearity
        
        + cross_pos_vel * x1 * x2
        
        + c_time_sq * x0**2
        
        + mixed_time_pos_cubic * x0 * (x1**3)
        
        + amp_forcing * np.sin(omega_forcing * x0)
        
        + np.sign(params[11]) * (x1 ** 2) * x2   # higher order mixed nonlinear interaction
       )
    
    return y
