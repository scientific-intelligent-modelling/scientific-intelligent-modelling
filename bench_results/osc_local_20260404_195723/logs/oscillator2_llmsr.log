def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration as a nonlinear function of time (t), position (x), and velocity (v),
    including:
      - constant offset
      - linear and quadratic dependence on time
      - linear, quadratic, cubic dependence on position
      - linear, quadratic, cubic dependence on velocity
      - cross terms between position and velocity up to cubic order

    Parameters:
    - params[0]: constant offset
    - params[1]: coefficient for time t (x0)
    - params[2]: coefficient for position x (x1)
    - params[3]: coefficient for velocity v (x2)
    - params[4]: coefficient for cubic term in position x^3
    - params[5]: coefficient for quadratic term in velocity v^2
    - params[6]: coefficient for cross term x*v
    - params[7]: coefficient for quadratic term in position x^2
    - params[8]: coefficient for cubic term in velocity v^3
    - params[9]: coefficient for cross term x^2 * v
    - params[10]: coefficient for cross term x * v^2
    - params[11]: coefficient for quadratic time t^2

    Returns:
        Acceleration array.
    
    Notes:
        Added an additional small nonlinear mixed term to capture subtle effects.
        The structure is consistent with typical nonlinear oscillator equations,
        including Duffing-type nonlinearity and damping.
    """
    
    # Base polynomial terms from equation_v1:
    y = (
        params[0] +                         # constant offset
        params[1] * x0 +                   # linear time dependence
        params[11] * (x0 ** 2) +           # quadratic time dependence
        
        params[2] * x1 +                   # linear position term (-k*x)
        params[7] * (x1 ** 2) +            # quadratic position nonlinearity 
        params[4] * (x1 ** 3) +            # cubic Duffing nonlinearity
        
        params[3] * x2 +                   # linear velocity damping (-c*v)
        params[5] * (x2 ** 2) +            # quadratic velocity effect 
