def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration y as a nonlinear function of time (t), position (x), and velocity (v),
    including linear, cubic nonlinear restoring force terms,
    linear and cubic damping terms,
    plus cross terms involving time-position and time-velocity interactions.

    Equation form:
        y = p0 
          + p1*t 
          + p2*x 
          + p3*x^3 
          + p4*v 
          + p5*v^3 
          + p6*t*x 
          + p7*t*v

    Parameters:
        params[0]: constant offset
        params[1]: coefficient for time t (forcing/drift)
        params[2]: linear restoring force coefficient (-a)
        params[3]: nonlinear restoring force coefficient (-b)
        params[4]: linear damping coefficient (-c)
        params[5]: nonlinear damping coefficient (-d)
        params[6]: cross term coefficient for t*x interaction
        params[7]: cross term coefficient for t*v interaction

    Returns:
        Acceleration array.
    """
    
    return (
        params[0] +
        params[1] * x0 +
        params[2] * x1 +
        params[3] * (x1 ** 3) +
        params[4] * x2 +
        params[5] * (x2 ** 3) +
        params[6] * x0 * x1 +
        params[7] * x0 * x2
    )
