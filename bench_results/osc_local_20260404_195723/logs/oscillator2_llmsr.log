def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1` with sinusoidal forcing term.

    Variables:
    - x0: time t
    - x1: position at time t
    - x2: velocity at time t

    Parameters:
    - params: array of 12 parameters controlling each term.

    Model structure:
    y = acceleration = 
        constant offset +
        linear time effect +
        linear stiffness * position +
        linear damping * velocity +
        cubic stiffness * position^3 +
        quadratic velocity damping * velocity^2 +
        quadratic stiffness * position^2 +
        cross term between position and velocity +
        quadratic time effect +
        mixed time-position cubic term +
        mixed time-velocity quadratic term +
        higher order mixed term (position squared times velocity) +
        sinusoidal forcing (amplitude * sin(frequency * time))
        
    Note:
    - Restoring forces have negative sign.
    - Damping forces have negative sign.
    """
    
    # Unpack parameters for clarity
    amp_forcing = params[0]       # amplitude of sinusoidal forcing
    freq_forcing = params[1]      # frequency of sinusoidal forcing
    
    c_time = params[2]            # linear in time offset
    k_lin = params[3]             # linear stiffness coefficient (position)
    c_damp = params[4]            # linear damping coefficient (velocity)
    
    k_cubic = params[5]           # cubic stiffness coefficient (position^3)
    
    c_quad_vel = params[6]         # quadratic velocity damping
    
    k_quad_pos = params[7]         # quadratic stiffness
    
    cross_pos_vel = params[8]      # cross product of pos*vel
    
    c_time_sq = params[9]          # quadratic in time
    
    mixed_time_pos_cubic = params[10]
    
    mixed_time_vel_quad = params[11]
    
  
    y = (
