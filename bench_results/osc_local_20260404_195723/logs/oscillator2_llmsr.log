def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Calculates acceleration y given time (x0), position (x1), and velocity (x2)
    for a nonlinear harmonic oscillator with cubic nonlinearity and damping,
    including additional cross terms and higher order nonlinearities.

    The model includes:
    - constant offset
    - linear dependence on time (forcing)
    - linear restoring force proportional to position
    - linear damping proportional to velocity
    - quadratic terms in position and velocity (nonlinear stiffness/damping)
    - cross terms between position and velocity
    - cubic term in position (Duffing-type nonlinearity)
    - cubic term in velocity (nonlinear damping)
    - mixed cubic term involving position squared times velocity

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array-like with at least 12 elements representing coefficients

            params[0]  = constant term
            params[1]  = linear coefficient for time (forcing)
            params[2]  = linear coefficient for position (restoring force)
            params[3]  = linear coefficient for velocity (damping)
            params[4]  = quadratic coefficient for position^2
            params[5]  = quadratic coefficient for velocity^2
            params[6]  = cross term coefficient for position*velocity
            params[7]  = cubic coefficient for velocity^3
            params[8]  = mixed cubic term coefficient for position^2 * velocity
            params[9]  = cubic coefficient for position^3

    Returns:
        y: acceleration values as numpy array.
    """

    c0   = params[0]
    c_t  = params[1]
    c_x  = params[2]
    c_v  = params[3]

    c_x2   = params[4]
    c_v2   = params[5]
    c_xv   = params[6]

    c_v3   = params[7]
    c_xxv  = params[8]
    
    c_x3   = params[9]

    
    y = (
        c0 +
        c_t * x0 +
        c_x * x1 +
        c_v * x2 +
        c_x2 * x1**2 +
        c_v2 * x2**2 +
        c_xv * x1 * x2 +
        c_v3 * x2**3 +
        c_xxv * (x1**2) * x2 +
        c_x3 * x1**3
     )
    
    return y
