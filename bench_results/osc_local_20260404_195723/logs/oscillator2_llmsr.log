            + p1 * t 
            + p11 * t^2
            + p12 * t^3
            + p13 * t * v
            + p2 * x 
            + p6 * x^2
            + p4 * x^3 
            + p14 * x^4
            + p3 * v 
            + p5 * v^2
            + p8 * v^3
            + p15 * v^4
            + p7  * x*v
            + p9  * x^2*v
            + p10 * x*v^2

    Parameters:
        x0 (np.ndarray): time variable t
        x1 (np.ndarray): position at time t
        x2 (np.ndarray): velocity at time t
        params (np.ndarray): array of parameters with length >= 16

    Returns:
        np.ndarray: acceleration values computed from the model.
    """
    
    # Assign parameters for clarity (assuming params length >= 16)
    c0   = params[0]   # constant offset / external forcing term
    c_t   = params[1]  # linear in time forcing coefficient
    c_x   = params[2]  # linear restoring force coefficient (-k*x)
    c_v   = params[3]  # linear damping coefficient (-c*v)
    
    c_x3  = params[4]  # cubic stiffness nonlinearity (-k3*x^3)
    c_v2  = params[5]  # quadratic velocity term (nonlinear damping)
    
    c_x2  = params[6]  # quadratic stiffness nonlinearity
    
    c_xv  = params[7]  # cross term position*velocity
    
    c_v3  = params[8]  # cubic velocity term
    
    c_x2v = params[9]   # quadratic position times velocity
    
    c_xv2 = params[10]  # position times quadratic velocity
    
    c_t2   = params[11] # quadratic in time forcing
    
    c_t3   = params[12] # cubic in time forcing
    
    c_tv   = params[13] # cross term between time and velocity
    
    c_x4   = params[14] # quartic stiffness nonlinearity (x^4)
    
    c_v4   = params[15] # quartic velocity term (v^4)

    
    y = (
        c0 +
        c_t * x0 +
        c_t2 * (x0 ** 2) +
        c_t3 * (x0 ** 3) +
        c_tv * (x0 * x2) +
        
        c_x * x1 +
        c_x2 * (x1 ** 2) +
        c_x3 * (x1 ** 3) +
        c_x4 * (x1 ** 4) +

        c_v * x2 +
        c_v2 *(x2 ** 2) +
