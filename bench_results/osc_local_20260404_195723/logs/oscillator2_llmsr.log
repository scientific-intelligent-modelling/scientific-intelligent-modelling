def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration y of a nonlinear harmonic oscillator with:
    - constant term
    - linear time dependence (forcing)
    - linear restoring force proportional to position (Hooke's law)
    - linear damping proportional to velocity
    - cubic nonlinearity in position (Duffing oscillator)
    - quadratic velocity term (nonlinear damping)
    - cross term between position and velocity (velocity-dependent stiffness or nonlinear damping)
    
    Parameters:
    - x0: time array
    - x1: position array at time t
    - x2: velocity array at time t
    - params: array-like coefficients with length >= 12
    
    Returns:
    - y: acceleration values as numpy array
    """
    
    c0 = params[0]     # constant offset acceleration / forcing baseline
    c_t = params[1]     # linear in time forcing term
    c_x = params[2]     # linear restoring force coefficient (-k/m)
    c_v = params[3]     # linear damping coefficient (-c/m)
    
    c_x2 = params[4]   # quadratic term in position (optional nonlinear stiffness)
    c_v2 = params[5]   # quadratic term in velocity (nonlinear damping)
    
    c_x3 = params[9]   # cubic nonlinearity in position (Duffing-type nonlinearity)
    
    c_xv = params[10]  # cross term between position and velocity
    
    y = (
        c0 +
        c_t * x0 +
        c_x * x1 +
        c_v * x2 +
        c_x2 * x1**2 +
        c_v2 * x2**2 +
        c_x3 * x1**3 +
        c_xv * x1 * x2
    )
    
    return y
