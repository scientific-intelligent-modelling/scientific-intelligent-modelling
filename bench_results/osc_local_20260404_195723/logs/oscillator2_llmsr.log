def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version refines the nonlinear harmonic oscillator acceleration model by:
    - Explicitly enforcing negative signs on restoring force and damping terms
    - Including higher order nonlinearities and mixed terms
    - Maintaining physical interpretability of parameters

    Parameters:
    - x0: time t
    - x1: position at time t
    - x2: velocity at time t
    - params: array of parameters (length >= 12)

    Returns:
    - y: acceleration at time t
    """
    
    # Extract parameters with physical constraints where appropriate
    c0 = params[0]  # constant forcing / offset
    
    c_time_linear = params[1]  # linear time coefficient (parametric excitation)
    
    k_linear = abs(params[2])  # linear stiffness coefficient (positive)
    
    c_damping = abs(params[3])  # linear damping coefficient (positive)
    
    alpha_cubic = abs(params[4])  # cubic stiffness coefficient (positive)
    
    beta_quad_vel = params[5]  # quadratic velocity term (can be pos or neg)
    
    gamma_quad_pos = params[6]  # quadratic position term
    
    delta_cross = params[7]  # cross term between position and velocity
    
    epsilon_quad_time = params[8]  # quadratic time effect
    
    zeta_mixed_time_pos_cubic = params[9]  # mixed time-position cubic effect
    
    eta_mixed_time_vel_quad = params[10]  # mixed time-velocity quadratic effect
    
    theta_high_order_mixed = params[11]  # higher order mixed term

    
    y = (
        c0
        
        + c_time_linear * x0
        
        - k_linear * x1
        
        - c_damping * x2
        
        - alpha_cubic * (x1 ** 3)
        
        + beta_quad_vel * (x2 ** 2)
        
        + gamma_quad_pos * (x1 ** 2)
        
        + delta_cross * (x1 * x2)
        
        + epsilon_quad_time * (x0 ** 2)
        
        + zeta_mixed_time_pos_cubic * (x0 * (x1 ** 3))
        
        + eta_mixed_time_vel_quad * (x0 * (x2 ** 2))
        
        + theta_high_order_mixed * ((x1 ** 2) * x2)
     )
    
    return y
