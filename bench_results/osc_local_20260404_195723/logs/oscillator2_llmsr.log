            p0                              # constant offset (bias)
            + p1 * sin(x0)                  # external periodic forcing (time-dependent)
            + p2 * cos(x0)                  # external periodic forcing (time-dependent)
            - p3 * x1                      # linear restoring force (-k*x)
            - p4 * x1**3                   # nonlinear restoring force (-alpha*x^3)
            - p5 * x2                      # linear damping (-c*v)
