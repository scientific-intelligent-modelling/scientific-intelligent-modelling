          params[0]
          + params[1] * x0 
          # Linear restoring force: always negative sign times positive magnitude param for stability 
          - abs(params[2]) * x1  
          # Linear viscous damping: always negative sign times positive magnitude param 
          - abs(params[3]) * x2  
         )
    
    # Cubic stiffness nonlinearity; can be stiffening or softening depending on param sign 
    y += params[4] * x1**3
    
