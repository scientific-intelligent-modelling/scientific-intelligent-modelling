def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Further enhanced model for acceleration in nonlinear harmonic oscillator.

    Physical reasoning:
    - Retains key restoring force and damping nonlinearities.
    - Adds second harmonic forcing components sin(2*t) and cos(2*t).
    - Includes mixed nonlinear interaction terms between position and velocity.
    - Includes polynomial time dependence up to cubic order.
    
    Parameters:
    - params (np.ndarray): array of length 12
    
    Returns:
    - y (np.ndarray): predicted acceleration
    """
    
    return (
        params[0]  # constant offset
        + params[1] * x1  # linear position term (restoring force)
        + params[2] * (x1 ** 3)  # cubic stiffness nonlinearity
        + params[3] * x2  # linear velocity term (damping)
        + params[4] * (x2 ** 3)  # nonlinear damping
        + params[5] * (x1 ** 2) * x2  # coupling quadratic position and velocity
        + params[6] * x0  # linear time term for slow drift or trend
        + params[7] * np.sin(x0)  # sinusoidal forcing at fundamental frequency
        + params[8] * np.cos(x0)  # cosine forcing at fundamental frequency
        + params[9] * np.sin(2 * x0)  # sinusoidal forcing at second harmonic frequency
        + params[10] * np.cos(2 * x0)   # cosine forcing at second harmonic frequency
        + params[11] * (x0 ** 3)   # cubic time term for flexible time dependence beyond quadratic
    )
