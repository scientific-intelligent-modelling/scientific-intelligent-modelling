def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Further improved equation for acceleration of nonlinear harmonic oscillator.

    Improvements over v1:
    - Explicitly enforce negative signs on restoring force and damping terms to ensure physically correct directions.
    - Allow flexible signs on nonlinear and mixed terms to capture richer dynamics.
    - Keep parametric excitation terms as in v1.
    - Maintain clear physical interpretation of each term.

    Parameters:
        params[0]: constant offset / forcing term
        params[1]: linear time-dependent parametric excitation coefficient
        params[2]: linear stiffness magnitude (>0)
        params[3]: linear damping magnitude (>0)
        params[4]: cubic stiffness magnitude (>0)
        params[5]: quadratic velocity dependent coefficient (sign flexible)
        params[6]: quadratic position dependent coefficient (sign flexible)
        params[7]: cross term coefficient between position and velocity (sign flexible)
        params[8]: quadratic time dependence coefficient (sign flexible)
        params[9]: mixed time-position cubic effect coefficient (sign flexible)
        params[10]: mixed time-velocity quadratic effect coefficient (sign flexible)
        params[11]: higher order mixed term coefficient (sign flexible)

    Returns:
        y: acceleration at time t as numpy array
    """

    # Enforce positive magnitudes for physically constrained parameters
    k = abs(params[2])      # linear stiffness magnitude > 0
    c = abs(params[3])      # linear damping magnitude > 0
    alpha = abs(params[4])  # cubic stiffness magnitude > 0

    y = (
          params[0]                        # constant offset / forcing

        + params[1] * x0                  # parametric excitation linear in time

        - k * x1                         # linear restoring force (-k*x)

        - c * x2                         # linear viscous damping (-c*v)

        - alpha * (x1 ** 3)              # cubic nonlinear restoring force

        + params[5] * (x2 ** 2)          # quadratic velocity dependent term

        + params[6] * (x1 ** 2)          # quadratic position dependent term

        + params[7] * (x1 * x2)          # cross term coupling position & velocity

        + params[8] * (x0 ** 2)          # quadratic time dependence

        + params[9] * (x0 * (x1 ** 3))   # mixed time-position cubic effect

        + params[10] * (x0 * (x2 ** 2))  # mixed time-velocity quadratic effect

        + params[11] * ((x1 ** 2) * x2)   # higher order mixed term
     )

    return y
