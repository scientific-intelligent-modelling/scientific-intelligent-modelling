def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Calculates acceleration for a nonlinear harmonic oscillator with:
    - linear restoring force,
    - linear damping,
    - cubic stiffness nonlinearity,
    - quadratic velocity damping,
    - quadratic position term (to capture asymmetry or softening/hardening effects),
    - cross term between position and velocity (coupling effects),
    - cubic velocity term (higher order damping/nonlinear effects),
    - time-position and time-velocity interaction terms (time-dependent forcing or parameter drift),
    - cubic time term (higher order time-dependent forcing/drift),
    - quadratic velocity-position coupling (v^2 * x) to capture nonlinear damping-position interaction.

    Parameters:
        x0 (np.ndarray): time variable t
        x1 (np.ndarray): position at time t
        x2 (np.ndarray): velocity at time t
        params (np.ndarray): array of parameters with length 12

    Returns:
        np.ndarray: acceleration values computed from the model.
    """
    
    return (
        params[0]                    # constant offset / external forcing
        + params[1]  * x0             # linear in time forcing/drift
        + params[2]  * x1             # linear restoring force ~ -k*x
        + params[3]  * x2             # linear damping ~ -c*v
        + params[4]  * (x1 ** 3)      # cubic stiffness nonlinearity ~ alpha*x^3
        + params[5]  * (x2 ** 2)      # nonlinear damping or velocity squared effect
        + params[6]  * (x1 ** 2)      # quadratic position term for asymmetry/softening/hardening effects
        + params[7]  * (x1 * x2)      # cross term between position and velocity coupling effects
        + params[8]  * (x2 ** 3)      # cubic velocity term for higher order nonlinear damping/effects
        + params[9]  * (x0   * x1)     # interaction between time and position for time-dependent stiffness/forcing
        + params[10] * (x0   * x2)     # interaction between time and velocity for time-dependent damping/forcing
        + params[11] * ((x2 ** 2) * x1)# quadratic velocity-position coupling to capture nonlinear damping-position interaction 
    )
