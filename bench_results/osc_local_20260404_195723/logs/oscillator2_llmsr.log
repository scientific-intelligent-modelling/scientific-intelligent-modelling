def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Calculates acceleration of a nonlinear harmonic oscillator given time (x0),
    position (x1), and velocity (x2).

    Parameters:
        params[0]: constant offset
        params[1]: linear time coefficient
        params[2]: linear stiffness coefficient (restoring force)
        params[3]: linear damping coefficient
        params[4]: cubic stiffness coefficient (nonlinear restoring force)
        params[5]: quadratic velocity damping coefficient
        params[6]: quadratic position term coefficient
        params[7]: cross term coefficient between position and velocity
        params[8]: time squared effect coefficient (parametric excitation)
        params[9]: mixed time-position cubic term coefficient
        params[10]: mixed time-quadratic velocity term coefficient
        params[11]: higher order mixed nonlinear term coefficient

    Returns:
        y: acceleration array corresponding to input arrays.
    """

    # Start with constant offset and linear terms in time, position, velocity
    y = (
          params[0]
          + params[1] * x0               # linear in time (forcing or parametric)
          + params[2] * x1               # linear stiffness (-k*x)
          + params[3] * x2               # linear damping (-c*v)
         )

    # Nonlinear cubic stiffness term (-alpha * x^3)
    y += params[4] * x1**3

    # Quadratic velocity damping term (e.g., d * v |v|)
    y += params[5] * x2 * np.abs(x2)

    # Quadratic position nonlinearity (e.g., softening/hardening effects)
    y += params[6] * x1**2

    # Cross coupling between position and velocity terms
    y += params[7] * x1 * x2

    # Time squared effect - parametric excitation possibility
    y += params[8] * x0**2

    # Mixed nonlinearities involving time and position cubed
    y += params[9] * x0 * x1**3

    # Mixed nonlinearities involving time and quadratic velocity terms
    y += params[10] * x0 * (x2**2)

    # Higher order mixed nonlinearities e.g. squared position times velocity 
    y += params[11] * (x1**2) * x2

    
    return y
