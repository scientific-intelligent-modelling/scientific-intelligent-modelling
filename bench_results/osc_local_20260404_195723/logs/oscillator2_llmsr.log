    quadratic_velocity_damping = params[11] * v**2
    cubic_velocity_damping = params[6] * v**3
    
    # Interaction terms between position & velocity and time & state variables
    pos_vel_interaction = params[7] * x * v
    time_pos_interaction = params[8] * t * x
    time_vel_interaction = params[9] * t * v
    
  
    return (
        constant_offset 
        + linear_time_forcing 
        + quadratic_time_forcing 
        + linear_restoring_force 
        + cubic_stiffness_nonlinearity 
        + quadratic_position_term 
        + linear_damping 
        + quadratic_velocity_damping 
        + cubic_velocity_damping 
        + pos_vel_interaction 
        + time_pos_interaction 
        + time_vel_interaction
     )
