def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version including nonlinear and damping effects.
    """
    # Constant + linear terms
    y = params[0] + params[1]*x0 + params[2]*x1 + params[3]*x2
    
    # Nonlinear cubic stiffness term
    y += params[4] * x1**3
    
    # Quadratic velocity damping term
    y += params[5] * x2**2
    
    # Quadratic position term (nonlinear stiffness)
    y += params[6] * x1**2
    
    # Cross term between position and velocity
    y += params[7] * x1 * x2
    
    # Possibly time squared effect
    y += params[8] * x0**2
    
    # Mixed time-position cubic
    y += params[9] * x0 * x1**3
    
    # Mixed time-velocity quadratic
    y += params[10] * x0 * x2**2
    
    # Higher order mixed term e.g. position squared times velocity
    y += params[11] * (x1**2) * x2

    return y
