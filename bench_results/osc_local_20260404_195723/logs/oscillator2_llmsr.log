        + (-c_quad_vel) * x2**2   # nonlinear damping
        
        + (-k_quad_pos) * x1**2   # additional nonlinear stiffness
        
        + cross_pos_vel * x1 * x2
        
        + c_time_sq * x0**2
        
        + mixed_time_pos_cubic * x0 * (x1**3)
        
        + mixed_time_vel_quad * x0 * (x2**2)
        
        + high_order_mixed * (x1**2) * x2
       )
       
       
     # Optional sinusoidal forcing with frequency omega and amplitude encoded in parameters:
     # For example, use param set [freq_param, amp_param], here reuse two parameters if desired,
