def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of nonlinear harmonic oscillator with polynomial terms up to quartic order,
    including mixed cubic and quartic interaction terms.

    Physically motivated:
    - Restoring force proportional to negative position (-k * x0)
    - Damping proportional to negative velocity (-c * x1)
    - Nonlinearities modeled by higher order polynomial terms including mixed quartic terms
    """
    # Constant offset term
    constant_term = params[0]

    # Linear restoring force (negative sign for restoring)
    linear_restoring = -params[1] * x0

    # Linear damping term (negative sign for damping)
    linear_damping = -params[2] * x1

    # Quadratic nonlinearities
    quadratic_terms = (
        params[3] * (x0 ** 2) +
        params[4] * (x1 ** 2) +
        params[5] * (x0 * x1)
    )

    # Cubic nonlinearities
    cubic_terms = (
        params[6] * (x0 ** 3) +
        params[7] * (x1 ** 3) +
        params[8] * (x0 ** 2) * x1 +
        params[9] * x0 * (x1 ** 2)
    )

    # Quartic nonlinearities with mixed terms included
    # We have only two parameters left: params[10], params[11]
    
    # Use param[10] for pure quartics in position and velocity combined:
    quartic_pure = (
        (x0 ** 4) + (x1 ** 4)
    )
    
    # Use param[11] for mixed quartics:
    
    quartic_mixed = (
        (x0 ** 3) * x1 + 
        x0 * (x1 ** 3) + 
        (x0 ** 2) * (x1 ** 2)
    )
    
    quartic_terms = params[10] * quartic_pure + params[11] * quartic_mixed

    
    return constant_term + linear_restoring + linear_damping + quadratic_terms + cubic_terms + quartic_terms
