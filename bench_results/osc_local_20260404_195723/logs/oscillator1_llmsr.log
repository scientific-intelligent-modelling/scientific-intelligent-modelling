def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of nonlinear harmonic oscillator with polynomial terms up to quartic order,
    plus nonlinear damping/friction-like effects with fractional powers,
    and periodic forcing components.

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Trainable coefficients array of length 14

    Returns:
    - y: Acceleration at time t
    """
    
    # Polynomial terms (up to quartic)
    poly_terms = (
        params[0]  # constant offset term
        + params[1] * x0  # linear restoring force term (-k*x)
        + params[2] * x1  # linear damping term (-c*v)
        + params[3] * (x0 ** 2)  # quadratic stiffness nonlinearity
        + params[4] * (x0 * x1)  # quadratic mixed term
        + params[5] * (x1 ** 2)  # quadratic velocity effect (nonlinear damping)
        + params[6] * (x0 ** 3)  # cubic stiffness nonlinearity (Duffing-type)
        + params[7] * (x0 ** 2) * x1  # cubic mixed interaction term
        + params[8] * x0 * (x1 ** 2)   # cubic mixed interaction term
        + params[9] * (x1 ** 3)       # cubic velocity nonlinearity (nonlinear damping)
        + params[10] * (x0 ** 4)      # quartic stiffness nonlinearity
        + params[11] * (x1 ** 4)      # quartic velocity nonlinearity
    )
    
    # Nonlinear friction/damping with fractional power dependence on velocity magnitude and sign:
    friction_term = (
        params[12]
        * np.sign(x1)
        * np.abs(x1)**(1/3)
    )
    
    # Periodic forcing or restoring force component, e.g., sinusoidal in position:
    forcing_term = (
        params[13]
        * np.sin(x0)
    )
    
    return poly_terms + friction_term + forcing_term
