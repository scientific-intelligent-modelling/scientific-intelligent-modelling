def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version models the acceleration of a nonlinear harmonic oscillator by combining:
    - Polynomial terms up to cubic order in position and velocity,
    - Cross terms capturing interaction between position and velocity,
    - Trigonometric nonlinearities reflecting pendulum-like restoring forces and velocity-dependent effects,
    - And includes a damping term proportional to velocity.

    Parameters:
    - params (np.ndarray): array of length 12 containing trainable coefficients.

    Returns:
    - y (np.ndarray): acceleration values.
    """
    p = params

    # Polynomial terms
    poly_terms = (
        p[0]                  # constant offset
        + p[1] * x0           # linear restoring force ~ position
        + p[2] * x1           # linear damping ~ velocity
        + p[3] * x0**2        # quadratic position nonlinearity
        + p[4] * x1**2        # quadratic velocity nonlinearity
        + p[5] * x0 * x1      # cross term between position and velocity
        + p[6] * x0**3        # cubic Duffing-type nonlinearity in position
        + p[7] * x1**3        # cubic nonlinear damping or forcing in velocity
        + p[8] * (x0**2) * x1 # higher order mixed nonlinear term
        + p[9] * x0 * (x1**2) # higher order mixed nonlinear term
    )

    # Trigonometric nonlinearities representing pendulum-like restoring force and velocity effects
    trig_terms = (
        p[10] * np.sin(x0)   # sinusoidal restoring force component (e.g., pendulum)
        + p[11] * np.cos(x1)  # cosine-based nonlinear effect on velocity
    )

    y = poly_terms + trig_terms

    return y
