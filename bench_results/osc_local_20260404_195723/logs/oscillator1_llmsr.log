        + p[8] * x0**2 * x1       # higher order mixed term
        + p[9] * x0 * x1**2       # another mixed nonlinear damping/stiffness effect
        + p[10]* np.sin(x0)       # possible periodic forcing or nonlinear effect
        + p[11]* np.cos(x1)       # possible nonlinear effect depending on velocity phase
    )
    
    return y
