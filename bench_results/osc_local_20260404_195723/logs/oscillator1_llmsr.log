    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` that models acceleration of a nonlinear harmonic oscillator.
    
    This function models acceleration y as a function of position x0 and velocity x1,
    including:
      - linear restoring force ~ x0
      - linear damping ~ x1
      - polynomial nonlinearities in position and velocity (quadratic, cubic)
      - cross terms between position and velocity
      - nonlinear periodic forcing/restoring effects via sin(x0) and cos(x1)
      - friction-like effects depending on sign(velocity)
      - quadratic drag term proportional to |velocity|*velocity
    
    Parameters:
    - x0 (np.ndarray): position at time t
    - x1 (np.ndarray): velocity at time t
    - params (np.ndarray): array of length >= 13 containing coefficients
    
        params indices:
        0: constant offset term
        1: linear position term (~ restoring force)
        2: linear velocity term (~ damping)
        3: quadratic position term
        4: quadratic velocity term
        5: cross product quadratic term (x0 * x1)
        6: cubic position nonlinearity (Duffing-type)
        7: cubic velocity nonlinearity
        8: mixed cubic term ((x0^2)*x1)
        9: mixed cubic term (x0*(x1^2))
        10: sin(x0) nonlinear periodic effect
        11: cos(x1) nonlinear periodic effect
        12: friction-like term proportional to sign(x1)
        13(optional): quadratic drag coefficient for |x1|*x1
    
    Returns:
    - y (np.ndarray): acceleration values at given positions and velocities.
    """
    
    p = params
    
    # If params length is only 13, set drag coefficient zero by default to avoid error.
    drag_coeff = p[13] if len(p) > 13 else 0.0
    
    y = (
          p[0]                          # constant offset
        + p[1] * x0                    # linear restoring force ~ -k*x 
        + p[2] * x1                    # linear damping ~ -c*v 
        + p[3] * (x0 ** 2)             # quadratic position nonlinearity 
        + p[4] * (x1 ** 2)             # quadratic velocity nonlinearity 
        + p[5] * (x0 * x1)             # cross product quadratic term 
        + p[6] * (x0 ** 3)             # cubic Duffing-type restoring force 
        + p[7] * (x1 ** 3)             # cubic velocity nonlinearity 
        + p[8] * ((x0 ** 2) * x1)     # mixed higher order terms 
        + p[9] * (x0 * (x1 ** 2))     # mixed higher order terms 
        + p[10] * np.sin(x0)           # nonlinear periodic forcing/restoring effect 
        + p[11] * np.cos(x1)           # nonlinear periodic effect on velocity 
        + p[12] * np.sign(x1)          # friction-like effect depending on sign of velocity 
        + drag_coeff * np.abs(x1)*x1   # quadratic drag proportional to |v|*v  
    )
    
    return y
