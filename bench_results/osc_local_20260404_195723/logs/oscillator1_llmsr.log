def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of nonlinear harmonic oscillator with polynomial terms up to cubic order,
    plus trigonometric nonlinearities reflecting restoring forces and damping effects.

    Physical motivation:
    - The acceleration in a nonlinear oscillator depends on position (x0) and velocity (x1).
    - Linear term in position corresponds to Hooke's law restoring force.
    - Nonlinear polynomial terms capture anharmonicity.
    - Velocity terms model damping (linear and nonlinear).
    - Sinusoidal terms model possible periodic or bounded nonlinear restoring forces.

    Parameters:
    - x0 (np.ndarray): Position at time t.
    - x1 (np.ndarray): Velocity at time t.
    - params (np.ndarray): Array of 12 coefficients.

    Returns:
    - y (np.ndarray): Calculated acceleration.
    """
    
    return (
        params[0]  # constant offset, e.g. bias force
        + params[1] * x0  # linear restoring force ~ -k*x0
        + params[2] * x1  # linear damping ~ -c*x1
        + params[3] * x0 ** 2  # quadratic nonlinearity in position
        + params[4] * x1 ** 2  # quadratic nonlinearity in velocity (nonlinear damping)
        + params[5] * x0 * x1  # cross term coupling position and velocity
        + params[6] * x0 ** 3  # cubic stiffness nonlinearity
        + params[7] * x1 ** 3  # cubic velocity nonlinearity
        + params[8] * (x0 ** 2) * x1  # mixed higher order term
        + params[9] * x0 * (x1 ** 2)  # another mixed higher order term
        + params[10] * np.sin(x0)     # sinusoidal restoring force component, e.g. pendulum-like behavior
        + params[11] * np.cos(x1)     # velocity-dependent periodic effect or correction term
    )
