def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator with:
    - polynomial nonlinearities in position (up to quintic),
    - polynomial and absolute value nonlinearities in velocity,
    - cross terms between position and velocity,
    - dry friction modeled by sign functions,
    - sinusoidal restoring force component (typical for pendulum-like systems),
    - cosine dependence on velocity to capture complex damping or forcing effects,
    - additional mixed sine-cosine terms for richer dynamics.

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Array of 12 parameters

    Returns:
        np.ndarray: Acceleration at time t
    """
    
    p0 = params[0]   # constant bias term
    p1 = params[1]   # linear restoring force coefficient (position)
    p2 = params[2]   # quadratic nonlinearity in position
    p3 = params[3]   # cubic nonlinearity in position
    p4 = params[4]   # quintic nonlinearity in position
    p5 = params[5]   # linear viscous damping coefficient (velocity)
    p6 = params[6]   # dry friction magnitude effect via abs(velocity)
    p7 = params[7]   # combined viscous & Coulomb friction effect via velocity * sign(velocity)
    p8 = params[8]   # cross term between position and velocity
    p9 = params[9]   # higher order cross term (position^2 * velocity)
    p10= params[10]  # higher order cross term with abs(velocity) (position * abs(velocity))
    p11= params[11]  # pure dry friction modeled by sign(velocity)

    
    y = (
        p0 
        + p1 * x0 
        + p2 * x0**2 
        + p3 * x0**3 
        + p4 * x0**5 
        
        + p5 * x1 
        + p6 * np.abs(x1) 
        + p7 * x1 * np.sign(x1) 
        
        + p8 * x0 * x1 
        + p9 * (x0**2) * x1 
        + p10* x0 * np.abs(x1) 
        
        + p11* np.sign(x1)

        # Sinusoidal restoring force typical for pendulum-like oscillators, scaled by linear stiffness param
        + 0.5*p1*np.sin(x0)

        # Cosine dependence on velocity capturing complex damping/forcing effects, scaled by viscous damping param
        - 0.3*p5*np.cos(x1)

        # Additional mixed trigonometric terms capturing richer nonlinear coupling
        
        + 0.4*p2*np.sin(x0)*np.cos(x1)       # coupling sin(position)*cos(velocity), weighted by quadratic pos param
        
        - 0.25*p3*np.sin(2*x0)*np.sign(x1)  # coupling sin(2*position)*sign(velocity), weighted by cubic pos param
        
       )
    
    return y
