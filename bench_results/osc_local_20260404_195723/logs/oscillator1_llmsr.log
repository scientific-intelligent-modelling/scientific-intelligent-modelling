def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration y as a nonlinear function of position (x0) and velocity (x1),
    incorporating linear stiffness, damping, cubic stiffness nonlinearity,
    nonlinear damping effects, mixed coupling terms,
    periodic forcing components, and exponential velocity-dependent damping.

    Parameters:
        x0: Position at time t (np.ndarray)
        x1: Velocity at time t (np.ndarray)
        params: array of coefficients with length 12

    Returns:
        Acceleration y as numpy array.
    """
    
    p = params
    
    y = (
        p[0] * x0                     # linear stiffness term (-k*x)
        + p[1] * x1                   # linear damping term (-c*v)
        + p[2] * x0**3                # cubic stiffness nonlinearity (Duffing type)
        + p[3] * np.abs(x1) * x1      # quadratic velocity-dependent damping (sign-sensitive)
        + p[4] * x0 * x1              # cross term between position and velocity
        + p[5] * np.sin(x0)           # periodic forcing or parametric excitation dependent on position
        + p[6] * np.cos(x0)           # additional periodic effect on position
        + p[7] * np.sin(x1)           # periodic forcing dependent on velocity phase
        + p[8] * np.cos(x1)           # additional periodic effect on velocity
        + p[9] * x0**2                # quadratic position nonlinearity retained for flexibility
        + p[10]* x0**2 * x1           # higher order mixed term capturing coupling effects
        + p[11]* (-np.sign(x1) * np.exp(-np.abs(x1)))  # exponential velocity-dependent nonlinear damping-like term
    )
    
    return y
