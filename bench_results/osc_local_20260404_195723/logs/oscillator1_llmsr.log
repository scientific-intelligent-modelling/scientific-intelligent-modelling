def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Calculates acceleration as a function of position and velocity including:
    - linear, cubic, quintic restoring force terms,
    - viscous damping (linear and quadratic),
    - nonlinear damping proportional to |velocity|,
    - dry friction modeled both smoothly (tanh) and sharply (sign),
    - cross terms between position and velocity,
    - sinusoidal restoring force for pendulum-like effects,
    - saturation effects on velocity-dependent forces,
    - additional nonlinear coupling terms involving trigonometric functions,
    - quintic viscous damping for stronger high-speed effect.

    Parameters:
        x0 (np.ndarray): Position at time t.
        x1 (np.ndarray): Velocity at time t.
        params (np.ndarray): Array of 12 parameters controlling each term.

    Returns:
        np.ndarray: Acceleration at time t.
    """

    p0 = params[0]   # constant bias term
    p1 = params[1]   # linear restoring force coefficient (position)
    p2 = params[2]   # cubic restoring force coefficient (position)
    p3 = params[3]   # quintic restoring force coefficient (position)

    p4 = params[4]   # linear viscous damping coefficient (velocity)
    p5 = params[5]   # quadratic viscous damping coefficient (velocity^2)

    p6 = params[6]   # nonlinear damping proportional to abs(velocity)
    
    p7 = params[7]   # smooth dry friction magnitude coefficient via tanh
    
    p8 = params[8]   # cross term coefficient: position * velocity
    p9 = params[9]   # higher order cross term: position^2 * velocity
     
    p10 = params[10]  # sinusoidal restoring force amplitude
    
    p11 = params[11]  # sharp dry friction or Coulomb friction modeled by sign(velocity)

    
    y = (
        p0 
        + p1 * x0 
        + p2 * x0**3 
        + p3 * x0**5 
        
        - p4 * x1                         # linear viscous damping opposes motion
        - p5 * x1 * np.abs(x1)           # quadratic viscous damping
        
        - 0.5 * p5 * x1**5               # quintic viscous damping for stronger high-speed effect
        
        - p6 * np.abs(x1)                 # nonlinear damping proportional to speed magnitude
        
        - p7 * np.tanh(10*x1)             # smooth approximation of dry friction
        
        + p8 * x0 * x1                    # cross term coupling position & velocity
        
        + p9 * (x0**2) * x1              
        
        - p10 * np.sin(x0)                # pendulum-like sinusoidal restoring force
        
        + 0.3*p10*x1*np.cos(x0)           # additional nonlinear coupling between vel and cos(pos)
        
        + 0.8*p11*np.sign(x1)             # sharp dry friction modeled by sign function
     )
    
    return y
