def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration as a polynomial function including:
    - constant bias
    - linear, cubic, quintic and septic stiffness terms in position
    - linear, quadratic and cubic damping terms in velocity
    - cross terms combining powers of position and velocity up to cubic order

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length at least 12.
        params[0]: constant bias
        params[1]: linear coefficient for position (x0)
        params[2]: cubic coefficient for position (x0^3)
        params[3]: quintic coefficient for position (x0^5)
        params[4]: septic coefficient for position (x0^7)
        params[5]: linear coefficient for velocity (x1)
        params[6]: quadratic coefficient for velocity (x1^2)
        params[7]: cubic coefficient for velocity (x1^3)
        params[8]: cross term: linear position * linear velocity (x0 * x1)
        params[9]: cross term: quadratic position * linear velocity ((x0^2) * x1)
        params[10]: cross term: cubic position * quadratic velocity ((x0^3) * (x1^2))
        params[11]: cross term: quintic position * cubic velocity ((x0^5) * (x1^3))

    Returns:
    - y: acceleration values as numpy array
    """
    
    return (
        params[0]
        + params[1] * x0
        + params[2] * x0**3
        + params[3] * x0**5
        + params[4] * x0**7
        + params[5] * x1
        + params[6] * x1**2
