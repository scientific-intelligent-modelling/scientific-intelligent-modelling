def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` that better captures nonlinear dynamics
    of a nonlinear harmonic oscillator.

    Parameters:
    - x0 (np.ndarray): position at time t
    - x1 (np.ndarray): velocity at time t
    - params (np.ndarray): array of length at least 12 containing coefficients

    Returns:
    - y (np.ndarray): acceleration values
    """
    p = params

    # Physically motivated terms:
    # p[0]: constant offset acceleration (usually zero)
    # p[1]: linear restoring force coefficient (~ -k)
    # p[2]: linear damping coefficient (~ -c)
    # p[3]: quadratic position nonlinearity
    # p[4]: quadratic velocity nonlinearity
    # p[5]: cross term linear in x0 and x1
    # p[6]: cubic restoring force coefficient (~ -k3)
    # p[7]: cubic velocity nonlinearity
    # p[8], p[9]: higher order mixed terms
    # p[10], p[11]: periodic nonlinear effects

    y = (
        p[0]  # constant offset acceleration
        + p[1] * (-x0)  # linear restoring force (-k*x)
        + p[2] * (-x1)  # linear damping (-c*v)
        + p[3] * (x0 ** 2)  # quadratic position nonlinearity
        + p[4] * (x1 ** 2)  # quadratic velocity nonlinearity
        + p[5] * (-x0 * x1)  # cross term with negative sign for physical consistency
        + p[6] * (-x0 ** 3)  # cubic restoring force (-k3*x^3)
        + p[7] * (-x1 ** 3)  # cubic damping-like effect on velocity
        + p[8] * ((x0 ** 2) * x1)  # mixed higher order term
        + p[9] * (x0 * (x1 ** 2))   # mixed higher order term 
        + p[10] * np.sin(x0)       # nonlinear periodic forcing/restoring effect 
        + p[11] * np.cos(x1)       # nonlinear periodic effect on velocity 
    )

    return y
