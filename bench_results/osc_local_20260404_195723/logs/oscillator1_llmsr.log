    - Nonlinear damping proportional to velocity magnitude times velocity,
    - Exponential damping capturing stronger dissipation at high speeds,
    - Velocity sign-dependent friction (Coulomb friction),
    - Additional mixed nonlinear forcing effects.

    Parameters:
    - params (np.ndarray): array of length 12 containing coefficients for each term.

    Returns:
    - y (np.ndarray): computed acceleration values.
    """
    
    p = params

    # Polynomial and cross terms
    poly_terms = (
        p[0]                    # constant offset
        + p[1] * x0             # linear restoring force term (-k*x)
        + p[2] * x1             # linear damping term (-c*v)
        + p[3] * x0**2          # quadratic position nonlinearity
        + p[4] * x1**2          # quadratic velocity nonlinearity
        + p[5] * x0 * x1        # cross quadratic term
        + p[6] * x0**3          # cubic Duffing-type nonlinearity in position
        + p[7] * x1**3          # cubic velocity nonlinearity
        + p[8] * (x0**2) * x1   # mixed higher order nonlinear term
        + p[9] * x0 * (x1**2)   # mixed higher order nonlinear term
    )

    trig_terms = (
        p[10] * np.sin(x0)      # pendulum-like restoring force component
        + 0                      # placeholder if needed for more trig terms later
    )

    nonlinear_damping = (
        p[11] * x1 * np.abs(x1)  # nonlinear damping proportional to v*|v|
    )

    exp_damping = -0.5 * np.exp(-np.abs(x1)) * x1  # exponential velocity-dependent damping

    coulomb_friction = -0.3 * np.sign(x1)          # Coulomb friction

    
    y = poly_terms + trig_terms + nonlinear_damping + exp_damping + coulomb_friction

    
    return y
