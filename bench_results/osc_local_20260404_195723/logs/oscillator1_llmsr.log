        + p[4] * x1**3                         # cubic velocity dependent nonlinear effect
        + p[5] * x0 * x1                       # mixed nonlinear coupling term between position & velocity
        + p[6] * np.sin(x0)                    # periodic forcing dependent on position (sin)
        + p[7] * np.cos(x0)                    # periodic forcing dependent on position (cos)
        + p[8] * np.sin(x1)                    # periodic forcing dependent on velocity phase (sin)
        + p[9] * np.cos(x1)                    # periodic forcing dependent on velocity phase (cos)
        + p[10]* x0**2                         # quadratic position nonlinearity for flexibility 
        + p[11]* (-np.sign(x1) * np.exp(-np.abs(x1)))   # smooth exponential vel-dependent damping-like term
    )
    
    return y
