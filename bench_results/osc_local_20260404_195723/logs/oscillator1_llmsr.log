def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator including:
    - linear and higher-order odd polynomial restoring forces,
    - linear and nonlinear damping,
    - cross terms between position and velocity,
    - periodic nonlinearities representing possible external forcing or intrinsic system properties.

    Mathematical form:
        a = c0 
          + c1*x 
          + c2*x^3 
          + c3*x^5 
          + c4*v 
          + c5*v^3 
          + c6*x*v
          + c7*(x^2)*v
          + c8*x*(v^2)
          + c9*sin(x)
          + c10*cos(x)
          + c11*sin(v)
    
    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length == 12.
    
    Returns:
        np.ndarray: acceleration values corresponding to inputs x0 (position) and x1 (velocity).
    """
    p = params
    return (
        p[0]  # constant offset term
        + p[1] * x0  # linear restoring force term (-k*x)
        + p[2] * (x0 ** 3)  # cubic nonlinearity in restoring force
        + p[3] * (x0 ** 5)  # quintic nonlinearity in restoring force
        + p[4] * x1  # linear damping term (-c*v)
        + p[5] * (x1 ** 3)  # cubic velocity term for complex damping behavior
        + p[6] * x0 * x1  # cross term between position and velocity
        + p[7] * (x0 ** 2) * x1  # nonlinear damping cross-term quadratic in position, linear in velocity
        + p[8] * x0 * (x1 ** 2)  # nonlinear damping/coupling quadratic in velocity, linear in position
        + p[9] * np.sin(x0)      # periodic forcing/nonlinearity in position
        + p[10] * np.cos(x0)     # periodic forcing/nonlinearity phase-shifted in position
        + p[11] * np.sin(x1)     # periodic effect related to velocity
    )
