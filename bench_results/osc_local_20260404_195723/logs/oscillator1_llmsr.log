        c5 * x0**3 +
        c6 * x1**3 +
        c7 * x0 * x1 +
        c8 * (x0**2) * x1 +
        c9 * x0 * (x1**2) +
        c10 * np.abs(x1) * x1 +      # nonlinear damping-like term
        c11 * np.abs(x0) * x0         # nonlinear stiffness-like term with absolute value for asymmetry
    )
