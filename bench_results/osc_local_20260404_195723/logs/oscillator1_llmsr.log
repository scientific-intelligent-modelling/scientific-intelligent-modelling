    return (
        params[0]                                  # constant offset (bias or external constant force)
        + params[1] * x0                           # linear restoring force (-k*x)
        + params[2] * x1                           # linear damping (-c*v)
        + params[3] * (x0 ** 3)                    # cubic stiffness nonlinearity
        + params[4] * (x0 ** 5)                    # quintic stiffness nonlinearity
        + params[5] * (x1 ** 2)                    # quadratic damping effect (velocity squared term)
