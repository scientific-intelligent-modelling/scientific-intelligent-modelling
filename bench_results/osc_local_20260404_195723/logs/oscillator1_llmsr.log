def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Models acceleration as a polynomial function of position (x0) and velocity (x1),
    including linear, quadratic, cubic terms and cross-terms for nonlinear harmonic oscillator.
    
    Parameters:
    - params (np.ndarray): Array of 12 coefficients.
    
    Returns:
    - y (np.ndarray): Calculated acceleration.
    """
    # Unpack parameters for clarity
    p = params
    
    # Terms:
    # Constant term
    term_const = p[0]
    
    # Linear terms
    term_x0 = p[1] * x0
    term_x1 = p[2] * x1
    
    # Quadratic terms
    term_x02 = p[3] * (x0 ** 2)
    term_x12 = p[4] * (x1 ** 2)
    
    # Cubic terms
    term_x03 = p[5] * (x0 ** 3)
    term_x13 = p[6] * (x1 ** 3)
    
    # Cross terms quadratic-linear combinations
    term_x0x1 = p[7] * (x0 * x1)
    
    # Higher order cross terms
    term_x02x1 = p[8] * ((x0 ** 2) * x1)
    term_x01x12 = p[9] * (x0 * (x1 ** 2))
    
    # Additional cubic cross-terms if needed
    term_x03x13 = 0.   # No parameter left for more complex terms; can be omitted or added if desired
    
    # Sum all contributions
    y = (
        term_const +
        term_x0 +
        term_x1 +
        term_x02 +
        term_x12 +
        term_x03 +
        term_x13 +
        term_x0x1 +
        term_x02x1 +
        term_x01x12 
        # No more parameters left for additional terms here.
       )
    
    return y
