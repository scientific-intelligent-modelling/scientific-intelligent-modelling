def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator as a combination of:
    - Polynomial terms up to quartic order in position (x0) and velocity (x1),
    - Cross terms representing coupling between position and velocity,
    - Nonlinear trigonometric terms reflecting pendulum-like restoring forces,
    - Nonlinear damping proportional to velocity magnitude times velocity,
    - Exponential damping capturing stronger dissipation at high speeds,
    - Velocity sign-dependent friction (Coulomb friction),
    - Additional mixed nonlinear forcing effects.

    Parameters:
    - params (np.ndarray): array of length 12 containing coefficients for each term.

    Returns:
    - y (np.ndarray): computed acceleration values.
    """
    
    p = params

    # Polynomial and cross terms up to quartic order
    poly_terms = (
        p[0]                    # constant offset
        + p[1] * x0             # linear restoring force term (-k*x)
        + p[2] * x1             # linear damping term (-c*v)
        + p[3] * x0**2          # quadratic position nonlinearity
        + p[4] * x1**2          # quadratic velocity nonlinearity
        + p[5] * x0 * x1        # cross quadratic term
        + p[6] * x0**3          # cubic Duffing-type nonlinearity in position
        + p[7] * x1**3          # cubic velocity nonlinearity
        + p[8] * (x0**2) * x1   # mixed higher order nonlinear term
        + p[9] * x0 * (x1**2)   # mixed higher order nonlinear term
        + p[10]* (x0 ** 4)      # quartic position nonlinearity for stiffness saturation effects
        + p[11]* (x1 ** 4)      # quartic velocity nonlinearity for strong damping effects
    )

    trig_terms = (
        0.8 * np.sin(x0)         # pendulum-like restoring force component (~sin(x))
        + 0.4 * np.cos(x1)       # periodic modulation related to velocity phase/frequency effects
        + 0.25* np.sin(x1)*x1     # combined sinusoidal-velocity modulation on damping/forcing 
    )

    nonlinear_damping = (
        0.5 * (x1 * np.abs(x1))   # nonlinear damping proportional to |v|*v 
    )

    exp_damping = -0.6 * np.exp(-np.abs(x1)) * x1  # exponential damping dependent on |velocity|

    coulomb_friction = -0.35 * np.sign(x1)         # Coulomb friction force

    
    y = poly_terms + trig_terms + nonlinear_damping + exp_damping + coulomb_friction

    return y
