def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration of nonlinear harmonic oscillator with physically motivated signs:
    - Negative linear restoring force proportional to position
    - Negative linear damping proportional to velocity
    - Nonlinear quadratic and cubic terms capturing system nonlinearities

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of coefficients [c0,...,c9]

    Returns:
    - Acceleration at time t
    """
    
    # Constant offset term (e.g., external forcing)
    constant_term = params[0]
    
    # Linear restoring force (-k * x)
    linear_restoring = -abs(params[1]) * x0
    
    # Linear damping (-c * v)
    linear_damping = -abs(params[2]) * x1
    
    # Quadratic nonlinearities
    quadratic_terms = (
        params[3] * (x0 ** 2) +       # could be positive or negative depending on system
        params[4] * (x1 ** 2) +       # often positive for nonlinear damping effects
        params[5] * (x0 * x1)         # mixed term, sign depends on system specifics
    )
    
    # Cubic nonlinearities
    cubic_terms = (
        params[6] * (x0 ** 3) +
        params[7] * (x1 ** 3) +
        params[8] * (x0 ** 2) * x1 +
        params[9] * x0 * (x1 ** 2)
    )
    
    return constant_term + linear_restoring + linear_damping + quadratic_terms + cubic_terms
