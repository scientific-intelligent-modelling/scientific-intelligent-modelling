        + p3 * x0**3 
        + p4 * x0**5 
        + p5 * x1 
        + p6 * np.abs(x1) 
        + p7 * x1 * np.sign(x1) 
        + p8 * x0 * x1 
        + p9 * (x0**2) * x1 
        + p10* x0 * np.abs(x1) 
        + p11* np.sign(x1)
        
        # Add sinusoidal restoring force component typical for pendulum-like oscillators
        + 0.5*params[1]*np.sin(x0) 
        
        # Add cosine dependence on velocity to capture complex damping/forcing effects
        - 0.3*params[5]*np.cos(x1)
        
       )
    
