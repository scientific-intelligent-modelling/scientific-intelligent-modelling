        - params[5] * x1                  # linear damping (negative sign)
        + params[6] * np.power(x1, 2)     # quadratic damping nonlinearity (sign can vary)
        + params[7] * np.power(x1, 3)     # cubic damping nonlinearity
        + params[8] * (x0 * x1)           # cross term coupling position & velocity linearly
        + params[9] * ((x0 ** 2) * x1)    # mixed quadratic-cubic term
        + params[10]* (x0 * (x1 ** 2))    # mixed cubic-quadratic term
        + params[11]* ((x0 ** 3) * x1)    # higher order coupling term 
        + params[12]* ((x0 ** 4))         # quartic stiffness nonlinearity added for flexibility 
    )
