    """
    
    (
        p0,  p1,  p2,  p3,  p4,  p5,
        p6,  p7,  p8,  p9,  p10, p11
    ) = params
    
    y = (
        # Constant term
        p0
        
        # Linear terms
        + p1 * x0
        + p2 * x1
        
        # Quadratic terms
