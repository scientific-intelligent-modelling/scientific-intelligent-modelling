def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Calculates acceleration for a nonlinear harmonic oscillator given position (x0) and velocity (x1).

    This version includes:
    - Linear restoring force term proportional to position (Hooke's law)
    - Linear damping proportional to velocity
    - Cubic stiffness nonlinearity (Duffing oscillator)
    - Optional sinusoidal restoring force term to model more complex potentials

    Parameters:
    - x0 (np.ndarray): Position at time t.
    - x1 (np.ndarray): Velocity at time t.
    - params (np.ndarray): Array of parameters with length at least 11.

      Expected parameters:
      params[0]: constant offset acceleration term
      params[1]: linear stiffness coefficient (restoring force)
      params[2]: linear damping coefficient
      params[3]: cubic stiffness coefficient
      params[4]: amplitude of sinusoidal restoring force term
      params[5]: frequency multiplier inside sine function (optional)
      # Remaining parameters can be ignored or used for further extensions

    Returns:
    - np.ndarray: Calculated acceleration.
    """
    
    p0 = params[0]  # constant offset
    k = params[1]   # linear stiffness coefficient (-k*x0)
    c = params[2]   # damping coefficient (-c*x1)
    alpha = params[3]  # cubic stiffness coefficient (-alpha*x0^3)
    
    A_sin = params[4] if len(params) > 4 else 0.0  # amplitude of sinusoidal term
    omega_sin = params[5] if len(params) > 5 else 1.0  # frequency multiplier inside sine
    
    # Acceleration formula based on Newton's second law for nonlinear oscillator:
    y = (
        p0 
        - k * x0 
        - c * x1 
        - alpha * x0 ** 3 
        + A_sin * np.sin(omega_sin * x0)
    )
    
    return y
