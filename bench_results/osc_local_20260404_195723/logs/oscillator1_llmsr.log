def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator with:
    - polynomial nonlinearities in position (up to quintic),
    - polynomial and smooth nonlinearities in velocity,
    - cross terms between position and velocity,
    - dry friction modeled by smooth approximations,
    - sinusoidal restoring force component (typical for pendulum-like systems),
    - cosine dependence on velocity to capture complex damping or forcing effects,
    - higher order nonlinear damping terms (velocity squared/cubed),
    - additional trigonometric interaction terms,
    - smooth approximations to sign functions for numerical stability.

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Array of 12 parameters

    Returns:
        np.ndarray: Acceleration at time t
    """
    
    p = params  # shorthand
    
    # Smooth approximation of sign function using tanh with steepness factor k
    k = 10.0
    sgn_x1 = np.tanh(k * x1)
    
    y = (
        p[0]                              # constant bias term
        
        + p[1] * x0                      # linear restoring force term
        
        + p[2] * x0**2                  # quadratic nonlinearity in position
        
        + p[3] * x0**3                  # cubic nonlinearity in position
        
        + p[4] * x0**5                  # quintic nonlinearity in position
        
        + p[5] * x1                     # linear viscous damping term
        
        + p[6] * np.abs(x1)             # dry friction magnitude effect via abs(velocity)
        
        + p[7] * x1 * sgn_x1            # combined viscous & Coulomb friction effect with smooth sign
        
        + p[8] * x0 * x1               # cross term between position and velocity
        
