            p[9]  = mixed quadratic position * linear velocity term coefficient
            p[10] = mixed linear position * quadratic velocity term coefficient
            p[11] = exponential nonlinear damping amplitude dependent on |velocity|

    Returns:
        np.ndarray: Calculated acceleration.
    """
    
    p = params
    
    y = (
        # Linear restoring force (-k*x0), negative sign for restoring force direction
        -p[0]*x0
        
        # Linear viscous damping (-c*x1), negative sign for energy dissipation 
        -p[1]*x1
        
        # Cubic stiffness nonlinearity (Duffing oscillator type) 
        -p[2]*x0**3
        
        # Quadratic velocity dependent nonlinear damping/effect 
        +p[3]*x1**2
        
        # Cubic velocity dependent nonlinear damping/effect 
        +p[4]*x1**3
        
        # Mixed linear coupling between position & velocity 
        +p[5]*x0*x1
        
        # Parametric excitation or forcing via sine(position) 
        +p[6]*np.sin(x0)
        
        # Parametric excitation or forcing via cosine(velocity) 
        +p[7]*np.cos(x1)
        
        # Quadratic position nonlinearity retained for flexibility 
        +p[8]*x0**2
        
        # Mixed higher order coupling: quadratic position * linear velocity 
        +p[9]*x0**2*x1
        
        # Mixed higher order coupling: linear position * quadratic velocity 
        +p[10]*x0*x1**2
        
        # Exponential nonlinear damping effect depending on |velocity| magnitude,
        # multiplied by sign to preserve directionality of the effect.
        +p[11]*(-np.sign(x1)*np.exp(-np.abs(x1)))
    )
    
    return y
