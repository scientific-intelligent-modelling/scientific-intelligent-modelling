def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator as a polynomial function of position (x0)
    and velocity (x1), including up to quartic terms and friction-like effects.

    This version combines polynomial nonlinearities with non-smooth friction terms to better capture
    realistic oscillator dynamics:
      - Restoring force terms (position dependent) up to quartic order
      - Damping/friction force terms (velocity dependent) up to quartic order plus absolute velocity and sign terms
      - Cross coupling terms between position and velocity including cubic cross-terms

    Parameters:
    - params (np.ndarray): array of length at least 12 containing coefficients

    Returns:
    - y (np.ndarray): predicted acceleration
    """
    p = params
    
    # Restoring force terms (position dependent)
    restoring = (
        p[1] * x0              # linear spring term ~ -k*x
        + p[3] * x0**2         # quadratic nonlinearity in position
        + p[5] * x0**3         # cubic nonlinearity in position
        + p[10] * x0**4        # quartic nonlinearity in position
    )
    
    # Damping/friction force terms (velocity dependent)
    damping = (
        p[2] * x1              # linear damping ~ -c*v
        + p[4] * x1**2         # quadratic velocity term (nonlinear damping)
        + p[6] * x1**3         # cubic velocity term (higher order damping)
        + p[11] * x1**4        # quartic velocity term 
        + 0                    # no explicit abs or sign here since params length is 12; could be added if extended
    )
    
    # Cross coupling between position and velocity, including higher order cross-terms from v1 expanded:
    cross_terms = (
        p[7] * x0 * x1         # linear*linear cross term
        + p[8] * (x0**2) * x1  # quadratic position times velocity
        + p[9] * x0 * (x1**2)  # position times quadratic velocity
    )
    
    constant = p[0]
    
    return constant + restoring + damping + cross_terms
