def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration y as a function of position x0 and velocity x1 with:
    - constant offset
    - linear restoring force term (proportional to position)
    - linear damping term (proportional to velocity)
    - quadratic and cubic nonlinear stiffness terms (position powers)
    - quadratic and cubic nonlinear damping terms (velocity powers)
    - cross terms between position and velocity capturing coupling effects
    - periodic nonlinearities via sine and cosine functions

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Array of coefficients with length >= 12

    Returns:
        y (np.ndarray): Acceleration at time t
    """
    
    p = params
    
    # Linear terms
    linear_pos = p[1] * x0           # restoring force ~ -k*x
    linear_vel = p[2] * x1           # damping force ~ -c*v
    
    # Nonlinear stiffness terms (Duffing oscillator style)
    quad_pos = p[3] * x0**2          # quadratic stiffness nonlinearity
    cubic_pos = p[5] * x0**3         # cubic stiffness nonlinearity
    
    # Nonlinear damping terms
    quad_vel = p[4] * x1**2          # quadratic velocity term for nonlinear damping
    cubic_vel = p[6] * x1**3         # cubic velocity nonlinearity
    
    # Cross coupling terms between position and velocity
    cross_1 = p[7] * x0 * x1         # first order cross term
    cross_2 = p[8] * (x0**2) * x1     # higher order mixed term 1
    cross_3 = p[9] * x0 * (x1**2)     # higher order mixed term 2
    
    # Periodic nonlinear effects possibly representing forcing or phase-dependent effects
    sin_term = p[10] * np.sin(x0)
    cos_term = p[11] * np.cos(x1)
    
    y = (
        p[0]             # constant offset term 
        + linear_pos 
        + linear_vel 
        + quad_pos 
        + quad_vel 
        + cubic_pos 
        + cubic_vel 
        + cross_1 
        + cross_2 
        + cross_3 
        + sin_term 
        + cos_term
     )
