    (
        c0,  # constant offset acceleration or bias
        c1,  # linear in position - restoring force coefficient (-k/m)
        c2,  # linear in velocity - damping coefficient (-b/m)
        c3,  # quadratic in position - second order stiffness effect
        c4,  # quadratic in velocity - nonlinear damping or drag effect
        c5,  # cubic in position - Duffing nonlinearity coefficient
