def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator with polynomial,
    cross-product, and trigonometric terms reflecting physical relationships.
    This version adds mixed cubic velocity-position terms and additional trig couplings
    to capture more complex nonlinear dynamics.

    Parameters:
    - params (np.ndarray): Array of 12 parameters.

    Returns:
    - y (np.ndarray): Calculated acceleration.
    """
    # Unpack parameters for clarity
    c0 = params[0]   # constant offset (bias)
    c1 = params[1]   # linear stiffness coefficient (-k)
    c2 = params[2]   # linear damping coefficient (-c)
    c3 = params[3]   # cubic stiffness nonlinearity
    c4 = params[4]   # sinusoidal stiffness effect (sin(x0))
    c5 = params[5]   # quadratic velocity effect (x1^2)
    c6 = params[6]   # quadratic position term (x0^2)
    c7 = params[7]   # position-velocity coupling term (x0 * x1)
    c8 = params[8]   # cosine stiffness component (cos(x0))
    
    # New terms added in v2:
    
    c9  = params[9]  # velocity-dependent periodic effect sin(x1)
    
    c10 = params[10]  # higher order coupling term x0^2 * x1
    
    c11 = params[11]  # higher order coupling term x0 * x1^2

    
    y = (
        c0
        + c1 * x0
        + c2 * x1
        + c3 * (x0 ** 3)
        + c4 * np.sin(x0)
        + c5 * (x1 ** 2)
        + c6 * (x0 ** 2)
        + c7 * (x0 * x1)
        + c8 * np.cos(x0)
        + c9 * np.sin(x1)          # velocity trig nonlinearity
        + c10 * (x0 ** 2) * x1     # mixed cubic coupling term
        + c11 * x0 * (x1 ** 2)     # mixed cubic coupling term
    )
    
    return y
