    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator with physically meaningful polynomial and trigonometric terms,
    emphasizing typical nonlinear oscillator physics: restoring force, damping, cubic stiffness nonlinearity,
    velocity-dependent nonlinearities, and higher order coupling effects.

    Parameters:
    - params (np.ndarray): Array of 12 parameters.

    Returns:
    - y (np.ndarray): Calculated acceleration.
    """
    # Unpack parameters for clarity
    c0 = params[0]   # constant offset (bias)
    c1 = params[1]   # linear stiffness coefficient (-k)
    c2 = params[2]   # linear damping coefficient (-c)
    c3 = params[3]   # cubic stiffness nonlinearity
    c4 = params[4]   # sinusoidal stiffness effect
    c5 = params[5]   # quadratic velocity effect (nonlinear damping/forcing)
    c6 = params[6]   # quadratic position term (softening/hardening)
    c7 = params[7]   # position-velocity coupling term (nonlinear damping)
    c8 = params[8]   # cosine stiffness component
    c9 = params[9]   # velocity-dependent periodic effect
    c10 = params[10]  # higher order coupling term x0^2 * x1
    c11 = params[11]  # higher order coupling term x0 * x1^2

    y = (
        c0
        + c1 * x0
        + c2 * x1
        + c3 * (x0 ** 3)
        + c4 * np.sin(x0)
        + c5 * (x1 ** 2)
        + c6 * (x0 ** 2)
        + c7 * (x0 * x1)
        + c8 * np.cos(x0)
        + c9 * np.sin(x1)
        + c10 * (x0 ** 2) * x1
        + c11 * x0 * (x1 ** 2)
    )
    
    return y
