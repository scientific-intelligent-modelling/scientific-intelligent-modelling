        y = 
            params[0]                   # constant offset (e.g., external forcing)
          + params[1] * x0             # linear restoring force (usually negative)
          + params[2] * x0**3          # cubic stiffness nonlinearity (Duffing term)
          + params[3] * x0**5          # quintic stiffness nonlinearity (higher order)
          + params[4] * x1             # linear damping term
          + params[5] * x1**2          # quadratic damping nonlinearity
          + params[6] * x1**3          # cubic damping nonlinearity
