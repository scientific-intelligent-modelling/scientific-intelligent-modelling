        + params[4] * np.power(x1, 2)
        + params[5] * np.power(x1, 3)
        + params[6] * (x0 * x1)
        + params[7] * ((x0 ** 2) * x1)
        + params[8] * (x0 * (x1 ** 2))
        + params[9] * ((x0 ** 3) * x1)
        + params[10]* (x0 *(x1 ** 3))
    )
