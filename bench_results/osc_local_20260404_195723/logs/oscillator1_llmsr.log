def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of nonlinear harmonic oscillator with polynomial terms up to cubic order.
    Includes physically motivated signs for restoring force (-k*x) and damping (-c*v).
    
    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients
    
    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    # Constant offset term (external forcing or bias)
    constant_term = params[0]
    
    # Linear restoring force term (-k * x)
    linear_restoring = -abs(params[1]) * x0
    
    # Linear damping term (-c * v)
    linear_damping = -abs(params[2]) * x1
    
    # Quadratic nonlinear stiffness/damping terms
    quadratic_terms = (
        params[3] * (x0 ** 2) +
        params[4] * (x1 ** 2) +
        params[5] * (x0 * x1)
    )
    
    # Cubic nonlinear stiffness/damping terms
    cubic_terms = (
        params[6] * (x0 ** 3) +
        params[7] * (x1 ** 3) +
        params[8] * (x0 ** 2) * x1 +
        params[9] * x0 * (x1 ** 2)
    )
    
    return constant_term + linear_restoring + linear_damping + quadratic_terms + cubic_terms
