def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculates acceleration for a nonlinear harmonic oscillator given position (x0) and velocity (x1).

    This model includes:
    - Linear restoring force (-k * x0)
    - Linear damping (-c * x1)
    - Cubic stiffness nonlinearity (Duffing term)
    - Quadratic and cubic velocity nonlinear damping
    - Quadratic and cubic position nonlinearities
    - Mixed nonlinear coupling terms between position and velocity up to cubic order
    - Parametric excitation via sine/cosine functions of position and velocity
    - Velocity-dependent exponential damping term for smooth saturation effects

    Parameters:
        x0 (np.ndarray): Position at time t.
        x1 (np.ndarray): Velocity at time t.
        params (np.ndarray): Array of parameters with length 12.

            params indices mapping:
            p[0]  = linear stiffness coefficient (-k)
            p[1]  = linear damping coefficient (-c)
            p[2]  = cubic stiffness coefficient (Duffing nonlinearity)
            p[3]  = quadratic velocity damping coefficient
            p[4]  = cubic velocity damping coefficient
            p[5]  = cross term coefficient between position and velocity (linear*linear)
            p[6]  = sine(position) parametric forcing amplitude
            p[7]  = cosine(position) parametric forcing amplitude
            p[8]  = sine(velocity) parametric forcing amplitude
            p[9]  = cosine(velocity) parametric forcing amplitude
            p[10] = quadratic position nonlinearity coefficient 
            p[11] = exponential velocity-dependent damping-like term coefficient

    Returns:
        np.ndarray: Calculated acceleration.
    """
    
    p = params
    
    y = (
        # Linear restoring force (negative sign for restoring force)
        -p[0] * x0
        
        # Linear viscous damping force (negative sign for dissipation)
        -p[1] * x1
        
        # Cubic stiffness nonlinearity (Duffing oscillator type)
        -p[2] * x0**3
        
        # Quadratic velocity dependent nonlinear damping/effect 
        + p[3] * x1**2
        
        # Cubic velocity dependent nonlinear damping/effect 
        + p[4] * x1**3
        
        # Cross term coupling linear position and linear velocity 
        + p[5] * x0 * x1
        
        # Parametric excitation or forcing via sine/cosine functions of position 
        + p[6] * np.sin(x0)
        
        + p[7] * np.cos(x0)
        
        # Parametric excitation or forcing via sine/cosine functions of velocity 
        + p[8] * np.sin(x1)
        
        + p[9] * np.cos(x1)

        # Quadratic position nonlinearity retained for flexibility 
        + p[10]* x0**2
        
        # Smooth exponential velocity-dependent damping-like term to capture saturation effects,
        # multiplied by sign to preserve directionality of dissipation.
        + p[11]* (-np.sign(x1) * np.exp(-np.abs(x1)))
    )
    
    return y
