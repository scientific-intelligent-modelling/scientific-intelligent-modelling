    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Calculates acceleration as a function of position and velocity including higher order nonlinearities,
    cross terms, nonlinear damping, dry friction (both smooth and discontinuous),
    saturation effects on velocity-dependent forces, and pendulum-like sinusoidal restoring force.

    Parameters:
    - x0 (np.ndarray): Position at time t.
    - x1 (np.ndarray): Velocity at time t.
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.

    Returns:
    - y (np.ndarray): Acceleration values.
    """

    p0  = params[0]   # constant bias force/acceleration offset
    p1  = params[1]   # linear stiffness coefficient (-k*x)
    p3  = params[3]   # cubic stiffness nonlinearity
    p4  = params[4]   # quintic stiffness nonlinearity

    p5  = params[5]   # linear viscous damping coefficient (-c*v)
    p6  = params[6]   # quadratic damping coefficient (v^2 term)

    p8  = params[8]   # cross term: position * velocity
    p9  = params[9]   # higher order cross term: position^2 * velocity
    p10 = params[10]  # higher order cross term: position * velocity^2

    p11 = params[11]  # dry friction modeled by sign(velocity)

    # Additional parameters for new terms:
    p2  = params[2]   # smooth dry friction magnitude coefficient via tanh approximation
                      # reused from v0 style for smooth friction effect

    p7  = params[7]   # nonlinear damping proportional to |velocity| (speed-dependent damping)

    p12 = None        # no param12 since MAX_NPARAMS=12; so we won't use index beyond 11

    
    y = (
        p0                                  # constant bias
        
        + p1 * x0                           # linear restoring force
        
        + p3 * x0**3                       # cubic restoring force
        
        + p4 * x0**5                       # quintic restoring force
        
        + p5 * x1                          # linear viscous damping
        
        + p6 * x1**2                      # quadratic velocity damping
        
        - p7 * np.abs(x1)                  # nonlinear speed-dependent damping
        
        + p8 * x0 * x1                    # cross term coupling position & velocity
        
        + p9 * (x0**2) * x1              
        
        + p10* x0 * (x1**2)              
        
        - p2 * np.tanh(10*x1)             # smooth approximation of dry friction via tanh with gain=10 for sharpness
        
        + p11* np.sign(x1)                 # pure dry friction modeled by sign function

        - 0.5*p4*np.sin(x0)                # pendulum-like sinusoidal restoring force scaled down by factor related to quintic coeff

                                           
       )
    
    return y
