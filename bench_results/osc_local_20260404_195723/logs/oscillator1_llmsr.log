def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Models acceleration of nonlinear harmonic oscillator with polynomial terms up to cubic order,
    including mixed cubic interaction terms.
    
    Physically motivated signs:
    - Restoring force proportional to -x0 (negative sign)
    - Damping proportional to -x1 (negative sign)
    
    Parameters:
        x0: Position at time t
        x1: Velocity at time t
        params: Array of coefficients [p0, p1, ..., p11]
            p0 : constant offset
            p1 : linear stiffness coefficient (should be positive, multiplied by -1 inside)
            p2 : linear damping coefficient (should be positive, multiplied by -1 inside)
            p3..p11 : nonlinear coefficients
    
    Returns:
        Acceleration at time t as numpy array.
    """
    
    # Constant offset term
    constant_term = params[0]
    
    # Linear restoring force (-k * x0), k = params[1] >= 0 physically
    linear_restoring = -params[1] * x0
    
    # Linear damping (-c * x1), c = params[2] >= 0 physically
    linear_damping = -params[2] * x1
    
    # Quadratic nonlinearities
    quadratic_terms = (
        params[3] * (x0 ** 2) +
        params[4] * (x1 ** 2) +
        params[5] * (x0 * x1)
    )
    
    # Cubic nonlinearities including mixed terms
    cubic_terms = (
        params[6] * (x0 ** 3) +
        params[7] * (x1 ** 3) +
        params[8] * (x0 ** 2) * x1 +
        params[9] * x0 * (x1 ** 2) +
        params[10] * (x0 ** 3) * x1 +
        params[11] * x0 * (x1 ** 3)
    )
    
    return constant_term + linear_restoring + linear_damping + quadratic_terms + cubic_terms
