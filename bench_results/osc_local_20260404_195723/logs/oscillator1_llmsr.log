def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0` including nonlinear terms for oscillator acceleration.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    # Unpack parameters for clarity
    c0 = params[0]   # constant term
    c1 = params[1]   # linear in position
    c2 = params[2]   # linear in velocity
    c3 = params[3]   # quadratic in position
    c4 = params[4]   # quadratic in velocity
    c5 = params[5]   # cubic in position
    c6 = params[6]   # cubic in velocity
    c7 = params[7]   # cross term: position * velocity
    c8 = params[8]   # cross term: position^2 * velocity
    c9 = params[9]   # cross term: position * velocity^2

    return (
        c0 +
        c1 * x0 +
        c2 * x1 +
        c3 * x0**2 +
        c4 * x1**2 +
        c5 * x0**3 +
        c6 * x1**3 +
        c7 * x0 * x1 +
        c8 * (x0**2) * x1 +
        c9 * x0 * (x1**2)
    )
