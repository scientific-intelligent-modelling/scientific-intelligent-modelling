def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version models acceleration in a nonlinear harmonic oscillator by including:
    - Polynomial terms up to cubic order in position and velocity,
    - Cross polynomial terms,
    - Nonlinear trigonometric restoring forces (sin(x0), cos(x0)),
    - Velocity-dependent periodic damping or forcing (sin(x1), cos(x1)),
    - Mixed polynomial-trigonometric interaction terms,
    - Saturation-like nonlinearities via tanh,
    - Additional coupling between trig functions and polynomials,
    - Explicit nonlinear damping term proportional to velocity times tanh(velocity),
    - Higher flexibility in coupling terms with separate parameters.

    Parameters:
    - params (np.ndarray): array of length 12 containing coefficients for each term.

    Returns:
    - y (np.ndarray): computed acceleration values.
    """
    p = params

    # Polynomial and cross terms up to cubic order
    poly_terms = (
        p[0]                    # constant offset
        + p[1] * x0             # linear restoring force (-k*x)
        + p[2] * x1             # linear damping (-c*v)
        + p[3] * x0**2          # quadratic position nonlinearity
        + p[4] * x1**2          # quadratic velocity nonlinearity
        + p[5] * x0 * x1        # cross quadratic term
        + p[6] * x0**3          # cubic Duffing-type nonlinearity in position
        + p[7] * x1**3          # cubic velocity nonlinearity
        + p[8] * (x0**2) * x1   # mixed higher order nonlinear term
        + p[9] * x0 * (x1**2)   # mixed higher order nonlinear term
    )

    trig_terms = (
        p[10] * np.sin(x0)      # pendulum-like restoring force component
        + p[11] * np.cos(x1)     # velocity-dependent periodic modulation on damping/forcing
    )

    mixed_trig_poly_terms = (
        0.5 * p[10] * np.sin(x0) * x1  # coupling between sinusoidal restoring force and velocity scaled by param 10 again for flexibility 
        - 0.3 * p[11] * np.tanh(x1)     # saturation effect on damping or forcing scaled by param 11 again with negative sign for richer dynamics 
        - 0.4 * x1 * np.tanh(x1)         # explicit nonlinear damping saturation effect independent of params for robustness 
    )

    y = poly_terms + trig_terms + mixed_trig_poly_terms

    return y
