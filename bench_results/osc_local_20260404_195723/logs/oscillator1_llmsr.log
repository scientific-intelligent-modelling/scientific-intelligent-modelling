def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration y as a function of position x0 and velocity x1 with:
    - constant offset term
    - linear restoring force (-k*x0)
    - linear damping (-c*x1)
    - cubic stiffness nonlinearity (Duffing term)
    - quadratic and cubic velocity-dependent damping
    - cross interaction terms between position and velocity powers
    - quartic stiffness correction
    - fractional power nonlinearities in velocity for dry friction effects
    - exponential decay damping term dependent on speed magnitude
    - periodic forcing via sine/cosine of both position and velocity
    - additional nonlinear coupling terms involving fractional powers

    Parameters:
        x0 (np.ndarray): Position at time t.
        x1 (np.ndarray): Velocity at time t.
        params (np.ndarray): Array of 12 coefficients.

    Returns:
        np.ndarray: Acceleration at time t.
    """
    
    # Fractional power of |x0| to capture softer/harder stiffness nonlinearity than cubic/quartic
    frac_x0 = np.sign(x0) * np.abs(x0)**(3/2)  # e.g., power 1.5
    
    # Fractional power of |x1| to capture complex damping/friction behavior
    frac_x1 = np.sign(x1) * np.abs(x1)**(3/2)
    
    return (
        params[0]  # constant offset force/acceleration term
        + params[1] * x0  # linear restoring force (Hooke's law)
        + params[2] * x1  # linear damping proportional to velocity
        + params[3] * (x0 ** 3)  # Duffing cubic stiffness nonlinearity
        + params[4] * (x1 ** 2)  # quadratic damping effect on velocity
        + params[5] * frac_x1   # fractional power nonlinear damping/friction effect on velocity 
        + params[6] * (x0 * x1)  # cross-term interaction between position and velocity 
        + params[7] * np.sin(x0)  # periodic forcing from position 
        + params[8] * np.sign(x1) * np.abs(x1)**(1/2)  # fractional dry friction effect on velocity magnitude 
        + params[9] * np.exp(-np.abs(x1))  # exponential decay capturing complex drag/damping effects 
        + params[10] * (x0 ** 4)   # quartic stiffness correction for strong nonlinearity 
        + params[11] * np.cos(x0)*x1   # velocity-modulated periodic forcing term 
    )
