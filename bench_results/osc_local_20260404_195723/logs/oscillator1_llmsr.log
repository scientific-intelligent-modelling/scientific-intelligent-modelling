def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Further extends the nonlinear harmonic oscillator acceleration model by including:
    - higher order odd and even powers of position (up to 7th power)
    - higher order velocity terms (up to 5th power)
    - mixed nonlinear terms combining various powers of position and velocity
    - constant offset

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 18 (can be extended if needed).

    Equation form:
        a = c0 
          + c1 * x 
          + c2 * x^3 
          + c3 * x^5 
          + c4 * v 
          + c5 * v^3 
          + c6 * x * v
          + c7 * x^2 * v
          + c8 * v^2
          + c9 * x^3 * v
          + c10 * x * v^2
          + c11 * v^4
          + c12 * x^7           # seventh power of position for stronger nonlinearity in restoring force
          + c13 * v^5           # quintic velocity term for strong nonlinear damping effects
          + c14 * (x^4)         # even power term for restoring force asymmetry/flexibility
          + c15 * (x^2) * (v^3) # mixed high-order cross term between position squared and cubic velocity damping
          + c16 * (x^5) * v     # mixed quintic position with linear velocity term
          + c17 * x*(v^5)       # linear position with quintic velocity cross term for complex damping behavior
    """
    
    a = (
        params[0]   # constant offset
        + params[1]  * x0             # linear position term (restoring force)
        + params[2]  * (x0 ** 3)      # cubic nonlinearity in position (restoring force)
        + params[3]  * (x0 ** 5)      # quintic nonlinearity in position (restoring force)
        + params[4]  * x1             # linear velocity term (damping)
        + params[5]  * (x1 ** 3)      # cubic damping term
        + params[6]  * x0     * x1    # cross term between position and velocity
        + params[7]  *(x0 ** 2)* x1   # higher order cross term between position squared and velocity
        + params[8]  *(x1 ** 2)       # quadratic velocity damping term
        + params[9]  *(x0 ** 3)* x1   # cubic position times linear velocity cross term
        + params[10]* x0     *(x1 **2)# linear position times quadratic velocity cross term
        + params[11]*(x1 **4)         # quartic velocity damping for strong nonlinear effects
        
        if len(params)>12 else 0.0   # safe fallback if not enough parameters
        
    )
    
    if len(params)>12:
        a += params[12]*(x0**7)       # seventh power of position
    
    if len(params)>13:
        a += params[13]*(x1**5)       # quintic velocity damping
    
    if len(params)>14:
        a += params[14]*(x0**4)       # fourth power even-position restoring force
    
    if len(params)>15:
        a += params[15]*(x0**2)*(x1**3)# mixed high-order cross-term
    
    if len(params)>16:
        a += params[16]*(x0**5)*x1     # mixed quintic pos with linear vel
    
    if len(params)>17:
        a += params[17]*x0*(x1**5)     # linear pos with quintic vel
    
    return a
