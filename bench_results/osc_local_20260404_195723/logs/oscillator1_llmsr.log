def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Calculates acceleration for a nonlinear harmonic oscillator given position (x0) and velocity (x1).

    This model includes:
    - Linear restoring force (-k * x0)
    - Linear damping (-c * x1)
    - Cubic stiffness nonlinearity (Duffing term)
    - Quadratic and cubic velocity nonlinear damping
    - Quadratic position nonlinearity
    - Parametric excitation via sine functions of position
    - Mixed nonlinear coupling terms between position and velocity

    Parameters:
        x0 (np.ndarray): Position at time t.
        x1 (np.ndarray): Velocity at time t.
        params (np.ndarray): Array of parameters with length >= 12.

            params indices mapping:
            p[0]  = linear stiffness coefficient (-k)
            p[1]  = linear damping coefficient (-c)
            p[2]  = cubic stiffness coefficient (Duffing nonlinearity)
            p[3]  = quadratic velocity damping coefficient
            p[4]  = cross term coefficient between position and velocity
            p[5]  = sine(position) parametric forcing amplitude
            p[6]  = squared sine(position) parametric effect amplitude
            p[7]  = cosine(velocity) nonlinear effect amplitude
            p[8]  = quadratic position nonlinearity coefficient
            p[9]  = cubic velocity nonlinearity coefficient
            p[10] = mixed quadratic-position * linear-velocity term coefficient
            p[11] = mixed linear-position * quadratic-velocity term coefficient

    Returns:
        np.ndarray: Calculated acceleration.
    """
    
    p = params
    
    y = (
        # Linear restoring force (typically negative sign for restoring force)
        -p[0] * x0
        
        # Linear viscous damping force (typically negative sign for dissipation)
        -p[1] * x1
        
        # Cubic stiffness nonlinearity (Duffing oscillator type)
        -p[2] * x0**3
        
        # Quadratic velocity dependent nonlinear damping/effect 
        + p[3] * x1**2
        
        # Cross term coupling position and velocity 
        + p[4] * x0 * x1
        
        # Parametric excitation or forcing via sine functions of position 
        + p[5] * np.sin(x0)
        
        + p[6] * np.sin(x0)**2
        
        # Nonlinear effect depending on the phase or magnitude of velocity 
        + p[7] * np.cos(x1)
        
        # Quadratic position nonlinearity retained for flexibility 
        + p[8] * x0**2
        
        # Cubic velocity nonlinearity retained for flexibility 
        + p[9] * x1**3
        
        # Higher order mixed nonlinear terms coupling position squared with velocity linearly 
        + p[10]* x0**2 * x1
        
        # Mixed nonlinear term coupling linear position with squared velocity 
        + p[11]* x0 * x1**2
    )
    
    return y
