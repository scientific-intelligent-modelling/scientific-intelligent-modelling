def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator as a combination of:
    - Polynomial terms up to cubic order in position (x0) and velocity (x1),
    - Cross terms representing coupling between position and velocity,
    - Nonlinear trigonometric restoring forces,
    - Velocity-dependent periodic modulation,
    - Exponential damping capturing nonlinear dissipation,
    - Velocity sign-dependent friction (Coulomb friction),
    - Mixed nonlinear interaction terms.

    Parameters:
    - params (np.ndarray): array of length 12 containing coefficients for each term.

    Returns:
    - y (np.ndarray): computed acceleration values.
    """
    
    p = params

    # Polynomial and cross terms
    poly_terms = (
        p[0]                    # constant offset
        + p[1] * x0             # linear restoring force term (-k*x)
        + p[2] * x1             # linear damping term (-c*v)
        + p[3] * x0**2          # quadratic position nonlinearity
        + p[4] * x1**2          # quadratic velocity nonlinearity
        + p[5] * x0 * x1        # cross quadratic term
        + p[6] * x0**3          # cubic Duffing-type nonlinearity in position
        + p[7] * x1**3          # cubic velocity nonlinearity
        + p[8] * (x0**2) * x1   # mixed higher order nonlinear term
        + p[9] * x0 * (x1**2)   # mixed higher order nonlinear term
    )

    # Nonlinear trigonometric restoring forces and velocity-dependent periodicities
    trig_terms = (
        p[10] * np.sin(x0)      # pendulum-like restoring force component
        + p[11] * (np.cos(x1) + np.sin(x1)*x1)  # combined periodic effect on velocity/damping modulation
    )

    # Exponential damping factor modulating linear and cubic velocity terms to model nonlinear dissipation 
    exp_damping = np.exp(-np.abs(x1))

    exp_damping_terms = (
        - 0.5 * exp_damping * (p[2]*x1 + p[7]*x1**3)
    )

    # Velocity sign dependent friction force (Coulomb friction)
    friction_term = - 0.3 * np.sign(x1)

    
    y = poly_terms + trig_terms + exp_damping_terms + friction_term

    
    return y
