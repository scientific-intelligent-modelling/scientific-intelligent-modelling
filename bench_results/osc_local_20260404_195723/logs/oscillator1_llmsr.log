def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator as a combination of:
    - Polynomial terms up to cubic order in position (x0) and velocity (x1)
    - Cross terms between position and velocity
    - Nonlinear trigonometric and hyperbolic functions
    - Exponential decay/growth terms modeling damping saturation or energy input
    - Additional nonlinearities such as cos^2 modulation, sinh velocity effects
    - Physically motivated damping modeled by velocity-dependent nonlinearities

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 16.

    Returns:
    - y (np.ndarray): Acceleration at time t given position x0 and velocity x1.
    """
    
    # Helper to safely get parameter or zero if not present
    def p(i):
        return params[i] if i < len(params) else 0.0
    
    # Polynomial terms
    poly = (
        p(0) +                      # constant offset
        p(1) * x0 +                 # linear restoring force term ~ position
        p(2) * x1 +                 # linear damping term ~ velocity
        p(3) * x0**2 +              # quadratic position nonlinearity
        p(4) * x1**2 +              # quadratic velocity nonlinearity (nonlinear damping)
        p(5) * x0 * x1 +            # cross term linear*linear
        p(6) * x0**3 +              # cubic position nonlinearity (Duffing-type)
        p(7) * x1**3 +              # cubic velocity nonlinearity 
        p(8) * (x0**2)*x1 +         # mixed cubic term 
        p(9) * x0*(x1**2)           # mixed cubic term 
    )
    
    # Nonlinear trigonometric/hyperbolic functions modeling restoring/damping forces
    trig_hyper = (
        p(10)*np.sin(x0) +          # sinusoidal restoring force component (periodic potential)
        p(11)*np.tanh(x1)           # hyperbolic tangent damping-like nonlinearity saturating at high velocities
    )
    
    # Additional nonlinearities with exponential decay/growth and modulation effects
    extra = (
        p(12)*np.exp(-np.abs(x1)) +     # exponential decay in velocity for damping saturation effect 
        p(13)*(np.cos(x0)**2) +         # squared cosine modulation of restoring force 
        p(14)*np.sinh(x1) +             # hyperbolic sine velocity effect modeling asymmetric damping/forcing 
        p(15)*x0*np.exp(-x1**2)         # position modulated by Gaussian-like decay in velocity magnitude 
    )
    
    return poly + trig_hyper + extra
