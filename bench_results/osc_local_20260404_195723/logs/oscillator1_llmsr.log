def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration as a combination of:
    - constant bias
    - linear, cubic, and quintic restoring forces (position terms)
    - linear, quadratic, and cubic damping terms (velocity terms)
    - cross terms between position and velocity with various powers
    - additional nonlinear coupling terms to capture complex dynamics
    
    Parameters:
    - params: array-like with at least 12 elements:
        params[0]: constant bias
        params[1]: linear coefficient for position (x0)
        params[2]: cubic coefficient for position (x0^3)
        params[3]: linear coefficient for velocity (x1)
        params[4]: quadratic coefficient for velocity (x1^2)
        params[5]: cross term coefficient (x0 * x1)
        params[6]: quintic coefficient for position (x0^5)
        params[7]: cubic coefficient for velocity (x1^3)
        params[8]: quadratic position times velocity ((x0^2) * x1)
        params[9]: quartic position times velocity squared ((x0^4) * x1^2)
        params[10]: cubic position times cubic velocity ((x0^3) * x1^3)
        params[11]: quadratic position squared times linear velocity ((x0^2) * x1)

    Returns:
    - y: acceleration values as numpy array
    """
    
    return (
        params[0]
        + params[1] * x0
        + params[2] * x0**3
        + params[3] * x1
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[6] * x0**5
        + params[7] * x1**3
        + params[8] * (x0**2) * x1
        + params[9] * (x0**4) * (x1**2)
        + params[10] * (x0**3) * (x1**3)
        + params[11] * (x0**2) * x1  # This term is similar to param 8 but can capture different effects if weighted differently.
    )
