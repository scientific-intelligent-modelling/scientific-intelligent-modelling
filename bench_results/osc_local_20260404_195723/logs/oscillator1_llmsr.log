def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further refines the nonlinear oscillator acceleration model by:

    - Maintaining physically meaningful terms representing restoring forces and damping.
    - Including quartic stiffness nonlinearity for richer potential well shapes.
    - Including mixed nonlinear coupling terms between position and velocity.
    - Using consistent ordering of parameters for clarity.
    - Explicitly enforcing negative signs on restoring force and damping terms to reflect physical meaning:
        * Restoring force opposes displacement (negative stiffness)
        * Damping opposes velocity (negative damping)
    - Keeping constant offset param[0] as bias.

    Equation form:
        y = 
            params[0]                  # constant offset (bias)
          - abs(params[1]) * x0         # linear restoring force (-k*x), k>0
          - abs(params[2]) * x1         # linear damping (-c*v), c>0
          + params[3] * x0**3           # cubic stiffness nonlinearity (Duffing term)
          + params[4] * x1**2           # quadratic damping nonlinearity
          + params[5] * x1**3           # cubic damping nonlinearity
          + params[6] * (x0 * x1)       # linear coupling between position and velocity
          + params[7] * (x0**2) * x1    # mixed quadratic-cubic term
          + params[8] * x0 * (x1**2)    # mixed cubic-quadratic term
          + params[9] * x0**4           # quartic stiffness nonlinearity
          + params[10]* (x0**3) * x1    # higher order coupling term
          + params[11]* x0 * (x1**3)    # higher order coupling term

    Parameters:
        - x0: Position at time t.
        - x1: Velocity at time t.
        - params: array-like with at least 12 elements representing coefficients.

    Returns:
        - y: Acceleration array corresponding to inputs.
    """
    
    return (
        params[0]
        - np.abs(params[1]) * x0
        - np.abs(params[2]) * x1
        + params[3]  * np.power(x0, 3)
        + params[4]  * np.power(x1, 2)
        + params[5]  * np.power(x1, 3)
        + params[6]  * (x0     * x1)
        + params[7]  * ((x0 ** 2)   * x1)
        + params[8]  * (x0     * (x1 ** 2))
        + params[9]  * np.power(x0, 4)
        + params[10] * ((x0 ** 3)   * x1)
        + params[11] * (x0     * (x1 ** 3))
    )
