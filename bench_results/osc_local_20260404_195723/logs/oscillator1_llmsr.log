def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version models acceleration in a nonlinear harmonic oscillator by including:
    - Polynomial terms up to quartic order in position (x0) and velocity (x1),
    - Cross terms representing coupling between position and velocity,
    - Nonlinear trigonometric terms reflecting pendulum-like restoring forces,
    - Mixed polynomial-trigonometric interaction terms capturing complex nonlinear dynamics,
    - Velocity-dependent damping modulated by trigonometric functions.

    Parameters:
    - params (np.ndarray): array of length 12 containing coefficients for each term.

    Returns:
    - y (np.ndarray): computed acceleration values.
    """
    p = params

    # Polynomial and cross terms up to quartic order
    poly_terms = (
        p[0]                      # constant offset
        + p[1] * x0               # linear restoring force (-k*x)
        + p[2] * x1               # linear damping (-c*v)
        + p[3] * x0**2            # quadratic stiffness nonlinearity
        + p[4] * x1**2            # quadratic damping nonlinearity
        + p[5] * x0 * x1          # cross term linear*linear
        + p[6] * x0**3            # cubic Duffing-type stiffness nonlinearity
        + p[7] * x1**3            # cubic velocity nonlinearity
        + p[8] * (x0**2) * x1     # mixed higher order nonlinear term
        + p[9] * x0 * (x1**2)     # mixed higher order nonlinear term
        + p[10] * x0**4           # quartic stiffness nonlinearity for richer dynamics
        + p[11] * x1**4           # quartic velocity nonlinearity for complex damping effects
    )

    # Add nonlinear trigonometric restoring force and velocity-dependent modulation terms 
    trig_terms = (
        np.sin(x0)                # pendulum-like restoring force component (non-polynomial)
        - 0.5 * np.cos(x1)         # velocity-dependent periodic modulation (damping or forcing)
    )

    y = poly_terms + trig_terms

    return y
