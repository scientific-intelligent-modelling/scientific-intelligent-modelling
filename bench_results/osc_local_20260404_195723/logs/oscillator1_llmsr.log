def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved equation modeling acceleration of a nonlinear harmonic oscillator.

    Includes:
    - linear, cubic, quintic restoring force terms in position,
    - linear viscous damping,
    - dry friction modeled smoothly with tanh,
    - cross terms between position and velocity,
    - nonlinear damping terms involving abs(velocity),
    - sinusoidal restoring force component for pendulum-like behavior.

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Array of 12 parameters

    Returns:
        np.ndarray: Acceleration at time t
    """

    p0 = params[0]   # constant bias term
    p1 = params[1]   # linear restoring force coefficient (position)
    p2 = params[2]   # cubic restoring force coefficient (position)
    p3 = params[3]   # quintic restoring force coefficient (position)
    
    p4 = params[4]   # linear viscous damping coefficient (velocity)
    p5 = params[5]   # dry friction magnitude coefficient (smooth approx)
    
    p6 = params[6]   # cross term coefficient: position * velocity
    p7 = params[7]   # higher order cross term: position^2 * velocity
    
    p8 = params[8]   # nonlinear damping term involving abs(velocity)
    
    p9  = params[9]  # sinusoidal restoring force amplitude
    
    p10 = params[10]  # saturation effect on velocity via tanh
    p11 = params[11]  # additional friction or forcing term depending on sign(velocity)

    
    y = (
        p0 
        + p1 * x0 
        + p2 * x0**3 
        + p3 * x0**5 
        - p4 * x1                         # viscous damping opposes motion
        
        - p5 * np.tanh(10*x1)             # smooth approximation of dry friction
        
        + p6 * x0 * x1                    # cross term coupling position & velocity
        
        + p7 * (x0**2) * x1              
        
        - p8 * np.abs(x1)                 # nonlinear damping proportional to speed magnitude
        
        - p9 * np.sin(x0)                 # pendulum-like sinusoidal restoring force
        
        - p10 * np.tanh(x1)               # saturation effect on velocity-dependent forces
        
        + p11 * np.sign(x1)               # pure dry friction modeled by sign function
     )
    
    return y
