def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator with:
    - polynomial nonlinearities in position (up to quintic),
    - polynomial nonlinearities in velocity (up to quintic),
    - absolute value and sign-based friction/damping effects,
    - cross terms between position and velocity including higher orders,
    - sinusoidal restoring force components typical for pendulum-like systems,
    - cosine dependence on velocity capturing complex damping or forcing effects,
    - additional mixed sine-cosine terms for richer dynamics,
    - higher harmonics in trigonometric terms.

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Array of 12 parameters

    Returns:
        np.ndarray: Acceleration at time t
    """
    
    p = params  # shorthand
    
    y = (
        p[0]                              # constant bias term
        
        + p[1] * x0                      # linear restoring force
        
        + p[2] * x0**2                   # quadratic nonlinearity in position
        
        + p[3] * x0**3                   # cubic nonlinearity in position
        
        + p[4] * x0**5                   # quintic nonlinearity in position
        
        + p[5] * x1                      # linear viscous damping
        
        + p[6] * np.abs(x1)              # damping/friction proportional to |velocity|
        
        + p[7] * x1 * np.sign(x1)       # combined viscous & Coulomb friction effect
        
        + p[8] * x0 * x1                 # cross term linear pos & vel
        
        + p[9] * (x0**2) * x1            # higher order cross term pos^2*vel
        
        + p[10]* x0 * np.abs(x1)         # cross term pos*|vel|
        
        + p[11]* np.sign(x1)             # pure dry friction modeled by sign(velocity)
        
        # Sinusoidal restoring force typical for pendulum-like oscillators, scaled by linear stiffness param
        + 0.5*p[1]*np.sin(x0)
        
        # Cosine dependence on velocity capturing complex damping/forcing effects, scaled by viscous damping param
        - 0.3*p[5]*np.cos(x1)
        
        # Additional mixed trigonometric terms capturing richer nonlinear coupling
        + 0.4*p[2]*np.sin(x0)*np.cos(x1)
        
        - 0.25*p[3]*np.sin(2*x0)*np.sign(x1)
        
        # New higher order velocity polynomial term for stronger high-speed effects
        + 0.15*p[6]*(x1**3)
        
        # Higher harmonic sinusoidal restoring force component
        - 0.2*p[4]*np.sin(3*x0)
        
        # Cross term involving cos(2*velocity) modulated by quadratic position term
        + 0.18*p[9]*(x0**2)*np.cos(2*x1)
        
         # Interaction between cubic position and abs(velocity) with sine modulation
         - 0.22*p[10]*(x0**3)*np.abs(np.sin(x1))
         
         # Additional dry friction asymmetry captured via product of sign and sin functions
         + 0.12*p[11]*np.sign(x1)*np.sin(x0)
         
         )
    
    return y
