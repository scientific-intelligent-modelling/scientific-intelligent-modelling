        + params[5] * (x1 ** 3)  # cubic damping effect on velocity
        + params[6] * (x0 * x1)  # cross-term interaction between position and velocity 
        + params[7] * sin_shifted  # periodic forcing from shifted position 
        + params[8] * frac_vel  # fractional dry friction effect on velocity magnitude 
        + params[9] * exp_decay_pos  # exponential decay capturing displacement-dependent damping 
        + params[10] * cross_frac   # mixed fractional power cross term between position and velocity 
        + params[11] * np.cos(x0)*x1   # velocity-modulated periodic forcing term 
    )
