def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator as a function of position and velocity,
    including linear and nonlinear stiffness terms, linear and nonlinear damping terms,
    and cross terms to capture coupling effects.

    The general form is inspired by the Duffing oscillator with damping and additional nonlinear velocity terms:

        y = c0 
            + c1 * x0                  # linear restoring force (stiffness)
            + c2 * x0**3              # cubic restoring force (nonlinear stiffness)
            + c3 * x1                 # linear damping
            + c4 * x1**2              # quadratic velocity term (nonlinear damping or drag)
            + c5 * x0 * x1            # coupling between position and velocity
            + c6 * x0**2              # quadratic stiffness term (optional)
            + c7 * x1**3              # cubic velocity term (higher order damping)
            + c8 * (x0**2) * x1       # cross nonlinear term
            + c9 * x0 * (x1**2)       # another cross nonlinear term

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Coefficients array with at least 10 elements

    Returns:
        np.ndarray: Acceleration at time t
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * np.power(x0, 3)
        + params[3] * x1
        + params[4] * np.power(x1, 2)
        + params[5] * x0 * x1
        + params[6] * np.power(x0, 2)
        + params[7] * np.power(x1, 3)
        + params[8] * (x0 ** 2) * x1
        + params[9] * x0 * (x1 ** 2)
    )
