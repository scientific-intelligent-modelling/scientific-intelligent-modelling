        + (-0.4)*p5*np.exp(-x1**2)     # exponential decay term modeling reduced damping at high velocities
        
        + (-0.3)*p11*np.sign(x1)*np.exp(-np.abs(x1))  # decaying dry friction effect
        
        + p8 * x0 * x1                # cross term between position and velocity
        
        + 1.2*p9 * (x0**2) * x1       # enhanced higher order cross term
        
        + 0.9*p10* x0 * np.abs(x1)     # higher order cross term with abs(velocity)
        
        + 0.5*p11* np.sign(x1)         # pure dry friction modeled by sign function again for stability
        
        
        + 0.5*p1*np.sin(x0)            # sinusoidal restoring force typical for pendulum-like oscillators
        
        - 0.3*p5*np.cos(x1)            # cosine dependence on velocity capturing complex damping/forcing effects
       
       )
    
    return y
