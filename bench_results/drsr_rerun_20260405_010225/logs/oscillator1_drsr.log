def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation_v0 including nonlinear and mixed polynomial terms.

    Parameters:
    - params (np.ndarray): Array of length 12 containing coefficients for each term.

    Returns:
    - y (np.ndarray): Calculated acceleration.
    
    Terms included:
      params[0] : constant term
      params[1] * x0 : linear position
      params[2] * x1 : linear velocity
      params[3] * x0**2 : quadratic position
      params[4] * x1**2 : quadratic velocity
      params[5] * x0**3 : cubic position
      params[6] * x1**3 : cubic velocity
      params[7] * x0 * x1 : interaction linear*linear
      params[8] * (x0**2) * x1 : quadratic position times velocity
      params[9] * x0 * (x1**2) : position times quadratic velocity
      # Optional extra terms to fill up to 12 parameters:
      params[10] * (x0**3) * x1  # cubic position times velocity (optional)
      params[11] * x0 * (x1**3)  # position times cubic velocity (optional)
    """
    
    y = (
        params[0]
        + params[1]*x0
        + params[2]*x1
        + params[3]*x0**2
        + params[4]*x1**2
        + params[5]*x0**3
        + params[6]*x1**3
        + params[7]*x0*x1
        + params[8]*(x0**2)*x1
        + params[9]*x0*(x1**2)
        + params[10]*(x0**3)*x1   # optional higher order mixed term 
        + params[11]*x0*(x1**3)   # optional higher order mixed term 
    )
    
    return y
