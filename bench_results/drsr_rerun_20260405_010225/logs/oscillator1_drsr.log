def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Nonlinear oscillator acceleration model including linear, cubic, 
    and mixed polynomial terms of position (x0) and velocity (x1).

    Parameters:
    - params: array-like of length 12 containing coefficients for each term:
      params[0]: constant term
      params[1]: linear term in x0
      params[2]: linear term in x1
      params[3]: cubic term in x0^3
      params[4]: cubic term in x1^3
      params[5]: mixed term x0^2 * x1
      params[6]: mixed term x0 * x1^2
      params[7]: quadratic term in x0^2
      params[8]: quadratic term in x1^2
      params[9]: mixed quadratic term x0 * x1
      params[10]: higher order mixed term e.g. x0^3 * x1
      params[11]: higher order mixed term e.g. x0 * x1^3

    Returns:
    - y: acceleration values as numpy array.
    """
    y = (
        params[0]
        + params[1] * x0               # linear stiffness/restoring force
        + params[2] * x1               # linear damping force
        + params[3] * (x0 ** 3)       # cubic stiffness nonlinearity (asymmetry)
        + params[4] * (x1 ** 3)       # cubic nonlinear damping effect
        + params[5] * (x0 ** 2) * x1  # mixed nonlinear coupling terms
        + params[6] * x0 * (x1 ** 2)
        + params[7] * (x0 ** 2)       # quadratic stiffness or correction terms 
        + params[8] * (x1 ** 2)       # quadratic damping or correction terms 
        + params[9] * x0 * x1         # cross-term coupling between position & velocity 
        + params[10] * (x0 ** 3) * x1 # higher order mixed nonlinearity 
        + params[11] * x0 * (x1 ** 3)
    )
    return y
