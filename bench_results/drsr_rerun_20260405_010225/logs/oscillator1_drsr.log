def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Nonlinear oscillator acceleration model including linear, cubic, 
    and mixed polynomial terms of position (x0) and velocity (x1).

    Parameters:
    - x0: Position array
    - x1: Velocity array
    - params: Array of 12 trainable parameters
    
    Returns:
    - y: Acceleration array
    """
    
    # Unpack parameters for clarity
    c0 = params[0]   # constant term
    c1 = params[1]   # linear in x0 (linear stiffness)
    c2 = params[2]   # linear in x1 (linear damping)
    
    c3 = params[3]   # cubic in x0 (nonlinear stiffness)
    c4 = params[4]   # cubic in x1 (nonlinear damping)
    
    c5 = params[5]   # mixed term: x0 * x1
    c6 = params[6]   # quadratic in x0 times linear in x1: (x0^2)*x1
    c7 = params[7]   # linear in x0 times quadratic in x1: x0*(x1^2)
    
    c8 = params[8]   # quadratic term in position: (x0)^2
    c9 = params[9]   # quadratic term in velocity: (x1)^2
    
    c10 = params[10]  # higher order mixed term e.g. (x0^3)*x1
    c11 = params[11]  # higher order mixed term e.g. x0*(x1^3)

    
    y = (
        c0 
        + c1 * x0 
        + c2 * x1 
        + c3 * np.power(x0, 3) 
        + c4 * np.power(x1, 3) 
        + c5 * x0 * x1 
        + c6 * np.power(x0, 2) * x1 
        + c7 * x0 * np.power(x1, 2) 
        + c8 * np.power(x0, 2) 
        + c9 * np.power(x1, 2)
        + c10 * np.power(x0, 3) * x1
        + c11 * x0 * np.power(x1, 3)
       )
    
    return y
