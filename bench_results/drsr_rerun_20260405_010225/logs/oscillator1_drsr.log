def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Nonlinear oscillator acceleration model including linear, quadratic,
    cubic, and interaction polynomial terms of position (x0) and velocity (x1).

    Parameters:
    - x0: Position array
    - x1: Velocity array
    - params: Array of 12 trainable parameters:
        params[0] : constant term
        params[1] : linear term in x0
        params[2] : linear term in x1
        params[3] : quadratic term in x0^2
        params[4] : quadratic term in x1^2
        params[5] : mixed quadratic term in x0*x1
        params[6] : cubic term in x0^3
        params[7] : cubic term in x1^3
        params[8] : mixed cubic term in x0^2 * x1
        params[9] : mixed cubic term in x0 * x1^2
        # Optionally reserve two more parameters for future extensions or bias adjustments:
        params[10], params[11]
    """
    return (
          params[0]
        + params[1]*x0 
        + params[2]*x1 
        + params[3]*x0**2 
        + params[4]*x1**2 
        + params[5]*x0*x1 
        + params[6]*x0**3 
        + params[7]*x1**3 
        + params[8]*(x0**2)*x1 
        + params[9]*x0*(x1**2)
        # Optional extra terms if needed:
        # + params[10]*(some_term)
        # + params[11]*(some_term)
    )
