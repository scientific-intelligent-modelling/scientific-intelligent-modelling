def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Nonlinear oscillator acceleration model including linear, quadratic,
    cubic, and interaction polynomial terms of position (x0) and velocity (x1).

    Parameters:
    - params: array-like with length >= 12
      params[0] : constant term
      params[1] : linear coefficient for x0
      params[2] : linear coefficient for x1
      params[3] : quadratic coefficient for x0^2
      params[4] : quadratic coefficient for x1^2
      params[5] : cubic coefficient for x0^3
      params[6] : cubic coefficient for x1^3
      params[7] : interaction term coefficient for (x0 * x1)
      params[8] : interaction term coefficient for (x0^2 * x1)
      params[9] : interaction term coefficient for (x0 * x1^2)
      # Optional extra parameters if needed:
      # params[10], params[11], ...
    """
    y = (
        params[0]
        + params[1]*x0
        + params[2]*x1
        + params[3]*x0**2
        + params[4]*x1**2
        + params[5]*x0**3
        + params[6]*x1**3
        + params[7]*x0*x1
        + params[8]*(x0**2)*x1
        + params[9]*x0*(x1**2)
    )
    return y
