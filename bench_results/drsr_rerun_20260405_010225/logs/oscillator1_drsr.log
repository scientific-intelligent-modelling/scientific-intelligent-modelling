def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1` with full 12 parameters.

    Nonlinear oscillator acceleration model including constant,
    linear, quadratic, cubic and mixed polynomial terms of position (x0)
    and velocity (x1).

    y = p0 
        + p1 * x0 
        + p2 * x1 
        + p3 * (x0 ** 3) 
        + p4 * (x1 ** 3) 
        + p5 * (x0 ** 2) * x1 
        + p6 * x0 * (x1 ** 2)
        + p7 * (x0 ** 2)
        + p8 * (x1 ** 2)
        + p9 * x0 * x1
        + p10 * some_other_term_10
        + p11 * some_other_term_11

    For placeholders at params[10] and params[11], we can add:
      - quartic or higher order terms,
      - or damping-like nonlinearities such as |x1|*x1,
      - or other physically meaningful nonlinear combinations.

    Here we use:
      - |x1|*x1 as a nonlinear damping term,
      - |x0|*x0 as a nonlinear stiffness term.

    Parameters:
    - params: array of length 12 for trainable coefficients.
    """
    
    # Nonlinear damping term example: |velocity|*velocity = sign(x1)*x1^2
    nonlinear_damping = np.abs(x1) * x1
    
    # Nonlinear stiffness term example: |position|*position = sign(x0)*x0^2
    nonlinear_stiffness = np.abs(x0) * x0
    
    return (
          params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * (x0 ** 3)
        + params[4] * (x1 ** 3)
        + params[5] * (x0 ** 2) * x1
        + params[6] * x0 * (x1 ** 2)
        + params[7] * (x0 ** 2)
        + params[8] * (x1 ** 2)
        + params[9] * x0 * x1
        + params[10] * nonlinear_damping   # e.g. damping nonlinearity term
        + params[11] * nonlinear_stiffness # e.g. stiffness nonlinearity term
    )
