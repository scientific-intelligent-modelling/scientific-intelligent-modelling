def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved equation skeleton for acceleration y in oscillator1.

    Includes constant, linear, quadratic, cubic, and mixed polynomial terms of position (x0) 
    and velocity (x1) to capture nonlinear restoring forces and damping effects.

    Parameters:
    - params (np.ndarray): Array of 12 trainable coefficients:
        params[0] : constant term
        params[1] : linear term in x0
        params[2] : linear term in x1
        params[3] : quadratic term in x0^2
        params[4] : quadratic term in x1^2
        params[5] : cubic term in x0^3
        params[6] : cubic term in x1^3
        params[7] : mixed term: x0 * x1
        params[8] : mixed term: (x0)^2 * x1
        params[9] : mixed term: x0 * (x1)^2
        # Reserve last two parameters for possible extensions or higher order terms:
        params[10]: unused or future use
        params[11]: unused or future use

    Returns:
    - y (np.ndarray): Calculated acceleration values.
    """
    return (
          params[0]
        + params[1]*x0 
        + params[2]*x1 
        + params[3]*x0**2 
        + params[4]*x1**2 
        + params[5]*x0**3 
        + params[6]*x1**3 
        + params[7]*x0*x1 
        + params[8]*(x0**2)*x1 
        + params[9]*x0*(x1**2)
    )
