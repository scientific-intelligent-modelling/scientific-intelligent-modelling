def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Nonlinear oscillator acceleration model including linear, cubic, 
    and mixed polynomial terms of position (x0) and velocity (x1).

    y = params[0] 
        + params[1]*x0                 # linear stiffness
        + params[2]*x1                 # linear damping
        + params[3]*x0**3              # cubic stiffness (nonlinear restoring force)
        + params[4]*x1**3              # cubic damping (nonlinear damping)
        + params[5]*x0*x1              # mixed linear term
        + params[6]*x0**2 * x1         # quadratic-cubic mixed term
        + params[7]*x0 * x1**2         # mixed term capturing nonlinear interaction
        + params[8]*x0**2              # quadratic stiffness term for asymmetry
        + params[9]*x1**2              # quadratic damping-like term
        + params[10]*x0**3 * x1        # higher order mixed term
        + params[11]*x0 * x1**3        # higher order mixed term
    """
    return (
          params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0**3
        + params[4] * x1**3
        + params[5] * x0 * x1
        + params[6] * (x0**2) * x1
        + params[7] * x0 * (x1**2)
        + params[8] * (x0**2)
        + params[9] * (x1**2)
        + params[10] * (x0**3) * x1
        + params[11] * x0 * (x1**3)
    )
