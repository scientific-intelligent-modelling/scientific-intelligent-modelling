def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Includes nonlinear terms typical for nonlinear harmonic oscillators:
    - Cubic stiffness term (x0^3)
    - Cubic damping or velocity nonlinearity (x1^3)
    - Mixed quadratic terms (x0^2 * x1, x0 * x1^2)

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 7.
    """
    return (
        params[0]  # constant term
        + params[1] * x0
        + params[2] * x1
        + params[3] * (x0 ** 3)
        + params[4] * (x1 ** 3)
        + params[5] * (x0 ** 2) * x1
        + params[6] * x0 * (x1 ** 2)
    )
