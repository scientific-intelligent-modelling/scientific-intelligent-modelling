    - Dependent: y (Stress)

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    
    This model captures linear and nonlinear effects of strain and temperature on stress,
    including interaction terms and quadratic terms to reflect typical material behavior.
    """
    # Linear terms
    linear = params[0] + params[1] * x0 + params[2] * x1
    
    # Interaction term between strain and temperature
    interaction = params[3] * x0 * x1
    
    # Quadratic terms to capture nonlinearities
    quad_strain = params[4] * x0**2
    quad_temp = params[5] * x1**2
    
    # Optional higher order or cross terms can be added if needed, up to MAX_NPARAMS
    
    y = linear + interaction + quad_strain + quad_temp
    return y
