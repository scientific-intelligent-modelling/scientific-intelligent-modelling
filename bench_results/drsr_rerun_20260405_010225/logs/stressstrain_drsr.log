def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    This function models stress (y) as a function of strain (x0) and temperature (x1),
    including linear, interaction, and quadratic terms to capture nonlinear behavior
    and coupling effects.

    Parameters:
    - x0 (np.ndarray): Strain input array.
    - x1 (np.ndarray): Temperature input array.
    - params (np.ndarray): Array of at least 12 trainable coefficients.

    Returns:
    - y (np.ndarray): Calculated stress values.
    
    Raises:
    - ValueError: If params length is less than 12.
    """
    
    if len(params) < MAX_NPARAMS:
        raise ValueError(f"params must have at least {MAX_NPARAMS} elements")
    
    # Equation skeleton including:
    # constant term,
    # linear terms in strain and temperature,
    # quadratic terms in strain and temperature,
    # interaction term between strain and temperature,
    # plus additional quadratic cross terms for flexibility
    
    y = (
        params[0]  # constant term
        + params[1] * x0  # linear strain
        + params[2] * x1  # linear temperature
        + params[3] * x0**2  # quadratic strain
        + params[4] * x1**2  # quadratic temperature
        + params[5] * x0 * x1  # interaction term
        + params[6] * x0**3  # cubic strain for slight nonlinearity extension
        + params[7] * x1**3  # cubic temperature for slight nonlinearity extension
        + params[8] * (x0**2) * x1  # mixed higher order term
        + params[9] * x0 * (x1**2)  # mixed higher order term
        + params[10] * np.abs(x0)   # absolute value to capture possible asymmetric effects in strain
        + params[11] * np.abs(x1)   # absolute value to capture possible asymmetric effects in temperature
    )
    
    return y
