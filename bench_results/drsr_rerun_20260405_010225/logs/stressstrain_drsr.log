def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Includes linear, interaction, and quadratic terms of strain (x0) and temperature (x1)
    to capture nonlinear behavior and coupling effects in stress-strain relationship.

    y = p0 
        + p1*x0 + p2*x1 
        + p3*x0*x1 
        + p4*x0^2 + p5*x1^2
        + p6*(x0^2)*x1 + p7*x0*(x1^2)
        + p8*(x0^3) + p9*(x1^3)
        + p10*(x0^2)*(x1^2) + p11

    Note: params length = 12
    """
    # Unpack parameters for clarity
    p = params

    y = (
        p[0]                     # constant term
        + p[1] * x0              # linear strain
        + p[2] * x1              # linear temperature
        + p[3] * x0 * x1         # interaction term
        + p[4] * x0**2           # quadratic strain
        + p[5] * x1**2           # quadratic temperature
        + p[6] * (x0**2) * x1    # higher order interaction 1
        + p[7] * x0 * (x1**2)    # higher order interaction 2
        + p[8] * (x0**3)         # cubic strain term for nonlinearity
        + p[9] * (x1**3)         # cubic temperature term for nonlinearity
        + p[10] * (x0**2)*(x1**2)# combined quadratic interaction term
        # Note: param 11 is unused here but reserved for future extension or bias if needed.
    )
    
    return y
