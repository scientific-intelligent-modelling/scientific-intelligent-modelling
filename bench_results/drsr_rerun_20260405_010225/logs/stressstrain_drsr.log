def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0 (Strain), x1 (Temperature)
    - Dependent: y (Stress)

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    
    This model includes linear and interaction terms to capture combined effects of strain and temperature on stress.
    """
    return (
        params[0]  # intercept
        + params[1] * x0  # linear strain term
        + params[2] * x1  # linear temperature term
        + params[3] * x0**2  # quadratic strain term to capture nonlinear elasticity
        + params[4] * x1**2  # quadratic temperature term to capture nonlinear thermal effects
        + params[5] * x0 * x1  # interaction term between strain and temperature
    )
