def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Includes linear, quadratic, and interaction terms of strain (x0) and temperature (x1).

    Parameters:
    - params (np.ndarray): Trainable coefficients with at least 12 elements.

    Returns:
    - y (np.ndarray): Predicted stress values.
    """
    # Validate params length
    if len(params) < MAX_NPARAMS:
        raise ValueError(f"params must have at least {MAX_NPARAMS} elements")

    # Unpack parameters for clarity
    p0 = params[0]   # intercept
    p1 = params[1]   # linear term for x0
    p2 = params[2]   # linear term for x1
    p3 = params[3]   # quadratic term for x0^2
    p4 = params[4]   # quadratic term for x1^2
    p5 = params[5]   # interaction term x0*x1

    # Optional additional higher order or cross terms can be added using remaining parameters if needed

    y = (
        p0 +
        p1 * x0 +
        p2 * x1 +
        p3 * np.power(x0, 2) +
        p4 * np.power(x1, 2) +
        p5 * x0 * x1
    )

    return y
