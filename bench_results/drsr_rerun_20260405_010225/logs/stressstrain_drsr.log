def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0 (Strain), x1 (Temperature)
    - Dependent: y (Stress)

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    
    This model includes linear and interaction terms to capture coupling between strain and temperature,
    as well as nonlinear terms to better represent typical stress-strain-temperature relationships.
    """
    # Linear terms
    linear = params[0] + params[1] * x0 + params[2] * x1
    
    # Interaction term
    interaction = params[3] * x0 * x1
    
    # Nonlinear terms (quadratic)
    nonlinear = params[4] * x0**2 + params[5] * x1**2
    
    # Optional higher order or exponential terms can be added if needed
    return linear + interaction + nonlinear
