def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Includes linear, quadratic, and interaction terms of strain (x0) and temperature (x1)
    to capture nonlinear behavior and coupling effects in stress-strain relationship.

    Parameters:
    - x0 (np.ndarray): Strain
    - x1 (np.ndarray): Temperature
    - params (np.ndarray): Trainable coefficients with length at least 12

    Returns:
    - y (np.ndarray): Calculated stress
    """
    # Ensure params has at least 12 elements to avoid index errors
    assert len(params) >= 12, "params must have at least 12 elements"

    # Equation skeleton:
    # y = p0 + p1*x0 + p2*x1 + p3*x0^2 + p4*x1^2 + p5*x0*x1 
    #   + p6*x0^3 + p7*x1^3 + p8*(x0^2)*x1 + p9*x0*(x1^2) 
    #   + p10*(x0^3)*x1 + p11*x0*(x1^3)

    y = (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[6] * x0**3
        + params[7] * x1**3
        + params[8] * (x0**2) * x1
        + params[9] * x0 * (x1**2)
        + params[10] * (x0**3) * x1
        + params[11] * x0 * (x1**3)
    )
    
    return y
