def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of equation_v0 including nonlinear cubic term.

    Background:
    Calculate Acceleration in Nonlinear Harmonic Oscillator given Time (x0),
    Position at time t (x1), and Velocity at time t (x2).

    Variables:
    - Independents: 
        - x0 : time or related variable
        - x1 : position at time t
        - x2 : velocity at time t
    - Dependent:
        - y  : acceleration

    Parameters:
    - params (np.ndarray): Trainable coefficients [a0,...a4] used by the equation skeleton.
      Expected length >= 5.
      params[0]: constant term,
      params[1]: linear coefficient for x0,
      params[2]: linear coefficient for x1,
      params[3]: linear coefficient for x2,
      params[4]: cubic coefficient for x1^3.
    """
    return (
        params[0] 
        + params[1] * x0 
        + params[2] * x1 
        + params[3] * x2 
        + params[4] * (x1 ** 3)
    )
