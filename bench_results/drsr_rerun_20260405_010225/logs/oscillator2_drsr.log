def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Calculates acceleration y for a nonlinear harmonic oscillator:
    y ≈ c0 + c1 * t + c2 * x + c3 * v + c4 * x^3

    where:
    - t = time (x0)
    - x = position (x1)
    - v = velocity (x2)
    
    params[0] : constant term
    params[1] : coefficient for time t
    params[2] : linear stiffness term (-ω²)
    params[3] : damping term (-β)
    params[4] : nonlinear stiffness term (-α)
    
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x2
        + params[4] * np.power(x1, 3)
    )
