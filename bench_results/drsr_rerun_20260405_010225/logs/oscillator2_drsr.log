def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Extended mathematical function skeleton for oscillator2 acceleration y.

    y = p0 + p1*x0 + p2*x1 + p3*x2 + p4*x1^3 + p5*x2^2 + p6*(x1*x2) + p7*(x0*x1) + p8*(x0*x2)

    Parameters:
    - params: array-like of length at least 9 containing coefficients.

    Returns:
    - y: calculated dependent variable
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x2
        + params[4] * (x1 ** 3)
        + params[5] * (x2 ** 2)
        + params[6] * (x1 * x2)
        + params[7] * (x0 * x1)
        + params[8] * (x0 * x2)
    )
