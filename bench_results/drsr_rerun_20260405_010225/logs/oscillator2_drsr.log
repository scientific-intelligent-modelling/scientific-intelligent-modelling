    """
    """Improved version of `equation_v0`.

    Includes nonlinear cubic term in position to capture nonlinear oscillator behavior.

    Parameters:
    - params (np.ndarray): Trainable coefficients [p0, p1, p2, p3, p4]

    Returns:
    - y (np.ndarray): Calculated dependent variable
    """
    return params[0] + params[1] * x0 + params[2] * x1 + params[3] * x2 + params[4] * (x1 ** 3)
