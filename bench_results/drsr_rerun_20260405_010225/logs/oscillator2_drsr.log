def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation_v0 including cubic nonlinearity in position.

    y = params[0] + params[1]*x0 + params[2]*x1 + params[3]*x2 + params[4]*x1**3

    Parameters:
    - x0: time
    - x1: position
    - x2: velocity
    - params: array of parameters with length >= 5

    Returns:
    - y: acceleration output as numpy array
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x2
        + params[4] * (x1 ** 3)
    )
