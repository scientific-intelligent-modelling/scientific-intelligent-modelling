def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation_v0 including nonlinear and interaction terms.

    Parameters:
    - params (np.ndarray): Array of length 12 containing coefficients for each term.

    Terms included:
    0: constant
    1: linear in time (x0)
    2: quadratic in time (x0^2)
    3: linear in position (x1)
    4: cubic in position (x1^3)
    5: linear in velocity (x2)
    6: quadratic in velocity (x2^2)
    7: cubic in velocity (x2^3)
    8: interaction term x1 * x2
    9: interaction term x1^2 * x2
   10: interaction term x1 * x2^2
   11: interaction term x0 * x1

    Returns:
        y (np.ndarray): Computed acceleration values.
    """
    
    return (
        params[0] +
        params[1] * x0 +
        params[2] * (x0 ** 2) +
        params[3] * x1 +
        params[4] * (x1 ** 3) +
        params[5] * x2 +
        params[6] * (x2 ** 2) +
        params[7] * (x2 ** 3) +
        params[8] * (x1 * x2) +
        params[9] * ((x1 ** 2) * x2) +
        params[10] * (x1 * (x2 ** 2)) +
        params[11] * (x0 * x1)
    )
