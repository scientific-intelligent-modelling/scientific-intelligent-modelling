        + p(15)*(x1 ** 4)          # quartic velocity nonlinearity
        
        + p(16)*(x0**3*x1)         # cubic position times velocity term 
        + p(17)*(x0*x1**3)         # position times cubic velocity term

        + p(18)*np.tanh(x1)         # smooth saturation-like damping effect

        + p(19)*np.log(np.abs(x0)+1e-6)*np.sign(x0)*x1**2   # logarithmic softening/hardening with velocity squared

