def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Model acceleration as a polynomial function of position (x0) and velocity (x1),
    including up to quartic nonlinearities in position and cubic nonlinearities in velocity,
    plus cross terms to capture coupling effects.

    Physically:
    - The linear term in x0 corresponds to Hooke's law restoring force.
    - Nonlinear powers of x0 model anharmonic restoring forces.
    - Terms involving x1 represent damping or velocity-dependent forces.
    - Cross terms capture interaction between position and velocity effects.

    Parameters:
    - x0 (np.ndarray): position at time t
    - x1 (np.ndarray): velocity at time t
    - params (np.ndarray): array-like with length at least 12

    Returns:
    - y (np.ndarray): predicted acceleration values
    """
    
    return (
        params[0]  # constant offset term (usually zero for physical oscillators)
        + params[1] * x0               # linear restoring force ~ -k*x
        + params[2] * x1               # linear damping ~ -c*v
        + params[3] * (x0 ** 2)        # quadratic nonlinearity in position
        + params[4] * (x0 * x1)        # cross term: position-velocity coupling
        + params[5] * (x1 ** 2)        # quadratic nonlinearity in velocity
        + params[6] * (x0 ** 3)        # cubic nonlinearity in position
        + params[7] * (x0 ** 2 * x1)   # higher order cross term
        + params[8] * (x0 * x1 ** 2)   # higher order cross term
        + params[9] * (x1 ** 3)        # cubic nonlinearity in velocity
        + params[10] * (x0 ** 4)       # quartic nonlinearity in position for strong anharmonicity
        + params[11] * (x0 ** 3 * x1)  # cubic-position times velocity cross term
    )
