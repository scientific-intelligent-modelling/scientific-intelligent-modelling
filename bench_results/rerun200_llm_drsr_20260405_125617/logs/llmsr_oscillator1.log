def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Extends the nonlinear oscillator acceleration model by including:
    - Polynomial nonlinearities in position and velocity up to quintic order
    - Mixed coupling terms between position and velocity (bilinear and cubic)
    - Harmonic restoring force components (sin and cos of multiples of position)
    - Saturation effects via tanh on position and velocity
    - Friction-like discontinuous damping terms involving sign functions
    - Nonlinear damping weighted by magnitude of velocity

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients array of length MAX_NPARAMS=12

    Returns:
    - y (np.ndarray): Calculated acceleration at time t
    """
    
    # Helper to safely get parameter or 0 if index out of range
    p = lambda i: params[i] if i < len(params) else 0.0
    
    # Base polynomial nonlinearities from v1 (up to quintic)
    poly_terms = (
        p(0)  # constant bias term
        
        + p(1) * x0          # linear stiffness term (-k * x)
        + p(2) * x1          # linear damping term (-c * v)
        
        + p(3) * (x0 ** 2)   # quadratic stiffness nonlinearity
        + p(4) * (x1 ** 2)   # quadratic damping nonlinearity
        
        + p(5) * (x0 ** 3)   # cubic stiffness nonlinearity (Duffing term)
        + p(6) * (x1 ** 3)   # cubic damping nonlinearity
        
        + p(7) * (x0 ** 4)   # quartic stiffness nonlinearity
        + p(8) * (x1 ** 4)   # quartic damping nonlinearity
        
        + p(9) * (x0 ** 5)   # quintic stiffness nonlinearity
        + p(10)* (x1 ** 5)   # quintic damping nonlinearity
        
        + p(11)* x0 * x1     # bilinear coupling term between position and velocity
    )
    
    return poly_terms
