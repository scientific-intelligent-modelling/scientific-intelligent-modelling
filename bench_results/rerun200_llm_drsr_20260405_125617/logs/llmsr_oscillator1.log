def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Models acceleration as a nonlinear function of position (x0) and velocity (x1):
    a = p0 + p1*x0 + p2*x0^3 + p3*x1 + p4*x1^3 + p5*x0^2 + p6*x1^2 + ...

    Parameters:
    - params (np.ndarray): array of coefficients with length at least 7

    Returns:
    - np.ndarray: acceleration values
    """
    # Unpack parameters for clarity
    p = params
    return (
        p[0]                      # constant term
        + p[1] * x0               # linear position term
        + p[2] * x0**3            # cubic position term (nonlinearity)
        + p[3] * x1               # linear velocity term (damping)
        + p[4] * x1**3            # cubic velocity term (nonlinear damping)
        + p[5] * x0**2            # quadratic position term
        + p[6] * x1**2            # quadratic velocity term
    )
