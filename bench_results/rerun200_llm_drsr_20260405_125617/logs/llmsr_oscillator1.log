def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Calculates acceleration y as a function of position (x0) and velocity (x1),
    including polynomial stiffness terms up to 7th order,
    polynomial damping terms up to quartic order,
    and multiple coupling terms between position and velocity.

    Parameters:
    - params[0]: constant offset term
    - params[1]: linear stiffness coefficient (x0)
    - params[2]: cubic stiffness coefficient (x0^3)
    - params[3]: quintic stiffness coefficient (x0^5)
    - params[4]: septic stiffness coefficient (x0^7)
    - params[5]: linear damping coefficient (x1)
    - params[6]: quadratic damping coefficient (x1^2)
    - params[7]: cubic damping coefficient (x1^3)
    - params[8]: quartic damping coefficient (x1^4)
    - params[9]: coupling term x0 * x1
    - params[10]: coupling term x0^2 * x1
    - params[11]: coupling term x0 * x1^2

    Returns:
        np.ndarray: predicted acceleration values.
    """
    
    # Polynomial stiffness terms: restoring force components
    stiffness = (
        params[1] * x0
        + params[2] * np.power(x0, 3)
        + params[3] * np.power(x0, 5)
        + params[4] * np.power(x0, 7)
    )
    
    # Polynomial damping terms: dissipative force components
    damping = (
        params[5] * x1
        + params[6] * np.power(x1, 2)
        + params[7] * np.power(x1, 3)
        + params[8] * np.power(x1, 4)
    )
    
    # Coupling terms between position and velocity
    coupling = (
        params[9] * x0 * x1
        + params[10] * (x0 ** 2) * x1
        + params[11] * x0 * (x1 ** 2)
    )
    
    # Constant offset term plus all contributions combined for acceleration prediction
    y = (
        params[0]
        + stiffness
        + damping
        + coupling
    )
    
    return y
