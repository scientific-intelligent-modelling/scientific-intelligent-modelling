    """
    """Improved version of `equation_v1`.

    Adds higher-order polynomial nonlinearities,
    smooth saturation effects,
    asymmetric restoring forces,
    and more complex coupling terms to better model
    acceleration in a nonlinear harmonic oscillator.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients [bias, linear & nonlinear terms]

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    p = lambda i: params[i % MAX_NPARAMS]
    
    # Base linear and low-order nonlinear terms from v1
    y = (
        p(0)  # bias
        
        + p(1)*x0           # linear stiffness (-k*x)
        + p(2)*x1           # linear damping (-c*v)
        
        + p(3)*(x0**2)      # quadratic stiffness nonlinearity
        + p(4)*(x1**2)      # quadratic velocity nonlinearity
        
        + p(5)*(x0**3)      # cubic stiffness nonlinearity (Duffing-type)
        + p(6)*(x1**3)      # cubic velocity nonlinearity
        
        + p(7)*(x0*x1)      # bilinear coupling
        
        + p(8)*(x0**2)*x1   # mixed quadratic position * velocity
        + p(9)*x0*(x1**2)   # mixed position * quadratic velocity
        
        + p(10)*np.sin(x0)  # periodic restoring force component (pendulum-like)
        + p(11)*np.sign(x1) # friction-like discontinuous damping
        
        + p(12)*np.cos(x0)          # additional periodic restoring force component
        + p(13)*np.exp(-np.abs(x1)) # exponential decay related to velocity magnitude
        
        + p(14)*(x0**4)     # quartic stiffness nonlinearity
        + p(15)*(x1**4)     # quartic velocity nonlinearity
        
        + p(16)*(x0**3)*x1  # cubic position times velocity term 
        + p(17)*x0*(x1**3)  # position times cubic velocity term

        + p(18)*np.tanh(x1)  # smooth saturation-like damping effect

        + p(19)*np.log(np.abs(x0)+1e-6)*np.sign(x0)*(x1**2)  # logarithmic softening/hardening with v^2
    )
    
    ## Additional higher order & complex nonlinearities
    
    y += (
          p(20)*np.sinh(x0)             # asymmetric restoring forces via hyperbolic sine
          
          +p(21)*np.tanh(x0*x1)         # smooth saturation of coupling between position and velocity

          +p(22)*(x0**5)                # quintic stiffness nonlinearity for strong anharmonicity

          +p(23)*(x1**5)                # quintic velocity nonlinearity

          +p(24)*(x0**4)*x1             # quartic position times linear velocity

          +p(25)*x0*(x1**4)             # linear position times quartic velocity

          ## Smooth approximations of dry friction / hysteresis effects:
          +(p(26)%MAX_NPARAMS != 26 and params[26%MAX_NPARAMS] or 0.0 )* np.arctan(x1)

          ## Mixed exponential-polynomial term capturing fast decay modulated by displacement:
          +(p(27)%MAX_NPARAMS != 27 and params[27%MAX_NPARAMS] or 0.0 )* x0*np.exp(- x1 ** 2)

         )
    
    return y
