def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version explicitly models the acceleration of a nonlinear harmonic oscillator,
    including linear and nonlinear stiffness terms (restoring force),
    linear and nonlinear damping terms,
    and cross terms capturing coupling between position and velocity.

    The general form is inspired by the Duffing oscillator with additional nonlinear damping
    and mixed terms to capture complex dynamics.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients [bias, linear & nonlinear terms]

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    # Unpack parameters for clarity (optional)
    c0 = params[0]   # constant offset / bias term
    k1 = params[1]   # linear stiffness coefficient (-k)
    c1 = params[2]   # linear damping coefficient (-c)
    
    k2 = params[3]   # quadratic stiffness nonlinearity
    c2 = params[4]   # quadratic velocity nonlinearity (nonlinear damping)
    
    k3 = params[5]   # cubic stiffness nonlinearity (Duffing term)
    c3 = params[6]   # cubic velocity nonlinearity
    
    cross1 = params[7]  # cross term linear*linear (x * v)
    
    cross2 = params[8]  # quadratic position * velocity
    cross3 = params[9]  # position * quadratic velocity
    
    cross4 = params[10]  # cubic position * velocity
    cross5 = params[11]  # position * cubic velocity

    
    y = (
        c0 
        + k1 * x0 
        + c1 * x1 
        + k2 * (x0 ** 2) 
        + c2 * (x1 ** 2) 
        + k3 * (x0 ** 3) 
        + c3 * (x1 ** 3) 
        + cross1 * x0 * x1 
        + cross2 * (x0 ** 2) * x1 
        + cross3 * x0 * (x1 ** 2) 
        + cross4 * (x0 ** 3) * x1 
        + cross5 * x0 * (x1 ** 3)
     )
    
    return y
