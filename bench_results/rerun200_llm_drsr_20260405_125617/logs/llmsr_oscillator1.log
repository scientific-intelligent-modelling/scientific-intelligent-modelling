        linear x1,
        quadratic x0^2,
        quadratic x1^2,
        cubic x0^3,
        cubic x1^3,
        cross term x0*x1,
        mixed term x0^2*x1,
        mixed term x0*x1^2,
        quartic stiffness term x0^4,
        quartic damping term x1^4,

        sin(x0),
        cos(x0),
