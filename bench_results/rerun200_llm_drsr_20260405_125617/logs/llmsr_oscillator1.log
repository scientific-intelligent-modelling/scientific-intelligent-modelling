    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Background:
    Calculate Acceleration in Non-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: 
        - x0: Position at time t
        - x1: Velocity at time t
    - Dependent:
        - y: Acceleration at time t

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 12 for this version.
    
    Returns:
    - y (np.ndarray): Calculated acceleration.
    """
    
    # Start with constant offset term
    y = params[0]
    
    # Linear terms
    y += params[1] * x0       # linear position term
    y += params[2] * x1       # linear velocity term
    
    # Quadratic nonlinearities
    y += params[3] * (x0 ** 2)
    y += params[4] * (x1 ** 2)
    
    # Cubic nonlinearities
    y += params[5] * (x0 ** 3)
    y += params[6] * (x1 ** 3)
    
    # Cross terms between position and velocity
    y += params[7] * (x0 * x1)
    
    # Additional cross nonlinear terms to capture more complex dynamics
    y += params[8] * (x0 ** 2) * x1     # quadratic position times velocity
    y += params[9] * x0 * (x1 ** 2)     # position times quadratic velocity
    
    # Higher order nonlinearities on position and velocity separately
    y += params[10] * (x0 ** 4)         # quartic position term
    y += params[11] * (x1 ** 4)         # quartic velocity term
    
    return y
