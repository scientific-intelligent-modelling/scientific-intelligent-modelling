    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients (length MAX_NPARAMS=12)

    Returns:
    - y (np.ndarray): Calculated acceleration at time t
    """
    
    p = lambda i: params[i % MAX_NPARAMS]
    
    # Polynomial powers for convenience
    x0_2 = x0 ** 2
    x0_3 = x0 ** 3
    x0_4 = x0 ** 4
    x0_5 = x0 ** 5
    
    x1_2 = x1 ** 2
    x1_3 = x1 ** 3
    x1_4 = x1 ** 4
    x1_5 = x1 ** 5
    
    return (
        p(0)                              # constant offset / bias
        
        + p(1) * x0                      # linear stiffness (-k * x)
        + p(2) * x1                      # linear damping (-c * v)
        
        + p(3) * x0_3                   # cubic stiffness nonlinearity (Duffing-type)
        + p(4) * x1_3                   # cubic damping-like nonlinearity
        
        + p(5) * x0_5                   # quintic stiffness nonlinearity
        
        + p(6) * x1_5                   # quintic damping-like nonlinearity
        
        + p(7) * (x0_2 * x1)            # mixed quadratic position times linear velocity
        
        + p(8) * (x0 * x1_2)            # mixed linear position times quadratic velocity
        
        + p(9) * np.sin(x0)             # periodic restoring force component
        
        + p(10)* np.tanh(x1)            # smooth saturation-like damping effect
        
        + p(11)* np.sign(x1)            # friction-like discontinuous damping term

        #
        # Additional physically meaningful composite terms using modulo indexing:
        
        + p(12)* (x0_4 * np.sign(x1))   # quartic position modulated by sign of velocity
        
        + p(13)* (x0**3 * np.tanh(x1))  # cubic position modulated by smooth saturation in velocity
        
        + p(14)* (np.cos(x0)**2 * (-x0))# squared cosine restoring force times negative position for stability effect

        +
          (
