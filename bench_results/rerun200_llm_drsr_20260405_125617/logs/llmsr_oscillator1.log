def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version models acceleration in a nonlinear harmonic oscillator including:
    - constant offset
    - linear terms in position and velocity (damping)
    - cubic and quadratic nonlinearities in position
    - quadratic nonlinearity in velocity
    - cross terms between position and velocity up to cubic order
    - physically meaningful nonlinear terms like sine of position (common in pendulum-like oscillators)
    - damping-like term depending on the sign of velocity

    Parameters:
        params (np.ndarray): array of length at least 12

    Returns:
        y (np.ndarray): predicted acceleration values
    """
    return (
        params[0]  # constant term
        + params[1] * x0  # linear restoring force term ~ -kx
        + params[2] * x1  # linear damping term ~ -c*v
        + params[3] * (x0 ** 3)  # cubic stiffness nonlinearity ~ k3*x^3
        + params[4] * (x0 ** 2)  # quadratic stiffness nonlinearity ~ k2*x^2 (sometimes appears)
        + params[5] * (x1 ** 2)  # quadratic velocity term, can model nonlinear damping effects
        + params[6] * (x0 * x1)  # cross term coupling position and velocity linearly
        + params[7] * (x0 ** 2 * x1)   # higher order cross term: quadratic position times velocity
        + params[8] * (x0 * x1 ** 2)   # higher order cross term: position times quadratic velocity
        + params[9] * (x1 ** 3)         # cubic velocity nonlinearity, e.g. nonlinear damping effects 
        + params[10] * np.sin(x0)       # physically meaningful nonlinear restoring force like pendulum 
        + params[11] * np.sign(x1)      # friction-like damping depending on direction of motion 
    )
