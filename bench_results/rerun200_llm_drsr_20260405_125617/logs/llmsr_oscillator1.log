    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    # Helper to safely get parameter or 0 if index out of range
    def p(i):
        return params[i % len(params)] if i < len(params) else 0.0
    
    return (
        p(0)  # constant term (bias)
        + p(1) * x0  # linear stiffness term (-k * x)
        + p(2) * x1  # linear damping term (-c * v)
        + p(3) * (x0 ** 2)  # quadratic stiffness nonlinearity
        + p(4) * (x1 ** 2)  # quadratic velocity nonlinearity (nonlinear damping)
        + p(5) * (x0 ** 3)  # cubic stiffness nonlinearity (Duffing-type)
        + p(6) * (x1 ** 3)  # cubic velocity nonlinearity
        + p(7) * (x0 * x1)  # bilinear coupling term
        + p(8) * (x0 ** 2) * x1  # mixed nonlinear term: quadratic position times velocity
        + p(9) * x0 * (x1 ** 2)   # mixed nonlinear term: position times quadratic velocity
        + p(10)* np.sin(x0)       # possible periodic restoring force component
        + p(11)* np.sign(x1)      # possible friction-like discontinuous damping term
        
        # Additional harmonic components beyond v1:
        
        + p(12)* np.sin(2*x0)
        + p(13)* np.cos(x0)
