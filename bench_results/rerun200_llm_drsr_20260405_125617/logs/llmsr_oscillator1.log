def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version models acceleration in a nonlinear harmonic oscillator including:
    - constant offset (params[0])
    - linear restoring force term proportional to position (params[1] * x0)
    - linear damping term proportional to velocity (params[2] * x1)
    - cubic nonlinearity in position (params[3] * x0**3)
    - quadratic nonlinearity in position (params[4] * x0**2)
    - quadratic term in velocity (params[5] * x1**2)
    - cross terms between position and velocity up to cubic order:
        * linear cross term (params[6] * x0 * x1)
        * cubic cross terms involving powers of position and velocity
          (params[7]*x0**3*x1 + params[8]*x0*x1**3 + params[9]*x0**2*x1**2)
    - nonlinear oscillatory restoring force term via sine function (params[10]*np.sin(x0))
    - nonlinear damping-like term depending on the sign of velocity (params[11]*np.sign(x1))

    Parameters:
        params: array-like with length at least 12

    Returns:
        y: acceleration values as numpy array
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * (x0 ** 3)
        + params[4] * (x0 ** 2)
        + params[5] * (x1 ** 2)
        + params[6] * (x0 * x1)
        + params[7] * (x0 ** 3) * x1
        + params[8] * x0 * (x1 ** 3)
        + params[9] * (x0 ** 2) * (x1 ** 2)
        + params[10] * np.sin(x0)
        + params[11] * np.sign(x1)
    )
