def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator with physically meaningful terms:
    - Linear restoring force proportional to position (x0)
    - Linear damping proportional to velocity (x1)
    - Cubic and quintic stiffness nonlinearities in position (x0^3, x0^5)
    - Quadratic and cubic velocity nonlinearities (x1^2, x1^3)
    - Mixed nonlinear terms involving powers of position and velocity
    - Periodic forcing components (sin and cos of position)
    - Velocity magnitude dependent friction-like term
    - Coulomb friction like sign-dependent damping term

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Trainable coefficients [c0,...c11]

    Returns:
        y (np.ndarray): Acceleration at time t
    """

    c0 = params[0]   # constant offset term
    c1 = params[1]   # linear stiffness coefficient (-k)
    c2 = params[2]   # linear damping coefficient (-c)
    c3 = params[3]   # cubic stiffness nonlinearity (-alpha * x^3)
    c4 = params[4]   # quadratic velocity nonlinearity (~ v^2 term)
    
    # Replace previous quadratic position nonlinearity with cubic velocity nonlinearity for variety
    c6 = params[5]   # cubic velocity nonlinearity (~ v^3), moved from param[6]
    
    c7 = params[6]   # cross term linear in both position & velocity (~ x*v), moved from param[7]
    
    c8 = params[7]   # mixed nonlinear term quadratic pos * linear vel (~ x^2 * v), moved from param[8]
    
    c9 = params[8]   # periodic forcing component cos(x), moved from param[9]
    
    c10= params[9]   # absolute value of velocity friction-like effect (~ |v|)
    
    c11= params[10]  # quintic stiffness nonlinearity (~ x^5)

    c_sign_friction = params[11]  # sign-dependent Coulomb friction-like damping

    
    return (
        c0 
        + c1 * x0 
        + c2 * x1 
        + c3 * (x0 ** 3) 
        + c4 * (x1 ** 2) 
        + c6 * (x1 ** 3) 
        + c7 * (x0 * x1) 
        + c8 * ((x0 ** 2) * x1) 
        + c9 * np.cos(x0)           # periodic forcing component cosine
        
        + 0.5*c9*np.sin(x0)         # added sine forcing component scaled by same parameter for economy
        
        + c10* np.abs(x1)           # friction-like effect depending on speed magnitude
        
        - c_sign_friction*np.sign(x1)# Coulomb friction like sign-dependent damping
        
        + c11* (x0 ** 5)            # quintic stiffness nonlinearity for stronger anharmonicity
       
       )
