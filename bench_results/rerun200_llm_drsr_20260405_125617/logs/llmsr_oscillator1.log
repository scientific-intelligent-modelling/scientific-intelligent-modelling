def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Extends the nonlinear oscillator acceleration model by including:
    - Polynomial stiffness and damping nonlinearities up to quintic order in position (x0) and velocity (x1)
    - Harmonic restoring force components (sin and cos terms)
    - Saturation effects via tanh on position and velocity
    - Friction-like damping term using sign function on velocity
    - Mixed cross terms coupling position and velocity powers
    - Velocity magnitude weighted damping terms

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients array of length MAX_NPARAMS=12

    Returns:
    - y (np.ndarray): Calculated acceleration at time t
    """
    
    # Helper to safely access params with zero fallback if index out of range
    p = lambda i: params[i] if i < len(params) else 0.0
    
    return (
        p(0)  # constant bias term
        
        + p(1) * x0              # linear restoring force (-k*x)
        
        + p(2) * x1              # linear damping (-c*v)
        
        + p(3) * (x0 ** 3)       # cubic stiffness nonlinearity (Duffing term)
        
        + p(4) * (x1 ** 3)       # cubic damping nonlinearity
        
        + p(5) * x0 * x1         # bilinear coupling term
        
        + p(6) * np.tanh(x0)     # saturation effect on position
        
        + p(7) * np.tanh(x1)     # saturation effect on velocity
        
        + p(8) * np.sign(x1)     # friction-like discontinuous damping
        
        + p(9) * (x0 ** 2)       # quadratic stiffness nonlinearity
        
        + p(10)* (x1 ** 2)       # quadratic damping nonlinearity
        
        + p(11)* (x0 ** 4)       # quartic stiffness nonlinearity for stronger anharmonicity

        # Additional physically meaningful nonlinear terms beyond v1:

        + p((12 % MAX_NPARAMS)) * np.sin(x0)          # fundamental harmonic restoring force

        + p((13 % MAX_NPARAMS)) * np.sin(2*x0)         # second harmonic restoring force

        + p((14 % MAX_NPARAMS)) * np.cos(x0)            # cosine restoring force component

        + p((15 % MAX_NPARAMS)) * np.cos(2*x0)          # second harmonic cosine component

        + p((16 % MAX_NPARAMS)) * x0**5                  # quintic stiffness nonlinearity

