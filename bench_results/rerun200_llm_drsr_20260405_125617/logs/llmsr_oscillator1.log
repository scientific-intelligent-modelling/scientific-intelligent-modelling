def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version models acceleration in a nonlinear harmonic oscillator including:
    - constant bias term
    - odd-powered restoring force terms in position (x0, x0^3, x0^5, x0^7)
    - even-powered restoring force terms in position (x0^2, x0^4, x0^6)
    - linear and nonlinear damping terms in velocity (x1, x1^2, x1^3)
    - cross interaction terms between position and velocity with various polynomial orders
    - higher order mixed terms involving powers of both position and velocity

    Parameters:
        params (np.ndarray): array-like coefficients [p0,...p11]

    Returns:
        y: acceleration values as np.ndarray
    """
    
    return (
        params[0]  # constant bias term
        + params[1] * x0  # linear restoring force (-k*x)
        + params[2] * (x0 ** 2)  # quadratic restoring force for asymmetry/non-idealities
        + params[3] * (x0 ** 3)  # cubic Duffing-type nonlinearity
        + params[4] * (x0 ** 4)  # quartic restoring force term for higher order effects
        + params[5] * (x0 ** 5)  # quintic nonlinearity
        + params[6] * (x0 ** 6)  # sextic restoring force term for even higher order effects
        + params[7] * (x0 ** 7)  # septic restoring force term for very high order effects
        + params[8] * x1         # linear damping (-c*v)
        + params[9] * (x1 ** 2)   # quadratic damping nonlinearity
        + params[10] * ((x1 ** 3))   # cubic damping nonlinearity
        + params[11] * ((x0 ** 3) * x1)   # cross term pos³*vel linear coupling 
    )
