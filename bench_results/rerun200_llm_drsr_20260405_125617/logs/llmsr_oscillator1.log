def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator as a function of position and velocity,
    including constant offset, linear, quadratic, cubic terms and cross terms to capture nonlinear stiffness
    and damping effects.

    y = params[0]                           # constant offset (could represent external forcing)
        + params[1]*x0                      # linear restoring force (Hooke's law)
        + params[2]*x1                      # linear damping force
        + params[3]*x0**3                   # cubic restoring force (nonlinear stiffness)
        + params[4]*x1**2                   # quadratic velocity term (nonlinear damping)
        + params[5]*x0**2                   # quadratic position term (nonlinear stiffness)
        + params[6]*x0*x1                   # cross term between position and velocity
        + params[7]*x1**3                   # cubic velocity term (higher order damping)
        + params[8]*(x0**2)*x1              # mixed cubic term (position squared times velocity)
        + params[9]*x0*(x1**2)              # mixed cubic term (position times velocity squared)
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * (x0 ** 3)
        + params[4] * (x1 ** 2)
        + params[5] * (x0 ** 2)
        + params[6] * (x0 * x1)
        + params[7] * (x1 ** 3)
        + params[8] * ((x0 ** 2) * x1)
        + params[9] * (x0 * (x1 ** 2))
    )
