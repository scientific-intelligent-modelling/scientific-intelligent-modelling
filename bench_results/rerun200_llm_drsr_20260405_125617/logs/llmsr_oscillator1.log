def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0` with nonlinear terms.

    Background:
    Calculate Acceleration in Non-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: 
        - x0: Position at time t
        - x1: Velocity at time t
    - Dependent:
        - y: Acceleration at time t

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 8 for this version.
    
    Returns:
    - y (np.ndarray): Calculated acceleration.
    """
    
    # Linear terms
    y = params[0]  # constant offset term
    
    y += params[1] * x0       # linear position term
    y += params[2] * x1       # linear velocity term
    
    # Quadratic nonlinearities
    y += params[3] * (x0 ** 2)
    y += params[4] * (x1 ** 2)
    
    # Cubic nonlinearities
    y += params[5] * (x0 ** 3)
    y += params[6] * (x1 ** 3)
    
    # Cross term between position and velocity
    y += params[7] * (x0 * x1)
    
    return y
