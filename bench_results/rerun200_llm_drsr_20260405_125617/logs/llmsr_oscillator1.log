        + params[7] * x0 * x1         # cross term: linear position times velocity
        + params[8] * x1**3           # cubic velocity nonlinearity (-c3 * v^3)
        + params[9] * (x0**3) * x1     # cross term: cubic position times velocity
        + params[10] * x0*(x1**2)     # cross term: linear position times quadratic velocity
        + params[11] * (x0**4)         # quartic position nonlinearity
    )
