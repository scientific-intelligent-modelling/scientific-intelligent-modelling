def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Background:
    Calculate Acceleration in Non-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: 
        - x0: Position at time t
        - x1: Velocity at time t
    - Dependent:
        - y: Acceleration at time t

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length = 12.
    
    Returns:
    - y (np.ndarray): Calculated acceleration.
    
    Equation form includes:
      - constant offset
      - linear terms in position and velocity
      - quadratic and cubic polynomial nonlinearities
      - mixed polynomial cross terms up to cubic order
      - quartic stiffness nonlinearity in position
      - trigonometric nonlinearities capturing periodic effects and anharmonicity
      - nonlinear damping modulated by position via velocity*sin(position)
    """
    
    y = params[0]  # constant offset
    
    # Linear terms (restoring force and damping)
    y += params[1] * x0       # linear stiffness term (restoring force)
    y += params[2] * x1       # linear damping term
    
    # Quadratic nonlinearities
    y += params[3] * (x0 ** 2)   # quadratic stiffness nonlinearity
    y += params[4] * (x1 ** 2)   # quadratic velocity nonlinearity
    
    # Cubic nonlinearities
    y += params[5] * (x0 ** 3)   # cubic stiffness nonlinearity
    y += params[6] * (x1 ** 3)   # cubic velocity nonlinearity
    
    # Mixed quadratic/cubic coupling terms between position and velocity
    y += params[7] * (x0 * x1)
    
    # Mixed cubic terms coupling position squared with velocity, and vice versa
    y += params[8] * ((x0 ** 2) * x1)
    
    # Trigonometric nonlinearities capturing anharmonicity effects
    y += params[9] * np.sin(x0)
    
    # Nonlinear damping modulated by position via velocity*sin(position)
    y += params[10] * x1 * np.sin(x0)
    
    # Quartic stiffness nonlinearity for higher order restoring force effect 
    y += params[11] * (x0 ** 4)
    
    return y
