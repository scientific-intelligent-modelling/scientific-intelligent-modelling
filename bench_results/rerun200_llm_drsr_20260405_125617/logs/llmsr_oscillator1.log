def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator with physically meaningful terms:
    - Linear restoring force proportional to position (x0)
    - Linear damping proportional to velocity (x1)
    - Cubic nonlinearity in position (x0^3)
    - Cubic nonlinearity in velocity (x1^3)
    - Mixed nonlinear terms involving powers of position and velocity
    - Periodic restoring force component via sine function
    - Friction-like effect depending on speed magnitude
    - Additional higher order nonlinearities for flexibility

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients [c0, c1, ..., c11]

      where:
        c0: constant offset term (usually zero)
        c1: linear stiffness coefficient (-k * x)
        c2: linear damping coefficient (-c * v)
        c3: cubic stiffness coefficient (-alpha * x^3)
        c4: cubic velocity nonlinearity coefficient
        c5: quadratic position times velocity term (x^2 * v)
        c6: position times quadratic velocity term (x * v^2)
        c7: sine of position term (periodic restoring force component)
        c8: absolute value of velocity term (friction-like effect)
        c9: quartic stiffness term (x^4) for higher order restoring force nonlinearity
        c10: quartic velocity term (v^4) for higher order damping/nonlinear drag
        c11: mixed quartic term x^2 * v^2

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    return (
        params[0]  # constant offset term
        + params[1] * x0  # linear restoring force (-k*x)
        + params[2] * x1  # linear damping (-c*v)
        + params[3] * x0**3  # cubic stiffness nonlinearity (-alpha*x^3)
        + params[4] * x1**3  # cubic velocity nonlinearity 
        + params[5] * x0**2 * x1  # mixed nonlinear term 
        + params[6] * x0 * x1**2  # another mixed nonlinear term 
        + params[7] * np.sin(x0)  # periodic restoring force component 
        + params[8] * np.abs(x1)  # friction-like effect depending on speed magnitude 
        + params[9] * x0**4       # quartic stiffness nonlinearity 
        + params[10] * x1**4      # quartic velocity nonlinearity 
        + params[11] * (x0**2) * (x1**2)  # mixed quartic nonlinear interaction 
    )
