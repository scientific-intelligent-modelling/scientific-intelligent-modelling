def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` including higher order nonlinearities and cross terms.

    Model acceleration as a polynomial function of position (x0) and velocity (x1),
    including up to quintic nonlinearities in position, quartic in velocity,
    and various cross interaction terms capturing complex restoring forces,
    damping effects, and their nonlinear interactions.

    Parameters:
    - params (np.ndarray): array of length at least 12

    Returns:
    - y (np.ndarray): predicted acceleration
    """
    
    return (
        params[0]                        # constant offset term
        - params[1] * x0                # linear restoring force (-k*x)
        - params[2] * x1                # linear damping (-c*v)
        + params[3] * (x0 ** 2)         # quadratic nonlinearity in position (+)
        + params[4] * (x0 * x1)         # cross term: position*velocity (+/-)
        + params[5] * (x1 ** 2)         # quadratic nonlinearity in velocity (+)
        - params[6] * (x0 ** 3)         # cubic restoring force (-k3*x^3)
        - params[7] * (x0 ** 2 * x1)    # cubic cross term with damping (-)
        - params[8] * (x0 * x1 ** 2)    # cubic cross term (-)
        - params[9] * (x1 ** 3)         # cubic damping nonlinearity (-)
        + params[10] * (x0 ** 4)        # quartic restoring force (+k4*x^4)
        + params[11] * (x0 ** 3 * x1)   # quartic cross term (+/-)

        # Additional higher order terms can be added if desired,
        # but limited here to keep param count at MAX_NPARAMS=12.
        
        # For example, if more parameters were allowed:
        #- k5*x^5 term: -params[12]*(x0**5),
        #- quartic velocity term: -params[13]*(x1**4),
        #- quintic mixed terms etc.
    )
