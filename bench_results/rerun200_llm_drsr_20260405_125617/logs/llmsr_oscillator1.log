def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved version of the nonlinear oscillator acceleration model.

    Includes:
    - Linear restoring force (-k * x0)
    - Linear damping (-c * x1)
    - Nonlinear restoring force via sin(x0) term
    - Quadratic, cubic, quartic nonlinearities in position and velocity
    - Cross interaction terms up to quartic order
    - Nonlinear damping proportional to |v|*v

    Parameters:
    - x0 : position array (numpy.ndarray)
    - x1 : velocity array (numpy.ndarray)
    - params : array-like with 12 elements

    Returns:
    - y : acceleration values as numpy array
    """

    return (
        params[0]                       # constant offset term
        - params[1] * x0               # linear restoring force (-k*x)
        - params[2] * x1               # linear damping (-c*v)
        + params[3] * (x0 ** 2)        # quadratic nonlinearity in position (+/- depending on system)
        + params[4] * (x0 * x1)        # cross term: position*velocity (+/-)
        + params[5] * (x1 ** 2)        # quadratic nonlinearity in velocity (+/-)
        - params[6] * (x0 ** 3)        # cubic restoring force term (-k3*x^3)
        - params[7] * (x0 ** 2 * x1)   # cubic cross term with damping effect (-/+ depending on system)
        - params[8] * (x0 * x1 ** 2)   # another cubic cross term (-/+ depending on system)
        - params[9] * (x1 ** 3)        # cubic damping nonlinearity (-/+ depending on system)
        + params[10]* np.sin(x0)       # nonlinear restoring force typical for pendulum-like oscillators
        - params[11]* (np.abs(x1)*x1)  # nonlinear damping proportional to |v|*v
    )
