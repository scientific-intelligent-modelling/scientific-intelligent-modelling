        - params[9] * (x1 ** 3)           # cubic damping nonlinearity (-/+ depending on system)
        + params[10] * np.sin(x0)         # pendulum-like nonlinear restoring force
        - params[11] * np.sign(x1)        # dry friction-like damping opposing motion direction
        - params[12] * np.abs(x1)*x1      # nonlinear viscous damping proportional to |v|*v
