def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Model acceleration as a polynomial function of position (x0) and velocity (x1),
    including up to quartic nonlinearities in position and cubic nonlinearities in velocity,
    plus cross terms to capture nonlinear damping and restoring forces.

    Physical motivation:
    - The acceleration in a nonlinear oscillator typically depends on position with restoring force terms,
      often including linear (-k x), cubic (-k3 x^3), and quartic (-k4 x^4) stiffness terms.
    - Velocity-dependent terms represent damping, which can be linear or nonlinear.
    - Cross terms between position and velocity capture coupling effects.

    Parameters:
    - params (np.ndarray): array of length at least 12

    Returns:
    - y (np.ndarray): predicted acceleration
    """
    return (
        params[0]  # constant offset term, usually zero or close to zero physically
        + params[1] * x0               # linear restoring force term ~ -k x
        + params[2] * x1               # linear damping term ~ -c v
        + params[3] * (x0 ** 2)       # quadratic stiffness nonlinearity
        + params[4] * (x0 * x1)       # cross term representing nonlinear damping/restoring coupling
        + params[5] * (x1 ** 2)       # quadratic velocity term for nonlinear damping effects
        + params[6] * (x0 ** 3)       # cubic stiffness nonlinearity ~ Duffing oscillator term
        + params[7] * (x0 ** 2 * x1)  # higher order cross term for complex coupling effects
        + params[8] * (x0 * x1 ** 2)  # another cross term involving velocity squared
        + params[9] * (x1 ** 3)       # cubic velocity damping nonlinearity
        + params[10] * (x0 ** 4)      # quartic stiffness nonlinearity for stronger restoring forces
        + params[11] * (x0 ** 3 * x1) # cubic position times velocity cross term capturing complex dynamics
    )
