def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator including:
    - linear restoring force (proportional to position)
    - linear damping (proportional to velocity)
    - nonlinear restoring terms (odd powers of position)
    - nonlinear damping terms (odd powers of velocity)
    - cross terms between position and velocity

    This structure is physically motivated by typical nonlinear oscillators such as the Duffing oscillator with damping.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    p = params  # for brevity
    
    return (
        p[0]                       # constant offset term, often zero in physical systems
        + p[1] * x0                # linear restoring force ~ position
        + p[2] * x1                # linear damping ~ velocity
        + p[3] * x0**3             # cubic stiffness nonlinearity
        + p[4] * x1**3             # cubic nonlinear damping term
        + p[5] * x0**5             # higher order stiffness nonlinearity
        + p[6] * x0**2 * x1        # cross term: quadratic position times velocity (nonlinear damping)
        + p[7] * x0 * x1           # cross term: linear position times velocity (damping-like)
        + p[8] * x0**4             # quartic stiffness nonlinearity
        + p[9] * (x0**3) * x1      # cubic position times velocity cross term
        + p[10]*x0*(x1**2)         # position times quadratic velocity cross term 
        + p[11]*(x1**2)            # quadratic velocity term, possibly related to nonlinear damping or forcing
    )
