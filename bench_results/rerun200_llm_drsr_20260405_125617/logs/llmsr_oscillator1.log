def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Extends the nonlinear oscillator acceleration model by including:
    - Polynomial stiffness and damping nonlinearities up to quintic order in position (x0) and velocity (x1)
    - Bilinear coupling term between position and velocity
    - Saturation effects via tanh on position and velocity (using limited params)
    - Friction-like damping term using sign function on velocity
    
    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients array of length MAX_NPARAMS=12
    
    Returns:
    - y (np.ndarray): Calculated acceleration at time t
    """
    
    # To keep within 12 parameters, assign as follows:
    # params[0]: constant bias term
    # params[1]: linear stiffness (-k * x)
    # params[2]: linear damping (-c * v)
    # params[3]: cubic stiffness nonlinearity (Duffing term)
    # params[4]: cubic damping nonlinearity
    # params[5]: bilinear coupling term x0*x1
    # params[6]: saturation effect on position tanh(x0)
    # params[7]: saturation effect on velocity tanh(x1)
    # params[8]: friction-like damping sign(x1)
    # params[9]: quadratic stiffness nonlinearity x0^2 
    # params[10]: quadratic damping nonlinearity x1^2 
    # params[11]: quartic stiffness nonlinearity x0^4
    
    return (
        params[0]  # constant bias
        
        + params[1] * x0          # linear restoring force
        
        + params[2] * x1          # linear damping
        
        + params[3] * (x0 ** 3)   # cubic stiffness nonlinearity
        
        + params[4] * (x1 ** 3)   # cubic damping nonlinearity
        
        + params[5] * x0 * x1     # bilinear coupling
        
        + params[6] * np.tanh(x0)  # saturation effect on position
        
        + params[7] * np.tanh(x1)  # saturation effect on velocity
        
        + params[8] * np.sign(x1)  # friction-like discontinuous damping
        
        + params[9] * (x0 ** 2)   # quadratic stiffness nonlinearity
        
        + params[10] * (x1 ** 2)  # quadratic damping nonlinearity
        
        + params[11] * (x0 ** 4)   # quartic stiffness nonlinearity for stronger anharmonicity
       
       )
