def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Includes constant offset, linear terms (stiffness and damping),
    nonlinear stiffness terms (quadratic to quintic in position),
    nonlinear damping terms (quadratic to quintic in velocity),
    and mixed coupling terms up to fifth order.

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.

    Returns:
    - y (np.ndarray): Calculated acceleration.
    """
    # To avoid index overflow if params length < 16,
    # use modulo indexing with MAX_NPARAMS
    p = lambda i: params[i % MAX_NPARAMS]

    return (
        p(0)                       # constant offset
        + p(1) * x0                # linear stiffness term (-k*x)
        + p(2) * x1                # linear damping term (-c*v)
        + p(3) * (x0 ** 2)         # quadratic stiffness nonlinearity
        + p(4) * (x1 ** 2)         # quadratic damping-like nonlinearity
        + p(5) * (x0 ** 3)         # cubic stiffness nonlinearity
        + p(6) * (x1 ** 3)         # cubic damping-like nonlinearity
        + p(7) * (x0 * x1)         # bilinear coupling term
        + p(8) * (x0 ** 2 * x1)     # mixed quadratic-cubic coupling
        + p(9) * (x0 * x1 ** 2)     # mixed quadratic-cubic coupling
        + p(10) * (x0 ** 4)         # quartic stiffness nonlinearity
        + p(11) * (x1 ** 4)         # quartic damping-like nonlinearity
        
        + p(12) * (x0 ** 5)          # quintic stiffness nonlinearity
        + p(13) * (x1 ** 5)          # quintic damping-like nonlinearity
        
        + p(14)* (x0**3 * x1**2 )     # mixed quintic coupling term
        + p(15)* (x0**2 * x1**3 )     # another mixed quintic coupling term
    )
