def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator with physically meaningful terms:
    - Linear restoring force proportional to position (x0)
    - Linear damping proportional to velocity (x1)
    - Polynomial stiffness nonlinearities in position (x0^2, x0^3, x0^5)
    - Polynomial velocity nonlinearities (x1^2, x1^3)
    - Mixed nonlinear terms involving powers of position and velocity
    - Periodic forcing components sin(x0), cos(x0), sin(2*x0)
    - Velocity magnitude dependent friction-like term |x1|
    - Velocity sign-dependent damping/friction term x1*|x1|

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Trainable coefficients [c0,...c11]

    Returns:
        y (np.ndarray): Acceleration at time t
    """

    return (
        params[0]                      # constant offset

        + params[1] * x0               # linear stiffness (-k*x)

        + params[2] * x1               # linear damping (-c*v)

        + params[3] * (x0 ** 2)         # quadratic stiffness nonlinearity

        + params[4] * (x1 ** 2)         # quadratic velocity nonlinearity

        + params[5] * (x0 ** 3)         # cubic stiffness nonlinearity

        + params[6] * (x1 ** 3)         # cubic velocity nonlinearity

        + params[7] * x0 * x1           # cross linear coupling term

        + params[8] * ((x0 ** 2) * x1)   # mixed nonlinear term: quadratic position times velocity

        + params[9] * (x0 * (x1 ** 2))   # mixed nonlinear term: linear position times quadratic velocity

        + params[10] * np.sin(x0)       # periodic forcing component sin(x)

        + params[11] * x1 * np.abs(x1)   # friction-like effect depending on speed magnitude and direction
    )
