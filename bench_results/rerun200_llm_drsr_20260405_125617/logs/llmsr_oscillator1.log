def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration as a function of position and velocity including nonlinear restoring force terms,
    damping terms, and their interactions up to fifth order in position and cubic order in velocity.

    Physical motivation:
    - The restoring force is often modeled as a polynomial in position (e.g., linear + cubic + quintic stiffness).
    - Damping depends on velocity (linear and nonlinear).
    - Cross terms capture coupling between position and velocity effects.

    Parameters:
    - x0 (np.ndarray): Position at time t.
    - x1 (np.ndarray): Velocity at time t.
    - params (np.ndarray): Trainable coefficients (length 12).

    Returns:
    - y (np.ndarray): Acceleration at time t.
    """
    
    return (
        params[0]                      # constant offset term
        + params[1] * x0              # linear stiffness term (-k*x)
        + params[2] * x1              # linear damping term (-c*v)
        + params[3] * x0**3           # cubic stiffness nonlinearity
        + params[4] * x1**2           # quadratic velocity term (nonlinear damping)
        + params[5] * x0**2 * x1      # cross term coupling position squared with velocity
        + params[6] * x0**5           # quintic stiffness nonlinearity
        + params[7] * x0 * x1         # another cross term coupling linear position with velocity
        + params[8] * x1**3           # cubic velocity term (higher order damping)
        + params[9] * (x0**3) * x1     # cross term cubic position times velocity
        + params[10] * x0 * (x1**2)   # cross term linear position times quadratic velocity
        + params[11] * (x0**4)         # quartic stiffness nonlinearity
    )
