def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Background:
    This version models the acceleration y of a nonlinear harmonic oscillator as a function of position (x0)
    and velocity (x1), incorporating polynomial terms up to fifth order in position and cubic order in velocity,
    as well as mixed terms. The form is flexible enough to capture complex nonlinear stiffness and damping effects,
    including coupling between position and velocity.

    Variables:
    - Independents: 
        x0 : position at time t
        x1 : velocity at time t
    - Dependent:
        y  : acceleration at time t

    Parameters:
    - params (np.ndarray): array of coefficients with length up to MAX_NPARAMS (12)

    Equation form:

        y = params[0]                       # constant offset (usually zero)
            + params[1]*x0                  # linear stiffness term (-k*x)
            + params[2]*x0**3               # cubic stiffness term (-alpha*x^3)
            + params[3]*x1                  # linear damping term (-c*v)
            + params[4]*x0**2               # quadratic position term (optional nonlinear stiffness)
            + params[5]*x1**2               # quadratic velocity term (optional nonlinear damping)
            + params[6]*x0*x1               # coupling between position and velocity
            + params[7]*x0**4               # quartic position nonlinearity
            + params[8]*x1**3               # cubic velocity nonlinearity
            + params[9]*(x0**2)*x1          # mixed nonlinear damping/position effect
            + params[10]*(x0)*(x1**2)       # another mixed nonlinear effect
            + params[11]*(x0**5)             # quintic position nonlinearity

    Returns:
        y : np.ndarray, acceleration at time t.
    """
    
    return (
        params[0]
        + params[1] * x0
        + params[2] * (x0 ** 3)
        + params[3] * x1
        + params[4] * (x0 ** 2)
        + params[5] * (x1 ** 2)
        + params[6] * (x0 * x1)
        + params[7] * (x0 ** 4)
        + params[8] * (x1 ** 3)
        + params[9] * ((x0 ** 2) * x1)
        + params[10] * (x0 * (x1 ** 2))
        + params[11] * (x0 ** 5)
    )
