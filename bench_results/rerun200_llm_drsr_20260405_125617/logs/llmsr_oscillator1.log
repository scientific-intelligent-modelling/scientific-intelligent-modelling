    """
    
    # Helper to safely get param or 0 if index out of range
    def p(i):
        return params[i] if i < len(params) else 0.0

    # Base terms from v1 for clarity (indices 0-23)
    
    y = (
        p(0)  # bias / constant term
        
        + p(1) * x0              # linear stiffness
        
        + p(2) * x1              # linear damping
        
        + p(3) * (x0 ** 2)       # quadratic stiffness
        
        + p(4) * (x1 ** 2)       # quadratic velocity nonlinearity
        
        + p(5) * (x0 ** 3)       # cubic stiffness
        
        + p(6) * (x1 ** 3)       # cubic velocity nonlinearity
        
        + p(7) * (x0 * x1)       # bilinear coupling
        
        + p(8) * (x0 ** 2 * x1)  # quadratic position times velocity
        
        + p(9) * (x0 * x1 ** 2)  # position times quadratic velocity
        
        + p(10)* np.sin(x0)      # periodic restoring force component
        
        + p(11)* np.sign(x1)     # friction-like discontinuous damping term

        + p(12)* np.sin(2*x0)
        
        + p(13)* np.cos(x0)
        
        + p(14)* np.tanh(x1)
        
        + p(15)* np.abs(x1)*x1
        
        + p(16)* (x0**3)*x1
        
        + p(17)* x0*(x1**3)
        
        + p(18)* np.sin(3*x0)
        
        + p(19)* np.cos(2*x0)
        
        + p(20)* np.tanh(x0)
        
        + p(21)* (np.sign(x1)*np.abs(x1))
        
        + p(22)* ((x0**4)*(x1**2))
        
