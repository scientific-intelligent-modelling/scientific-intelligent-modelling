def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculate acceleration for a nonlinear harmonic oscillator given position and velocity.

    Model form:
        y = params[0] 
            + params[1] * x0           # linear restoring force term
            + params[2] * x0**3       # nonlinear stiffness term
            + params[3] * x1          # damping term

    Parameters:
    - params (np.ndarray): array of at least 4 parameters

    Returns:
    - y (np.ndarray): acceleration values
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * np.power(x0, 3)
        + params[3] * x1
    )
