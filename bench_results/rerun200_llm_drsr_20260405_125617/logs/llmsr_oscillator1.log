def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Adds more complex nonlinear coupling terms, saturation effects,
    and smooth approximations of friction-like forces to better capture
    complex nonlinear oscillator dynamics.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients [bias, linear & nonlinear terms]

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    # Use modulo indexing to safely access params even if length < 20
    p = lambda i: params[i % MAX_NPARAMS]
    
    return (
        p(0)  # constant offset / bias term
        
        + p(1) * x0          # linear stiffness term (-k * x)
        + p(2) * x1          # linear damping term (-c * v)
        
        + p(3) * (x0 ** 2)   # quadratic stiffness nonlinearity
        + p(4) * (x1 ** 2)   # quadratic velocity nonlinearity
        
        + p(5) * (x0 ** 3)   # cubic stiffness nonlinearity (Duffing-type)
        + p(6) * (x1 ** 3)   # cubic velocity nonlinearity
        
        + p(7) * (x0 * x1)   # bilinear coupling term
        
        + p(8) * (x0 ** 2)*x1     # mixed quadratic position times velocity
        + p(9) * x0*(x1 ** 2)     # mixed position times quadratic velocity
        
        + p(10)*np.sin(x0)         # periodic restoring force component (e.g., pendulum-like)
        + p(11)*np.sign(x1)        # friction-like discontinuous damping term
        
