def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Further extends the nonlinear oscillator acceleration model by adding:
    - Higher-order polynomial stiffness and damping terms (up to 6th order)
    - Mixed coupling terms between position and velocity with various powers
    - Smooth approximations of friction and saturation effects
    - Exponential and logarithmic nonlinearities capturing softening/hardening
    - Hyperbolic functions for asymmetric restoring forces

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients [bias, linear & nonlinear terms]

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    p = lambda i: params[i % len(params)]
    
    # Base linear and low-order nonlinear terms (from v1)
    y = (
        p(0)  # bias / constant offset
        
        + p(1) * x0          # linear stiffness (-k*x)
        + p(2) * x1          # linear damping (-c*v)
        
        + p(3) * (x0 ** 2)   # quadratic stiffness nonlinearity
        + p(4) * (x1 ** 2)   # quadratic velocity nonlinearity
        
        + p(5) * (x0 ** 3)   # cubic stiffness nonlinearity (Duffing-type)
        + p(6) * (x1 ** 3)   # cubic velocity nonlinearity
        
        + p(7) * (x0 * x1)   # bilinear coupling term
        
        + p(8) * (x0 ** 2)*x1     # mixed quadratic position times velocity
        + p(9) * x0*(x1 ** 2)     # mixed position times quadratic velocity
        
        + p(10)*np.sin(x0)         # periodic restoring force component
        
        + p(11)*np.sign(x1)        # friction-like discontinuous damping term
        
        + p(12)*np.cos(x0)         # additional periodic restoring force component
        
        + p(13)*np.exp(-np.abs(x1))# exponential decay related to velocity magnitude
        
        + p(14)*(x0 ** 4)          # quartic stiffness nonlinearity for stronger anharmonicity
        + p(15)*(x1 ** 4)          # quartic velocity nonlinearity
        
        + p(16)*(x0**3*x1)         # cubic position times velocity term 
        + p(17)*(x0*x1**3)         # position times cubic velocity term

        + p(18)*np.tanh(x1)         # smooth saturation-like damping effect

        + p(19)*np.log(np.abs(x0)+1e-6)*np.sign(x0)*x1**2   # logarithmic softening/hardening with velocity squared

        + p(20)*np.sinh(x0)            # hyperbolic sine capturing asymmetric restoring forces
    
        + p(21)*np.tanh(x0*x1)         # smooth saturation of coupling between position and velocity
    
        + p(22)*(x0**5)                # quintic stiffness nonlinearity for strong anharmonicity
    
        + p(23)*(x1**5)                # quintic velocity nonlinearity
    
        + p(24)*(x0**4)*x1             # quartic position times linear velocity
    
        + p(25)*x0*(x1**4)             # linear position times quartic velocity
    )
    
    ### Additional higher-order & complex nonlinearities ###
    
    y += (
          p(26)*(x0**6)
        
       + p(27)*(x1**6)
       
