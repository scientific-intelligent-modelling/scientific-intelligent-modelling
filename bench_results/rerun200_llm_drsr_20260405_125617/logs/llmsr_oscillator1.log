def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Further extends the nonlinear harmonic oscillator acceleration model by including
    polynomial terms up to 4th order, trigonometric nonlinearities (sin and cos),
    and rational terms to mimic velocity-dependent damping/restoring forces.

    Model acceleration as:
        y = p0 
          + p1*x0 
          + p2*x1 
          + p3*x0**2 
          + p4*x1**2 
          + p5*x0*x1 
          + p6*x0**3
          + p7*(x0**2)*x1
          + p8*x0*(x1**2)
          + p9*(x1**3)
          + p10*sin(x0)*cos(x1)
          + p11 * (x0 / (1 + |x1|))

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Coefficients [p0,...p11]

    Returns:
    - y: Acceleration at time t
    """
    
    denom = 1.0 + np.abs(x1)  # denominator for rational term mimicking velocity-dependent damping
    
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * (x0 ** 2)
        + params[4] * (x1 ** 2)
        + params[5] * (x0 * x1)
        + params[6] * (x0 ** 3)
        + params[7] * ((x0 ** 2) * x1)
        + params[8] * (x0 * (x1 ** 2))
        + params[9] * (x1 ** 3)
        # Nonlinear periodic interaction term for richer dynamics:
        + params[10] * np.sin(x0) * np.cos(x1)
        # Rational term to capture velocity-dependent damping/restoring force:
        + params[11] * (x0 / denom)
    )
