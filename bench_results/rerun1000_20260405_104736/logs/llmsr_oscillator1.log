def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Models acceleration as a nonlinear function of position (x0) and velocity (x1):
    Includes constant term, linear terms in position and velocity,
    cubic nonlinearity in position, and possibly quadratic velocity term.

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected usage:
        params[0]: constant offset
        params[1]: linear coefficient for position (x0)
        params[2]: linear coefficient for velocity (x1)
        params[3]: cubic coefficient for position (x0^3)
        params[4]: quadratic coefficient for velocity (x1^2)
        params[5]: quadratic coefficient for position (x0^2)
        ... up to MAX_NPARAMS if needed
    """
    # Unpack parameters with safe defaults if fewer provided
    p = np.pad(params, (0, max(0, 6 - len(params))), 'constant')

    return (
        p[0] +
        p[1] * x0 +
        p[2] * x1 +
        p[3] * x0**3 +
        p[4] * x1**2 +
        p[5] * x0**2
    )
