def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0` that models nonlinear harmonic oscillator acceleration.
    
    Model form:
        y = params[0] 
            + params[1] * x0 
            + params[2] * x1 
            + params[3] * x0**3
    
    Parameters:
    - params (np.ndarray): array of at least length 4
    
    Returns:
    - y (np.ndarray): acceleration values
    """
    return (
        params[0]
        + params[1] * x0       # linear restoring force term
        + params[2] * x1       # damping term proportional to velocity
        + params[3] * x0**3    # nonlinear restoring force term
    )
