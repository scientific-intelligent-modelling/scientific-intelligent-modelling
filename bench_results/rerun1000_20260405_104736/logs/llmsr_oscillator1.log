def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation modeling acceleration in nonlinear harmonic oscillator.

    Model includes:
    - constant offset
    - linear position and velocity (restoring force and damping)
    - quadratic position and velocity
    - cubic position and velocity (nonlinear stiffness/damping)
    - cross product terms including quadratic-cubic interactions

    Parameters:
        params[0]: constant offset
        params[1]: linear position coefficient
        params[2]: linear velocity coefficient
        params[3]: quadratic position coefficient
        params[4]: quadratic velocity coefficient
        params[5]: cubic position coefficient
        params[6]: cubic velocity coefficient
        params[7]: cross term linear*linear (x0*x1)
        params[8]: cross term quadratic*linear ((x0**2)*x1)
        params[9]: cross term linear*quadratic (x0*(x1**2))
        params[10]: possibly higher order or mixed term ((x0**3)*x1)
        params[11]: possibly higher order or mixed term (x0*(x1**3))

    Returns:
        Acceleration array.
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * np.power(x0, 2)
        + params[4] * np.power(x1, 2)
        + params[5] * np.power(x0, 3)
        + params[6] * np.power(x1, 3)
        + params[7] * x0 * x1
        + params[8] * (np.power(x0, 2)) * x1
        + params[9] * x0 * (np.power(x1, 2))
        + params[10] * (np.power(x0, 3)) * x1
        + params[11] * x0 * (np.power(x1, 3))
