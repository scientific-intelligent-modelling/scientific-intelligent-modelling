def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Model acceleration as a nonlinear function of position and velocity,
    including up to cubic terms and physically meaningful nonlinearities:

    a = p0 
        + p1*x0                 # linear restoring force (Hooke's law)
        + p2*x0**3              # cubic stiffness (Duffing oscillator nonlinearity)
        + p3*x1                 # linear damping
        + p4*x1**2              # nonlinear damping term
        + p5*x0*x1              # coupling term between position and velocity
        + p6*np.sin(x0)         # nonlinear oscillatory restoring force component
        + p7*np.sign(x1)        # friction-like term depending on velocity direction

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.

    Returns:
    - np.ndarray: Computed acceleration values.
    """
    
    return (
        params[0]  # constant offset term
        + params[1] * x0  # linear position term (restoring force)
        + params[2] * x0**3  # cubic nonlinearity in position (Duffing type)
        + params[3] * x1  # linear damping term
        + params[4] * x1**2  # nonlinear damping effect
        + params[5] * x0 * x1  # coupling between position and velocity
        + params[6] * np.sin(x0)  # nonlinear oscillatory restoring force component
        + params[7] * np.sign(x1)  # friction-like effect depending on velocity direction
    )
