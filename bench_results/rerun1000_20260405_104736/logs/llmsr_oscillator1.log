def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation representing acceleration of nonlinear harmonic oscillator.
    
    Model includes constant, linear and cubic position terms,
    linear and quadratic velocity terms, and cross term.
    
    Parameters:
    - x0 (np.ndarray): Position at time t.
    - x1 (np.ndarray): Velocity at time t.
    - params (np.ndarray): Coefficients array of length MAX_NPARAMS=12.
    
    Returns:
    - y (np.ndarray): Acceleration at time t.
    """
    
    # Unpack parameters for clarity
    c = params[0]          # constant term
    a1 = params[1]         # linear position coefficient
    a3 = params[2]         # cubic position coefficient
    b1 = params[3]         # linear velocity coefficient (damping)
    b2 = params[4]         # quadratic velocity coefficient (nonlinear damping)
    cros = params[5]       # cross term coefficient
    
    # Additional higher order or interaction terms if desired:
    p2 = params[6]         # quadratic position term (x0^2)
    p4 = params[7]         # quartic position term (x0^4)
    
    v3 = params[8]         # cubic velocity term (x1^3)
    
    cross2 = params[9]     # cross quadratic term e.g. x0^2*x1
    
    cross3 = params[10]     # another cross term e.g. x0*x1^2
    
    const_high_order = params[11]
    
    y = (
        c +
        a1 * x0 +
        p2 * np.power(x0, 2) +
        a3 * np.power(x0, 3) +
        p4 * np.power(x0, 4) +
        b1 * x1 +
        b2 * np.power(x1, 2) +
        v3 * np.power(x1, 3) +
        cros * x0 * x1 +
        cross2 * np.power(x0, 2) * x1 +
        cross3 * x0 * np.power(x1, 2) +
        const_high_order   # could be used as bias or extra constant offset
       )
    
    return y
