def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Models acceleration as a nonlinear function of position (x0) and velocity (x1),
    including linear, quadratic, and cubic terms for position,
    linear and quadratic terms for velocity,
    and cross terms.

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 10.
    
    Returns:
    - np.ndarray: Calculated acceleration.
    """
    return (
        params[0]  # constant term
        + params[1] * x0  # linear position
        + params[2] * x1  # linear velocity (damping)
        + params[3] * x0**2  # quadratic position nonlinearity
        + params[4] * x1**2  # quadratic velocity nonlinearity (less common but possible)
        + params[5] * x0**3  # cubic position nonlinearity
        + params[6] * x1**3  # cubic velocity nonlinearity (rare but included)
        + params[7] * x0 * x1  # cross term linear*linear
        + params[8] * (x0**2) * x1  # cross term quadratic*linear
        + params[9] * x0 * (x1**2)  # cross term linear*quadratic
    )
