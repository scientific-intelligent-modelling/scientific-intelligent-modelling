def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0` including nonlinear terms.
    
    Parameters:
    - x0: position at time t
    - x1: velocity at time t
    - params: array of coefficients
    
    Returns:
    - acceleration at time t
    """
    
    # Linear terms
    y = params[0]  # constant offset term, often zero in physics but kept for flexibility
    y += params[1] * x0  # linear position term (restoring force)
    y += params[2] * x1  # linear velocity term (damping)
    
    # Nonlinear terms
    y += params[3] * x0**2       # quadratic position term
    y += params[4] * x1**2       # quadratic velocity term
    y += params[5] * x0**3       # cubic position term (typical nonlinearity)
    
    # Cross term between position and velocity
    y += params[6] * x0 * x1
    
    return y
