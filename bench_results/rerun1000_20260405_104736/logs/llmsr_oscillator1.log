def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration y as a function of position x0 and velocity x1 with nonlinear terms,
    including higher order cross terms and mixed powers relevant to nonlinear oscillators.

    Parameters:
        params (np.ndarray): array-like with 12 elements corresponding to coefficients:
            params[0]: constant offset
            params[1]: linear position term (restoring force)
            params[2]: linear velocity term (damping)
            params[3]: cubic position term (nonlinear stiffness)
            params[4]: cubic velocity term (nonlinear damping)
            params[5]: quadratic position term
            params[6]: quadratic velocity term
            params[7]: cross-term x0 * x1
            params[8]: cross-term x0^2 * x1
            params[9]: cross-term x0 * x1^2
            params[10]: quartic position term (x0^4)
            params[11]: quartic velocity term (x1^4)

    Returns:
        np.ndarray: acceleration values.
    """
    # To improve physical interpretability, reorder terms grouping by powers and interactions.
    return (
        params[0]
        + params[1] * x0                      # linear restoring force ~ -k*x
        + params[2] * x1                      # linear damping ~ -c*v
        + params[5] * np.power(x0, 2)        # quadratic stiffness-like nonlinearity
        + params[6] * np.power(x1, 2)        # quadratic damping-like nonlinearity
        + params[7] * x0 * x1                 # coupling between position and velocity
        + params[3] * np.power(x0, 3)        # cubic stiffness nonlinearity
        + params[4] * np.power(x1, 3)        # cubic damping nonlinearity
        + params[8] * np.power(x0, 2) * x1   # mixed higher order coupling terms
        + params[9] * x0 * np.power(x1, 2)
        + params[10] * np.power(x0, 4)       # quartic stiffness nonlinearity 
        + params[11] * np.power(x1, 4)       # quartic damping nonlinearity 
    )
