def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Calculates acceleration for a nonlinear harmonic oscillator using polynomial terms 
    up to cubic order in position (x0) and velocity (x1), with physically meaningful structure:
    
    - The acceleration typically depends on restoring force terms proportional to position (linear and nonlinear),
      and damping terms proportional to velocity (linear and nonlinear).
    - Common nonlinear oscillator models include terms like -k*x0 - c*x1 - alpha*x0^3.
    
    Parameters:
    - params (np.ndarray): Array of 12 coefficients.

    Returns:
    - y (np.ndarray): Calculated acceleration.
    """
    p = params

    # Physically motivated structure:
    # y = acceleration = 
    #   constant term + linear damping + linear restoring force + nonlinear restoring force + nonlinear damping
    #
    # Typical form for a Duffing-type oscillator with damping:
    # y = p0 
    #   + p1 * x0           # linear restoring force term (~-k*x)
    #   + p2 * x1           # linear damping term (~-c*v)
    #   + p5 * x0**3        # cubic stiffness nonlinearity (~-alpha*x^3)
    #   + p4 * x1**2        # quadratic velocity term (nonlinear damping)
    #
    # Additional cross terms can capture more complex dynamics.

    y = (
        p[0]                      # constant offset
        + p[1] * x0               # linear position term (restoring force)
        + p[2] * x1               # linear velocity term (damping)
        + p[3] * (x0 ** 2)        # quadratic position term
        + p[4] * (x1 ** 2)        # quadratic velocity term
        + p[5] * (x0 ** 3)        # cubic position term (nonlinear stiffness)
        + p[6] * (x1 ** 3)        # cubic velocity term (nonlinear damping)
        + p[7] * (x0 * x1)        # cross linear terms
        + p[8] * (x0 ** 2 * x1)   # mixed quadratic-cubic terms
        + p[9] * (x0 * x1 ** 2)   # mixed quadratic-cubic terms
        + p[10] * (x0 ** 3 * x1)  # quartic mixed term
        + p[11] * (x0 * x1 ** 3)  # quartic mixed term
    )

    return y
