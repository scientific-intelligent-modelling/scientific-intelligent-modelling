def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Includes linear terms, cubic nonlinearities, and mixed nonlinear terms to capture
    complex oscillator dynamics.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients [params[0] ... params[6]]

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    return (
        params[0]                  # constant offset
        + params[1] * x0           # linear stiffness term (restoring force)
        + params[2] * x1           # linear damping/driving term
        + params[3] * x0**3        # cubic stiffness nonlinearity
        + params[4] * (x0**2) * x1 # mixed quadratic position & linear velocity term
        + params[5] * x0 * (x1**2) # mixed linear position & quadratic velocity term
        + params[6] * x1**3        # cubic velocity nonlinearity (nonlinear damping)
    )
