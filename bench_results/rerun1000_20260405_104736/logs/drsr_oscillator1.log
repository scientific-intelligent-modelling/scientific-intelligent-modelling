def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Mathematical function skeleton representing acceleration y in oscillator1,
    given position x0 and velocity x1.

    The model includes:
    - Constant offset
    - Linear terms in position (x0) and velocity (x1)
    - Cubic nonlinearities in both variables
    - Mixed nonlinear interaction terms between position and velocity

    Parameters:
        x0 (np.ndarray): Position array at time t.
        x1 (np.ndarray): Velocity array at time t.
        params (np.ndarray): Parameter array with length >= 7:
            params[0]: constant offset
            params[1]: linear coefficient for x0
            params[2]: linear coefficient for x1
            params[3]: cubic coefficient for x0^3
            params[4]: mixed term coefficient for x0^2 * x1
            params[5]: mixed term coefficient for x0 * x1^2
            params[6]: cubic coefficient for x1^3

    Returns:
        y (np.ndarray): Acceleration array corresponding to inputs.
    """
    
    # Ensure parameter length is sufficient
    if len(params) < 7:
        raise ValueError("Parameter array 'params' must have at least 7 elements.")
    
    y = (
        params[0]
        + params[1] * x0          # linear restoring force term ~ displacement
        + params[2] * x1          # linear damping/driving term ~ velocity
        + params[3] * (x0 ** 3)   # cubic stiffness nonlinearity 
        + params[4] * (x0 ** 2) * x1  # mixed nonlinear term coupling position squared with velocity 
        + params[5] * x0 * (x1 ** 2)  # mixed nonlinear term coupling position with velocity squared 
        + params[6] * (x1 ** 3)   # cubic nonlinear damping/driving term 
    )
    
    return y
