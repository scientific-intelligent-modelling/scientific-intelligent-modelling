def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Includes:
    - constant offset
    - linear terms in position (x0) and velocity (x1)
    - cubic stiffness term in position (x0^3)
    - nonlinear mixed terms involving position and velocity

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 12.

    Returns:
    - y (np.ndarray): acceleration output of the nonlinear oscillator.
    """
    # Unpack parameters for clarity
    c0 = params[0]   # constant offset
    c1 = params[1]   # linear term in position x0
    c2 = params[2]   # linear term in velocity x1
    c3 = params[3]   # cubic stiffness term x0^3
    c4 = params[4]   # quadratic velocity term x1^2
    c5 = params[5]   # quadratic position term x0^2
    c6 = params[6]   # mixed term x0*x1
    c7 = params[7]   # mixed cubic term x0^2 * x1
    c8 = params[8]   # mixed cubic term x0 * x1^2
    c9 = params[9]   # cubic velocity term x1^3
    c10= params[10]  # higher order mixed term e.g. x0^3 * x1
    c11= params[11]  # higher order mixed term e.g. x0 * x1^3

    
    y = (
        c0 
        + c1 * x0 
        + c2 * x1 
        + c3 * (x0 ** 3) 
        + c4 * (x1 ** 2) 
        + c5 * (x0 ** 2) 
        + c6 * (x0 * x1) 
        + c7 * (x0 ** 2) * x1 
