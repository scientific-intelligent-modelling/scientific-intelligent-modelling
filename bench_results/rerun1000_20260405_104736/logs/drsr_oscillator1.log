    y = params[0] 
        + params[1]*x0 
        + params[2]*x1 
        + params[3]*x0**3 
        + params[4]*x1**3 
        + params[5]*x0**2 
        + params[6]*x0*x1 
        + params[7]*x0**2 * x1 
        + params[8]*x1**2 
        + params[9]*np.sign(x1)*np.abs(x1)**(5/3) 
        + params[10]*x0*x1**2
    """
    # Ensure params has at least 11 elements
    assert len(params) >= 11, "params must have at least 11 elements"

    term_const = params[0]
    term_x0 = params[1] * x0
    term_x1 = params[2] * x1
    term_x03 = params[3] * (x0 ** 3)
    term_x13 = params[4] * (x1 ** 3)
    term_x02 = params[5] * (x0 ** 2)
    term_x01 = params[6] * (x0 * x1)
    term_x02_x01 = params[7] * (x0 ** 2) * x1
    term_x12 = params[8] * (x1 ** 2)
    
    # fractional power damping-like term for velocity
    fractional_term = params[9] * np.sign(x1) * np.abs(x1) ** (5 / 3)

    mixed_term = 0. if len(params) <= 10 else params[10] * (x0 * (x1 ** 2))

    y = (
        term_const +
        term_x0 +
        term_x1 +
        term_x03 +
        term_x13 +
        term_x02 +
        term_x01 +
        term_x02_x01 +
        term_x12 +
        fractional_term +
        mixed_term
    )
    
    return y
