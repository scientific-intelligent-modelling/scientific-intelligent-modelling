def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculate acceleration y for oscillator1 given position x0 and velocity x1.

    Parameters:
    - x0: Position array
    - x1: Velocity array
    - params: Array of parameters with length >= 10
    
    Returns:
    - y: Acceleration array
    """
    # Validate params length to avoid indexing errors
    if len(params) < 10:
        raise ValueError("params must have at least 10 elements")

    # Fractional power term with sign preservation (damping-like)
    frac_power_term = params[9] * np.sign(x1) * np.abs(x1)**(5/3)

    # Construct acceleration y as sum of terms:
    y = (
        params[0]                  # constant offset
        + params[1] * x0          # linear stiffness term (Hooke's law)
        + params[2] * x1          # linear damping/driving term
        + params[3] * x0**3       # cubic stiffness nonlinearity (Duffing-type)
        + params[4] * x1**3       # cubic damping nonlinearity
        + params[5] * (x0**2)*x1  # mixed nonlinear term 1 (position^2 * velocity)
        + params[6] * x0*(x1**2)  # mixed nonlinear term 2 (position * velocity^2)
        + params[7] * (x0**2)     # quadratic position nonlinearity
        + params[8] * (x1**2)     # quadratic velocity nonlinearity
        + frac_power_term         # fractional power damping-like term 
    )
    
    return y
