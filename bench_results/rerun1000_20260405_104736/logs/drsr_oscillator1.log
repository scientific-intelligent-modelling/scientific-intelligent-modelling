def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculate acceleration y for nonlinear harmonic oscillator given position x0 and velocity x1.

    Parameters:
    - x0 (np.ndarray): Position array
    - x1 (np.ndarray): Velocity array
    - params (np.ndarray): Array of at least 12 trainable coefficients

    Returns:
    - y (np.ndarray): Acceleration array
    """
    # Ensure params length is sufficient
    assert len(params) >= 12, "params must have at least 12 elements"

    # Linear terms
    y = params[0]               # constant offset term
    y += params[1] * x0        # linear stiffness term (restoring force)
    y += params[2] * x1        # linear damping/driving term

    # Nonlinear position terms
    y += params[3] * x0**3     # cubic stiffness nonlinearity
    y += params[7] * x0**2     # quadratic position term for asymmetry

    # Nonlinear velocity terms
    y += params[4] * x1**3     # cubic velocity damping/driving nonlinearity
    y += params[8] * x1**2     # quadratic velocity term for asymmetric damping/driving

    # Fractional power velocity damping-like term with sign preserving directionality
    y += params[9] * np.sign(x1) * np.abs(x1)**(5/3)

    # Mixed nonlinear coupling terms between position and velocity
    y += params[5] * (x0**2) * x1   # quadratic position times linear velocity coupling
    y += params[6] * (x0) * (x1**2) # linear position times quadratic velocity coupling

    return y
