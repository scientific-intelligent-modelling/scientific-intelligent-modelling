def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Calculates acceleration y in a nonlinear harmonic oscillator given position (x0)
    and velocity (x1).

    Model includes linear and cubic stiffness terms and linear damping.

    y = params[0] + params[1]*x0 + params[2]*x1 + params[3]*x0**3

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients [offset, linear stiffness, damping, nonlinear stiffness]

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    return params[0] + params[1] * x0 + params[2] * x1 + params[3] * (x0 ** 3)
