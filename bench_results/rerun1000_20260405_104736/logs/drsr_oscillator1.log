def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Calculates acceleration y for nonlinear harmonic oscillator given position (x0)
    and velocity (x1).

    Parameters:
    - params (np.ndarray): Array of at least 12 trainable coefficients.

    Returns:
    - y (np.ndarray): Calculated acceleration.
    """
    # Ensure params has at least 12 elements
    if len(params) < 12:
        raise ValueError("Parameter array 'params' must have at least 12 elements.")

    y = (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * (x0 ** 2)
        + params[4] * (x1 ** 2)
        + params[5] * (x0 * x1)
        + params[6] * (x0 ** 3)
        + params[7] * (x1 ** 3)
        + params[8] * ((x0 ** 2) * x1)
        + params[9] * (x0 * (x1 ** 2))
        + params[10] * np.sin(x0)
        + params[11] * np.cos(x1)
    )
    
    return y
