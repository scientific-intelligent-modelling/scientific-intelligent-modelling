def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculate acceleration y in a nonlinear harmonic oscillator given position (x0) and velocity (x1).

    Parameters:
    - x0 (np.ndarray): Position array
    - x1 (np.ndarray): Velocity array
    - params (np.ndarray): Parameter array with at least 12 elements
    
    Returns:
    - y (np.ndarray): Acceleration array
    """
    
    if len(params) < MAX_NPARAMS:
        raise ValueError(f"Parameter array 'params' must have at least {MAX_NPARAMS} elements.")
    
    # Linear terms
    y = params[0]               # constant offset term
    y += params[1] * x0         # linear stiffness term
    y += params[2] * x1         # linear damping/driving term
    
    # Cubic and quadratic position terms
    y += params[3] * (x0 ** 3)  # cubic stiffness nonlinearity
    y += params[7] * (x0 ** 2)  # quadratic position term
    
    # Cubic and quadratic velocity terms
    y += params[4] * (x1 ** 3)  # cubic velocity nonlinearity
    y += params[8] * (x1 ** 2)  # quadratic velocity term
    
    # Fractional power damping-like term on velocity
    y += params[9] * np.sign(x1) * np.abs(x1)**(5/3)
    
    # Mixed nonlinear interaction terms between position and velocity
    y += params[5] * (x0 * x1)
    y += params[6] * (x0**2 * x1)
    
    # Additional mixed nonlinear term involving position and squared velocity
    y += params[10] * (x0 * (x1**2))
    
    # Possibly another mixed nonlinear term involving higher order or cross product 
    y += params[11] * ((x0**3) * x1)
    
    return y
