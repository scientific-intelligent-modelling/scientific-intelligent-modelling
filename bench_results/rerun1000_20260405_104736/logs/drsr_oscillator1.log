    m21 = params[10]     # another mixed nonlinear coupling
    
    m22 = params[11]     # another mixed nonlinear coupling

    
    y = (
        c0 
        + k1 * x0 
        + d1 * x1 
        + k3 * np.power(x0, 3) 
        + d3 * np.power(x1, 3) 
        + m11 * x0 * x1 
        + m12 * np.power(x0, 2) 
        + qv2 * np.power(x1, 2) 
        + fvdamp * np.sign(x1) * np.abs(x1)**(5/3)
        + m21 * (x0**2)*x1      # example of a higher order mixed term; can be adjusted as needed
