def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved equation skeleton for nonlinear harmonic oscillator acceleration.

    Args:
        x0 (np.ndarray): Position at time t.
        x1 (np.ndarray): Velocity at time t.
        params (np.ndarray): Array of parameters with length >= 12.

    Returns:
        np.ndarray: Computed acceleration y.
    """
    # Validate params length
    if len(params) < 12:
        raise ValueError("params must have at least 12 elements.")

    # Unpack parameters for clarity
    p = params

    # Linear terms
    linear = p[0] + p[1]*x0 + p[2]*x1

    # Quadratic terms
    quadratic = p[3]*x0**2 + p[4]*x1**2 + p[5]*x0*x1

    # Cubic terms
    cubic = p[6]*x0**3 + p[7]*x1**3 + p[8]*(x0**2)*x1 + p[9]*x0*(x1**2)

    # Fractional power damping-like term with sign preservation on velocity
    fractional_damping = p[10] * np.sign(x1) * np.abs(x1)**0.5

    # Constant offset or bias term
    constant = p[11]

    y = linear + quadratic + cubic + fractional_damping + constant

    return y
