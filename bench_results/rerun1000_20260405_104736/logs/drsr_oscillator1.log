def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Includes nonlinear terms up to cubic order for position and velocity.

    Parameters:
    - params (np.ndarray): Must have at least 12 elements.
    
    Returns:
    - y (np.ndarray): Computed acceleration.
    """
    # Validate params length
    if len(params) < 12:
        raise ValueError("params must have at least 12 elements")

    # Linear terms
    y = params[0] \
        + params[1] * x0 \
        + params[2] * x1

    # Quadratic terms
    y += params[3] * (x0 ** 2) \
         + params[4] * (x1 ** 2) \
         + params[5] * (x0 * x1)

    # Cubic terms
    y += params[6] * (x0 ** 3) \
         + params[7] * (x1 ** 3) \
         + params[8] * (x0 ** 2 * x1) \
         + params[9] * (x0 * x1 ** 2)

    # Additional linear terms or constants if needed
    y += params[10] * np.sin(x0) \
         + params[11] * np.cos(x1)

    return y
