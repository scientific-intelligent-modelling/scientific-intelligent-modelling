def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of equation_v0 including nonlinear and mixed terms.

    Parameters:
    - x0 (np.ndarray): Position array.
    - x1 (np.ndarray): Velocity array.
    - params (np.ndarray): Array of at least 12 parameters.

    Returns:
    - y (np.ndarray): Acceleration array computed from the nonlinear oscillator model.
    """
    if len(params) < MAX_NPARAMS:
        raise ValueError(f"params must have at least {MAX_NPARAMS} elements")

    # Unpack parameters for clarity
    c0 = params[0]   # constant offset
    c1 = params[1]   # linear stiffness coefficient (x0)
    c2 = params[2]   # linear damping coefficient (x1)
    c3 = params[3]   # cubic stiffness coefficient (x0^3)
    c4 = params[4]   # cubic damping coefficient (x1^3)
    c5 = params[5]   # mixed quadratic term: x0 * x1
    c6 = params[6]   # quadratic position term: x0^2
    c7 = params[7]   # quadratic position term: x0^2 (possibly different effect)
    c8 = params[8]   # quadratic velocity term: x1^2
    c9 = params[9]   # fractional power velocity damping-like term: sign(x1)*|x1|^{5/3}
    c10= params[10]  # mixed nonlinear term: e.g. x0^2 * x1 or similar
    c11= params[11]  # another mixed nonlinear or higher order term

    y = (
        c0
        + c1 * x0
        + c2 * x1
        + c3 * np.power(x0, 3)
        + c4 * np.power(x1, 3)
        + c5 * x0 * x1
        + c6 * np.power(x0, 2)
        + c7 * np.power(x0, 2)  # could be combined with above or represent asymmetric effect
        + c8 * np.power(x1, 2)
        + c9 * np.sign(x1) * np.abs(x1)**(5/3)
        + c10 * (np.power(x0, 2) * x1)
        + c11 * (x0 * np.power(x1, 2))
       )

    return y
