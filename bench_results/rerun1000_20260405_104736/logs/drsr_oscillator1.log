    """Improved version of `equation_v0`.

    This function represents a mathematical skeleton for acceleration y in a nonlinear harmonic oscillator,
    given position (x0) and velocity (x1).

    The model includes:
    - Constant term
    - Linear terms in position and velocity
    - Quadratic nonlinearities (position^2, velocity^2)
    - Cubic nonlinearities (position^3, velocity^3)
    - Mixed terms (position * velocity, position^2 * velocity, position * velocity^2)
    - Fractional power damping-like term with sign preservation to capture complex damping behavior

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Array of at least 12 trainable coefficients

    Returns:
        y (np.ndarray): Computed acceleration at time t
    """
    
    if len(params) < MAX_NPARAMS:
        raise ValueError(f"params must have at least {MAX_NPARAMS} elements.")
    
    # Unpack parameters for clarity
    c0 = params[0]   # constant offset
    c1 = params[1]   # linear in position x0
    c2 = params[2]   # linear in velocity x1
    
    c3 = params[3]   # quadratic in position x0^2
    c4 = params[4]   # quadratic in velocity x1^2
    
    c5 = params[5]   # cubic in position x0^3
    c6 = params[6]   # cubic in velocity x1^3
    
    c7 = params[7]   # mixed linear term: x0 * x1
    
    c8 = params[8]   # mixed quadratic-cubic terms: x0^2 * x1
    c9 = params[9]   # mixed quadratic-cubic terms: x0 * x1^2
    
    c10 = params[10]  # fractional power damping-like term coefficient
    
    c11 = params[11]  # fractional power exponent (> 0), typically between 0 and 1 for fractional damping

    
    sign_x1 = np.sign(x1)
    
    y = (
        c0 
        + c1 * x0 
        + c2 * x1 
        + c3 * (x0 ** 2) 
        + c4 * (x1 ** 2) 
        + c5 * (x0 ** 3) 
        + c6 * (x1 ** 3) 
        + c7 * (x0 * x1) 
        + c8 * ((x0 ** 2) * x1) 
        + c9 * (x0 * (x1 ** 2)) 
        + c10 * sign_x1 * (np.abs(x1) ** c11)
       )
    
    return y
