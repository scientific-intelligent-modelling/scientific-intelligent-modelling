def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculate acceleration y in a nonlinear harmonic oscillator given position (x0)
    and velocity (x1), using a parameterized nonlinear function skeleton.

    Parameters:
    - x0: Position array
    - x1: Velocity array
    - params: Parameter array with at least 12 elements

    Returns:
    - y: Acceleration array
    """
    if len(params) < MAX_NPARAMS:
        raise ValueError(f"Parameter array 'params' must have at least {MAX_NPARAMS} elements.")

    # Extract parameters for readability
    p = params

    # Compute fractional power term safely
    sign_x1 = np.sign(x1)
    abs_x1_pow = np.abs(x1)**(5/3)

    y = (
        p[0]
        + p[1]*x0
        + p[2]*x1
        + p[3]*x0**3
        + p[4]*x1**3
        + p[5]*(x0**2 * x1)
        + p[6]*(x0 * x1**2)
        + p[7]*x0**2
        + p[8]*x1**2
        + p[9]*(sign_x1 * abs_x1_pow)
        + p[10]*(x0**3 * x1)
        + p[11]*(x0 * x1**3)
    )

    return y
