def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Includes nonlinear cubic terms and mixed position-velocity interactions
    to capture oscillator acceleration dynamics more accurately.

    Parameters:
    - x0: Position array
    - x1: Velocity array
    - params: Array of trainable parameters with at least 7 elements

    Returns:
    - y: Acceleration array computed from the model skeleton
    """
    y = (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * (x0 ** 3)
        + params[4] * (x0 ** 2) * x1
        + params[5] * x0 * (x1 ** 2)
        + params[6] * (x1 ** 3)
    )
    return y
