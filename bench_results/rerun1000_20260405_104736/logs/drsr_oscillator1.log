def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    This function represents a mathematical skeleton for acceleration y in a nonlinear harmonic oscillator,
    given position x0 and velocity x1 at time t.

    The model includes:
    - Constant term
    - Linear terms in position and velocity
    - Quadratic and cubic nonlinearities in position and velocity
    - Mixed nonlinear terms (e.g., x0*x1)
    - A fractional power damping-like term with sign preservation to capture complex damping effects

    Parameters:
    - params (np.ndarray): Array of at least 12 trainable coefficients.

    Returns:
    - y (np.ndarray): Computed acceleration values.
    """
    
    # Validate params length
    if len(params) < MAX_NPARAMS:
        raise ValueError(f"params must have at least {MAX_NPARAMS} elements")
    
    # Unpack parameters for clarity
    c0 = params[0]   # constant term
    c1 = params[1]   # linear in x0 (position)
    c2 = params[2]   # linear in x1 (velocity)
    
    c3 = params[3]   # quadratic in x0^2
    c4 = params[4]   # quadratic in x1^2
    c5 = params[5]   # mixed quadratic term x0*x1
    
    c6 = params[6]   # cubic in x0^3
    c7 = params[7]   # cubic in x1^3
    
    c8 = params[8]   # mixed cubic term x0^2 * x1
    c9 = params[9]   # mixed cubic term x0 * x1^2
    
    c10 = params[10]  # fractional power damping-like term coefficient
    
    c11 = params[11]  # additional nonlinear or correction term coefficient

    
    y = (
        c0 
        + c1 * x0 
        + c2 * x1 
        + c3 * (x0 ** 2) 
        + c4 * (x1 ** 2) 
        + c5 * (x0 * x1) 
        + c6 * (x0 ** 3) 
        + c7 * (x1 ** 3) 
        + c8 * (x0 ** 2) * x1 
        + c9 * x0 * (x1 ** 2)
        + c10 * np.sign(x1) * (np.abs(x1) ** 0.5)
        + c11 * np.sign(x0) * (np.abs(x0) ** 3.5)
       )
    
    return y
