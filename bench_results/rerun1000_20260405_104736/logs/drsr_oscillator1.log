            params[5]: mixed term coefficient for (x0 * x1^2)
            params[6]: cubic coefficient for velocity (x1^3)

    Returns:
        y (np.ndarray): Acceleration output array
    """
    
    y = (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * np.power(x0, 3)
        + params[4] * np.power(x0, 2) * x1
        + params[5] * x0 * np.power(x1, 2)
        + params[6] * np.power(x1, 3)
    )
    
    return y
