    """
    Calculate acceleration y for nonlinear harmonic oscillator given position (x0) 
    and velocity (x1), using a parameterized nonlinear model.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Array of parameters with length >= 12
    
    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    if len(params) < MAX_NPARAMS:
        raise ValueError(f"Parameter array 'params' must have at least {MAX_NPARAMS} elements.")
    
    # Unpack parameters for clarity (indices correspond to physical meaning)
    c0 = params[0]   # constant offset term
    
    k1 = params[1]   # linear stiffness coefficient for position (x0)
    d1 = params[2]   # linear damping coefficient for velocity (x1)
    
    k3 = params[3]   # cubic stiffness coefficient for position^3 (x0^3)
    
    d3 = params[4]   # cubic damping coefficient for velocity^3 (x1^3)
    
    k2_pos = params[7]  # quadratic stiffness coefficient for position^2 (x0^2)
    
    d2_vel = params[8]  # quadratic damping coefficient for velocity^2 (x1^2)
    
    frac_damping_coeff = params[9]  # fractional power damping-like term coeff
    
    # Mixed nonlinear terms coupling position and velocity
    mix_x0_x1 = params[5]     # e.g. linear mixed term: x0 * x1
    mix_x0_sq_x1 = params[6]  # e.g. quadratic mixed term: x0^2 * x1
    
    mix_x0_x1_sq = params[10]  # e.g. mixed term: x0 * x1^2
    
    mix_x0_cub_x1_cub = params[11]  # e.g. higher order mixed term: x0^3 * x1^3
    
    sign_x1 = np.sign(x1)
    
    y = (
        c0 
        + k1 * x0 
        + d1 * x1 
        + k3 * np.power(x0, 3) 
        + d3 * np.power(x1, 3) 
        + k2_pos * np.power(x0, 2) 
        + d2_vel * np.power(x1, 2) 
        + frac_damping_coeff * sign_x1 * np.abs(x1)**(5/3)
        
        + mix_x0_x1 * x0 * x1 
        + mix_x0_sq_x1 * np.power(x0, 2) * x1
        
        + mix_x0_x1_sq * x0 * np.power(x1, 2)
        
        + mix_x0_cub_x1_cub * np.power(x0, 3) * np.power(x1, 3)
       )
    
    return y
