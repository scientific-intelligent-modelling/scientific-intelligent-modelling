def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculate acceleration y for nonlinear harmonic oscillator given position (x0) and velocity (x1).

    Parameters:
    - x0 (np.ndarray): Position array
    - x1 (np.ndarray): Velocity array
    - params (np.ndarray): Array of parameters with length at least 12

    Returns:
    - y (np.ndarray): Acceleration array
    """
    # Ensure params length is sufficient
    assert len(params) >= MAX_NPARAMS, f"params must have at least {MAX_NPARAMS} elements"

    # Fractional power damping-like term with sign preservation
    frac_damping = params[9] * np.sign(x1) * np.abs(x1)**(5/3)

    y = (
        params[0]                    # constant offset
        + params[1] * x0             # linear stiffness term
        + params[2] * x1             # linear damping/driving term
        + params[3] * x0**3          # cubic stiffness nonlinearity
        + params[4] * x1**3          # cubic velocity nonlinearity
        + frac_damping               # fractional power damping-like term
        + params[5] * x0 * x1        # mixed linear interaction term
        + params[6] * (x0**2) * x1   # mixed nonlinear interaction term quadratic in position and linear in velocity
        + params[7] * (x0**2)        # quadratic position nonlinearity 
        + params[8] * (x1**2)        # quadratic velocity nonlinearity 
        + params[10] * (x0**3)*x1    # higher order mixed nonlinear term 
        + params[11] * x0*(x1**2)    # another mixed nonlinear term 
    )
    
    return y
