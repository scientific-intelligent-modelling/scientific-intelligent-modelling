def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Calculates acceleration y for a nonlinear harmonic oscillator given position (x0)
    and velocity (x1), using up to cubic nonlinearities and cross terms.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Array of at least 12 trainable coefficients

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    # Ensure params has at least 12 elements
    if len(params) < 12:
        raise ValueError("params must have at least 12 elements")
    
    # Linear terms
    term_const = params[0]
    term_x0 = params[1] * x0
    term_x1 = params[2] * x1
    
    # Quadratic terms
    term_x0_sq = params[3] * x0**2
    term_x1_sq = params[4] * x1**2
    
    # Cubic terms
    term_x0_cu = params[5] * x0**3
    
    # Cross terms between position and velocity
    term_x0_x1 = params[6] * x0 * x1
    term_x0_sq_x1 = params[7] * (x0**2) * x1
    term_x0_x1_sq = params[8] * x0 * (x1**2)
    
    # Higher order or additional nonlinearities if needed
    term_x1_cu = params[9] * x1**3
    
    # Possibly mixed higher order cross terms 
    term_cross_2 = params[10] * (x0**3) * x1
    term_cross_3 = params[11] * x0 * (x1**3)
    
  
    y = (
        term_const + 
        term_x0 + 
        term_x1 + 
        term_x0_sq + 
        term_x1_sq + 
        term_x0_cu +
        term_x0_x1 +
        term_x0_sq_x1 +
        term_x0_x1_sq +
        term_x1_cu +
        term_cross_2 +
        term_cross_3
       )
    
    return y
