        np.ndarray: Acceleration y.
    """
    
    # Ensure params has at least 12 elements to avoid errors
    if len(params) < 12:
        raise ValueError("Parameter array 'params' must have at least 12 elements.")
    
    # Unpack parameters for clarity (optional)
    c0 = params[0]   # constant offset
    c1 = params[1]   # linear stiffness coefficient for position
    c2 = params[2]   # linear damping/driving coefficient for velocity
    c3 = params[3]   # cubic stiffness coefficient for position^3
