    c6 = params[6]   # quadratic term coefficient for position^2
    c7 = params[7]   # another quadratic or mixed term involving position or velocity
    
    c8 = params[8]   # quadratic term coefficient for velocity^2
    
    c9  = params[9]  # fractional power damping-like term coefficient
    
    c10 = params[10] # additional mixed nonlinear term
    
