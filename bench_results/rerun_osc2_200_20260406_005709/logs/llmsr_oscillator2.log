    """
    """
    Improved version of `equation_v0` representing acceleration in a nonlinear harmonic oscillator.
    
    y ≈ params[0] 
        + params[1] * x1           # linear restoring force term (-ω² * position)
        + params[2] * (x1 ** 3)   # nonlinear stiffness term (-α * position³)
        + params[3] * x2           # damping term (-β * velocity)
    
    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    
    Returns:
    - np.ndarray: Calculated acceleration values.
    """
    return (
        params[0]
        + params[1] * x1
        + params[2] * (x1 ** 3)
        + params[3] * x2
    )
