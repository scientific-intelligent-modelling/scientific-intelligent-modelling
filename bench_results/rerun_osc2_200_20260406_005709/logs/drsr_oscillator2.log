def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved equation skeleton for nonlinear harmonic oscillator acceleration.

    This version adds quadratic position term and quadratic velocity term to capture
    additional nonlinearities observed in the data analysis.

    y = p0 
        + p1 * x0 
        + p2 * x1 
        + p3 * x2 
        + p4 * (x1 ** 3)
        + p5 * (x0 * x1)
        + p6 * (x0 * x2)
        + p7 * (x1 ** 2)
        + p8 * (x2 ** 2)

    Parameters:
    - params: array of length >= 9 containing trainable coefficients

    Returns:
    - y: acceleration values as numpy array
    """
    return (
        params[0]                      # constant term
        + params[1] * x0              # linear time effect
        + params[2] * x1              # linear position effect (restoring force)
        + params[3] * x2              # linear velocity effect (damping)
        + params[4] * (x1 ** 3)       # cubic nonlinearity in position
        + params[5] * (x0 * x1)       # interaction between time and position
        + params[6] * (x0 * x2)       # interaction between time and velocity
        + params[7] * (x1 ** 2)       # quadratic nonlinearity in position
        + params[8] * (x2 ** 2)       # quadratic nonlinearity in velocity/damping
    )
