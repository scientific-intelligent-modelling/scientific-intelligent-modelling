================= Evaluated Function =================
def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Nonlinear harmonic oscillator acceleration model with forcing and damping.

    y = p0 
        + p1 * x0 
        + p2 * x1 
        + p3 * (x1 ** 3) 
        + p4 * x2 
        + p5 * (x0 * x1) 
        + p6 * (x0 * x2)

    Parameters:
    - params: array-like coefficients [p0,...p6]
    """
    return (
        params[0] +
        params[1] * x0 +
        params[2] * x1 +
        params[3] * (x1 ** 3) +
        params[4] * x2 +
        params[5] * (x0 * x1) +
        params[6] * (x0 * x2)
    )
