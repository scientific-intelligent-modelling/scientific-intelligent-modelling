def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Mathematical function skeleton representing acceleration y in oscillator2.

    y = p0 
        + p1 * x0 
        + p2 * x1 
        + p3 * x2 
        + p4 * (x1 ** 3)
        + p5 * (x0 * x1)
        + p6 * (x0 * x2)

    Parameters:
    - params: array-like of length >= 7 containing trainable coefficients

    Returns:
    - y: numpy array of acceleration values
    """
    return (
        params[0]                      # constant offset
        + params[1] * x0              # linear time dependence
        + params[2] * x1              # linear restoring force (position)
        + params[3] * x2              # damping force (velocity)
        + params[4] * (x1 ** 3)       # cubic nonlinear stiffness
        + params[5] * (x0 * x1)       # interaction between time and position
        + params[6] * (x0 * x2)       # interaction between time and velocity
    )
