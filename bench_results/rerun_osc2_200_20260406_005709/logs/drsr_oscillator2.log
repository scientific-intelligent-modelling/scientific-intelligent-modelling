def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Models acceleration in a nonlinear harmonic oscillator:
    y''(t) = params[0] 
             + params[1]*x1           # linear position term (-ω² y)
             + params[2]*x2           # linear velocity term (damping)
             + params[3]*x1**3        # cubic nonlinearity
             + params[4]*x2**3        # optional cubic velocity nonlinearity
             + params[5]*x1*x2        # optional cross-term nonlinearity

    Parameters:
    - x0: time t (not explicitly used here but included for completeness)
    - x1: position y(t)
    - x2: velocity dy/dt
    - params: array of coefficients

    Returns:
    - acceleration y''(t)
    """
    
    return (params[0]
            + params[1] * x1
            + params[2] * x2
            + params[3] * x1**3
            + params[4] * x2**3
            + params[5] * x1 * x2)
