def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved equation skeleton for oscillator2 acceleration y.

    y = p0 
        + p1 * x0                 # linear time effect
        + p2 * x1                 # linear position restoring force
        + p3 * x1**3              # cubic nonlinear stiffness
        + p4 * x2                 # linear damping term
        + p5 * (x0 * x1)          # interaction between time and position
        + p6 * (x0 * x2)          # interaction between time and velocity

    Parameters:
    - params: array of at least length 7 trainable coefficients

    Returns:
    - y: acceleration values as numpy array
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * (x1 ** 3)
        + params[4] * x2
        + params[5] * (x0 * x1)
        + params[6] * (x0 * x2)
    )
