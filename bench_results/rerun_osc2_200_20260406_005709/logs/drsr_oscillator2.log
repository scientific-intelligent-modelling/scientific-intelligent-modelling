def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of equation_v0 for nonlinear harmonic oscillator acceleration.

    Calculates acceleration given time (x0), position (x1), and velocity (x2).

    Model form:
        y = params[0]
            + params[1]*x1          # linear restoring force term
            + params[2]*x1**3      # nonlinear restoring force term
            + params[3]*x2         # damping term

    Parameters:
    - x0: time array (not explicitly used here but included for completeness)
    - x1: position array
    - x2: velocity array
    - params: array of parameters [offset, linear_coeff, nonlinear_coeff, damping_coeff]

    Returns:
    - acceleration array
    """
    return (
        params[0]
        + params[1] * x1
        + params[2] * np.power(x1, 3)
        + params[3] * x2
    )
