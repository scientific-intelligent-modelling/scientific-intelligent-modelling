def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved equation for acceleration in nonlinear harmonic oscillator.

    y = p0 + p1*x0 + p2*x1 + p3*x1^3 + p4*x2

    Parameters:
    - params (np.ndarray): coefficients [p0, p1, p2, p3, p4,...]
    """
    return (
        params[0]              # constant offset
        + params[1] * x0       # time-dependent forcing/modulation
        + params[2] * x1       # linear restoring force
        + params[3] * (x1**3)  # cubic nonlinear restoring force
        + params[4] * x2       # damping force proportional to velocity
    )
