================= Evaluated Function =================
def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Nonlinear harmonic oscillator acceleration model:
    y = params[0] 
        + params[1] * x0           # optional time-dependent forcing (can be zero)
        + params[2] * x1           # linear restoring force coefficient (negative)
        + params[3] * (x1 ** 3)   # nonlinear restoring force coefficient (negative)
        + params[4] * x2           # damping coefficient (negative)
    
    Parameters:
    - params: array of coefficients [offset, time_coeff, lin_pos_coeff, cubic_pos_coeff, vel_coeff]
    
    Returns:
    - y: acceleration
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * (x1 ** 3)
        + params[4] * x2
    )
