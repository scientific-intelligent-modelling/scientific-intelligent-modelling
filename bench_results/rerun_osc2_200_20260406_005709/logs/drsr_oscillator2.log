def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Calculates acceleration in a nonlinear harmonic oscillator given time (x0),
    position (x1), and velocity (x2).

    This version includes:
    - linear terms in time, position, velocity
    - nonlinear polynomial terms up to cubic order
    - cross terms between position and velocity
    - possible parametric forcing modulated by time and position

    Parameters:
    - params (np.ndarray): Trainable coefficients [p0,...p9]

    Returns:
    - y (np.ndarray): acceleration
    """
    
    # Linear terms
    lin_term = params[0] + params[1]*x0 + params[2]*x1 + params[3]*x2
    
    # Nonlinear polynomial terms (quadratic and cubic)
    nonlin_term = (
        params[4]*x1**2 +
        params[5]*x2**2 +
        params[6]*x1**3 +
        params[7]*x2**3 +
        params[8]*x1*x2 +
        params[9]*x0*x1
    )
    
    return lin_term + nonlin_term
