def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Models acceleration in a nonlinear harmonic oscillator as a function of time,
    position and velocity including nonlinear terms.
    
    Variables:
    - x0: time t
    - x1: position y(t)
    - x2: velocity dy/dt
    
    Returns:
        Acceleration (second derivative of position).
    
    Parameters:
        params (np.ndarray): array of parameters [a,b,c,d,e,f,g,h,...]
                             length at least 10.
    """
    # Linear terms
    linear_part = (
        params[0]  # constant term
        + params[1] * x0  # linear in time
        + params[2] * x1  # linear in position
        + params[3] * x2  # linear in velocity
    )
    
    # Nonlinear terms (up to cubic)
    nonlinear_part = (
        params[4] * (x1 ** 3)   # cubic in position
        + params[5] * (x1 ** 2) # quadratic in position
        + params[6] * (x2 ** 2) # quadratic in velocity
        + params[7] * (x1 * x2) # product term
        + params[8] * np.sin(x0)  # possible forcing term depending on time nonlinearly
        + params[9] * np.cos(x0)
    )
    
    return linear_part + nonlinear_part
