      params[5] : quadratic temperature coefficient
      params[6] : exponential decay multiplier for thermal softening on stiffness times strain
      params[7] : exponential decay rate w.r.t. temperature
      params[8] : logarithmic strain hardening coefficient
      params[9] : inverse temperature stiffening coefficient (scale)
     params[10] : tanh amplitude parameter (strain saturation)
     params[11] : tanh argument scale parameter (strain saturation)

