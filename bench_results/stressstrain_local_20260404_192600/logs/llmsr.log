    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements over v1:
    - Added tanh(strain) term to model saturation/hardening at large strains.
    - Added exp(-temperature) term to model softening or recovery at high temp.
    - Added interaction term strain^2 * temperature for nonlinear coupling.
    - Removed cubic temp^3 term (params[7]) to keep param count within 12,
      replaced with tanh and exp terms for better physical interpretability.

    Parameters mapping (length=12):
        p[0] : constant offset
        p[1] : linear strain
        p[2] : linear temp
        p[3] : interaction strain*temp
        p[4] : quadratic strain^2
        p[5] : quadratic temp^2
        p[6] : cubic strain^3
        p[7] : log(strain)
        p[8] : reciprocal temp (1/temp)
        p[9] : exp(-strain)
        p[10]: rational coupling term (strain / temp)
        p[11]: tanh(strain) + exp(-temp) + strain^2 * temp combined as weighted sum

    Note: To keep the number of parameters fixed at 12, we combine multiple nonlinear terms into one param with a weighted sum inside.

    """
    
    eps = 1e-8
    
    safe_x0 = np.maximum(x0, eps)
    safe_x1 = np.maximum(x1, eps)
    
    # Nonlinear combined term:
    # Weights inside this combined term are fixed constants chosen heuristically.
    combined_nonlinear = (
          np.tanh(safe_x0)                # saturation/hardening effect in strain
        + np.exp(-safe_x1)               # softening/recovery effect in temperature
        + safe_x0**2 * safe_x1          # nonlinear interaction term 
    )
    
    y = (
          params[0]
        
        + params[1] * safe_x0                       # linear strain
        
        + params[2] * safe_x1                       # linear temp
        
        + params[3] * safe_x0 * safe_x1             # interaction
        
        + params[4] * safe_x0**2                    # quadratic strain
        
        + params[5] * safe_x1**2                    # quadratic temp
        
        + params[6] * safe_x0**3                    # cubic strain
        
        + params[7] * np.log(safe_x0)               # logarithmic strain
        
        + params[8] / safe_x1                        # reciprocal temperature
        
        + params[9]* np.exp(-safe_x0)               # exponential decay in strain
        
        + params[10]* (safe_x0 / safe_x1)           # rational coupling term

        + params[11]* combined_nonlinear             # combined nonlinear effects
       )
    
    return y
