        + p7/(x1 + eps) 
        + p8 * exp(-p9 * x1)   # exponential decay with temperature
        + p10 * log(|x0| + eps)  # logarithmic strain effect
        + p11 * x0**2 * x1      # higher order interaction

    where
    x0 = Strain
    x1 = Temperature
