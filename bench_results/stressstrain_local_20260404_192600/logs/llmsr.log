def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends primarily on strain (Hooke's law) with a temperature-dependent modulus.
    - Temperature typically reduces the effective stiffness exponentially or linearly.
    - Include nonlinear strain terms and temperature effects to capture softening.
    - Use an exponential decay term to model stiffness reduction with temperature.

    Model form:
    y = (p0 + p1*x0 + p2*x0^2) * exp(-p3 * x1) + p4*x1 + p5*x1^2

    where
    x0 = Strain
    x1 = Temperature
    y = Stress

    Parameters:
        params[0]: base linear stiffness coefficient
        params[1]: quadratic strain coefficient
        params[2]: constant offset in strain terms
        params[3]: temperature decay rate of stiffness
        params[4]: linear temperature offset term
        params[5]: quadratic temperature offset term
    """
    
    strain_term = params[0] * x0 + params[1] * x0**2 + params[2]
    temp_decay = np.exp(-params[3] * x1)
    
    temp_offset = params[4] * x1 + params[5] * x1**2
    
    return strain_term * temp_decay + temp_offset
