        + params[8] * (x0**2) * temp_safe          # interaction quadratic*linear 
        + params[9] * x0 * (temp_safe**2)          # interaction linear*quadratic 
        + params[10] / temp_safe                    # inverse temp dependence 
        + params[11] * np.exp(-temp_safe)          # exp(-temp) thermal softening 
       )
