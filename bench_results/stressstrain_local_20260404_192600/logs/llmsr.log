def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Physical reasoning:
    - Stress generally depends linearly on strain (Hooke's law) for small strains.
    - Temperature affects material properties, often reducing stiffness as temperature increases.
    - Include interaction term between strain and temperature to capture coupling effects.
    - Add quadratic terms to allow some nonlinearity.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length at least 9 for this model.
      params[0]: intercept
      params[1]: linear strain coefficient
      params[2]: linear temperature coefficient
      params[3]: strain * temperature interaction coefficient
      params[4]: quadratic strain coefficient
      params[5]: quadratic temperature coefficient
      params[6]: cubic strain coefficient (optional)
      params[7]: cubic temperature coefficient (optional)
      params[8]: higher order interaction or offset term (optional)
    """
    
    # Linear terms
    linear = params[0] + params[1]*x0 + params[2]*x1
    
    # Interaction term between strain and temperature
    interaction = params[3] * x0 * x1
    
    # Quadratic terms to capture nonlinearity in strain and temperature effects
    quad = params[4] * x0**2 + params[5] * x1**2
    
    # Optional cubic terms for more flexibility (can be zero if not needed)
    cubic = 0.0
    if len(params) > 6:
        cubic += params[6] * x0**3
        cubic += params[7] * x1**3
    
    # Optional higher order or offset term if provided
    extra = 0.0
    if len(params) > 8:
        extra += params[8]
    
    return linear + interaction + quad + cubic + extra
