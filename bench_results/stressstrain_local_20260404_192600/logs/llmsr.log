def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements over v1:
    - Add inverse temperature stiffening/softening term.
    - Include quadratic strain-temperature interaction term.
    - Refine softening factor to better capture combined effects.
    - Keep all terms within 12 parameters limit.

    Parameters usage (12 total):
      params[0]  : constant offset
      params[1]  : linear strain coefficient
      params[2]  : linear temperature coefficient
      params[3]  : linear strain-temperature interaction coefficient
      params[4]  : quadratic strain coefficient
      params[5]  : tanh scale for saturation effects
      params[6]  : cubic tanh multiplier (nonlinear saturation)
      params[7]  : exponential softening multiplier
      params[8]  : exponential decay rate w.r.t. temperature and strain squared
      params[9]  : log(1 + x0^2) multiplier (nonlinear smooth growth)
      params[10] : interaction multiplier for cubic tanh * sqrt(temp)
      params[11] : inverse temperature multiplier (stiffening/softening)
    """
    
    epsilon = 1e-6
    
    # Linear term modulated by temperature-dependent modulus decay:
    linear_modulated = (
        params[0]
        + params[1] * np.exp(-np.abs(params[8]) * x1) * x0
        + params[2] * x1
        + params[3] * x0 * x1
    )
    
    # Nonlinear strain terms with smooth saturation via tanh for cubic term:
    nonlinear_strain = (
          params[4] * x0 ** 2
        + params[6] * np.tanh(params[5] * x0) ** 3
        + params[9] * np.log(1.0 + x0 ** 2)
        + # Quadratic strain-temperature interaction reused here by multiplying param4 and param3:
          (params[4]*params[3]) * (x0**2) * x1  
        # Exponential softening on combined temp and strain squared:
        +
        params[7]
            *
            np.exp(
                -np.abs(params[8])*(x1+epsilon)
                -np.abs(params[8])*(x0**2)
            )
            *
            x0
    )
    
    # Softening factor depends on both temperature and absolute strain magnitude:
    softening_factor = 1. / (1. + np.abs(params[8])*(np.abs(x1)+np.abs(x0)+epsilon))
    
    # Interaction term: cubic tanh(strain) times sqrt(temperature):
    interaction = (
          params[10]
          *
          (np.tanh(params[5]*x0))**3
          *
          np.sqrt(np.abs(x1)+epsilon)
      )
    
    # Inverse temperature effect capturing stiffening or softening at low temperatures:
    inv_temp_effect = -params[11]/(x1 + epsilon)
    
    y = linear_modulated + softening_factor*nonlinear_strain + interaction + inv_temp_effect
    
    return y
