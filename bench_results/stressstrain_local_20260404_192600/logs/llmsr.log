        + extended_params[9]  *(x0)*(x1**2)
        + extended_params[10]   * inv_temp
        + extended_params[11]   *(x0)*inv_temp
        + extended_params[12]   *(np.log(safe_strain))
        + extended_params[13]   *(exp_decay)
        + extended_params[14]   *(np.log(safe_strain)*inv_temp)

