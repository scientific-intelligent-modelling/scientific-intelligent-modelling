def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of equation_v1 with strain saturation and inverse temperature softening.

    Physical reasoning:
    - Stress depends nonlinearly on strain (x0) and temperature (x1).
    - Thermal softening modeled by exponential decay multiplied by strain.
    - Strain saturation modeled by tanh function.
    - Inverse temperature softening to capture stiffening at low temperatures.
    - Smooth nonlinear terms to avoid singularities.

    Parameters usage:
      params[0]  : constant offset
      params[1]  : linear strain coefficient
      params[2]  : linear temperature coefficient
      params[3]  : strain-temperature interaction linear term
      params[4]  : quadratic strain term
      params[5]  : quadratic temperature term
      params[6]  : cubic strain term
      params[7]  : inverse temperature softening coefficient (used here)
      params[8]  : exponential decay rate w.r.t. temperature (also used in exp decay)
      params[9]  : tanh coefficient for strain saturation effect
      params[10] : sqrt(abs(temperature)) sublinear temp effect
      params[11] : quadratic strain * temperature interaction

    """
    
    epsilon = 1e-6
    
    return (
        params[0]
        + params[1]*x0
        + params[2]*x1
        + params[3]*x0*x1
        + params[4]*x0**2
        + params[5]*x1**2
        + params[6]*x0**3
        
        # Thermal softening exponential decay on stiffness times strain:
        + np.exp(-params[8]*x1)*params[7]*x0
        
        # Strain saturation nonlinear effect via tanh:
        + params[9]*np.tanh(params[9]*x0)
        
        # Sublinear temp effect remains unchanged:
        + params[10]*np.sqrt(np.abs(x1))
        
        # Quadratic strain-temperature interaction remains unchanged:
        + params[11]*(x0**2)*x1
        
        # Inverse temperature softening (stiffness increase at low temp):
        - abs(params[7])/(x1 + epsilon)   # use absolute value to ensure physical sign; subtracting since it's a softening correction
        
    )
