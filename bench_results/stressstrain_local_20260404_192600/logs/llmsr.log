        + params[9] * (x0 ** 3)                       # higher order nonlinearity in strain 
        + params[10] * np.log(x1 + eps)               # logarithmic temp effect 
        + params[11] / (x1 + eps)                      # inverse temp effect capturing softening or phase change effects 
