def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain and temperature with nonlinearities and interactions.
    - Include inverse temperature terms to capture Arrhenius-type or softening effects.
    - Include logarithmic and exponential terms to capture complex material behavior.
    - Use absolute value in some nonlinear terms to ensure physical meaningfulness.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params (np.ndarray): Trainable coefficients (length 12)

    Model form:
        y = p0 
            + p1 * strain 
            + p2 * temperature 
            + p3 * strain * temperature 
            + p4 * strain^2 
            + p5 * temperature^2 
            + p6 * strain^2 / (temperature + epsilon)
            + p7 * strain / (temperature^2 + epsilon)
            + p8 * strain^3
            + p9 * log(1 + abs(strain))
            + p10 * exp(-strain)
            + p11 * exp(-temperature)
    
    This form adds inverse temperature dependence in mixed terms and a logarithmic term on strain,
    capturing more complex stress-strain-temperature relationships.
    """
    
    epsilon = 1e-8  # small number to avoid division by zero or log(0)
    
    p = params
    
    term_linear = p[1] * x0 + p[2] * x1
    term_interaction = p[3] * x0 * x1
    term_quadratic = p[4] * x0**2 + p[5] * x1**2
    
    # Inverse temperature dependent mixed terms
    term_mixed_inv_temp = (
        p[6] * (x0**2) / (x1 + epsilon) +
        p[7] * x0 / (x1**2 + epsilon)
    )
    
    term_cubic = p[8] * x0**3
    term_log_strain = p[9] * np.log(1.0 + np.abs(x0) + epsilon)
    
    term_exp = (
        p[10] * np.exp(-x0) +
        p[11] * np.exp(-x1)
    )
    
    y = (
        p[0]
        + term_linear
        + term_interaction
        + term_quadratic
        + term_mixed_inv_temp
        + term_cubic
        + term_log_strain
        + term_exp
    )
    
    return y
