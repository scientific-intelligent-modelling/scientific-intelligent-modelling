def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retain all terms from v1.
    - Add rational coupling term: strain / temperature.
    - Add logarithmic temperature term to capture possible log-dependence on temp.
    - To keep params length fixed at 12, replace p5 (quadratic temp) with log(temp),
      and add rational term using p9 (previously exp(temp)).

    Variables:
    - x0: Strain (assumed > 0 for log and exp)
    - x1: Temperature (assumed > 0 for reciprocal and exp)

    Parameters:
    - params: array of coefficients (length 12)
      p[0] ... p[11]

      Mapping:
        p0 : constant
        p1 : linear strain
        p2 : linear temp
        p3 : interaction strain*temp
        p4 : quadratic strain^2
        p5 : replaced with log(temperature)
        p6 : quadratic strain^2 * temp
        p7 : strain * temp^2
        p8 : exp(-strain)
        p9 : rational coupling strain/temperature   <-- new usage here replacing exp(temp)
        p10: log(strain)
        p11: 1/temperature

    Note:
      Small epsilon added to avoid domain errors in log/division.
    """
    
    # Unpack parameters for clarity
    p = params
    
    eps = 1e-8
    
    safe_x0 = np.maximum(x0, eps)
    safe_x1 = np.maximum(x1, eps)
    
    y = (
        p[0]
        + p[1] * safe_x0                          # linear strain
        + p[2] * safe_x1                          # linear temp
        
        + p[3] * safe_x0 * safe_x1                # interaction
        
        + p[4] * safe_x0**2                       # quadratic strain
        
        + p[5] * np.log(safe_x1)                  # logarithmic temperature replacing quadratic temp
        
        + p[6] * (safe_x0**2) * safe_x1           # quadratic strain^2 * temp
        
        + p[7] * safe_x0 * (safe_x1**2)           # strain * temp^2
        
        + p[8] * np.exp(-safe_x0)                  # exponential decay with strain
        
        + p[9] * (safe_x0 / safe_x1)               # rational coupling term
        
        + p[10] * np.log(safe_x0)                   # logarithmic strain
        
        + p[11] / safe_x1                           # reciprocal temperature
        
       )
    
    return y
