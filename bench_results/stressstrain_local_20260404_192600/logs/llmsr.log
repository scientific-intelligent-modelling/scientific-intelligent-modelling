def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements over v1:
    - Add inverse temperature term to capture Arrhenius-type behavior.
    - Include additional nonlinear cross terms between strain and temperature.
    - Retain exponential decay softening and saturation effects.
    
    Model form:

        linear_modulated = p0 
                         + p1 * exp(-|p8| * x1) * x0 
                         + p2 * x1 
                         + p3 * x0 * x1

        nonlinear_strain = p4 * x0**2
                         + p6 * tanh(p5 * x0)**3
                         + p9 * log(1 + x0**2)
                         + p11 * (x0**2) * x1
                         + p7 * exp(-|p8|*(x1+x0**2)) * x0

        softening_factor = 1 / (1 + |p8|*(|x1|+|x0|+epsilon))

        interaction = p10 * (tanh(p5*x0))**3 * sqrt(|x1|+epsilon)

        inverse_temp_term = p12 / (p13 + x1)  # but we only have 12 params, so reuse param[11] cleverly

    Since MAX_NPARAMS=12, we merge inverse_temp_term into param[11] with a smooth approximation.

    Final y:

        y = linear_modulated 
            + softening_factor*nonlinear_strain 
            + interaction
            + param[11] / (epsilon + x1)
    
    """
    
    epsilon = 1e-6
    
    abs_p8 = np.abs(params[8])
    
    # Linear term modulated by temperature-dependent modulus decay
    linear_modulated = (
        params[0]
        + params[1] * np.exp(-abs_p8 * x1) * x0
        + params[2] * x1
        + params[3] * x0 * x1
    )
    
    # Nonlinear strain terms with smooth saturation via tanh for cubic term,
    # plus exponential softening on strain squared modulated by temperature using param7:
    nonlinear_strain = (
          params[4] * (x0 ** 2)
        + params[6] * np.tanh(params[5] * x0) ** 3
        + params[9] * np.log(1.0 + x0 ** 2)
        + params[11] * (x0 ** 2) * x1
        +
          params[7]
          *
          np.exp(
              -abs_p8*(x1+epsilon)
              -abs_p8*(x0**2)
          )
          *
          x0
    )
    
    # Softening factor depends on both temperature and absolute strain magnitude to better capture material behavior
    softening_factor = 1. / (1. + abs_p8*(np.abs(x1)+np.abs(x0)+epsilon))
    
    # Interaction term: cubic tanh(strain) times sqrt(temperature)
    interaction = (
          params[10]
          *
          (np.tanh(params[5]*x0))**3
          *
          np.sqrt(np.abs(x1)+epsilon)
      )
    
    # Inverse temperature effect approximated with param11 reused as coefficient:
    inverse_temp_term = params[11] / (epsilon + x1)
    
    y = linear_modulated \
      + softening_factor*nonlinear_strain \
      + interaction \
      + inverse_temp_term
    
    return y
