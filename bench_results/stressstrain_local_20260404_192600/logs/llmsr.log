        + p13 * (1 / (1 + exp(-p14*(x1 - p15))))  # sigmoid temp-dependent modulus shift
        + p16 * log(|x0|+eps) / (x1+eps)     # coupling log-strain and inverse temp
        + p17 * x0**2 * x1                   # additional interaction term

    Parameters:
    - params: array of length 18 containing coefficients [p0,...,p17]
    
    Variables:
    - x0: Strain
    - x1: Temperature
