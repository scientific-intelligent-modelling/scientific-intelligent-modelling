def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress-strain relationship includes linear, quadratic, cubic terms and their interactions with temperature.
    - Reciprocal strain term captures singularity near zero strain (e.g., initial yielding).
    - Logarithmic terms in strain and temperature capture hardening/softening and complex temp effects.
    - Exponential decay in temperature models thermal softening or activation energy effects.

    Variables:
    - x0: Strain (assumed > 0)
    - x1: Temperature (assumed > 0)

    Parameters:
    - params: array of coefficients (length = MAX_NPARAMS=12)

      Model form:

        y = p0 
            + p1 * strain 
            + p2 * temperature 
            + p3 * strain * temperature 
            + p4 * strain^2 
            + p5 * temperature^2
            + p6 * strain^2 * temperature
            + p7 * strain * temperature^2
            + p8 * strain^3
            + p9 / strain
            + p10 * log(strain)
            + p11 * exp(-temperature)
    
      Small epsilon added where needed to avoid domain errors.
    """
    
    eps = 1e-8  # small number to avoid log(0), division by zero
    
    safe_x0 = np.maximum(x0, eps)
    safe_x1 = np.maximum(x1, eps)
    
    p = params
    
    y = (
        p[0]
        + p[1] * safe_x0
        + p[2] * safe_x1
        + p[3] * safe_x0 * safe_x1
        + p[4] * safe_x0**2
        + p[5] * safe_x1**2
        + p[6] * (safe_x0**2) * safe_x1
        + p[7] * safe_x0 * (safe_x1**2)
        + p[8] * safe_x0**3
        
        # Reciprocal strain term captures singular behavior near zero strain        
        + p[9] / safe_x0
        
        # Logarithmic term for hardening/softening effects        
