def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation_v1.

    Physical reasoning:
    - Retain all terms from v1.
    - Add dedicated nonlinear saturation/hardening term in strain via tanh with new params.
    - Add inverse squared temperature term explicitly for thermal softening.
    - Add interaction between quadratic strain and linear temperature term.
    - Use shifted log of strain to handle small strains safely.
    
    Parameters:
        params: array-like with length 14
            p0 ... p13 coefficients

    Variables:
        x0 = strain
        x1 = temperature (°C)
        y = stress
    """

    # Numerical stability
    strain_offset = 1e-3  # small offset to avoid log(0)
    strain_safe = np.clip(x0, 1e-6, None) + strain_offset
    temp_kelvin = x1 + 273.15

    # Base linear/quadratic/exponential terms
    base = (
        params[0]                                  # intercept/base stress
        + params[1] * x0                          # linear in strain
        + params[2] * x1                          # linear in temperature
        + params[3] * x0 * x1                     # interaction term
        + params[4] * x0 ** 2                     # quadratic in strain
        + params[5] * x1 ** 2                     # quadratic in temperature
        + params[6] * np.exp(params[7] * x1) * x0   # exp temp effect on stiffness modulated by temp
        + params[8] / temp_kelvin * x0            # inverse linear temp effect on stiffness (thermal softening)
        + params[9] / (temp_kelvin ** 2)          # inverse squared temp effect on stress (thermal softening)
        + params[10] * np.sinh(x1)                # asymmetric thermal effect via sinh(temp)
        + params[11] * np.log(strain_safe)         # shifted log of strain for small-strain behavior
    )

    # Additional nonlinear/coupling terms:
    
    cubic_strain_term = 0.5 * params[4] * x0**3           # cubic term scaled from quadratic coefficient
    
