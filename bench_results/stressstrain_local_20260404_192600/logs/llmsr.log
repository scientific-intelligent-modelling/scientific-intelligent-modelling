def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Physical reasoning:
    - Stress typically depends linearly on strain (Hooke's law) for small strains.
    - Temperature affects material properties, often reducing stiffness as temperature increases.
    - Interaction terms and nonlinearities can capture more complex behavior.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params (np.ndarray): Trainable coefficients (length 12)
    
    Model form:
        y = p0 
            + p1 * strain 
            + p2 * temperature 
            + p3 * strain * temperature 
            + p4 * strain^2 
            + p5 * temperature^2 
            + p6 * strain^2 * temperature 
            + p7 * strain * temperature^2
            + p8 * strain^3
            + p9 * temperature^3
            + p10 * exp(-strain)
            + p11 * exp(-temperature)
    
    This form allows capturing linear, quadratic, cubic and some nonlinear exponential effects.
    """
    
    # Unpack parameters for clarity
    p = params
    
    term_linear = p[1] * x0 + p[2] * x1
    term_interaction = p[3] * x0 * x1
    term_quadratic = p[4] * x0**2 + p[5] * x1**2
    term_mixed_quad = p[6] * (x0**2) * x1 + p[7] * x0*(x1**2)
    term_cubic = p[8] * x0**3 + p[9] * x1**3
    term_exp = p[10]*np.exp(-x0) + p[11]*np.exp(-x1)
    
    y = (
        p[0]
        + term_linear
        + term_interaction
        + term_quadratic
        + term_mixed_quad
        + term_cubic
        + term_exp
    )
    
    return y
