def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain linearly at small strains (Hooke's law).
    - Temperature affects stiffness, often reducing it as temperature increases.
    - Nonlinearities in both variables are important at larger strains or temperatures.
    - Interaction terms capture coupling effects between strain and temperature.
    - Exponential term models thermal softening/hardening effects.
    - Logarithmic term captures behavior near zero strain avoiding singularity.
    - Saturation effect models limits on stress changes due to temperature extremes.
    - Cubic terms model higher order nonlinearities in strain and temperature.

    Parameters:
        params: array-like with length 12
            p0: constant offset
            p1: linear strain
            p2: linear temp
            p3: quadratic strain
            p4: quadratic temp
            p5: interaction linear*linear
            p6: exponential modulation coefficient for temp*strain
            p7: exponent coefficient inside exp()
            p8: log(strain) coefficient
            p9: saturation amplitude for tanh(temp)
            p10: saturation steepness inside tanh()
            p11: cubic strain coefficient

    Returns:
        y (np.ndarray): predicted stress values
    """
    # Unpack parameters for clarity
    p = params

    # To avoid log(0), add a small epsilon inside log argument; also handle sign of x0 properly if needed
    eps = 1e-8

    # Compute each term separately for clarity:
    
    constant = p[0]
    
    linear_strain = p[1] * x0
    
    linear_temp = p[2] * x1
    
    quad_strain = p[3] * x0**2
    
    quad_temp = p[4] * x1**2
    
    interaction_linear = p[5] * x0 * x1
    
    exp_modulation = p[6] * np.exp(p[7]*x1) * x0
    
    log_strain = 0.0
    # Only compute log where |x0| > eps to avoid numerical issues; else zero contribution 
    mask = np.abs(x0) > eps
    if np.any(mask):
        log_strain_arr = np.zeros_like(x0)
        log_strain_arr[mask] = np.log(np.abs(x0[mask]) + eps)
        log_strain = p[8] * log_strain_arr
    
    saturation_temp = p[9] * np.tanh(p[10]*x1)
    
    cubic_strain = p[11] * x0**3

    
    y = (constant + linear_strain + linear_temp + quad_strain + quad_temp +
         interaction_linear + exp_modulation + log_strain +
         saturation_temp + cubic_strain)

    
    return y
