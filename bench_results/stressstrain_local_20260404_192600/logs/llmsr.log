        p[4] : quadratic strain^2
        p[5] : quadratic temp^2
        p[6] : cubic strain^3
        p[7] : cubic temp^3
        p[8] : log(strain)
        p[9] : reciprocal temp (1/temp)
        p[10]: exp(-strain)
        p[11]: rational coupling term (strain / temp)

      To incorporate new terms without increasing param count,
      we reuse parameters with combined terms.

      Note: eps added to avoid domain errors.
    """
    
    eps = 1e-8
    
    safe_x0 = np.maximum(x0, eps)
    safe_x1 = np.maximum(x1, eps)

    # Base polynomial + log + reciprocal + exp + rational coupling from v1
    base = (
          params[0]
        
        + params[1] * safe_x0                       # linear strain
        
        + params[2] * safe_x1                       # linear temp
        
        + params[3] * safe_x0 * safe_x1             # interaction
        
        + params[4] * safe_x0**2                    # quadratic strain
        
        + params[5] * safe_x1**2                    # quadratic temp
        
