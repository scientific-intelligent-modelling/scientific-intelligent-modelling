    y = (params[0]
         + linear_strain 
         + linear_temp 
         + quad_strain 
         + quad_temp 
         + interaction 
         + exp_strain 
         + log_strain 
         + arrhenius_temp 
         + tanh_strain)

    
    if len(params) > 12:
        # Inverse strain term to capture softening/damage at low strains,
        inv_strain_term = 0. if np.any(np.abs(x0) < eps) else  \
