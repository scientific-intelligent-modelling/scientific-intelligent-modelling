def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain with polynomial terms up to cubic order.
    - Temperature affects stress with polynomial terms up to cubic order.
    - Interaction terms between strain and temperature capture coupling effects.
    - Inverse absolute temperature term models softening at high temperatures.
    - Exponential decay term models thermal softening or relaxation effects,
      modulated by strain to capture coupling.
    - Additional interaction terms involving inverse temperature and powers of strain
      model complex thermo-mechanical behavior.
    
    Variables:
        x0: Strain (dimensionless)
        x1: Temperature in Celsius
        y : Stress
    
    Parameters (length >= 12):
        params[0]: intercept (baseline stress)
        params[1]: linear strain coefficient
        params[2]: linear temperature coefficient
        params[3]: quadratic strain coefficient (strain^2)
        params[4]: quadratic temperature coefficient (temperature^2)
        params[5]: strain * temperature interaction
        params[6]: cubic strain coefficient (strain^3)
        params[7]: cubic temperature coefficient (temperature^3)
        params[8]: strain^2 * temperature interaction
        params[9]: strain * temperature^2 interaction
        params[10]: inverse absolute temperature coefficient (1 / T_kelvin)
        params[11]: exponential decay rate for temp-dependent softening

    Returns:
        y: Calculated stress as numpy array.
    """
    
    T_kelvin = x1 + 273.15  # Convert Celsius to Kelvin
    
    exp_decay = np.exp(-params[11] * x1)  # Thermal softening exponential decay
    
    inv_T = 1.0 / T_kelvin
    
    # Base polynomial + interactions
    base = (
          params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[6] * x0**3
        + params[7] * x1**3
        + params[8] * (x0**2) * x1
        + params[9] * x0 * (x1**2)
    )
    
    # Inverse absolute temp effect plus interactions with strain powers 
    inv_temp_effect = (
          params[10] * inv_T 
        + inv_T * (params[5]*x0)            # reuse p5 for inverse temp*strain coupling 
        + inv_T * (params[8]*x0**2)         # inverse temp*strain^2 coupling 
    )
    
    # Exponential thermal softening modulated by linear and quadratic strain-temp interactions 
    exp_softening = exp_decay * (
          params[5]*x0                      # linear term modulated by exp decay 
       + params[8]*(x0**2)                 # quadratic term modulated by exp decay 
       )
    
    y = base + inv_temp_effect + exp_softening
    
    return y
