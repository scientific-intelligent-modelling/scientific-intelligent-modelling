        + params[8] / temp_kelvin * x0            # inverse linear temp effect on stiffness (thermal softening)
        + params[9] * np.tanh(params[10] * x0)   # nonlinear saturation/hardening in strain response
        + params[11] * np.log(strain_safe)         # shifted log of strain for small-strain behavior

