def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retain all terms from v1.
    - Add cubic strain term (x0**3) to capture higher order strain hardening.
    - Add inverse squared temperature term (1/(T^2)) for stronger thermal softening at low temperatures.
    - Use shifted logarithm of strain (log(x0 + offset)) to avoid singularity at zero strain.
    - Include interaction between x0^2 and x1 for coupling effects.
    - Add cubic temperature term (x1**3) for nonlinear thermal effects.
    - Add interaction between cubic strain and quadratic temperature (x0**3 * x1**2).

    Parameters:
    - params: array-like with length 12
      p0 ... p11 coefficients

    Model:

        y = p0 
          + p1*x0 
          + p2*x1 
          + p3*x0*x1 
          + p4*x0**2 
          + p5*x1**2 
          + p6*np.exp(p7 * x1) * x0  
          + p8 / temp_kelvin * x0  
          + p9*np.tanh(p10 * x0)
          + p11*np.log(strain_safe)
          + 0.5*p4*x0**3                      # cubic strain term scaled from quadratic param
          - 0.3*p5/(temp_kelvin**2)           # inverse squared temp effect
          + 0.25*p3*x0**2*x1                  # interaction quadratic strain & temp
          + 0.15*p5*x1**3                     # cubic temp effect scaled from quadratic param
          - 0.10*p4*x0**3 * x1**2             # interaction cubic strain & squared temp

    """

    # Numerical stability
    strain_offset = 1e-3  # small offset to avoid log(0)
    strain_safe = np.clip(x0, 1e-6, None) + strain_offset
    temp_kelvin = x1 + 273.15

    return (
        params[0]                                  # intercept/base stress
        + params[1] * x0                          # linear in strain
        + params[2] * x1                          # linear in temperature
        + params[3] * x0 * x1                     # interaction term
