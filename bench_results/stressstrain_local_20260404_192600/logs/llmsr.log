def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress-strain relationship includes linear and nonlinear strain terms (strain hardening).
    - Temperature affects stiffness/modulus exponentially (thermal softening).
    - Interaction terms between strain and temperature capture coupling effects.
    - Additional nonlinearities via tanh (saturation) and logarithmic strain for small strains.
    - Inverse temperature term models Arrhenius-type thermal activation.
    
    Model structure:
    y = p0 
        + p1*x0 
        + p2*x1 
        + p3*x0*x1 
        + p4*x0**2 
        + p5*x1**2 
        + p6*np.exp(p7 * x1) * x0
        + p8 / (x1 + 273.15) * x0
        + p9*np.tanh(p10 * x0)
        + p11*np.log(x0_clip)
        + p12*(x0**3)
        + p13*(x0**2)*x1

    where
    x0 = strain,
    x1 = temperature in °C,
    y = stress
    """

    # Clip strain to avoid log(0) or negative values inside log
    strain_safe = np.clip(x0, 1e-6, None)
    
    # Convert temperature to Kelvin for inverse temp term to avoid division by zero
    temp_kelvin = x1 + 273.15
    
    # Calculate each term explicitly for clarity
    linear_strain = params[1] * x0
    linear_temp = params[2] * x1
    interaction = params[3] * x0 * x1
    strain_sq = params[4] * (x0 ** 2)
    temp_sq = params[5] * (x1 ** 2)
    
    exp_modulus_term = params[6] * np.exp(params[7] * x1) * x0
    
    inverse_temp_term = params[8] / temp_kelvin * x0
    
    tanh_strain_term = params[9] * np.tanh(params[10] * x0)
    
    log_strain_term = params[11] * np.log(strain_safe)
    
    cubic_strain_term = 0 if len(params) < 13 else params[12] * (x0 ** 3)
    
    quadratic_strain_temp_interaction_term = 0 if len(params) < 14 else params[13] * (x0 ** 2) * x1
    
  
    return (params[0]
            + linear_strain
            + linear_temp
            + interaction
            + strain_sq
            + temp_sq
            + exp_modulus_term
            + inverse_temp_term
            + tanh_strain_term
            + log_strain_term
            + cubic_strain_term
            + quadratic_strain_temp_interaction_term)
