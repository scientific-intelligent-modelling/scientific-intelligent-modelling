        # To keep it simple, multiply param7 with exp(-param8*x1)*exp(-param8*x0^2)
        # This captures combined softening effect at high strains and temperatures.
        +
        params[7] *
            np.exp(
                -np.abs(params[8])*(x1+epsilon)
                -np.abs(params[8])*(x0**2)
