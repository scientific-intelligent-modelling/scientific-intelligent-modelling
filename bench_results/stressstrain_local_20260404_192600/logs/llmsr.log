    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements over v1:
    - Explicit exponential modulus softening factor with temperature.
    - Additional cross terms between strain powers and temperature powers.
    - Refined interaction term using tanh for smooth saturation in strain.
    - Added logarithmic temperature dependence for subtle thermal effects.
    
    Model form:

    # Linear terms
    linear = p0 + p1*x0 + p2*x1 + p3*x0*x1

    # Modulus softening factor (exponential decay with temperature)
    softening = exp(-p8 * x1)

    # Nonlinear strain terms modulated by softening
    nonlinear_strain = (
          p4 * x0**2
        + p6 * x0**3
        + p11 * (x0**2) * x1
        + p5 * (np.tanh(p10 * x0))**3  # smooth cubic saturation in strain
        + p9 * np.log(1. + x0**2)
        + p7 * np.sqrt(np.abs(x1)+1e-6)  # sqrt temp effect on nonlinearities
        + p12 * (x0**3) * np.log(1. + x1+1e-6)  # cross term cubic strain & log temp
    )

    # Interaction term between tanh-strain^3 and sqrt-temperature 
    interaction = params[10] * (np.tanh(params[5]*x0))**3 * np.sqrt(np.abs(x1)+1e-6)

    y = linear + softening*nonlinear_strain + interaction

    Note: params array length should be at least 13 for this model.

    """
    
    # Unpack parameters for clarity (assuming params length >=13)
    p0, p1, p2, p3, p4, p5, p6, p7, p8, p9, p10, _, p12 = params[:13]

    linear = (
        p0 
        + p1 * x0 
        + p2 * x1 
        + p3 * x0 * x1
    )
    
    softening = np.exp(-p8 * x1)
    
    nonlinear_strain = (
          p4 * x0 ** 2
        + p6 * x0 ** 3
        + (p11 if len(params)>11 else 0.)*(x0 ** 2) * x1   # safe fallback if param missing
        + p5 * (np.tanh(p10 * x0)) ** 3  
        + p9 * np.log(1. + x0 ** 2)
        + p7 * np.sqrt(np.abs(x1)+1e-6)
        + p12*(x0 ** 3)*np.log(1. + x1+1e-6)
        
    )
    
    interaction = params[10] * (np.tanh(params[5]*x0))**3*np.sqrt(np.abs(x1)+1e-6)

    
    y = linear + softening*nonlinear_strain + interaction
    
