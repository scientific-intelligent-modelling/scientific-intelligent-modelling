def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain linearly, quadratically, cubically.
    - Temperature affects stress polynomially (linear, quadratic, cubic).
    - Interaction terms between strain and temperature capture coupling effects.
    - Inverse absolute temperature (Kelvin) terms model thermal softening at high temperatures.
    - Exponential decay terms model relaxation/softening effects modulated by strain powers.
    - Additional nonlinear interaction terms added for flexibility.

    Variables:
        x0: Strain
        x1: Temperature in Celsius
        y : Stress

    Parameters (length >= 12):
        params[0]: intercept (baseline stress)
        params[1]: linear strain coefficient
        params[2]: linear temperature coefficient
        params[3]: quadratic strain coefficient (strain^2)
        params[4]: quadratic temperature coefficient (temperature^2)
        params[5]: strain * temperature interaction
        params[6]: cubic strain coefficient (strain^3)
        params[7]: cubic temperature coefficient (temperature^3)
        params[8]: inverse absolute temp coefficient (1 / T_kelvin)
        params[9]: inverse absolute temp squared coefficient ((1 / T_kelvin)^2)
        params[10]: exp decay rate for temp-dependent softening on linear term
        params[11]: exp decay rate for temp-dependent softening on quadratic term

    Returns:
        y: Calculated stress as numpy array.
    """
    
    eps = 1e-6  # small number to avoid division by zero
    
    T_kelvin = x1 + 273.15  # Convert Celsius to Kelvin
    
    inv_T = 1.0 / T_kelvin
    inv_T_sq = inv_T ** 2
    
    exp_decay_lin = np.exp(-params[10] * x1)   # exponential decay modulating linear term
    exp_decay_quad = np.exp(-params[11] * x1)  # exponential decay modulating quadratic term
    
    return (
          params[0]
        
        + params[1] * x0                              # linear strain
        
        + params[2] * x1                              # linear temp
        
        + params[3] * x0**2                           # quadratic strain
        
        + params[4] * x1**2                           # quadratic temp
        
        + params[5] * x0 * x1                         # interaction term
        
        + params[6] * x0**3                           # cubic strain
        
        + params[7] * x1**3                           # cubic temp
        
        + params[8] * inv_T                           # inverse absolute temp effect
        
        + params[9] * inv_T_sq                        # inverse absolute temp squared effect
        
         # Nonlinear interaction involving inverse temp and cubic strain
         + inv_T * (params[6] * x0**3)
        
         # Exponential decay modulated by linear and quadratic strains capturing thermal softening/relaxation
         + exp_decay_lin * (params[1] * x0)
         + exp_decay_quad * (params[3] * x0**2)
         
         # Interaction of exponential decay with product of strain and temperature squared for flexibility
         + exp_decay_quad * (params[5] * x0 * x1**2)
         
         # Small correction term combining exponential decay and inverse temp modulated by linear temp 
         + exp_decay_lin * inv_T * (params[2] * x1)
         
         # Optional nonlinear coupling term involving division by temperature plus epsilon 
         + params[5] * (x0 ** 2) / (x1 + eps)
        
    )
