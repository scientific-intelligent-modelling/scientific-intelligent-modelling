def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements over v1:
    - Adds inverse strain term to capture softening or damage effects at low strain.
    - Adds exponential temperature term to model thermal activation effects.
    - Adds a logarithmic temperature term for slow varying temperature dependence.
    - Includes a nonlinear coupling term with strain^(1/2)*temperature^(1/3).
    - Retains all terms from v1 for flexibility.

    Variables:
    - x0: Strain (assumed > 0)
    - x1: Temperature (assumed > 0)

    Parameters:
    - params: array of coefficients (length = MAX_NPARAMS=12)

      Mapping:
        p[0] : constant offset
        p[1] : linear strain
        p[2] : linear temp
        p[3] : interaction strain*temp
        p[4] : quadratic strain^2
        p[5] : quadratic temp^2
        p[6] : tanh(strain) term (saturation)
        p[7] : fractional power strain^(2/3)
        p[8] : log(strain)
        p[9] : reciprocal temperature (1/temp)
        p[10]: exp(-strain) decay term
        p[11]: tanh(strain)*temp interaction

      Note: Since MAX_NPARAMS=12, we reuse params indices by combining terms smartly,
      or you can consider replacing less important terms if needed.
      
      Here, we replace param indices 8 and 9 usage with new terms to keep param count fixed.

      Alternatively, if allowed to increase param count, add new params accordingly.

      For this implementation, we will reuse some params with weighted sums.

    """
    
    eps = 1e-8
    
    safe_x0 = np.maximum(x0, eps)
    safe_x1 = np.maximum(x1, eps)

    # Existing terms from v1:
    y = (
          params[0]
        
        + params[1] * safe_x0                           # linear strain
        
        + params[2] * safe_x1                           # linear temp
        
        + params[3] * safe_x0 * safe_x1                 # interaction
        
        + params[4] * safe_x0**2                        # quadratic strain
        
        + params[5] * safe_x1**2                        # quadratic temp
        
        + params[6] * np.tanh(safe_x0)                  # saturation effect in strain
        
        + params[7] * safe_x0**(2/3)                    # fractional power law in strain

       )

    # Replace param 8 and 9 usage by combining two new nonlinear terms:

    y += (
          params[8]*np.log(safe_x1)                      # logarithmic temperature instead of log(strain)
        
        + params[9]*np.exp(-safe_x1)                     # exponential decay in temperature instead of reciprocal temp
       )

    y += (
          params[10]*np.exp(-safe_x0)                     # exponential decay in strain (as before)
        
        + params[11]*np.tanh(safe_x0)*safe_x1           # nonlinear coupling term (as before)
       )
    
    # Add inverse strain term weighted by a fraction of param_7 to keep param count fixed,
    # or alternatively add it scaled by param_7 as well:

    y += 0.5*params[7]/safe_x0                          # inverse strain softening effect

    
    return y
