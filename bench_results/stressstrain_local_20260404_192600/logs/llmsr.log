def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress-strain relationship is nonlinear and temperature-dependent.
    - Temperature affects stiffness exponentially (softening).
    - Include cubic strain term to capture more complex material behavior.
    - Include higher order temperature terms and cross terms for better accuracy.
    - Add inverse temperature term to capture possible Arrhenius-type effects on stress.

    Model form:
    y = (p0 + p1*x0 + p2*x0**2 + p3*x0**3) * exp(-p4 * x1) 
        + p5*x1 + p6*x1**2 + p7/x1 
        + p8*x0*x1 + p9*x0**2 * x1 + p10*x0 * x1**2

    where
    x0 = Strain
    x1 = Temperature
    y = Stress

    Parameters:
        params[0]: base stiffness offset
        params[1]: linear strain coefficient
        params[2]: quadratic strain coefficient
        params[3]: cubic strain coefficient
        params[4]: temperature decay rate of stiffness (exponential)
        params[5]: linear temperature offset term
        params[6]: quadratic temperature offset term
        params[7]: inverse temperature term coefficient
        params[8]: linear strain-temperature interaction term
        params[9]: quadratic strain-temperature interaction term
        params[10]: strain-linear temp squared interaction term
    """
    
    # Polynomial in strain up to cubic order
    strain_poly = (params[0] 
                   + params[1]*x0 
                   + params[2]*x0**2 
                   + params[3]*x0**3)
    
    # Exponential decay with temperature (softening effect)
    temp_decay = np.exp(-params[4] * x1)
    
    # Temperature offset terms including inverse temperature for Arrhenius-like effect,
    # avoid division by zero by adding a small epsilon if needed.
    epsilon = 1e-8  # small number to avoid division by zero if any x1=0
    
    temp_offset = (params[5]*x1 
                   + params[6]*x1**2 
                   + params[7]/(x1 + epsilon))
    
    # Interaction terms between strain and temperature, including higher order cross terms
    interaction_terms = (params[8]*x0*x1 
                         + params[9]*x0**2 * x1 
                         + params[10]*x0 * x1**2)
    
    return strain_poly * temp_decay + temp_offset + interaction_terms
