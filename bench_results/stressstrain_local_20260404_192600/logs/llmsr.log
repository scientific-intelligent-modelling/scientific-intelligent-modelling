def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Builds on v1 with additional nonlinear and interaction terms.
    - Includes logarithmic temperature dependence for softening near phase transitions.
    - Strain-dependent exponential decay rate models coupling between strain and thermal relaxation.
    - Rational term models saturation or limiting behavior at high strains/temperatures.

    Variables:
        x0: Strain
        x1: Temperature in Celsius
        y : Stress

    Parameters (length == 12):
        params[0]: intercept (baseline stress)
        params[1]: linear strain coefficient
        params[2]: linear temperature coefficient
        params[3]: quadratic strain coefficient (strain^2)
        params[4]: quadratic temperature coefficient (temperature^2)
        params[5]: strain * temperature interaction
        params[6]: cubic strain coefficient (strain^3)
        params[7]: cubic temperature coefficient (temperature^3)
        params[8]: strain^2 * temperature interaction
        params[9]: strain * temperature^2 interaction
        params[10]: inverse absolute temperature coefficient (1 / T_kelvin)
        params[11]: base exponential decay rate for temp-dependent softening

    Returns:
        y: Calculated stress as numpy array.
    """
    
    T_kelvin = x1 + 273.15  # Convert Celsius to Kelvin
    
    # Avoid log(0) or negative by clipping T_kelvin minimum value slightly above zero
    T_clip = np.clip(T_kelvin, 1e-3, None)
    
    # Strain-modulated exponential decay rate: base rate scaled by (1 + alpha*strain), here alpha ~ param scaling via p5 or p11 could be used,
    # but since param count is fixed, we use a simple modulation with param5 as proxy.
    
    exp_decay_rate = params[11] * (1 + 0.5 * np.abs(x0))  
    exp_decay = np.exp(-exp_decay_rate * x1)
    
    # Rational term denominator to model saturation effects; add small epsilon to avoid division by zero
    denom = 1 + 0.1 * x0**2 + 0.05 * x1**2 + 1e-6
    
    return (
          params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[6] * x0**3
        + params[7] * x1**3
        + params[8] * (x0**2) * x1
        + params[9] * x0 * (x1**2)
        
        + (params[10] / T_clip)                      # inverse absolute temp effect
        
        + exp_decay * (params[5] * x0)               # exponential decay modulated by linear strain-temp coupling
        
        + ((params[10]/T_clip) * x0)                  # additional inverse temp times strain coupling
        
        + 5.0*params[6]*x0*(x1 / T_clip)             # new cubic cross-term capturing complex coupling
        
        - 3.0*params[7]*np.log(T_clip)                # logarithmic temp dependence for softening
        
      ) / denom                                        # rational saturation term denominator
