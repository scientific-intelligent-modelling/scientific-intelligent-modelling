                 + p8 * (strain^2) * temperature  (interaction nonlinear)
                 + p9  * strain / temperature     (interaction inverse temp)
                 + p10 * (strain^2) / temperature  (higher order interaction)
                 + p11 * (strain^3) / temperature  (cubic interaction with inverse temp)
                 
               + p12 * strain^4                  (quartic nonlinear elasticity)
               + p13 * log(temperature)          (logarithmic temp effect)
               + p14 * strain * log(temperature)   (cross term with log temp)
               + p15 * strain^2 * log(temperature)  # if more params available

    Note: Since MAX_NPARAMS=12 in the original code, here we assume extending params length if needed,
          or we can drop some less important terms if limited to 12 parameters.

    For now, we will implement up to param index 15 assuming extension is allowed.
    
    To keep within MAX_NPARAMS=12, we can replace some terms or omit the last ones.

    Here is an implementation assuming extended params length >=16.
    
    """
    
    epsilon = 1e-8
    inv_temp = 1.0 / (x1 + epsilon)
    
    # To avoid domain error in log when x1 <=0, clip minimum value
    safe_temp = np.clip(x1, a_min=epsilon, a_max=None)
    
    log_temp = np.log(safe_temp)

    # If params length <16 fallback to original v1 model
    n_params = len(params)

    stress = (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[6] * inv_temp
        + params[7] * x0**3
        + params[8] * (x0**2) * x1
        + params[9]  * x0      * inv_temp
        + params[10] * x0**2   * inv_temp
        + params[11] * x0**3   * inv_temp
    )
    
    if n_params > 12:
        stress += params[12] * x0**4
    
    if n_params > 13:
        stress += params[13] * log_temp
    
    if n_params > 14:
        stress += params[14] * x0       * log_temp
    
    if n_params > 15:
        stress += params[15]   *(x0**2)*log_temp

    
    return stress
