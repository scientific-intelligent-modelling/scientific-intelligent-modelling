                -np.abs(params[8])*(x0**2)
            )
            *
            x0
    )
    
    # Softening factor depends smoothly on both |temp| and |strain|:
    softening_factor = 1. / (1. + np.abs(params[8])*(np.abs(x1)+np.abs(x0)+epsilon))
    
    # Interaction term: cubic tanh(strain) times sqrt(temperature):
