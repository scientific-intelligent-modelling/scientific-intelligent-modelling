    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements over v1:
    - Added sigmoid(strain) term for smooth saturation/hardening.
    - Added log(1/temp) term for capturing complex temp effects.
    - Split combined nonlinear terms into two separate weighted sums (params[11] and params[10]).
    - Added exp(-strain * temp^2) term for higher-order coupled softening/damage effect.
    
    Parameters mapping (length=12):
        p[0] : constant offset
        p[1] : linear strain
        p[2] : linear temp
        p[3] : interaction strain*temp
        p[4] : quadratic strain^2
        p[5] : quadratic temp^2
        p[6] : cubic strain^3
        p[7] : logarithmic strain (log(strain))
        p[8] : reciprocal temperature (1/temp)
        p[9] : exponential decay in strain (exp(-strain))
        p[10]: combined nonlinear #1: rational coupling + exp(-strain*temp^2)
               = (strain / temp) + exp(-strain * temp**2)
        p[11]: combined nonlinear #2: tanh(strain) + exp(-temp) + sigmoid(strain)
               = tanh(strain) + exp(-temp) + 1/(1+exp(-k*(strain - s0))) with k=10, s0=0.5

    Note:
      - Small epsilon added to avoid domain errors in log and division.
      - Sigmoid parameters chosen heuristically to model smooth transition near moderate strains.

    """
    
    eps = 1e-8
    
    safe_x0 = np.maximum(x0, eps)
    safe_x1 = np.maximum(x1, eps)

    # Sigmoid function parameters for smooth saturation near moderate strains (~0.5)
    k = 10.0   # steepness of sigmoid
    s0 = 0.5   # midpoint of sigmoid

    sigmoid_strain = 1 / (1 + np.exp(-k * (safe_x0 - s0)))

    combined_nonlinear_10 = (
          (safe_x0 / safe_x1)                  # rational coupling term
        + np.exp(-safe_x0 * safe_x1**2)       # higher order coupled exponential decay
    )

    combined_nonlinear_11 = (
          np.tanh(safe_x0)                      # saturation/hardening effect in strain
        + np.exp(-safe_x1)                     # softening/recovery effect in temperature
        + sigmoid_strain                       # smooth saturation via sigmoid function 
    )

    
    y = (
          params[0]
        
        + params[1] * safe_x0                       # linear strain
        
        + params[2] * safe_x1                       # linear temp
        
        + params[3] * safe_x0 * safe_x1             # interaction
        
        + params[4] * safe_x0**2                    # quadratic strain
        
        + params[5] * safe_x1**2                    # quadratic temp
        
        + params[6] * safe_x0**3                    # cubic strain
        
        + params[7] * np.log(safe_x0)               # logarithmic strain
        
        + params[8] / safe_x1                        # reciprocal temperature
        
        + params[9]* np.exp(-safe_x0)               # exponential decay in strain

        + params[10]* combined_nonlinear_10         # rational coupling & higher order exp decay

        + params[11]* combined_nonlinear_11         # tanh, exp decay & sigmoid saturation 
       )
    
    return y
