def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends nonlinearly on strain (x0) and temperature (x1).
    - Temperature reduces stiffness exponentially (Arrhenius-type decay).
    - Logarithmic terms capture slow variation effects in both strain magnitude and temperature.
    - Inverse terms model softening/damage effects at low strain or low temperature.
    - Polynomial terms capture elastic/plastic nonlinearities.
    - Interaction term between squared strain and squared temperature captures complex coupling.
    - Added a logarithmic term for temperature to capture slow variation effects in temperature as well.

    Model form:
        y = p0
            + p1 * x0
            + p2 * x1
            + p3 * x0 * x1
            + p4 * x0**2
            + p5 * x1**2
            + p6 * x0**3
            + p7 / (x1 + eps)
            + p8 * exp(-p9 * x1)
            + p10 * log(|x0| + eps)
            + p11 * (x0**2) * (x1**2)
            + p12 * log(x1 + eps)

    where:
        x0 = Strain
        x1 = Temperature
        y = Stress
        eps = small number to avoid division by zero or log(0)

    Parameters:
        params: array of length 13 containing coefficients [p0,...,p12]
    """
    
    eps = 1e-6
    
    log_strain = np.log(np.abs(x0) + eps)
    log_temp = np.log(x1 + eps)
    
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 * x1
        + params[4] * x0**2
        + params[5] * x1**2
        + params[6] * x0**3
        + params[7] / (x1 + eps)
        + params[8] * np.exp(-params[9] * x1)
        + params[10] * log_strain
        + params[11] * (x0**2) * (x1**2)
        + params[12] * log_temp
    )
