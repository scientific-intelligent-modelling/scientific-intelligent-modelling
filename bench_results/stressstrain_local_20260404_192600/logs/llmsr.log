def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Physical reasoning:
    - Stress often depends linearly on strain (Hooke's law) for small strains.
    - Temperature can affect the modulus of elasticity and cause thermal stress.
    - Interaction terms and nonlinearities can capture more complex behavior.

    Variables:
    - x0: Strain
    - x1: Temperature

    Parameters:
    - params: array of coefficients (length up to MAX_NPARAMS=12)
    
    Model form (example):
        y = p0 
            + p1 * strain 
            + p2 * temperature 
            + p3 * strain^2 
            + p4 * temperature^2 
            + p5 * strain * temperature
            + p6 * exp(p7 * strain)
            + p8 * log(1 + abs(strain))
            + p9 * exp(p10 * temperature)
            + p11 * strain^3
    """
    
    # To avoid domain errors in log, add a small epsilon inside log argument
    eps = 1e-8
    
    term_linear_strain = params[1] * x0
    term_linear_temp = params[2] * x1
    
    term_quad_strain = params[3] * x0**2
    term_quad_temp = params[4] * x1**2
    
    term_interaction = params[5] * x0 * x1
    
    # Exponential terms with parameters controlling growth/decay rate
    term_exp_strain = params[6] * np.exp(params[7] * x0)
    
    # Logarithmic term to capture saturation or diminishing returns effects in strain
    term_log_strain = params[8] * np.log(np.abs(x0) + eps)
    
    # Exponential temperature effect
    term_exp_temp = params[9] * np.exp(params[10] * x1)
    
    # Cubic strain for higher order nonlinearity
    term_cubic_strain = params[11] * x0**3
    
    y = (params[0]
         + term_linear_strain
         + term_linear_temp
         + term_quad_strain
         + term_quad_temp
         + term_interaction
         + term_exp_strain
         + term_log_strain
         + term_exp_temp
         + term_cubic_strain)
    
    return y
