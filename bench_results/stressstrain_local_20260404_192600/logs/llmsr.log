    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements over v1:
    - Added combined nonlinear terms with weighted sums inside single parameters to keep param count fixed.
    - Included tanh(strain) for saturation/hardening.
    - Included exp(-temperature) for thermal softening.
    - Included strain^2 * temperature interaction term.
    - Added reciprocal strain term (1/strain) safely handled.
    - Added logarithmic temperature term.
    
    Parameters mapping (length=12):
        p[0] : constant offset
        p[1] : linear strain
        p[2] : linear temp
        p[3] : interaction strain*temp
        p[4] : quadratic strain^2 + nonlinear coupling with temp (strain^2 * temp)
        p[5] : quadratic temp^2 + nonlinear coupling with strain (strain * temp^2)
        p[6] : cubic strain^3
        p[7] : cubic temp^3 (kept but can be small)
        p[8] : log(strain) + log(temp) combined
        p[9] : reciprocal temp (1/temp) + reciprocal strain (1/strain) combined
        p[10]: exp(-strain) modulated by temperature effect
        p[11]: combined nonlinear saturation and interaction:
               tanh(strain), exp(-temp), and strain^2 * temp weighted sum

    Note:
      eps added to avoid domain errors in log and division.
      Combined terms use fixed weights inside to reduce parameter count while capturing complex physics.

    """
    
    eps = 1e-8
    
    safe_x0 = np.maximum(x0, eps)
    safe_x1 = np.maximum(x1, eps)
    
    # Combined logarithmic term: log(strain) + 0.5*log(temp)
    log_combined = np.log(safe_x0) + 0.5 * np.log(safe_x1)
    
    # Combined reciprocal term: 1/temp + 0.3*(1/strain)
    reciprocal_combined = 1.0 / safe_x1 + 0.3 / safe_x0
    
    # Combined exponential decay modulated by temperature:
    # exp(-strain)*(1 - 0.5*exp(-temp)) models decay softened by temperature increase
    exp_modulated = np.exp(-safe_x0)*(1 - 0.5*np.exp(-safe_x1))
    
    # Combined nonlinear saturation/interactions weighted sum inside param[11]
    combined_nonlinear = (
          0.6 * np.tanh(safe_x0)            # saturation/hardening in strain
        + 0.4 * np.exp(-safe_x1)           # thermal softening/recovery effect
        + 0.8 * safe_x0**2 * safe_x1       # nonlinear coupling: strain^2 * temperature
     )
    
    y = (
          params[0]
        
        + params[1]*safe_x0                         # linear strain
        
        + params[2]*safe_x1                         # linear temperature
        
        + params[3]*safe_x0*safe_x1                 # interaction term
        
        + params[4]*(safe_x0**2 + 0.7*safe_x0**2*safe_x1)   # quadratic strain plus coupling
        
        + params[5]*(safe_x1**2 + 0.6*safe_x0*safe_x1**2)   # quadratic temp plus coupling
        
        + params[6]*safe_x0**3                       # cubic strain
        
        + params[7]*safe_x1**3                       # cubic temperature
        
        + params[8]*log_combined                      # combined logarithmic terms
        
        + params[9]*reciprocal_combined               # combined reciprocal terms
        
        + params[10]*exp_modulated                     # exponential decay modulated by temp
        
        + params[11]*combined_nonlinear                # combined nonlinear effects 
       )
    
    return y
