        y = p0 
            + p1 * strain 
            + p2 * temperature 
            + p3 * strain * temperature 
            + p4 * strain^2 
            + p5 * temperature^2 
            + p6 * strain^3
            + p7 * temperature^3
            + p8 / (1 + abs(strain)) 
            + p9 / (1 + abs(temperature))
            + p10 * exp(-strain)
            + p11 * log(1 + abs(temperature))
            
