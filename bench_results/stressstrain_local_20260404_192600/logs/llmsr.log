    - Retains logarithmic and reciprocal terms for physical realism.
    - Includes rational coupling term (strain / (temp + 1)) to avoid singularities at low temp.
    
    Variables:
    - x0: Strain (assumed > 0)
    - x1: Temperature (assumed > 0)

    Parameters mapping (length=12):
        p[0] : constant offset
        p[1] : linear strain
        p[2] : linear temperature
        p[3] : interaction strain*temp
        p[4] : quadratic strain^2
        p[5] : quadratic temp^2
        p[6] : tanh(strain) saturation term
        p[7] : fractional power strain^(2/3)
        p[8] : log(strain)
        p[9] : reciprocal temperature (1/temp)
        p[10]: exp(-strain) * tanh(temp) decay term
        p[11]: combined nonlinear coupling:
               tanh(temp) + fractional power coupling + rational coupling

    Note:
      eps added to avoid domain errors in log and division.
      Nonlinear combinations use fixed weights inside parameters to keep param count fixed while capturing complex physics.

    """
    
    eps = 1e-8
    
    safe_x0 = np.maximum(x0, eps)
    safe_x1 = np.maximum(x1, eps)

    # Logarithmic term for strain
    log_strain = np.log(safe_x0)

    # Reciprocal temperature term
    rec_temp = 1.0 / safe_x1

    # Saturation terms via hyperbolic tangent on both variables separately
    tanh_strain = np.tanh(safe_x0)
    tanh_temp = np.tanh(safe_x1)

    # Fractional power terms for nonlinear behavior
    frac_pow_strain = safe_x0**(2/3)
    
    # Combined fractional power coupling term: sqrt(strain)*temp^(1/3)
    frac_coupling = (safe_x0**0.5) * (safe_x1**(1/3))

    
    # Exponential decay in strain modulated by tanh(temperature), models thermal softening smoothly
    exp_decay_modulated = np.exp(-safe_x0) * tanh_temp

    
    # Rational coupling term with offset in denominator to avoid singularity at low temp 
    rational_coupling = safe_x0 / (safe_x1 + 1.0)

    
    y = (
          params[0]
        
        + params[1]*safe_x0                              # linear strain
        
        + params[2]*safe_x1                              # linear temperature
        
        + params[3]*safe_x0*safe_x1                      # interaction term
        
        + params[4]*safe_x0**2                            # quadratic strain
        
        + params[5]*safe_x1**2                            # quadratic temp
        
        + params[6]*tanh_strain                           # saturation effect in strain
        
        + params[7]*frac_pow_strain                        # fractional power law in strain
        
        + params[8]*log_strain                             # logarithmic strain
        
        + params[9]*rec_temp                               # reciprocal temperature
        
        + params[10]*exp_decay_modulated                   # exp(-strain)*tanh(temp) decay
        
        + params[11]*( 
