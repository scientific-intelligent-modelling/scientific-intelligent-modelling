def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends primarily on strain (Hooke's law) but stiffness decreases with temperature.
    - Temperature effect often acts multiplicatively on strain-dependent stiffness.
    - Include nonlinear terms and interaction terms to capture complex coupling.
    - Use an exponential decay term to model stiffness reduction with temperature.
    
    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length at least 10 for this model.
      params[0]: intercept
      params[1]: linear strain coefficient (base stiffness)
      params[2]: linear temperature coefficient (offset)
      params[3]: interaction coefficient for strain*temperature
      params[4]: quadratic strain coefficient
      params[5]: quadratic temperature coefficient
      params[6]: cubic strain coefficient
      params[7]: cubic temperature coefficient
      params[8]: exponential decay rate of stiffness with temperature
      params[9]: additional offset or correction term

    Model form:
        y = p0 
            + (p1 * x0 + p4 * x0**2 + p6 * x0**3) * exp(-p8 * x1)
            + p2 * x1 + p3 * x0 * x1 + p5 * x1**2 + p7 * x1**3 
            + p9

    Explanation:
        - The term (p1*x0 + ...) models stress-strain relationship modulated by an exponential decay in temperature,
          representing the reduction in effective stiffness as temperature increases.
        - Other polynomial terms in temperature and interactions capture additional nonlinear effects.

    """
    
    # Exponential decay factor modeling stiffness reduction with increasing temperature
    exp_decay = np.exp(-params[8] * x1)
    
    # Strain-dependent terms modulated by exponential decay in temperature
    strain_terms = (params[1] * x0 
                    + params[4] * x0**2 
                    + params[6] * x0**3) * exp_decay
    
    # Polynomial terms in temperature and interaction terms
    temp_and_interaction = (params[2] * x1 
                            + params[3] * x0 * x1 
                            + params[5] * x1**2 
                            + params[7] * x1**3)
    
    # Intercept and extra offset term
    intercept_and_offset = params[0] + params[9]
    
    return intercept_and_offset + strain_terms + temp_and_interaction
