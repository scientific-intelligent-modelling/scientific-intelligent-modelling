    tanh_term = np.tanh(p[10] * x1)
    
    return (
        p[0]  # constant term
        + p[1] * x0  # linear strain
        + p[2] * x1  # linear temperature
        + p[3] * x0**2  # quadratic strain
        + p[4] * x1**2  # quadratic temperature
        + p[5] * x0 * x1  # interaction term strain*temperature
        + p[6] * exp_term * x0  # exponential temp effect modulating strain (thermal softening/hardening)
        + p[8] * safe_log_strain  # logarithmic term for small strains
        + p[9] * tanh_term  # saturation effect of temperature on stress
        + p[11] * (x0**3)  # cubic strain nonlinearity at large strains
    )
