    # Exponential term in strain capturing nonlinear stiffening/softening effects
    exp_strain_term = params[6] * np.exp(params[7] * x0)
    
    # Logarithmic term in absolute value of strain for asymmetry and numerical stability
    log_strain_term = params[8] * np.log(np.abs(x0) + 1.0)
    
    # Arrhenius-like exponential dependence on inverse temperature for thermally activated processes
    exp_inv_temp_term = params[9] * np.exp(params[10] / (x1 + eps))
    
    # Saturation/yielding effect modeled by hyperbolic tangent of strain
    tanh_strain_term = params[11] * np.tanh(x0)
    
    y = (params[0]
         + temp_modulated_strain
         + temp_terms
         + interaction_term
         + exp_strain_term
         + log_strain_term
         + exp_inv_temp_term
