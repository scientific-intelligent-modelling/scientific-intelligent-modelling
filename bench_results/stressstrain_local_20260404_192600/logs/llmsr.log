def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements over v1:
    - More explicit nonlinear coupling terms combining strain and temperature powers.
    - Separate tanh saturation on strain and temperature with distinct weights.
    - Exponential decay terms for both strain and temperature combined multiplicatively.
    - Logarithmic terms separated for strain and temperature with individual weights.
    - Reciprocal terms for both strain and temperature included separately.
    - Polynomial terms up to cubic order retained.
    - Interaction terms expanded to include higher-order cross-terms.

    Parameters mapping (length=12):
        p[0] : constant offset
        p[1] : linear strain
        p[2] : linear temp
        p[3] : interaction strain*temp
        p[4] : quadratic strain^2 + coupling term (strain^2 * temp)
        p[5] : quadratic temp^2 + coupling term (strain * temp^2)
        p[6] : cubic strain^3
        p[7] : cubic temp^3
        p[8] : log(strain)
        p[9] : reciprocal temp (1/temp)
        p[10]: exp(-strain)*exp(-temp) combined decay
        p[11]: nonlinear saturations: tanh(strain) + tanh(temp)

    Note:
      eps added to avoid domain errors in log and division.
      Nonlinearities are combined carefully to maintain interpretability.

    """
    
    eps = 1e-8
    
    safe_x0 = np.maximum(x0, eps)
    safe_x1 = np.maximum(x1, eps)
    
    # Logarithmic terms separated for clarity
    log_strain = np.log(safe_x0)
    log_temp = np.log(safe_x1)
    
    # Reciprocal terms separated
    rec_strain = 1.0 / safe_x0
    rec_temp = 1.0 / safe_x1
    
    # Exponential decay combined multiplicatively to model joint softening effects
    exp_decay = np.exp(-safe_x0) * np.exp(-safe_x1)
    
    # Saturation effects modeled by tanh separately on strain and temperature,
    # weighted inside param[11]
    
    saturation_effects = (
          0.7 * np.tanh(safe_x0)   # saturation/hardening on strain 
        + 0.5 * np.tanh(safe_x1)   # saturation/hardening on temperature 
     )
    
    # Nonlinear polynomial interaction expansions:
    
    poly_terms = (
          params[4]*(safe_x0**2 + 0.8*safe_x0**2*safe_x1)   # quadratic strain plus coupling with temp
        
        + params[5]*(safe_x1**2 + 0.7*safe_x0*safe_x1**2)   # quadratic temp plus coupling with strain
        
     )
    
    y = (
          params[0]
        
        + params[1]*safe_x0                         # linear strain
        
        + params[2]*safe_x1                         # linear temperature
        
        + params[3]*safe_x0*safe_x1                 # interaction term
        
        + poly_terms                                # quadratic & coupled polynomial terms
        
        + params[6]*safe_x0**3                       # cubic strain
        
        + params[7]*safe_x1**3                       # cubic temperature
        
        + params[8]*log_strain                       # logarithmic strain term
        
        - 0.4*params[8]*log_temp                     # logarithmic temperature scaled negatively for physical effect 
        
        - 0.6*params[9]*rec_strain                    # reciprocal of strain scaled negatively 
        
        + params[9]*rec_temp                          # reciprocal of temperature positive contribution 
        
        + params[10]*exp_decay                         # combined exponential decay term
        
        + params[11]*saturation_effects                # nonlinear saturations from tanh functions

       )
    
    return y
