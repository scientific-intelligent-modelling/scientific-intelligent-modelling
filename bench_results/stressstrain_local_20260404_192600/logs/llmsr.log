def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Physical reasoning:
    - Stress often depends linearly on strain (Hooke's law) with a modulus that can depend on temperature.
    - Temperature can affect the modulus and introduce nonlinear effects.
    - Include interaction terms and nonlinear terms to capture temperature dependence and possible nonlinear elasticity.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params: array of coefficients [p0, p1, ..., p11]
      where:
        p0 : intercept (baseline stress)
        p1 : linear strain coefficient (modulus at reference temp)
        p2 : linear temperature coefficient (baseline stress shift)
        p3 : strain * temperature interaction term
        p4 : quadratic strain term (nonlinear elasticity)
        p5 : quadratic temperature term
        p6 : cubic strain term
        p7 : cubic temperature term
        p8 : exp(-temperature) decay effect on strain
        p9 : log(1 + abs(strain)) to capture softening/hardening effects
        p10: strain * log(1 + abs(temperature)) interaction
        p11: optional higher order or cross term

    """
    # To avoid domain errors in log, add small epsilon inside log arguments.
    eps = 1e-8

    # Compute nonlinear terms safely
    strain_abs = np.abs(x0)
    
    return (
        params[0]
        + params[1] * x0                              # linear in strain
        + params[2] * x1                              # linear in temperature
        + params[3] * x0 * x1                         # interaction term
        + params[4] * x0**2                           # quadratic strain term (nonlinear elasticity)
        + params[5] * x1**2                           # quadratic temperature effect
        + params[6] * x0**3                           # cubic strain nonlinearity 
        + params[7] * x1**3                           # cubic temperature nonlinearity 
        + params[8] * x0 * np.exp(-x1)                # exponential decay effect of temp on strain contribution 
        + params[9] * np.log(1.0 + strain_abs + eps)  # logarithmic softening/hardening with strain magnitude 
        + params[10]*x0*np.log(1.0+np.abs(x1)+eps)   # interaction with log temp magnitude 
        + params[11]*x0**2*x1                         # higher order cross-term 
    )
