def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retain nonlinear strain terms up to cubic order.
    - Include quadratic temperature term.
    - Model thermal softening via exponential decay multiplied by strain.
    - Use tanh for strain saturation effect with separate scale and amplitude parameters.
    - Add inverse temperature term to capture stiffening at low temperatures.
    - Keep sqrt(abs(temperature)) term for sublinear temp effects.
    - Include quadratic strain-temperature interaction term explicitly.
    - Keep total parameters fixed at 12.

    Parameters usage (12 total):
      params[0]  : constant offset
      params[1]  : linear strain coefficient
      params[2]  : linear temperature coefficient
      params[3]  : linear strain-temperature interaction coefficient
      params[4]  : quadratic strain coefficient
      params[5]  : quadratic temperature coefficient
      params[6]  : cubic strain coefficient
      params[7]  : exponential decay multiplier (thermal softening)
      params[8]  : exponential decay rate w.r.t. temperature
      params[9]  : tanh argument scale (strain saturation)
      params[10] : tanh multiplier (strain saturation amplitude)
      params[11] : quadratic strain-temperature interaction coefficient

    """
    
    epsilon = 1e-6
    
    # Linear terms:
    linear_strain = params[1]*x0
    linear_temp = params[2]*x1
    
    # Interaction linear term:
    interaction_linear = params[3]*x0*x1
    
    # Nonlinear terms in strain and temperature:
    quad_strain = params[4]*x0**2
    quad_temp = params[5]*x1**2
    cubic_strain = params[6]*x0**3
    
    # Thermal softening modeled as exponential decay with temperature times strain:
    thermal_softening = params[7]*np.exp(-params[8]*x1)*x0
    
    # Strain saturation modeled by tanh with separate scale and amplitude parameters:
    strain_saturation = params[10]*np.tanh(params[9]*x0)
    
    # Sublinear temperature effect without parameter to keep flexibility:
    sqrt_temp_effect = np.sqrt(np.abs(x1))
    
    # Inverse temperature effect capturing stiffening/softening at low temperatures:
    inv_temp_effect = -params[11]/(x1 + epsilon)
    
    # Quadratic strain-temperature interaction term explicitly included:
    quad_strain_temp_interaction = params[11]*(x0**2)*x1
    
    
    
    return (
        params[0]
        + linear_strain
        + linear_temp
        + interaction_linear
        + quad_strain
        + quad_temp
        + cubic_strain
        + thermal_softening
        + strain_saturation
        + sqrt_temp_effect 
        + inv_temp_effect 
        + quad_strain_temp_interaction 
       )
