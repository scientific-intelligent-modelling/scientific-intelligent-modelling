def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends linearly on strain (Hooke's law) at small strains.
    - Temperature reduces stiffness, often modeled as a negative effect on the linear strain term.
    - Nonlinear elasticity and thermal softening effects captured by quadratic terms.
    - Interaction terms capture coupling between strain and temperature.
    - Added cubic strain term to capture strain hardening at larger strains.
    - Added inverse temperature term to model possible Arrhenius-type temperature dependence.
    - Added exponential decay of stiffness with temperature times strain.
    - Added higher order interaction terms for better flexibility:
      * cubic temperature term (temperature nonlinearities)
      * quadratic interaction term (strain^2 * temperature)
      * logarithmic temperature dependence to model softening/hardening effects.

    Model structure:
    y = params[0] 
        + params[1]*x0                     # linear strain term
        + params[2]*x1                     # linear temperature term
        + params[3]*x0**2                  # quadratic strain term (nonlinear elasticity)
        + params[4]*x1**2                  # quadratic temperature term (nonlinear temp effect)
        + params[5]*x0*x1                  # interaction between strain and temperature
        + params[6]*x0**3                  # cubic strain term (strain hardening)
        + params[7]/(x1 + 1e-6)           # inverse temperature effect (avoid div by zero)
        + params[8]*np.exp(-params[9]*x1)*x0  # exponential decay of stiffness with temp times strain
        + params[10]*x1**3                 # cubic temperature term
        + params[11]*(x0**2)*x1            # quadratic interaction: strain^2 * temp
        + 0.0                             # placeholder if needed for future extension
    """
    
    # To avoid log(0) or negative values inside log, clip x1 to a minimum positive value
    x1_safe = np.clip(x1, 1e-6, None)

    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[6] * x0**3
        + params[7] / (x1_safe)
        + params[8] * np.exp(-params[9] * x1) * x0
        + params[10] * x1**3
        + params[11] * (x0**2) * x1
    )
