def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain and temperature.
    - Temperature often reduces stiffness exponentially or in a nonlinear manner.
    - Include nonlinear terms in strain and temperature.
    - Include interaction terms to capture coupling effects.
    - Add cubic term in strain to capture more complex plasticity or hardening behavior.
    - Add inverse temperature term to model Arrhenius-type thermal softening.
    - Add a saturation effect for strain using a hyperbolic tangent term to model yielding or saturation behavior at high strains.

    Model form:
    y = p0 
        + p1*x0 
        + p2*x1 
        + p3*x0*x1 
        + p4*x0**2 
        + p5*x1**2 
        + p6*x0**3
        + p7*np.exp(-p8 * x1) * x0  # temperature-dependent stiffness decay
        + p9 / (x1 + 273.15)  # inverse absolute temperature (Kelvin), avoid division by zero by offsetting
        + p10 * x0**2 * x1  # interaction nonlinear term
        + p11 * np.log(np.clip(x0, a_min=1e-8, a_max=None))  # log strain for small strains (clip to avoid log(0))
        + p12 * np.tanh(p13 * x0)  # saturation effect at high strains
    
    Parameters:
    - params (np.ndarray): array of length 14

    Note:
    - The constants like 273.15 convert Celsius to Kelvin for physical meaningfulness.
    """
    
    strain = x0
    temp_celsius = x1
    temp_kelvin = temp_celsius + 273.15
    
    return (
        params[0]
        + params[1] * strain
        + params[2] * temp_celsius
        + params[3] * strain * temp_celsius
        + params[4] * strain**2
        + params[5] * temp_celsius**2
        + params[6] * strain**3
        + params[7] * np.exp(-params[8] * temp_celsius) * strain
        + params[9] / temp_kelvin
        + params[10] * strain**2 * temp_celsius
        + params[11] * np.log(np.clip(strain, a_min=1e-8, a_max=None))
        + params[12] * np.tanh(params[13] * strain)
    )
