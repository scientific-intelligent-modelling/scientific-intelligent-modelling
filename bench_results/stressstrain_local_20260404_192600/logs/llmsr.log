def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning enhancements:
    - Retain polynomial terms up to cubic for strain and temperature.
    - Include logarithmic temperature dependence to capture slow varying thermal effects.
    - Use multiple exponential decay terms modulated by strain powers for complex thermal softening.
    - Add rational term (strain^2 / (temperature + eps)) to model nonlinear saturation effects.
    - Include inverse absolute temperature and inverse temperature squared terms for thermal softening.
    - Introduce cross terms involving inverse temperature and powers of strain for richer coupling.
    - Add interaction terms between log(temperature) and strain powers.

    Variables:
        x0: Strain
        x1: Temperature in Celsius
        y : Stress

    Parameters (length >= 12):
        params[0]: intercept (baseline stress)
        params[1]: linear strain coefficient
        params[2]: linear temperature coefficient (used with log(T_kelvin))
        params[3]: strain * temperature interaction coefficient
        params[4]: quadratic strain coefficient (strain^2)
        params[5]: quadratic temperature coefficient (temperature^2)
        params[6]: strain^2 / (temperature + eps) coefficient
        params[7]: exponential decay rate for temp-dependent softening (first)
        params[8]: exponential decay rate for temp-dependent softening (second)
        params[9]: cubic strain coefficient (strain^3)
        params[10]: exp(-p8 * T) * x0 term coefficient
        params[11]: exp(-p7 * T) * x0^2 term coefficient

    Returns:
        y: Calculated stress as numpy array.
    """
    
    eps = 1e-6  # small number to avoid division by zero
    
    T_kelvin = x1 + 273.15  # Convert Celsius to Kelvin
    
    # Clip T_kelvin to avoid log(0) or division by zero issues
    T_clip = np.clip(T_kelvin, eps, None)
    
    inv_T = 1.0 / T_clip
    inv_T_sq = inv_T ** 2
    
    log_T = np.log(T_clip)
    
    exp_decay_1 = np.exp(-params[7] * x1)
    exp_decay_2 = np.exp(-params[8] * x1)

    # Rational term modeling saturation/nonlinear coupling between strain squared and temp
    rational_term = params[6] * (x0 ** 2) / (x1 + eps)

    # Interaction between log(temperature) and linear & quadratic strain terms
    log_temp_strain_interaction = (
          log_T * (params[3] * x0 + params[4] * x0**2)
      )
    
    return (
          params[0]
        
        + params[1] * x0
        
        + params[2] * log_T
        
        + log_temp_strain_interaction
        
        + rational_term
        
        + exp_decay_1 * (params[10] * x0)             # exponential decay modulated linear strain
        
        + exp_decay_2 * (params[11] * x0 ** 2)       # exponential decay modulated quadratic strain
        
        + params[9] * (x0 ** 3)                       # cubic strain term
        
         # Thermal softening modeled by inverse absolute temp terms coupled with strain powers
         + inv_T * (params[3] * x0)                    # inverse temp times linear interaction
        
         + inv_T_sq * (params[4] * x0**2)              # inverse temp squared times quadratic strain
        
         # Additional nonlinear coupling term: inverse temp times cubic strain term 
         + inv_T * (params[9] * x0**3)
         
         # Small nonlinear correction term involving inverse temp squared 
         + inv_T_sq * rational_term 
     )
