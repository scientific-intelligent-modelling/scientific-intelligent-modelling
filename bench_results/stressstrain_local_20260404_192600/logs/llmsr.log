def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements over v1:
    - Combines saturation effects on both strain and temperature via tanh.
    - Adds separate logarithmic terms for strain and temperature.
    - Includes reciprocal terms for both strain and temperature.
    - Adds exponential decay terms modulated by tanh functions to capture softening/hardening.
    - Introduces nonlinear coupling terms with powers and cross-terms.
    - Keeps parameter count fixed at 12 while capturing richer physics.

    Variables:
    - x0: Strain (assumed > 0)
    - x1: Temperature (assumed > 0)

    Parameters mapping (length=12):
        p[0] : constant offset
        p[1] : linear strain
        p[2] : linear temp
        p[3] : interaction strain*temp
        p[4] : quadratic strain^2 + coupling term (strain^2 * temp)
        p[5] : quadratic temp^2 + coupling term (strain * temp^2)
        p[6] : cubic strain^3 + cubic interaction term (strain^3 * temp)
        p[7] : cubic temp^3 + cubic interaction term (strain * temp^3)
        p[8] : log(strain) term
        p[9] : reciprocal(temp) term
        p[10]: exp(-strain) modulated by tanh(temperature)
        p[11]: combined nonlinear saturation/interactions:
               tanh(strain), tanh(temperature), exp(-temp), rational coupling

    Note:
      eps added to avoid domain errors in log and division.
      Nonlinear combinations use fixed weights inside to reduce parameter count while capturing complex physics.

    """
    
    eps = 1e-8
    
    safe_x0 = np.maximum(x0, eps)
    safe_x1 = np.maximum(x1, eps)

    # Logarithmic terms separated for flexibility
    log_strain = np.log(safe_x0)
    
    # Reciprocal temperature term
    rec_temp = 1.0 / safe_x1

    # Exponential decay in strain modulated by tanh(temperature) for smooth thermal softening effect
    exp_decay_strain = np.exp(-safe_x0) * (0.5 + 0.5 * np.tanh(safe_x1))

    # Saturation effects via hyperbolic tangent on both variables
    tanh_strain = np.tanh(safe_x0)
    tanh_temp = np.tanh(safe_x1)

    
    y = (
          params[0]
        
        + params[1]*safe_x0                              # linear strain
        
        + params[2]*safe_x1                              # linear temperature
        
        + params[3]*safe_x0*safe_x1                      # interaction term
        
        + params[4]*(safe_x0**2 + 0.8*safe_x0**2*safe_x1)   # quadratic strain plus coupling
        
        + params[5]*(safe_x1**2 + 0.7*safe_x0*safe_x1**2)   # quadratic temp plus coupling
        
        + params[6]*(safe_x0**3 + 0.6*safe_x0**3*safe_x1)   # cubic strain plus cubic interaction
        
        + params[7]*(safe_x1**3 + 0.5*safe_x0*safe_x1**3)   # cubic temp plus cubic interaction
        
        + params[8]*log_strain                             # logarithmic strain
        
        + params[9]*rec_temp                               # reciprocal temperature
        
        + params[10]*exp_decay_strain                      # exponential decay modulated by tanh(temp)
        
        + params[11]*(
              0.5*tanh_strain                              # saturation/hardening in strain
            
            + 0.4*tanh_temp                                # saturation/hardening in temperature
            
            - 0.3*np.exp(-safe_x1)                         # thermal softening
            
            + 0.6*(safe_x0 / safe_x1)                       # rational coupling term
            
          )
       )
    
    return y
