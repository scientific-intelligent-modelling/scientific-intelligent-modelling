def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends primarily on strain (Hooke's law) with nonlinear corrections.
    - Temperature reduces stiffness exponentially and adds nonlinear thermal stress.
    - Interaction terms between strain and temperature capture coupling effects.
    - Use smooth nonlinear functions (tanh) to model saturation effects in strain and temperature.
    
    Variables:
    - x0: Strain
    - x1: Temperature

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length at least 12 for this model.
      params[0]: intercept
      params[1]: linear strain coefficient (base stiffness)
      params[2]: linear temperature coefficient (offset)
      params[3]: interaction coefficient for strain*temperature
      params[4]: quadratic strain coefficient
      params[5]: quadratic temperature coefficient
      params[6]: cubic strain coefficient
      params[7]: cubic temperature coefficient
      params[8]: exponential decay rate of stiffness with temperature
      params[9]: tanh saturation scale for strain
      params[10]: tanh saturation scale for temperature
      params[11]: additional offset or correction term

    Model form:
        y = p0 
            + [p1 * x0 + p4 * x0**2 + p6 * x0**3] * exp(-p8 * x1)
            + p2 * x1 + p5 * x1**2 + p7 * x1**3 
            + p3 * x0 * x1 
            + p9 * tanh(x0 / scale_strain)
            + p10 * tanh(x1 / scale_temp)
            + p11

    Explanation:
        - The polynomial in strain modulated by an exponential decay in temperature models stiffness reduction.
        - Polynomial terms in temperature capture thermal stress contributions.
        - Interaction term captures coupling between strain and temperature.
        - Tanh terms model saturation/nonlinear limiting behavior in both variables.

    """
    
    # Exponential decay factor modeling stiffness reduction with increasing temperature
    exp_decay = np.exp(-params[8] * x1)
    
    # Polynomial terms in strain modulated by exponential decay with temp
    poly_strain = (params[1] * x0 
                   + params[4] * x0**2 
                   + params[6] * x0**3) * exp_decay
    
    # Polynomial terms in temperature and interaction term
    poly_temp_interact = (params[2] * x1 
                         + params[5] * x1**2 
                         + params[7] * x1**3 
                         + params[3] * x0 * x1)
    
    # Saturation effects modeled by hyperbolic tangent functions scaled by parameters 9 and 10,
    # using scaling factors to normalize inputs before applying tanh to keep argument dimensionless and reasonable magnitude.
    
    # To avoid division by zero or too small scales, add a small epsilon if needed:
    eps = 1e-8
    
    scale_strain = max(np.std(x0), eps)  # characteristic scale of strain input for normalization
    scale_temp = max(np.std(x1), eps)   # characteristic scale of temp input for normalization
    
    tanh_strain = params[9] * np.tanh(x0 / scale_strain)
    
    tanh_temp = params[10] * np.tanh(x1 / scale_temp)
    
    intercept_and_offset = params[0] + params[11]
    
    y = intercept_and_offset + poly_strain + poly_temp_interact + tanh_strain + tanh_temp
    
    return y
