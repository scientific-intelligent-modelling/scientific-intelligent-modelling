        + params[6] * x0**3                       # cubic strain effect capturing nonlinearity
        + params[9] * x1**3                       # cubic temp effect capturing complex thermal behavior
     )
    
    # Modulate linear strain by exponential softening/hardening with temp:
    modulated_strain = exp_temp * (params[1] * x0)
    
    return base_stress \
           + modulated_strain \
           + params[8] * inv_temp \
           + logistic_strain  # add saturation effect on stress at high strains
