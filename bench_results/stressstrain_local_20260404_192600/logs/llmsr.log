    linear_modulated = (
        params[0]
        + params[1] * np.exp(-np.abs(params[8]) * x1) * x0
        + params[2] * x1
        + params[3] * x0 * x1
    )
    
    # Nonlinear strain terms with smooth saturation via temp-dependent tanh for cubic term:
    nonlinear_strain = (
          params[4] * x0 ** 2
        + params[6] * np.tanh(tanh_scale * x0) ** 3
        + params[9] * np.log(1.0 + x0 ** 2)
