def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain primarily (Hooke's law) with nonlinear corrections (quadratic, cubic).
    - Temperature affects stiffness via exponential softening and nonlinear terms.
    - Include inverse and logarithmic temperature terms to capture phase changes or softening.
    - Add cross terms with higher order strain-temperature coupling.
    - Modulate cubic strain term by temperature-dependent exponential decay to capture temp-dependent nonlinearity.

    Variables:
        x0: strain
        x1: temperature

    Parameters:
        params (np.ndarray): coefficients array with length >= 12
            params[0]: intercept (baseline stress)
            params[1]: linear strain coefficient
            params[2]: linear temperature coefficient
            params[3]: strain * temperature interaction
            params[4]: quadratic strain term
            params[5]: quadratic temperature term
            params[6]: quadratic strain / temperature term
            params[7]: exponential decay factor multiplier for linear strain term
            params[8]: exponential decay rate parameter for temperature in exp()
            params[9]: cubic strain term coefficient modulated by exp decay 
            params[10]: logarithmic temperature term coefficient
            params[11]: inverse temperature term coefficient

    """
    eps = 1e-8  # small number to avoid division by zero
    
    # Exponential decay factor for temp-dependent softening/modulation
    exp_decay = np.exp(-params[8] * x1)
    
    # Logarithm safely computed with offset eps to avoid log(0)
    log_temp = np.log(x1 + eps)
    
    # Inverse temp safely computed with offset eps to avoid division by zero
    inv_temp = 1.0 / (x1 + eps)
    
    return (
        params[0]                                      # intercept baseline stress
        + params[1] * x0                              # linear in strain (Hooke's law)
        + params[2] * x1                              # linear in temperature baseline effect 
        + params[3] * x0 * x1                         # interaction between strain and temp 
        + params[4] * (x0 ** 2)                       # quadratic nonlinear elasticity 
        + params[5] * (x1 ** 2)                       # quadratic nonlinear temp effect 
        + params[6] * (x0 ** 2) / (x1 + eps)         # coupling quadratic strain / temp 
        + params[7] * exp_decay * x0                  # temp-dependent softening of stiffness via exp decay times linear strain 
        + params[9] * exp_decay * (x0 ** 3)           # cubic nonlinearity modulated by temp softening 
        + params[10] * log_temp                        # logarithmic temp effect capturing phase changes or transitions 
        + params[11] * inv_temp                        # inverse temp effect capturing softening or phase change effects 
    )
