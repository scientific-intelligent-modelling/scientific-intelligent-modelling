def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Combines polynomial strain terms with temperature-dependent softening and saturation effects.
    - Uses a sigmoid function to model smooth transition of temperature effects on stiffness.
    - Includes rational terms to capture asymptotic strain hardening behavior.
    - Cross-terms include logarithmic and exponential temperature dependencies for complex coupling.
    - Ensures numerical stability by adding small epsilons where needed.

    Model structure:
    y = params[0]
        + params[1]*x0                              # linear strain term
        + params[2]*x1                              # linear temperature term
        + params[3]*x0*x1                           # interaction term (strain * temperature)
        + params[4]*x0**2                           # quadratic strain term (strain hardening)
        + params[5]*x1**2                           # quadratic temperature term
        + params[6]/(x1 + eps)                       # inverse temperature effect (thermal activation)
        + params[7]*x0**3                           # cubic strain term for higher order nonlinearity
        + params[8]*x0**2*x1                        # interaction of quadratic strain and temperature
        + params[9]*np.exp(-params[10]*x1)*x0      # exponential decay of stiffness with temp times strain
        + params[11]*np.log(x1 + eps)               # logarithmic temp dependence for low-temp behavior
        + (params[12] if len(params) > 12 else 0)* (x0 / (1.0 + np.abs(x0)))  # rational asymptotic strain term
        + (params[13] if len(params) > 13 else 0)* x0 * (1 / (1.0+np.exp(-params[14]*(x1-params[15]))))  # sigmoid temp softening on strain

    Note: The last two terms are optional extensions if more parameters are available.
    """

    eps = 1e-8

    y = (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 * x1
        + params[4] * x0**2
        + params[5] * x1**2
        + params[6] / (x1 + eps)
        + params[7] * x0**3
        + params[8] * x0**2 * x1
        + params[9] * np.exp(-params[10] * x1) * x0
        + params[11] * np.log(x1 + eps)
    )

    if len(params) > 12:
      y += params[12] * (x0 / (1.0+np.abs(x0)))

    if len(params) > 15:
      sigmoid = 1. / (1. + np.exp(-params[14]*(x1 - params[15])))
      y += params[13] * x0 * sigmoid

    return y
