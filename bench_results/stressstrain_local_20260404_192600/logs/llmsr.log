    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements:
    - Split combined nonlinear term into two separate weighted parts for better flexibility.
    - Added sinusoidal modulation in strain to capture oscillatory behavior.
    - Added squared logarithmic temperature term for complex thermal effects.

    Parameters mapping (length=12):
        p[0]: constant offset
        p[1]: linear strain
        p[2]: linear temp
        p[3]: interaction strain*temp
        p[4]: quadratic strain^2
        p[5]: quadratic temp^2
        p[6]: cubic strain^3
        p[7]: log(strain)
        p[8]: reciprocal temp (1/temp)
        p[9]: exp(-strain)
        p[10]: rational coupling term (strain / temp)
        p[11]: weight for second nonlinear group

    """
    
    eps = 1e-8
    
    safe_x0 = np.maximum(x0, eps)
    safe_x1 = np.maximum(x1, eps)
    
    # First nonlinear group: tanh(strain)
    nonlinear_1 = np.tanh(safe_x0)
    
    # Second nonlinear group: exp(-temp), strain² * temp, sin(5*strain), log(temp)^2
    nonlinear_2 = (
          np.exp(-safe_x1) 
        + safe_x0**2 * safe_x1 
        + np.sin(5 * safe_x0) 
        + np.log(safe_x1)**2
    )
    
    y = (
          params[0]
        
        + params[1] * safe_x0                       # linear strain
        
        + params[2] * safe_x1                       # linear temp
        
        + params[3] * safe_x0 * safe_x1             # interaction
        
        + params[4] * safe_x0**2                    # quadratic strain
        
        + params[5] * safe_x1**2                    # quadratic temp
        
        + params[6] * safe_x0**3                    # cubic strain
        
        + params[7] * np.log(safe_x0)               # logarithmic strain
        
        + params[8] / safe_x1                        # reciprocal temperature
        
        + params[9]* np.exp(-safe_x0)               # exponential decay in strain
        
        + params[10]* (safe_x0 / safe_x1)           # rational coupling term

        + (params[11]/2)*nonlinear_1                 # half weight on tanh(strain)

        + (params[11]/2)*nonlinear_2                 # half weight on second nonlinear group

       )
    
    return y
