def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain with linear, quadratic, and cubic terms to capture elasticity and nonlinear elasticity.
    - Temperature affects stress linearly and nonlinearly (quadratic, cubic).
    - Interaction terms between strain and temperature capture coupling effects.
    - Inverse absolute temperature term models softening at high temperatures.
    - Exponential decay term models thermal softening or relaxation phenomena.
    - Additional interaction term with inverse temperature to capture complex coupling.

    Variables:
        x0: Strain
        x1: Temperature in Celsius
        y : Stress

    Parameters (length >= 12):
        params[0]: intercept (baseline stress)
        params[1]: linear strain coefficient
        params[2]: linear temperature coefficient
        params[3]: quadratic strain coefficient (strain^2)
        params[4]: quadratic temperature coefficient (temperature^2)
        params[5]: strain * temperature interaction
        params[6]: cubic strain coefficient (strain^3)
        params[7]: cubic temperature coefficient (temperature^3)
        params[8]: strain^2 * temperature interaction
        params[9]: strain * temperature^2 interaction
        params[10]: inverse absolute temperature coefficient
        params[11]: exponential decay rate multiplier for thermal softening

    """
    
    T_kelvin = x1 + 273.15  # Convert Celsius to Kelvin
    
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[6] * x0**3
        + params[7] * x1**3
        + params[8] * (x0**2) * x1
        + params[9] * x0 * (x1**2)
        + params[10] / T_kelvin                      # inverse absolute temp effect 
        + params[11] * np.exp(-params[11] * x1)     # exponential thermal softening 
    )
