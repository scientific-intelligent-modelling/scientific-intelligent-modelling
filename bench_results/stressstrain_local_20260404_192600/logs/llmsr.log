def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends linearly on strain (Hooke's law) at small strains.
    - Temperature reduces stiffness, modeled as an exponential decay factor on strain terms.
    - Nonlinear elasticity captured by quadratic and cubic strain terms.
    - Interaction terms capture coupling between strain and temperature.
    - Additional nonlinear temperature dependence via logarithmic term to model complex thermal effects.

    Proposed model form:
        y = p0
            + p1 * x0
            + p2 * x1
            + p3 * x0 * x1
            + p4 * x0**2
            + p5 * x1**2
            + p6 * (x0**2) / (x1 + eps)
            + p7 * np.exp(-p8 * x1) * x0
            + p9 * (x0**3) * np.exp(-p10 * x1)
            + p11 * np.log(x1 + eps)

    where
        - x0 = strain,
        - x1 = temperature,
        - y = stress,
        - eps is a small number to avoid division by zero or log(0).

    Parameters:
        params (np.ndarray): Trainable coefficients used by the equation skeleton.
                             Expected length >= 12
                             params[0] to params[11] used here.
    """
    eps = 1e-6  # small number to avoid division by zero or log(0)
    
    term_linear_strain = params[1] * x0
    term_linear_temp = params[2] * x1
    term_interaction = params[3] * x0 * x1
    
    term_quad_strain = params[4] * (x0 ** 2)
    term_quad_temp = params[5] * (x1 ** 2)
    
    term_quad_strain_over_temp = params[6] * (x0 ** 2) / (x1 + eps)
    
    term_exp_decay_strain = params[7] * np.exp(-params[8] * x1) * x0
    
    term_cubic_strain_exp_decay_temp = params[9] * (x0 ** 3) * np.exp(-params[10] * x1)
    
    term_log_temp = params[11] * np.log(x1 + eps)
    
    y = (
        params[0]
        + term_linear_strain
        + term_linear_temp
        + term_interaction
        + term_quad_strain
        + term_quad_temp
        + term_quad_strain_over_temp
        + term_exp_decay_strain
        + term_cubic_strain_exp_decay_temp
        + term_log_temp
    )
    
    return y
