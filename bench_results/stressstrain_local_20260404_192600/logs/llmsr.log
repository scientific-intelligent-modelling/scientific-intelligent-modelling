            + p11 * tanh(x0)
            + p12 / (|x0| + eps)
            + (p13 * x0**3) * exp(-p14 * x1)

    Notes:
        - Added inverse strain term to capture softening/damage at low strains.
        - Added cubic strain term modulated by an exponential decay in temperature to model stiffness reduction in nonlinear regime.
        - eps added for numerical stability.

    """
    
    eps = 1e-8
    
    # Basic polynomial and interaction terms
    linear_strain = params[1] * x0
    linear_temp = params[2] * x1
    
    quad_strain = params[3] * x0**2
    quad_temp = params[4] * x1**2
    
    interaction = params[5] * x0 * x1
    
    # Exponential in strain capturing nonlinear stiffening/softening effects
    exp_strain = params[6] * np.exp(params[7] * x0)
    
    # Logarithmic term for asymmetry and nonlinearity in small strains
    log_strain = params[8] * np.log(np.abs(x0) + 1.0)
    
