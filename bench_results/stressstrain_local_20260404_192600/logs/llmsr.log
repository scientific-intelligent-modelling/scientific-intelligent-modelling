        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[6] * inv_temp
        + params[7] * x0**3
        + params[8] * (x0**2) * x1
    )
