def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress-strain relationship is linear at small strains (Hooke's law).
    - Temperature reduces stiffness, often nonlinearly.
    - Interaction terms capture coupling effects.
    - Nonlinear saturation and softening effects modeled by tanh and exp.
    - Logarithmic temperature term captures diminishing returns of temperature effect.
    - Added inverse strain term to capture possible strain softening or damage effects at low strain.
    - Added sigmoid function to model smooth transitions in material behavior with temperature.

    Model form:
        y = p0 
            + p1*x0 
            + p2*x1 
            + p3*x0*x1 
            + p4*x0**2 
            + p5*x1**2
            + p6*np.exp(p7 * x1) * x0  # temperature-dependent stiffness modifier
            + p8*np.tanh(p9 * x0)      # nonlinear strain saturation effect
            + p10*np.log(np.abs(x1)+1) # logarithmic temperature effect
            + p11*(x0 ** 3)
            + p12 / (np.abs(x0) + 1e-6)  # inverse strain term for softening/damage at low strain
            + p13 / (1.0 + np.exp(-p14*(x1 - p15)))  # sigmoid temp transition

    Parameters:
        params: array-like with length >=16 (if fewer, truncate terms accordingly)
    
    Notes:
        To avoid division by zero, small epsilon added in denominator for inverse strain term.
        Sigmoid models smooth transition in stress behavior around a critical temperature.

    """
    
    # Ensure params length is sufficient; if not, fill missing with zeros
    n_params = len(params)
    
    # Safe inputs for log and division
    safe_x1 = np.abs(x1) + 1.0
    safe_x0_inv = 1.0 / (np.abs(x0) + 1e-6)
    
    # Sigmoid parameters default if missing
    def sigmoid(z):
        return 1.0 / (1.0 + np.exp(-z))
    
    # Unpack parameters safely with defaults zero if missing
    p = np.zeros(16)
    length_to_copy = min(n_params,16)
    p[:length_to_copy] = params[:length_to_copy]
    
    y = (
        p[0]
        + p[1] * x0
        + p[2] * x1
        + p[3] * x0 * x1
        + p[4] * x0**2
        + p[5] * x1**2
        + (p[6] * np.exp(p[7] * x1) * x0 if n_params >7 else 0)
        + (p[8] * np.tanh(p[9] * x0) if n_params >9 else 0)
        + (p[10] * np.log(safe_x1) if n_params >10 else 0)
        + (p[11] * (x0 **3) if n_params >11 else 0)
        + (p[12] * safe_x0_inv if n_params >12 else 0)
        # sigmoid term uses three parameters: scale=p14, center=p15; coefficient=p13 multiplies sigmoid output.
        + ((p[13]) *
           sigmoid(p[14]*(x1 - p[15])) if n_params >15 else 0)
     )
    
    return y
