def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain primarily via Hooke's law (linear term).
    - Temperature reduces stiffness exponentially (softening effect).
    - Include nonlinear strain terms to capture material nonlinearity.
    - Include interaction terms between strain and temperature to capture coupling effects.
    - Add quadratic temperature terms for more accurate temperature dependence.
    - Add cubic strain term for higher order nonlinearity.
    - Add a logarithmic temperature term to capture possible saturation or threshold effects.

    Model form:
    y = (p0 + p1*x0 + p2*x0**2 + p7*x0**3) * exp(-p3 * x1) 
        + p4*x0*x1 + p5*x1 + p6*x1**2 
        + p8 * np.log(1 + x1)

    where
    x0 = Strain
    x1 = Temperature
    y = Stress

    Parameters:
        params[0]: constant base stress offset
        params[1]: linear strain coefficient (stiffness)
        params[2]: quadratic strain coefficient (nonlinearity)
        params[3]: temperature decay rate of stiffness (softening)
        params[4]: interaction coefficient between strain and temperature
        params[5]: linear temperature offset term
        params[6]: quadratic temperature offset term
        params[7]: cubic strain coefficient (higher order nonlinearity)
        params[8]: logarithmic temperature coefficient (saturation effect)
    """
    
    strain_poly = params[0] + params[1]*x0 + params[2]*x0**2 + params[7]*x0**3
    temp_decay = np.exp(-params[3] * x1)
    
    interaction = params[4] * x0 * x1
    
    temp_offset = params[5]*x1 + params[6]*x1**2
    
    log_temp_term = 0.0
    # To avoid log(<= 0), ensure argument > 0; assume temperatures >= 0 or shift if needed.
    # Here we assume x1 >= 0; if not, user should preprocess data accordingly.
    
    if np.any(x1 < 0):
        # Shift temperatures by adding abs(min(x1)) + small epsilon to make positive inside log.
        shift = abs(np.min(x1)) + 1e-6
        log_temp_term = params[8] * np.log(1 + x1 + shift)
    else:
        log_temp_term = params[8] * np.log(1 + x1)
    
