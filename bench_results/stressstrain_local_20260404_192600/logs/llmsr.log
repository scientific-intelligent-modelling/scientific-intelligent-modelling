def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain and temperature.
    - Include linear, quadratic, and cubic terms in strain and temperature.
    - Include interaction terms to capture coupling effects.
    - Add exponential decay term in temperature to model thermal softening more physically.
    - Add saturation effect in strain via tanh to model yielding or plastic flow saturation.
    - Add inverse temperature term (in Kelvin) for Arrhenius-type thermal softening.
    - Add logarithmic strain term for small strain behavior.
    
    Model form:
    y = p0 
        + p1*x0 
        + p2*x1 
        + p3*x0*x1 
        + p4*x0**2 
        + p5*x1**2 
        + p6*x0**3
        + p7*(x1 * np.exp(-p8 * x1))  # thermal softening effect
        + p9*(x0**2 * x1)  # nonlinear interaction term
        + p10*np.tanh(p11 * x0)  # saturation effect in strain
        + p12 / (x1 + 273.15)  # inverse absolute temperature (Kelvin)
        + p13 * np.log(np.clip(x0, a_min=1e-8, a_max=None))  # log strain for small strains

    Note:
    - This requires params array of length 14.

    Parameters:
    - params (np.ndarray): array of length 14

    Inputs:
    - x0: strain (dimensionless)
    - x1: temperature in Celsius
    """
    
    temp_kelvin = x1 + 273.15
    
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 * x1
        + params[4] * x0 ** 2
        + params[5] * x1 ** 2
        + params[6] * x0 ** 3
        + params[7] * (x1 * np.exp(-params[8] * x1))
        + params[9] * (x0 ** 2 * x1)
        + params[10] * np.tanh(params[11] * x0)
        + params[12] / temp_kelvin
        + params[13] * np.log(np.clip(x0, a_min=1e-8, a_max=None))
    )
