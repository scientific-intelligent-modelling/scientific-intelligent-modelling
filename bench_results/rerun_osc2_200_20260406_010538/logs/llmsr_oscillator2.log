def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` for nonlinear harmonic oscillator acceleration.

    This version includes physically meaningful terms commonly used in nonlinear oscillators:
    - Constant forcing term
    - Linear time dependence (forcing or parameter drift)
    - Linear restoring force (-k * x)
    - Cubic nonlinearity (-alpha * x^3)
    - Linear damping (-beta * v)
    - Quadratic and cubic velocity terms to capture nonlinear damping effects
    - Interaction terms between position and velocity to capture coupling effects

    Parameters:
        params[0]: constant forcing term (c0)
        params[1]: linear coefficient for time (c_time)
        params[2]: linear restoring force coefficient (-k_lin)
        params[3]: cubic nonlinearity coefficient (-alpha_cu)
        params[4]: linear damping coefficient (-beta_damp)
        params[5]: quadratic term for velocity (v^2) coefficient
        params[6]: cubic term for velocity (v^3) coefficient
        params[7]: interaction term between position and velocity (x*v) coefficient
        params[8]: quadratic term for position (x^2) coefficient
        params[9]: interaction term between time and position (t*x) coefficient
        params[10]: interaction term between time and velocity (t*v) coefficient
        params[11]: higher order mixed term e.g. x^2 * v or similar

    Returns:
        Acceleration array modeled by the nonlinear oscillator equation.
    """
    
    c0         = params[0]
    c_time     = params[1]
    k_lin      = params[2]
    alpha_cu   = params[3]
    beta_damp  = params[4]
    
    v_quad     = params[5]
    v_cubic    = params[6]
    
    xv_inter   = params[7]
    
    x_quad     = params[8]
    
    tx_inter   = params[9]
    
    tv_inter   = params[10]

    # For the last param, assume a mixed nonlinear interaction: x^2 * v
    x2v_inter  = 0 if len(params)<12 else params[11]

    
    return (
        c0 +
        c_time * x0 -
        k_lin * x1 -
        alpha_cu * (x1 ** 3) -
        beta_damp * x2 +
        
        v_quad * (x2 ** 2) +
        v_cubic * (x2 ** 3) +
        
        xv_inter * x1 * x2 +
        
        x_quad * (x1 ** 2) +
        
        tx_inter * x0 * x1 +
        
        tv_inter * x0 * x2 +

        x2v_inter * (x1 ** 2) * x2
    )
