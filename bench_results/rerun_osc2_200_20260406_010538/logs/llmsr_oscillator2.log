def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version extends the previous model by adding:
    - Quartic nonlinear stiffness and damping terms.
    - Mixed nonlinearities with absolute values and sign functions for friction-like effects.
    - Additional cross terms involving time-position-velocity-trig interactions.
    - Parametric excitation with polynomial-time modulated trigonometric functions.
    
    Physical reasoning:
    - Retains linear restoring force and damping.
    - Includes cubic and quartic stiffness nonlinearities (Duffing + higher order).
    - Includes cubic and quartic velocity nonlinear damping plus friction-like effects using abs() and sign().
    - Time-dependent forcing modeled by sinusoids, cosines, exponentials of time (x0).
    - Cross parametric excitation terms involving products of position, velocity, time with trig functions.
    
    Parameters:
        x0 (np.ndarray): time variable t
        x1 (np.ndarray): position at time t
        x2 (np.ndarray): velocity at time t
        params (np.ndarray): array of 12 trainable coefficients

    Returns:
        y (np.ndarray): predicted acceleration d²x/dt²
    """
    
    p = params
    
    y = (
        p[0]                               # constant bias term
        + p[1] * x0                        # linear in time
        + p[2] * x1                        # linear restoring force (-omega^2 * x)
        + p[3] * x2                        # linear damping (-c * v)
        + p[4] * (x1 ** 3)                 # cubic stiffness nonlinearity (Duffing)
        + p[5] * (x2 ** 3)                 # cubic velocity nonlinearity (nonlinear damping)
        + p[6] * (x1 ** 4)                 # quartic stiffness nonlinearity
        + p[7] * np.abs(x2) * x2           # quadratic velocity times abs(velocity), friction-like nonlinear damping
        + p[8] * np.sin(x0)                # sinusoidal forcing in time
        + p[9] * np.exp(-x0)               # exponential decay/growth in time
        + p[10] * ((x1 ** 2) * np.cos(x0))   # quadratic position modulated by cosine(time)
        + p[11] * ((x2 ** 2) * np.sin(x0))   # quadratic velocity modulated by sine(time)
        
        # Optional extended cross parametric excitation terms could be added if more parameters available,
        # but limited here to 12 parameters as per MAX_NPARAMS constraint.
        
        # For example:
        # + p[12]*x0*x1*np.sin(x0)
        
    )
    
    return y
