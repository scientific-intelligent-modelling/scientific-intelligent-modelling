        + params[7]*x2**3             # cubic damping or higher order velocity nonlinearity 
        + params[8]*x0*x1             # cross term time*position
        + params[9]*x0*x2             # cross term time*velocity
        + params[10]*x1*x2            # cross term position*velocity
        + params[11]*(x1**2)*x2       # mixed nonlinear cross term: quadratic position * velocity 
    )
