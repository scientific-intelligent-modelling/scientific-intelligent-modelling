def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration y of a nonlinear harmonic oscillator with damping and nonlinear effects,
    including quadratic terms in position and velocity, and interaction terms with time.

    y ≈ p0 
        + p1*x0                 # linear time dependence (if any)
        + p2*x1                 # linear position term (restoring force)
        + p3*x2                 # linear velocity term (damping)
        + p4*(x1 ** 3)          # cubic nonlinearity in position (Duffing-type)
        + p5*(x2 ** 2)          # quadratic nonlinearity in velocity
        + p6*(x1 * x2)          # cross term position*velocity
        + p7*(x1 ** 2)          # quadratic position term
        + p8*(x2 ** 3)          # cubic velocity term
        + p9*(x0 * x1)          # time-position interaction
        + p10*(x0 * x2)         # time-velocity interaction
        + p11*(x0 ** 2)         # quadratic time term

    Parameters:
    - x0: time t
    - x1: position at time t
    - x2: velocity at time t
    - params: array of parameters [p0,...,p11]

    Returns:
    - y: acceleration at time t
    """
    
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x2
        + params[4] * (x1 ** 3)
        + params[5] * (x2 ** 2)
        + params[6] * (x1 * x2)
        + params[7] * (x1 ** 2)
        + params[8] * (x2 ** 3)
        + params[9] * (x0 * x1)
        + params[10] * (x0 * x2)
        + params[11] * (x0 ** 2)
    )
