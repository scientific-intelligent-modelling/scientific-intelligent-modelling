    return (
        params[0]                             # constant offset / forcing term
        + params[1] * x0                     # linear time dependence (optional external forcing)
        + params[2] * x1                     # linear restoring force (-k * x)
        + params[3] * (x1 ** 3)              # cubic stiffness nonlinearity (-k_nl * x^3)
