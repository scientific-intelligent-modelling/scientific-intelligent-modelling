def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration of nonlinear harmonic oscillator with polynomial terms,
    emphasizing physically meaningful contributions:
    - Linear restoring force proportional to position (x1)
    - Linear damping proportional to velocity (x2)
    - Nonlinear stiffness via cubic term in position (x1**3) and quadratic term (x1**2)
    - Nonlinear damping via cubic term in velocity (x2**3) and quadratic term (x2**2)
    - Cross terms between position and velocity for coupling effects
    - Time-dependent forcing or parametric excitation terms up to quadratic order

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of 12 parameters

    Returns:
        y: acceleration array computed from the model
    """
    
    return (
        params[0] * x1 +            # linear restoring force ~ -k*x
        params[1] * x2 +            # linear damping ~ -c*v
        params[2] * x1**3 +         # nonlinear stiffness cubic term
        params[3] * x2**3 +         # nonlinear damping cubic term
        params[4] * x1 * x2 +       # coupling linear cross-term
        params[5] * x1**2 +         # quadratic nonlinearity in position
        params[6] * x2**2 +         # quadratic nonlinearity in velocity
        params[7] * x0 +            # linear time-dependent forcing/parametric effect 
        params[8] * x0**2 +         # quadratic time-dependent forcing/parametric effect 
        params[9] * x0 * x1 +       # cross-term between time and position 
        params[10]* x0 * x2 +       # cross-term between time and velocity 
        params[11]                   # constant offset / bias force if any 
    )
