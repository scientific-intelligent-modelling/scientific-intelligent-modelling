        + params[1]*x0
        + params[9]*(x0**2)
        + params[10]*x0*x1
        + params[11]*x0*x2
        
        + params[2]*x1
        + params[3]*(x1**3)
        
        + params[4]*x2
        + params[5]*(x2**2)
        
        + params[6]*x1*x2
        + params[7]*(x1**2)*x2
        + params[8]*x1*(x2**2)
        
# If you want to include the last three high-order couplings from v1 instead of some above terms,
# you can extend param size or replace some lower priority terms.
# For example:
#     #+params[n]*(...) for n=9..11 as in v1 for more complex interactions.
        
    )
