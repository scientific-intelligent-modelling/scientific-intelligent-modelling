def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0` that includes nonlinear terms typical for nonlinear oscillators.
    
    Parameters:
    - params (np.ndarray): Trainable coefficients [a0, a1, ..., a11]
    
    Returns:
    - y (np.ndarray): Predicted acceleration
    """
    # Unpack parameters for clarity
    p = params
    
    # Construct nonlinear terms:
    # Constant term + linear in time, position and velocity
    # Cubic and quadratic cross terms in position and velocity to capture nonlinearity
    y = (
        p[0]                      # constant term
        + p[1] * x0               # linear time dependence (often zero or small)
        + p[2] * x1               # linear position term (-omega^2 * x)
        + p[3] * x2               # linear velocity term (damping)
        + p[4] * (x1 ** 3)        # cubic position nonlinearity (Duffing type)
        + p[5] * (x2 ** 3)        # cubic velocity nonlinearity
        + p[6] * (x1 ** 2) * x2   # quadratic position times velocity
        + p[7] * x1 * (x2 ** 2)   # position times quadratic velocity
        + p[8] * (x0 ** 2)        # quadratic time dependence if needed
        + p[9] * np.sin(x0)       # possible periodic forcing or parametric excitation term
        + p[10] * np.exp(-x0)     # damping or decay related exponential term in time 
        + p[11] * np.abs(x2)      # absolute velocity effect e.g. friction-like nonlinearity 
    )
    
    return y
