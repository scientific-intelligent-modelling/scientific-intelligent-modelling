def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Calculates acceleration for a nonlinear harmonic oscillator given time (x0),
    position (x1), and velocity (x2).

    Model includes:
    - linear and cubic stiffness terms,
    - linear damping,
    - quadratic nonlinearities in position and velocity,
    - cross terms between position and velocity,
    - sinusoidal forcing terms dependent on time.

    Parameters:
        x0 (np.ndarray): time
        x1 (np.ndarray): position at time t
        x2 (np.ndarray): velocity at time t
        params (np.ndarray): array of coefficients [a0,...,a13]

    Returns:
        np.ndarray: acceleration values
    """

    (
        a0,   # constant offset
        a1,   # linear time dependence
        a2,   # linear position coefficient (~ -ω²)
        a3,   # damping coefficient (~ -β)
        a4,   # cubic stiffness coefficient (~ -α)
        a5,   # sine forcing amplitude 1
        a6,   # sine forcing frequency multiplier 1
        a7,   # quadratic position coefficient
        a8,   # quadratic velocity coefficient
        a9,   # cross term coefficient (position * velocity)
        a10,  # cosine forcing amplitude 1
        a11,  # cosine forcing frequency multiplier 1
        a12,  # sine forcing amplitude 2 (higher harmonic)
        a13   # sine forcing frequency multiplier 2 (higher harmonic)
    ) = params[:14]

    return (
          a0
        + a1 * x0                         # linear in time term for possible drift or external influence 
        + a2 * x1                        # linear restoring force term (-ω² x)
        + a3 * x2                        # damping term (-β v)
        + a4 * (x1 ** 3)                 # cubic nonlinearity in restoring force (-α x³)
        + a7 * (x1 ** 2)                 # quadratic nonlinearity in position 
        + a8 * (x2 ** 2)                 # quadratic nonlinearity in velocity 
        + a9 * (x1 * x2)                 # cross term between position and velocity 
        + a5 * np.sin(a6 * x0)           # sinusoidal forcing term at fundamental frequency 
        + a10 * np.cos(a11 * x0)         # cosine forcing term at fundamental frequency 
        + a12 * np.sin(a13 * x0)         # additional sinusoidal forcing at higher harmonic or different freq.
    )
