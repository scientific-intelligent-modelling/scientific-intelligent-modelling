def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version includes:
    - Constant term
    - Linear terms in time (x0), position (x1), velocity (x2)
    - Cubic nonlinearities in position and velocity
    - Quadratic cross-terms between position and velocity
    - Quadratic time dependence
    - Periodic forcing term via sine(time)
    - Exponential decay/growth term in time
    - Absolute velocity term for friction-like effects
    - Additional mixed nonlinear terms to capture complex interactions

    Parameters:
        x0 (np.ndarray): Time variable array
        x1 (np.ndarray): Position at time t array
        x2 (np.ndarray): Velocity at time t array
        params (np.ndarray): Array of 12 trainable parameters

    Returns:
        y (np.ndarray): Predicted acceleration array
    """
    
    p = params
    
    y = (
        p[0]                        # constant offset term
        + p[1] * x0                 # linear time dependence (e.g., slow drift or parametric effect)
        + p[2] * x1                 # linear restoring force (-omega^2 * x)
        + p[3] * x2                 # linear damping term (-c * v)
        + p[4] * (x1 ** 3)          # cubic stiffness nonlinearity (Duffing oscillator)
        + p[5] * (x2 ** 3)          # cubic velocity nonlinearity, e.g., nonlinear damping or drag
        + p[6] * (x1 ** 2) * x2     # quadratic position times velocity coupling term 
        + p[7] * x1 * (x2 ** 2)     # position times quadratic velocity coupling 
        + p[8] * (x0 ** 2)          # quadratic time dependence for parametric effects or trends 
        + p[9] * np.sin(x0)         # periodic forcing or parametric excitation 
        + p[10] * np.exp(-x0)       # exponential decay/growth with time, e.g., transient effects 
        + p[11] * np.abs(x2)         # friction-like absolute velocity effect 
    )
    
    return y
