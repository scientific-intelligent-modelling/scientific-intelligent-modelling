def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version refines the nonlinear oscillator acceleration model by including
    additional interaction terms and nonlinearities that can capture complex dynamics.

    Parameters:
    - x0 (np.ndarray): time variable
    - x1 (np.ndarray): position at time t
    - x2 (np.ndarray): velocity at time t
    - params (np.ndarray): Trainable coefficients [a0,...,a11]

    Returns:
    - y (np.ndarray): predicted acceleration at time t
    """
    
    p = params
    
    # Nonlinear oscillator acceleration model including:
    # constant offset,
    # linear terms in time, position and velocity,
    # cubic and quadratic nonlinearities in position and velocity,
    # cross terms between position and velocity,
    # quadratic time dependence,
    # periodic forcing term in time,
    # exponential decay term in time,
    # friction-like absolute velocity term.
    
    y = (
        p[0]                      # constant term
        + p[1] * x0               # linear dependence on time (e.g., slow drift or parametric effect)
        + p[2] * x1               # linear restoring force (-omega^2 * x)
        + p[3] * x2               # linear damping term (-c * v)
        + p[4] * (x1 ** 3)        # Duffing-type cubic stiffness nonlinearity
        + p[5] * (x2 ** 3)        # cubic velocity nonlinearity (less common but possible)
        + p[6] * (x1 ** 2) * x2   # quadratic position times velocity coupling
        + p[7] * x1 * (x2 ** 2)   # position times quadratic velocity coupling
        + p[8] * (x0 ** 2)        # quadratic time dependence for parametric effects or trends
        + p[9] * np.sin(x0)       # periodic forcing or parametric excitation term in time
        + p[10] * np.exp(-x0)     # exponential decay/damping related to time
        + p[11] * np.abs(x2)      # friction-like nonlinearity depending on speed magnitude
    )
    
    return y
