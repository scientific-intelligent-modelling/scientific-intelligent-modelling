def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration as a nonlinear harmonic oscillator with damping,
    nonlinear restoring forces, velocity-dependent damping, and time-dependent forcing.
    
    The model includes:
    - Constant offset (bias)
    - Linear terms in time (x0), position (x1), velocity (x2)
    - Nonlinear restoring force terms: cubic and quadratic in position
    - Nonlinear damping terms: quadratic and cubic in velocity
    - Cross terms coupling position and velocity
    - Quadratic time dependence and cross terms involving time
    
    Mathematical form:
    
        y ≈ p0 
            + p1*x0 
            + p2*x1 
            + p3*x2 
            + p4*(x1 ** 3) 
            + p5*(x2 ** 2) 
            + p6*(x1 * x2)
            + p7*(x1 ** 2)
            + p8*(x0 ** 2)
            + p9*(x0 * x1)
            + p10*(x0 * x2)
            + p11*(x2 ** 3)

    Parameters:
        x0 (np.ndarray): time array
        x1 (np.ndarray): position array at time t
        x2 (np.ndarray): velocity array at time t
        params (np.ndarray): array of length 12 containing coefficients

    Returns:
        y (np.ndarray): acceleration values at each time step
    """
    
    # Unpack parameters for clarity
    (
        c0,   # constant offset / bias term
        c_t,  # linear in time term (external forcing or drift)
        c_x,  # linear restoring force coefficient (~position)
        c_v,  # linear damping coefficient (~velocity)
        c_x3, # cubic restoring force nonlinearity (~position^3)
        c_v2, # quadratic velocity term (nonlinear damping ~ velocity^2)
        c_xv, # coupling between position and velocity (~position*velocity)
        c_x2, # quadratic position term for asymmetry/nonlinearity (~position^2)
        c_t2, # quadratic time dependence for complex forcing/drift (~time^2)
        c_tx, # cross term between time and position (~time*position)
        c_tv, # cross term between time and velocity (~time*velocity)
        c_v3  # cubic velocity term for higher order damping effects (~velocity^3)
    ) = params

    y = (
          c0
          + c_t * x0
          + c_x * x1
          + c_v * x2
          + c_x3 * (x1 ** 3)
          + c_v2 * (x2 ** 2)
          + c_xv * (x1 * x2)
          + c_x2 * (x1 ** 2)
          + c_t2 * (x0 ** 2)
          + c_tx * (x0 * x1)
          + c_tv * (x0 * x2)
          + c_v3 * (x2 ** 3)  
      )
    
    return y
