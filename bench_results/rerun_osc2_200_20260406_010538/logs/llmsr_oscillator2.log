def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1` for nonlinear harmonic oscillator acceleration.

    Model structure:
        y = a0 
            + a1*x0                     # linear time dependence (e.g., drift or parametric excitation)
            + a2*x1                     # linear restoring force (~ -ω² * x)
            + a3*x2                     # linear damping (~ -β * v)
            + a4*(x1**3)                # cubic stiffness nonlinearity (~ -α * x³)
            + a5*sin(a6*x0)             # sinusoidal forcing term
            + a7*(x1**2)                # quadratic position term (nonlinear correction)
            + a8*(x2**2)                # quadratic velocity term (nonlinear damping effect)
            + a9*(x1*x2)                # cross term coupling position and velocity
            + a10*cos(a11*x0)           # cosine forcing term

    Parameters:
        params (np.ndarray): array of coefficients [a0,a1,...a11]

    Returns:
        np.ndarray: acceleration values
    """

    (
        a0,  # constant offset
        a1,  # linear time dependence
        a2,  # linear position coefficient (~ -ω²)
        a3,  # damping coefficient (~ -β)
        a4,  # cubic stiffness coefficient (~ -α)
        a5,  # sine forcing amplitude
        a6,  # sine forcing frequency multiplier
        a7,  # quadratic position coefficient
        a8,  # quadratic velocity coefficient
        a9,  # cross term coefficient (position * velocity)
        a10, # cosine forcing amplitude
        a11  # cosine forcing frequency multiplier
    ) = params[:12]

    return (
          a0
        + a1 * x0
        + a2 * x1
        + a3 * x2
        + a4 * (x1 ** 3)
        + a5 * np.sin(a6 * x0)
        + a7 * (x1 ** 2)
        + a8 * (x2 ** 2)
       +a9 * (x1 * x2)
       +a10 * np.cos(a11 * x0)
    )
