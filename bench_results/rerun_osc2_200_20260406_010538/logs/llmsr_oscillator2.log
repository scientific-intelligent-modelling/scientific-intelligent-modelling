def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version includes:
    - Constant offset and linear/quadratic time dependence
    - Linear, quadratic, cubic position dependence (restoring force + nonlinear stiffness)
    - Linear, quadratic, cubic velocity dependence (damping + nonlinear damping)
    - Cross terms between position and velocity capturing interaction effects
    - Time-modulated quadratic velocity term modeling time-varying damping

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array-like coefficients [p0,...p11]

    Returns:
        acceleration array y approximating the nonlinear oscillator acceleration.
    """
    
    return (
        params[0]                      # constant offset
        
        + params[1] * x0               # linear time dependence
        
        + params[2] * (x0 ** 2)       # quadratic time dependence
        
        + params[3] * x1              # linear position term (restoring force)
        
        + params[4] * (x1 ** 2)       # quadratic position nonlinearity
        
