def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Further extends the nonlinear harmonic oscillator acceleration model by including:
    - Quadratic and cubic terms in time to capture possible time-dependent forcing or drift.
    - Mixed nonlinear terms involving position and velocity to capture complex damping/restoring forces.
    - Cross terms involving velocity squared times position and vice versa.
    - Nonlinear friction-like effects using absolute values of velocity.
    - Parametric excitation modeled by sinusoids of combined variables.

    Equation form:
        y = p0 
            + p1 * t 
            + p2 * x 
            + p3 * v 
            + p4 * x^3 
            + p5 * v^3 
            + p6 * (x^2) * v 
            + p7 * x * (v^2) 
            + p8 * sin(t) 
            + p9 * exp(-t) 
            + p10 * |v| 
            + p11 * t*x
            + p12 * t^2
            + p13 * t^3
            + p14 * |x|*v
            + p15 * sin(x*v)
    
    Parameters:
        x0 (np.ndarray): time variable t
        x1 (np.ndarray): position at time t
        x2 (np.ndarray): velocity at time t
        params (np.ndarray): array of 16 trainable coefficients

    Returns:
        y (np.ndarray): predicted acceleration d²x/dt²
    """
    
    # Ensure params has length 16 for this extended model
    assert len(params) >= 16, "params must have at least 16 elements"
    
    y = (
        params[0]                             # constant bias term
        + params[1] * x0                      # linear in time
        + params[2] * x1                      # linear restoring force term (-omega^2*x)
        + params[3] * x2                      # linear damping term (-c*v)
        + params[4] * (x1 ** 3)               # cubic stiffness nonlinearity (Duffing term)
        + params[5] * (x2 ** 3)               # cubic velocity nonlinearity (nonlinear damping)
        + params[6] * (x1 ** 2) * x2          # quadratic position times velocity coupling
        + params[7] * x1 * (x2 ** 2)          # position times quadratic velocity coupling
        + params[8] * np.sin(x0)               # sinusoidal forcing or parametric excitation in time
        + params[9] * np.exp(-x0)              # exponential decay/growth with time
        + params[10] * np.abs(x2)              # friction-like absolute velocity effect
        + params[11] * x0 * x1                 # cross term: time times position modulation
        
        # Additional higher order / nonlinear terms beyond v1:
        
        + params[12] * (x0 ** 2)               # quadratic in time for more complex drift/forcing
        
        + params[13] * (x0 ** 3)               # cubic in time
        
        + params[14] * np.abs(x1)*x2           # friction-like effect modulated by position magnitude
        
        + params[15] * np.sin(x1*x2)           # parametric excitation from product of position & velocity
        
    )
    
    return y
