def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Physically motivated nonlinear harmonic oscillator acceleration model.

    Model form:
        y = p0 * x1                      # linear restoring force (-k*x)
          + p1 * (x1 ** 3)               # cubic stiffness nonlinearity
          + p2 * x2                      # linear damping (-c*v)
          + p3 * (x2 ** 3)               # nonlinear damping
          + p4 * (x1 ** 2) * x2          # mixed nonlinear damping/restoring interaction
          + p5 * np.sin(p6 * x0 + p7)   # periodic forcing with frequency and phase shift
          + p8                           # constant offset

    Parameters:
        - x0: time array
        - x1: position array at time t
        - x2: velocity array at time t
        - params: array-like of length >= 9 containing parameters:
            params[0]: linear stiffness coefficient (should be negative for restoring force)
            params[1]: cubic stiffness coefficient 
            params[2]: linear damping coefficient (should be negative for dissipation)
            params[3]: nonlinear damping coefficient 
            params[4]: mixed nonlinear interaction coefficient 
            params[5]: forcing amplitude 
            params[6]: forcing angular frequency 
            params[7]: forcing phase shift 
            params[8]: constant offset

    Returns:
        - y: acceleration array corresponding to the input arrays.
    """
    
    return (
        params[0] * x1
        + params[1] * (x1 ** 3)
        + params[2] * x2
        + params[3] * (x2 ** 3)
        + params[4] * (x1 ** 2) * x2
        + params[5] * np.sin(params[6] * x0 + params[7])
        + params[8]
    )
