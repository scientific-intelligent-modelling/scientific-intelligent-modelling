    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Background:
    Calculate Acceleration in Non-linear Harmonic Oscillator given Time (x0), Position (x1), and Velocity (x2).

    Variables:
    - Independents: x0 (time), x1 (position), x2 (velocity)
    - Dependent: y (acceleration)

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.

    Returns:
    - y (np.ndarray): acceleration computed from the model.

    Notes:
    This version adds higher order nonlinearities, cross terms,
    and time-dependent modulations to better capture complex dynamics.
    """
    
    # Base linear and low-order nonlinear terms
    y = (
        params[0]                              # constant offset / bias
        + params[1] * x0                      # linear forcing term in time
        + params[2] * x1                      # linear restoring force ~ position
        + params[3] * x2                      # linear damping ~ velocity
        + params[4] * (x1 ** 3)               # cubic nonlinearity in position (Duffing term)
        + params[5] * (x1 ** 2)               # quadratic nonlinearity in position
        + params[6] * (x2 ** 2)               # quadratic nonlinearity in velocity (nonlinear damping)
        + params[7] * (x1 * x2)               # cross term between position and velocity
        + params[8] * (x0 * x1)               # time-position interaction term
        + params[9] * (x0 * x2)               # time-velocity interaction term
        + params[10] * (x2 ** 3)              # cubic nonlinearity in velocity
        + params[11] * np.sin(x0)             # periodic forcing from time variable
    )
    
    n = len(params)
    
    if n > 12:
        y += 0.5 * params[12 % n] * (x1 ** 4)           # quartic stiffness nonlinearity
    
    if n > 13:
        y += 0.5 * params[13 % n] * ((x1 ** 2) * x2)     # mixed quadratic position with velocity
    
    if n > 14:
        y += 0.5 * params[14 % n] * np.cos(x0) * x1      # parametric forcing modulated by cos(time)
    
    if n > 15:
        y += 0.5 * params[15 % n] * np.exp(-np.abs(x0)) * x2   # exponentially decaying damping modulation
    
    if n > 16:
        y += 0.3 * params[16 % n] * np.tanh(x1)          # saturation effect on restoring force
    
    if n > 17:
        y += 0.3 * params[17 % n] * np.sign(x2)          # dry friction-like damping
    
    if n > 18:
        y += 0.3*params[18 % n]*np.sin(2*x0)*x1          # higher harmonic parametric forcing
    
