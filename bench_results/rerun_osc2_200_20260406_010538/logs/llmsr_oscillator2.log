def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Further improved version of `equation_v1`.

    This version adds more nonlinear interaction terms and flexible time dependencies,
    aiming to capture complex dynamics of a nonlinear harmonic oscillator.

    Parameters:
    - params (np.ndarray): Trainable coefficients [p0, p1, ..., p11]

    Returns:
    - y (np.ndarray): Predicted acceleration values
    """
    p = params

    # Terms explanation:
    # p[0]: constant bias term
    # p[1]*x0 + p[8]*x0^2 + p[9]*sin(x0) + p[10]*exp(-x0): time-dependent forcing/drift
    # p[2]*x1 + p[4]*x1^3: linear + cubic restoring force (Duffing nonlinearity)
    # p[3]*x2 + p[5]*x2^3 + p[11]*|x2|: linear and nonlinear damping/friction effects
    # Cross nonlinear couplings between position and velocity:
    #   p[6]*(x1^2)*x2 + p[7]*x1*(x2^2)
    
    y = (
        p[0]                      # constant term (bias)
        + p[1] * x0               # linear time dependence (parametric excitation)
        + p[8] * (x0 ** 2)        # quadratic time dependence
        + p[9] * np.sin(x0)       # sinusoidal time forcing
        + p[10] * np.exp(-x0)     # exponential decay/growth in time
        
        + p[2] * x1               # linear restoring force (-omega^2 * x)
        + p[4] * (x1 ** 3)        # cubic stiffness nonlinearity
        
        + p[3] * x2               # linear damping term
        + p[5] * (x2 ** 3)        # cubic velocity nonlinearity (nonlinear damping)
        + p[11] * np.abs(x2)      # friction-like absolute velocity effect
        
        + p[6] * (x1 ** 2) * x2   # quadratic position times velocity coupling
        + p[7] * x1 * (x2 ** 2)   # position times quadratic velocity coupling
    )

    return y
