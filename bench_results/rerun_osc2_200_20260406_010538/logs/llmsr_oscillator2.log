def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further refines the nonlinear oscillator acceleration model by including:
    - Constant forcing term
    - Linear and quadratic time dependence terms (to model external or parametric forcing)
    - Linear, quadratic, cubic restoring force terms in position
    - Linear, quadratic, cubic damping terms in velocity
    - Interaction terms between position and velocity up to cubic order
    - Higher order cross terms for more flexibility

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of parameters with length up to MAX_NPARAMS (12),
                where each param corresponds to a coefficient of a term below.

                Suggested param indexing:
                params[0]  = constant forcing term (c0)
                params[1]  = linear time coefficient (c_time)
                params[2]  = linear position coefficient (-k_lin)
                params[3]  = quadratic position coefficient (pos^2)
                params[4]  = cubic position coefficient (-alpha_cu)
                params[5]  = linear velocity coefficient (-beta_damp)
                params[6]  = quadratic velocity coefficient (vel^2)
                params[7]  = cubic velocity coefficient (-gamma_cu_vel)
                params[8]  = interaction pos * vel term
                params[9]  = interaction pos^2 * vel term
                params[10] = interaction pos * vel^2 term
                params[11] = higher order interaction pos^2 * vel^2 or other

    Returns:
        Acceleration array modeled by the nonlinear oscillator equation.
    """

    c0           = params[0]
    c_time       = params[1]
    k_lin        = params[2]
    quad_pos     = params[3]
    alpha_cu     = params[4]
    beta_damp    = params[5]
    quad_vel     = params[6]
    gamma_cu_vel = params[7]

    inter_pos_vel      = params[8]
    inter_pos2_vel     = params[9]
    inter_pos_vel2     = params[10]
    inter_pos2_vel2_hi= params[11]

    return (
        c0 +
        c_time * x0 +
        # Time squared term could be added if desired as well,
        # but limited to MAX_NPARAMS=12 here.
        
        # Restoring force terms in position (linear + nonlinear)
        - k_lin * x1 +
        quad_pos * (x1 ** 2) -
        alpha_cu * (x1 ** 3) +

        # Damping terms in velocity (linear + nonlinear)
        - beta_damp * x2 +
        quad_vel * (x2 ** 2) -
        gamma_cu_vel * (x2 ** 3) +

        # Interaction terms between position and velocity
        inter_pos_vel * (x1 * x2) +
        inter_pos2_vel * (x1 ** 2 * x2) +
        inter_pos_vel2 * (x1 * x2 ** 2) +
        
        # Higher order interaction term for flexibility
        inter_pos2_vel2_hi * (x1 ** 2 * x2 ** 2)
    )
