def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved physically meaningful nonlinear harmonic oscillator acceleration model.

    Model:
        y = params[0] 
            + params[1]*x1             # linear restoring force
            + params[2]*x1**3         # nonlinear restoring force
            + params[3]*x2            # damping (should be negative)
            + params[4]*np.cos(params[5]*x0)   # external periodic forcing
            + sum of small correction terms from remaining parameters if desired

    Parameters:
        - params (np.ndarray): array of length MAX_NPARAMS=12

    Returns:
        - y (np.ndarray): predicted acceleration values
    """
    # Base physically meaningful terms
    y = (
        params[0] +
        params[1] * x1 +
        params[2] * (x1 ** 3) +
        params[3] * x2 +
        params[4] * np.cos(params[5] * x0)
    )
    
    # Optionally add small correction terms using remaining parameters if desired,
    # e.g. quadratic velocity or cross terms:
    
    y += (
        params[6] * (x2 ** 2) +
        params[7] * (x1 ** 2) +
        params[8] * (x0 * x1) +
        params[9] * (x0 * x2) +
        params[10] * (x1 * x2) +
        params[11] * np.sin(x0)
    )
    
    return y
