def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of nonlinear harmonic oscillator with cubic and quartic nonlinearities,
    linear and nonlinear damping, various cross terms, and additional mixed nonlinearities.

    Variables:
    - x0: time t (optional linear time dependence)
    - x1: position at time t
    - x2: velocity at time t

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length up to 12.

    Equation form:
      y = p0 
        + p1*x0 
        + p2*x1 
        + p3*x1^3 
        + p4*x2 
        + p5*x2^2 
        + p6*x1*x2
        + p7*(x1^2)*x2
        + p8*x1*(x2^2)
        + p9*(x1^4)
        + p10*(x2^3)
        + p11*(x1^3)*x2

    Physically:
      - p0 : constant forcing term
      - p1 : linear time dependence (optional external forcing)
      - p2 : linear restoring force coefficient (-k)
      - p3 : cubic stiffness coefficient (-k_nl)
      - p4 : linear damping coefficient (-c)
      - p5 : quadratic velocity term (nonlinear damping or forcing)
      - p6 : coupling between position and velocity (energy exchange/damping modulation)
      - p7 : higher order cross term involving position squared times velocity
      - p8 : higher order cross term involving position times velocity squared
      - p9 : quartic stiffness nonlinearity (higher order restoring force)
      - p10: cubic velocity nonlinearity (higher order damping or forcing)
      - p11: mixed higher order nonlinear term combining cubic position and velocity

    Returns:
    - y: acceleration at time t
    """
    
    return (
        params[0]                             # constant offset / forcing term
        + params[1] * x0                     # linear time dependence (optional external forcing)
        + params[2] * x1                     # linear restoring force (-k * x)
        + params[3] * (x1 ** 3)              # cubic stiffness nonlinearity (-k_nl * x^3)
        + params[4] * x2                     # linear damping term (-c * v)
        + params[5] * (x2 ** 2)              # quadratic velocity term (nonlinear damping/forcing)
        + params[6] * x1 * x2                # cross term between position and velocity
        + params[7] * (x1 ** 2) * x2         # higher order cross term involving position squared times velocity
        + params[8] * x1 * (x2 ** 2)         # higher order cross term involving position times velocity squared
        + params[9] * (x1 ** 4)               # quartic stiffness nonlinearity in position
        + params[10] * (x2 ** 3)              # cubic nonlinearity in velocity for advanced damping effects
        + params[11] * (x1 ** 3) * x2         # mixed higher order nonlinear coupling between cubic position and velocity
    )
