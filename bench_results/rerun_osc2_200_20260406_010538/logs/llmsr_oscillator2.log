def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1` with additional physically meaningful nonlinear and mixed terms.

    Background:
    Calculate Acceleration in Nonlinear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: 
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
    - Dependent:
        y: acceleration array

    Equation form:
    y = p0 
        + p1 * x1                      # linear restoring force term (like -k*x)
        + p2 * (x1 ** 3)              # cubic nonlinearity in position (Duffing oscillator term)
        + p3 * x2                     # linear damping term (like -c*v)
        + p4 * (x2 ** 3)              # nonlinear damping term
        + p5 * (x1 ** 2) * x2         # mixed nonlinearity coupling position squared and velocity
        + p6 * x1 * (x2 ** 2)         # another mixed nonlinearity coupling position and velocity squared
        + p7 * x0                     # linear time dependence / forcing term
        + p8 * (x0 ** 2)              # quadratic time dependence / forcing term
        + p9 * (x0 * x1)              # cross term between time and position
        + p10 * (x0 * x2)             # cross term between time and velocity
        + p11 * (x1 ** 4)             # quartic nonlinearity in position for stronger anharmonicity

    Parameters:
    - params: array of parameters [p0,...p11]

    Returns:
    - y: acceleration array at each point corresponding to inputs.
    """
    
    return (
        params[0]
        + params[1] * x1 
        + params[2] * (x1 ** 3)
        + params[3] * x2 
        + params[4] * (x2 ** 3)
        + params[5] * (x1 ** 2) * x2 
        + params[6] * x1 * (x2 ** 2)
        + params[7] * x0 
        + params[8] * (x0 ** 2)
        + params[9] * (x0 * x1)
        + params[10] * (x0 * x2)
        + params[11] * (x1 ** 4)
    )
