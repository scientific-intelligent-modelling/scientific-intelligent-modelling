    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration of nonlinear harmonic oscillator with polynomial terms,
    including linear and nonlinear stiffness, damping, mixed interaction terms,
    and time-dependent forcing up to cubic order.

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of 12 parameters corresponding to coefficients:

            params[0]  = constant forcing term (c0)
            params[1]  = linear time coefficient (c_time)
            params[2]  = linear position stiffness (-k_lin)
            params[3]  = cubic position stiffness (-alpha_cu)
            params[4]  = linear velocity damping (-beta_damp)

            params[5]  = quadratic position stiffness (-k_quad_pos)
            params[6]  = quadratic velocity damping (-beta_quad_vel)

            params[7]  = mixed quadratic pos-vel interaction (pos^2 * vel)
            params[8]  = mixed quadratic pos-vel interaction (pos * vel^2)

            params[9]  = quadratic time forcing term (c_time_quad * x0^2)
            params[10] = cubic time forcing term (c_time_cu * x0^3)

            params[11] = quartic position stiffness (-alpha_qt_pos4)

    Returns:
        Acceleration array modeled by the nonlinear oscillator equation.
    """

    c0             = params[0]
    c_time         = params[1]
    k_lin          = params[2]
    alpha_cu       = params[3]
    beta_damp      = params[4]

    k_quad_pos     = params[5]
    beta_quad_vel  = params[6]

    mix_pos2_vel   = params[7]
    mix_pos_vel2   = params[8]

    c_time_quad    = params[9]
    c_time_cu      = params[10]

    alpha_qt_pos4  = params[11]

    return (
        c0
        + c_time * x0
        + c_time_quad * (x0 ** 2)
        + c_time_cu * (x0 ** 3)
        - k_lin * x1
