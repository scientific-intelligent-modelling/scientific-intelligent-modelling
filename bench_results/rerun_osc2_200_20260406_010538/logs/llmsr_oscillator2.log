        # Nonlinear damping / velocity squared term without explicit time dependence
        + params[5] * (x2 ** 2)
        
        # Cross nonlinearities without explicit time dependence
        + params[6] * x1 * x2
        
        # Additional mixed nonlinearity term without explicit time dependence
        + params[8] * (x1 ** 2) * x2
    )
