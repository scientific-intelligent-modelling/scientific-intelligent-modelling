def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved nonlinear harmonic oscillator acceleration model.

    Adds:
    - Mixed polynomial coupling terms between position and velocity.
    - Parametric excitation modulated by both time and state variables.
    - Nonlinear damping including sign-dependent friction.
    - Higher order nonlinearities within 12 parameters.

    Parameters:
        x0 (np.ndarray): time variable t
        x1 (np.ndarray): position at time t
        x2 (np.ndarray): velocity at time t
        params (np.ndarray): array of 12 trainable coefficients

    Returns:
        y (np.ndarray): predicted acceleration d²x/dt²
    """
    
    p = params
    
    y = (
        p[0]                              # constant bias term
        
        + p[1] * x0                       # linear in time
        
        + p[2] * x1                       # linear restoring force (-omega^2 * x)
        
        + p[3] * x2                       # linear damping (-c * v)
        
        + p[4] * (x1 ** 3)                # cubic stiffness nonlinearity (Duffing)
        
        + p[5] * (x2 ** 3)                # cubic nonlinear damping
        
        + p[6] * x1 * (x2 ** 2)           # mixed nonlinear coupling: position times squared velocity
        
        + p[7] * (x1 ** 2) * x2           # mixed nonlinear coupling: squared position times velocity
        
        + p[8] * np.sin(x0) * x1          # parametric excitation modulated by sin(time)*position
        
        + p[9] * np.exp(-x0) * x2         # exponential decay/growth modulated by velocity
        
        + p[10] * np.sign(x2)              # friction-like effect depending on direction of velocity
        
        + p[11] * np.cos(2*x0)             # higher harmonic forcing in time only
    )
    
    return y
