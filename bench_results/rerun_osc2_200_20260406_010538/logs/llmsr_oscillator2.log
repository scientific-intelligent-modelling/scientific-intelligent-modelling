      y = 
        p0 
        + p1 * x0 
        + (p2 + p9 * x0) * x1 
        + (p3 + p10 * x0) * (x1 ** 3)
        + p12 * (x1 ** 5)                          # quintic stiffness term, no time modulation
        
        + (p4 + p11 * x0) * x2
        + p5 * (x2 ** 2)
        + p13 * (x2 ** 3)                         # cubic velocity damping term
        
        + p6 * x1 * x2
