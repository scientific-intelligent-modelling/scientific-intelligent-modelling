          get_param(0)                       # constant offset / forcing term
        + get_param(1) * x0                 # linear time dependence
        + get_param(2) * (x0 ** 2)          # quadratic time dependence
        + get_param(3) * (x0 ** 3)          # cubic time dependence
        
