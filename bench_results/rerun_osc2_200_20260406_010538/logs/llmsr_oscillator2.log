def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator with:
    - Constant offset and linear/quadratic time dependence (external forcing or drift)
    - Linear to quartic nonlinearities in position (restoring force)
    - Linear to cubic nonlinearities in velocity (damping/nonlinear friction)
    - Cross terms between position and velocity capturing coupling effects
    - Mixed terms involving time-position-velocity interactions
    - Additional mixed nonlinear interaction terms for richer dynamics

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of 12 parameters [p0,...p11]

    Returns:
        Acceleration array y.
    """

    return (
        params[0]                       # constant offset term
        + params[1] * x0                # linear time dependence (forcing/drift)
        + params[8] * (x0 ** 2)         # quadratic time dependence
        
        + params[2] * x1                # linear restoring force term (-k*x)
        + params[10] * (x1 ** 2)       # quadratic nonlinearity in position
        + params[4] * (x1 ** 3)        # cubic nonlinearity in position
        + params[7] * (x1 ** 4)         # quartic nonlinearity in position
        
        + params[3] * x2                # linear damping term (-c*v)
        + params[5] * (x2 ** 2)         # quadratic velocity nonlinearity
        + params[11] * (x2 ** 3)       # cubic velocity nonlinearity
        
        + params[6] * (x1 * x2)         # cross term between position and velocity
        
        + params[9] * (x0 * x1)         # interaction between time and position
        
        + params[(12 % len(params))] * (x0 * x2)   # interaction between time and velocity; wraps index if needed

    )
