    Since MAX_NPARAMS=12 here, we keep the same as equation_v1 but rearranged for clarity.

    Parameters:
        - x0: time array
        - x1: position array at time t
        - x2: velocity array at time t
        - params: array of 12 parameters
    
    Returns:
        Acceleration array y.
    """
    
    return (
        params[0]
        + params[1] * x0                  # linear time dependence
        + params[7] * (x0 ** 2)           # quadratic time dependence
        + params[8] * (x0 * x1)           # interaction between time and position
        + params[9] * (x0 * x2)           # interaction between time and velocity
        
        + params[2] * x1                  # linear restoring force term in position
        
        + params[10] * (x1 ** 2)           # quadratic nonlinearity in position
        
        + params[3] * (x1 ** 3)            # cubic nonlinearity in position
        
        
        + params[4] * x2                  # linear damping term in velocity
        
        + params[5] * (x2 ** 2)            # quadratic nonlinearity in velocity
        
        
        + params[11] * (x2 ** 3)           # cubic nonlinearity in velocity
        
        
        + params[6] * (x1 * x2)            # cross term between position and velocity

    )
