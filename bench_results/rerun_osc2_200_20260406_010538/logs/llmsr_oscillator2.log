def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` for nonlinear harmonic oscillator acceleration.

    This version includes physically meaningful polynomial terms and cross terms up to cubic order,
    capturing nonlinear restoring forces, damping effects, and possible time dependence.

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of parameters (length up to MAX_NPARAMS=12)
            params[0]: constant forcing term
            params[1]: linear coefficient for time (x0)
            params[2]: linear coefficient for position (x1)
            params[3]: linear coefficient for velocity (x2)
            params[4]: quadratic term for position (x1^2)
            params[5]: cubic term for position (x1^3)
            params[6]: quadratic term for velocity (x2^2)
            params[7]: interaction term between position and velocity (x1 * x2)
            params[8]: quadratic interaction term between time and position (x0 * x1)
            params[9]: quadratic interaction term between time and velocity (x0 * x2)
            params[10]: cubic term in velocity (x2^3)
            params[11]: cubic interaction term between position squared and velocity (x1^2 * x2)

    Returns:
        Acceleration array modeled by the nonlinear oscillator equation.
    """
    
    return (
        params[0] +
        params[1] * x0 +
        params[2] * x1 +
        params[3] * x2 +
        params[4] * x1**2 +
        params[5] * x1**3 +
        params[6] * x2**2 +
        params[7] * x1 * x2 +
        params[8] * x0 * x1 +
        params[9] * x0 * x2 +
        params[10]* x2**3 +
        params[11]* (x1**2) * x2
    )
