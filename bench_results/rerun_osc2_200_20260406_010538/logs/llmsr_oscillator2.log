def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Further improved version of `equation_v1`.

    Enhancements:
    - Adds quartic nonlinearities in position and velocity to capture stronger anharmonic effects.
    - Includes mixed polynomial coupling terms up to quartic order between position and velocity.
    - Incorporates trigonometric functions modulated by time multiplied by nonlinear state terms for richer parametric excitation modeling.
    - Adds exponential decay/growth modulated by nonlinear state variables.
    - Uses hyperbolic tangent saturation on both position and velocity to model limiting/friction effects more realistically.
    - Includes cross terms involving quadratic time multiplied by mixed powers of position and velocity.

    Parameters:
        x0 (np.ndarray): time variable t
        x1 (np.ndarray): position at time t
        x2 (np.ndarray): velocity at time t
        params (np.ndarray): array of 12 trainable coefficients

    Returns:
        y (np.ndarray): predicted acceleration d²x/dt²
    """
    
    p = params
    
    y = (
        p[0]                               # constant bias term
        + p[1] * x1                        # linear restoring force (-omega^2 * x)
        + p[2] * x2                        # linear damping (-c * v)
        + p[3] * (x1 ** 3)                 # cubic stiffness nonlinearity (Duffing term)
        + p[4] * (x2 ** 3)                 # cubic velocity nonlinearity (nonlinear damping)
        + p[5] * (x1 ** 4)                 # quartic stiffness nonlinearity
        + p[6] * (x2 ** 4)                 # quartic damping nonlinearity
        + p[7] * (x1 ** 2) * x2            # quadratic position times velocity coupling
        + p[8] * x1 * (x2 ** 2)            # position times quadratic velocity coupling
        + p[9] * np.sin(x0) * x1           # sinusoidal parametric excitation modulated by position
        + p[10] * np.exp(-x0) * np.tanh(x2)   # exponential decay/growth modulated by saturated velocity damping effect
        + p[11] * (x0 ** 2) * x1           # quadratic time times position modulation for parametric effects 
    )
    
    return y
