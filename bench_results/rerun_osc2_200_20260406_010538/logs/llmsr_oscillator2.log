def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Mathematical function skeleton representing acceleration in a nonlinear harmonic oscillator.

    Background:
    The acceleration y = d²x/dt² depends on time t (x0), position x(t) (x1), and velocity v(t) (x2).
    The physical model typically includes:
      - Linear restoring force proportional to position (-ω² * x)
      - Nonlinear restoring force terms (e.g., cubic nonlinearity -α * x³)
      - Damping terms proportional to velocity (-β * v) and possibly nonlinear damping
      - Possible forcing terms depending on time or cross-terms

    Variables:
    - x0: time t
    - x1: position at time t
    - x2: velocity at time t

    Parameters:
    - params: array of length 12 containing coefficients for each term

    Returns:
    - y: predicted acceleration at time t
    """

    return (
        params[0]                     # constant forcing term / offset
        + params[1] * x0             # linear forcing term in time (e.g., parametric excitation)
        + params[2] * x1             # linear restoring force (-ω² * x)
        + params[3] * (x1 ** 3)      # cubic nonlinear restoring force (-α * x³)
        + params[4] * x2             # linear damping (-β * v)
        + params[5] * (x2 ** 2)      # quadratic velocity damping / drag term
        + params[6] * (x1 ** 2)      # quadratic position nonlinearity
        + params[7] * (x0 ** 2)      # quadratic time-dependent forcing term
        + params[8] * (x0 * x1)     # cross-term between time and position
        + params[9] * (x0 * x2)     # cross-term between time and velocity
        + params[10] * (x1 * x2)     # cross-term between position and velocity
        + params[11] * (x1 ** 4)     # quartic nonlinear restoring force for stronger nonlinearity effects
    )
