def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Background:
    Calculate Acceleration in Nonlinear Harmonic Oscillator given Time (x0), Position (x1), and Velocity (x2).

    Variables:
    - Independents: 
        x0 : time t
        x1 : position at time t
        x2 : velocity at time t
    - Dependent:
        y  : acceleration at time t

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.

    Model includes:
    - Linear terms in position and velocity (restoring force and damping)
    - Nonlinear stiffness terms (cubic and quartic in position)
    - Nonlinear damping terms (quadratic and cubic in velocity)
    - Cross terms coupling position and velocity
    - Time-dependent forcing/modulation terms involving powers of time multiplied by position or velocity
    """

    return (
        params[0]                              # constant offset / bias acceleration term
        + params[1] * x0                      # linear forcing term dependent on time
        + params[2] * x1                      # linear restoring force ~ position
        + params[3] * x2                      # linear damping ~ velocity
        + params[4] * (x1 ** 3)               # cubic nonlinearity in position (Duffing-type)
        + params[5] * (x1 ** 2)               # quadratic term in position for asymmetry/nonlinearity
        + params[6] * (x2 ** 3)               # cubic nonlinearity in velocity (nonlinear damping)
        + params[7] * (x1 * x2)               # cross term between position and velocity
        + params[8] * ((x0 ** 2) * x1)         # quadratic time-position interaction (time-dependent stiffness modulation)
        + params[9] * ((x0 ** 2) * x2)         # quadratic time-velocity interaction (time-dependent damping modulation)
        + params[10] * (x1 ** 4)              # quartic nonlinearity in position for higher order stiffness effects
        + params[11] * ((x1 ** 3) * x2)       # mixed nonlinear coupling cubic position with velocity for complex dynamics
    )
