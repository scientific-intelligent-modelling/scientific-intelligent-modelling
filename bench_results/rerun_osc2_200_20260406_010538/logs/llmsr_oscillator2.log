def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculate acceleration for nonlinear harmonic oscillator:
    y = a0 
        + a1 * t 
        + a2 * x 
        + a3 * v 
        + a4 * t**2 
        + a5 * x**2 
        + a6 * v**2 
        + a7 * t*x 
        + a8 * t*v 
        + a9 * x*v 
        + a10 * x**3
        # optionally cubic velocity term if needed
    """
    return (
          params[0]                       # constant term
        + params[1] * x0                 # linear time term
        + params[2] * x1                 # linear position term
        + params[3] * x2                 # linear velocity term (damping)
        + params[4] * (x0 ** 2)          # quadratic time term
        + params[5] * (x1 ** 2)          # quadratic position term
        + params[6] * (x2 ** 2)          # quadratic velocity term
        + params[7] * (x0 * x1)          # cross time-position
        + params[8] * (x0 * x2)          # cross time-velocity
        + params[9] * (x1 * x2)          # cross position-velocity
        + params[10] * (x1 ** 3)         # cubic nonlinearity in position
    )
