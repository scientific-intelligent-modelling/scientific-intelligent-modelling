def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved version of the nonlinear oscillator acceleration model.
    
    Parameters:
    - x0 : time
    - x1 : position at time t
    - x2 : velocity at time t
    - params : array of coefficients (length 12)
    
    Returns:
    - acceleration y as numpy array
    
    Model structure extends v1 by including:
        - cubic velocity-position coupling (x1^3 * x2)
        - quadratic velocity-position coupling (x1 * x2^2)
        - cubic time dependence (x0^3)
    
    This captures more complex nonlinear interactions and possible higher order forcing effects.
    
    Equation form:
        y = a0 
          + a1 * x1 
          + a2 * x1**3 
          + a3 * x2 
          + a4 * x2**3 
          + a5 * x0 
          + a6 * x0 * x1 
          + a7 * x0 * x2 
          + a8 * x1**2 
          + a9 * x2**2 
          + a10* x1 * x2
          + a11* (x0 ** 3)   # replacing quadratic time term with cubic for richer dynamics
          
    Note: We replaced the quadratic time term with cubic to explore richer temporal forcing patterns.
    """
    
    return (
        params[0]                      # constant offset / bias / baseline forcing
        + params[1] * x1              # linear restoring force ~ position
        + params[2] * (x1 ** 3)       # cubic nonlinearity in position
        + params[3] * x2              # linear damping ~ velocity
        + params[4] * (x2 ** 3)       # nonlinear damping term in velocity cubed
        + params[5] * x0              # explicit time dependence / forcing term
        + params[6] * (x0 * x1)       # parametric modulation: time-position coupling
        + params[7] * (x0 * x2)       # parametric modulation: time-velocity coupling
        + params[8] * (x1 ** 2)       # quadratic position nonlinearity for flexibility 
        + params[9] * (x2 ** 2)       # quadratic velocity nonlinearity for flexibility 
        + params[10]* (x1 * x2)       # coupling between position and velocity 
        + params[11]* (x0 ** 3)       # cubic time dependence for richer external forcing pattern  
    )
