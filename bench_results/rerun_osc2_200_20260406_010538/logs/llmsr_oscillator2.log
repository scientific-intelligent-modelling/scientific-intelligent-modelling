def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Further extends the nonlinear harmonic oscillator acceleration model by including:
    - Higher order polynomial nonlinearities in position and velocity
    - Mixed trigonometric-exponential modulations coupled with state variables
    - Velocity sign-dependent nonlinear damping/friction effects
    - Parametric excitation at multiple harmonics
    - Cross terms involving time, position, velocity

    Parameters:
        x0 (np.ndarray): time variable t
        x1 (np.ndarray): position at time t
        x2 (np.ndarray): velocity at time t
        params (np.ndarray): array of 12 trainable coefficients

    Returns:
        y (np.ndarray): predicted acceleration d²x/dt²
    """
    
    p = params
    
    y = (
        p[0]                              # constant bias term
        
        + p[1] * x0                       # linear in time
        
        + p[2] * x1                       # linear restoring force term (-omega^2 * x)
        
        + p[3] * x2                       # linear damping term (-c * v)
        
        + p[4] * (x1 ** 3)                # cubic stiffness nonlinearity (Duffing term)
        
        + p[5] * (x2 ** 3)                # cubic velocity nonlinearity (nonlinear damping)
        
        + p[6] * (x1 ** 2) * x2           # quadratic position times velocity coupling
        
        + p[7] * x1 * (x2 ** 2)           # position times quadratic velocity coupling
        
        + p[8] * np.sin(x0)               # sinusoidal forcing or parametric excitation in time
        
        + p[9] * np.exp(-x0)              # exponential decay/growth with time
        
        + p[10] * np.sign(x2)             # friction-like effect depending on direction of velocity
        
        + p[11] * x0 * x1                 # cross term: time times position modulation
        
        # Additional enriched terms using existing parameters to keep param count fixed:
        
        + 0.5*p[4]*np.cos(2*x0)*x1**3     # higher harmonic cosine modulation on cubic stiffness
        
        + 0.4*p[5]*np.sin(2*x0)*x2**3     # higher harmonic sine modulation on cubic damping
        
        + 0.3*p[6]*np.exp(-x0)*x1*x2      # exponential decay modulated bilinear coupling
        
        + 0.25*p[7]*np.sign(x2)*x1**2     # sign-dependent quadratic stiffness effect
        
    )
    
    return y
