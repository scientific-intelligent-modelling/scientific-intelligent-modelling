    sin_arg = p[6] * x0 + p[7]
    cos_arg = sin_arg + np.pi / 4  # phase shifted cosine term sharing frequency and phase offset

    return (
        p[0]
        + p[1] * x0
        - p[2] * x1
        - p[3] * x2
        - p[4] * (x1 ** 3)
        + p[5] * np.sin(sin_arg)
        + p[8] * (x2 ** 3)
        + p[9] * (x1 ** 2)
        + p[10] * (x1 * x2)
        + p[11] * np.cos(cos_arg)
    )
