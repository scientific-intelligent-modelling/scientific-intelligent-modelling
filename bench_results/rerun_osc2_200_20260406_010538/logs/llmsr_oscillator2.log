def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Further improved version of `equation_v1`.

    This version includes additional nonlinear cross terms,
    mixed time-position-velocity interactions,
    and nonlinear damping effects to better capture complex oscillator dynamics.

    Physical reasoning:
    - Linear restoring force proportional to position (x1)
    - Linear damping proportional to velocity (x2)
    - Cubic stiffness nonlinearity (x1^3)
    - Nonlinear damping terms involving velocity powers and mixed terms
    - Time-dependent forcing modeled by sinusoids and exponentials of time (x0)
    - Cross terms involving time, position, and velocity to capture parametric excitation or modulation
    - Additional quadratic time dependence for more flexible forcing modeling
    - Mixed nonlinear damping with sign-dependent friction-like effect
    - Cosine forcing term complementary to sine

    Parameters:
        x0 (np.ndarray): time variable t
        x1 (np.ndarray): position at time t
        x2 (np.ndarray): velocity at time t
        params (np.ndarray): array of 12 trainable coefficients

    Returns:
        y (np.ndarray): predicted acceleration d²x/dt²
    """
    
    p = params
    
    y = (
        p[0]                          # constant bias term
        + p[1] * x0                   # linear in time
        + p[2] * x1                   # linear restoring force term (-omega^2 * x)
        + p[3] * x2                   # linear damping term (-c * v)
        + p[4] * (x1 ** 3)            # cubic stiffness nonlinearity (Duffing term)
        + p[5] * (x2 ** 3)            # cubic velocity nonlinearity (nonlinear damping)
        + p[6] * (x1 ** 2) * x2       # quadratic position times velocity coupling
        + p[7] * x1 * (x2 ** 2)       # position times quadratic velocity coupling
        + p[8] * np.sin(x0)           # sinusoidal forcing or parametric excitation in time
        + p[9] * np.exp(-x0)          # exponential decay/growth with time
        
        # Replace previous absolute value term with sign-dependent friction-like effect:
        + p[10] * x2 * np.abs(x2)     # nonlinear damping asymmetric in velocity
        
        + p[11] * x0**2               # quadratic in time for more flexible forcing modeling
        
        # Note: We have used all 12 parameters; if you want cosine instead of exp(-x0),
        # you can swap one out accordingly.
        
# If you want cosine instead of exp(-x0), replace line with:
#     + p[9] * np.cos(x0)

# Or add a cross-term like:
#     + p[...] * x0*x1*x2

# But that would require increasing MAX_NPARAMS beyond 12.
    
    )
    
    return y
