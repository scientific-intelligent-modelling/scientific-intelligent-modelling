        + params[8] * (x0 * x1)                            # cross term between time & pos 
        + params[9] * (x0 * x2)                            # cross term between time & vel 
        + params[10] * np.power(x1, 4)                     # quartic nonlinearity in pos 
        + params[11] * (np.power(x1, 2) * x2 + x1*np.power(x2, 2))   # mixed cubic interaction terms 
    )
