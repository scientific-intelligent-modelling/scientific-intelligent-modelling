def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retain polynomial terms up to cubic order for nonlinear elastic/plastic behavior.
    - Include inverse temperature term for thermal activation effects.
    - Use exponential softening term with trainable decay rate depending on strain magnitude and temperature.
    - Add logarithmic temperature terms capturing slow varying thermal effects and possible phase transitions.
    - Add interaction terms involving logarithm squared to capture more complex coupling.
    - Introduce a small linear temperature-dependent softening term modulated by strain.
    
    Variables:
    - x0: Strain
    - x1: Temperature

    Parameters:
    - params: array of coefficients (length=12)

    Model form:
        y = p0 
            + p1 * x0 
            + p2 * x1 
            + p3 * x0**2 
            + p4 * x1**2 
            + p5 * x0 * x1
            + p6 * x0**3
            + p7 * x1**3
            + p8 * (x0**2) * x1
            + p9 * x0 * (x1**2)
            + p10 / (x1 + epsilon)
            + exp_term
            + log_temp_term_1
            + log_temp_term_2

        where,
        exp_term = p11 * exp(-abs(p11) * abs(x0) * x1)
        log_temp_term_1 = (p0 / 10.0) * x0 * log(1+max(x1, 0))
        log_temp_term_2 = (p1 / 20.0) * x0 * (log(1+max(x1, 0)))**2

        epsilon is a small positive number to avoid division by zero.

    """
    
    epsilon = 1e-6  # avoid division by zero
    
    # Unpack parameters for clarity
    p = params
    
    decay_rate = np.abs(p[11])
    
    inv_temp_term = p[10] / (x1 + epsilon)
    
    exp_term = p[11] * np.exp(-decay_rate * np.abs(x0) * x1)
    
    temp_clip = np.maximum(x1, 0)
    
    log_temp_1 = np.log(1.0 + temp_clip)
    
    log_temp_term_1 = (p[0] / 10.0) * x0 * log_temp_1
    
    log_temp_term_2 = (p[1] / 20.0) * x0 * (log_temp_1 ** 2)
    
    return (
        p[0]
        + p[1] * x0
        + p[2] * x1
        + p[3] * (x0 ** 2)
        + p[4] * (x1 ** 2)
        + p[5] * x0 * x1
        + p[6] * (x0 ** 3)
        + p[7] * (x1 ** 3)
        + p[8] * (x0 ** 2) * x1
        + p[9] * x0 *(x1 ** 2)
        + inv_temp_term
        + exp_term
        + log_temp_term_1
        + log_temp_term_2  
       )
