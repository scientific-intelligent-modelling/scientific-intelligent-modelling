    """
    
    # Base linear and polynomial terms (from v1)
    linear = params[0] + params[1]*x0 + params[2]*x1
    interaction = params[3] * x0 * x1
    quad_strain = params[4] * x0**2
    quad_temp = params[5] * x1**2
    cross_quad = params[6] * (x0**2) * x1
    cross_quad_2 = params[7] * x0 * (x1**2)
    cubic_strain = params[8] * x0**3
    
    # Exponential temperature effect modulating strain stiffness (thermal softening/hardening)
    exp_temp_effect = (params[9] + params[10]*x0) * np.exp(params[11]*x1)
    
    # Logarithmic strain term to capture nonlinear microstructural effects,
    # add small epsilon inside log to avoid log(0)
    eps = 1e-8
    log_strain = 0.0
