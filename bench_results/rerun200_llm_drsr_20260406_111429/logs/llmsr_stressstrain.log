def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain and temperature.
    - At small strains, stress is approximately linear in strain (Hooke's law).
    - Temperature reduces stiffness (modulus), so include terms that reduce effective modulus as temperature increases.
    - Include nonlinear strain terms to capture strain hardening or softening.
    - Include exponential decay term to model thermal softening more physically.
    - Include inverse temperature term to capture Arrhenius-type effects if relevant.
    
    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 12 for this model.
      
    Model form:
      y = p0 
          + p1*x0 
          + p2*x1 
          + p3*x0*x1 
          + p4*x0**2 
          + p5*x1**2 
          + p6*(x0**2)*x1 
          + p7*x0*(x1**2) 
          + p8*x0**3
          + p9*np.exp(-p10 * x1) * x0  # thermal softening exponential decay modulating strain
          + p11 / (x1 + 273.15)        # inverse absolute temperature effect (Kelvin)
          
    Note:
      We add 273.15 to convert Celsius to Kelvin for physical meaningfulness in inverse T term.

    """
    
    # To avoid division by zero or negative Kelvin temperatures, ensure x1+273.15 > 0
    kelvin_temp = x1 + 273.15
    kelvin_temp = np.where(kelvin_temp <= 0, 1e-6, kelvin_temp)
    
    linear = params[0] + params[1]*x0 + params[2]*x1
    interaction = params[3]*x0*x1
    quad_strain = params[4]*x0**2
    quad_temp = params[5]*x1**2
    cross_quad_1 = params[6]*(x0**2)*x1
    cross_quad_2 = params[7]*x0*(x1**2)
    cubic_strain = params[8]*x0**3
    
    thermal_softening = params[9] * np.exp(-params[10] * x1) * x0
    
    inv_temp_effect = params[11] / kelvin_temp
    
    return (linear 
            + interaction 
            + quad_strain 
            + quad_temp 
            + cross_quad_1 
            + cross_quad_2 
            + cubic_strain
            + thermal_softening
            + inv_temp_effect)
