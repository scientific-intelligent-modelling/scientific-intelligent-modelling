def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Builds on v1 by introducing a temperature-dependent modulus factor multiplying strain terms.
    - Adds smooth saturation effects for both strain and temperature using tanh functions.
    - Includes exponential decay modulated by temperature to capture thermal softening/hardening.
    - Adds inverse strain correction term to capture steep changes near zero strain.
    - Retains polynomial nonlinearities and interaction terms for flexibility.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params (np.ndarray): array of coefficients (length at least 12)
      params[0]: intercept
      params[1]: linear strain coefficient
      params[2]: linear temperature coefficient
      params[3]: strain * temperature interaction
      params[4]: strain^2 term (nonlinear elasticity)
      params[5]: temperature^2 term (nonlinear temp effect)
      params[6]: strain^3 term (higher order nonlinearity)
      params[7]: temperature^3 term
      params[8]: strain^2 * temperature interaction
      params[9]: strain * temperature^2 interaction
      params[10]: exponential decay with temp 
      params[11]: log(strain), avoid log(0)

    Returns:
        Stress values as np.ndarray.
    """

    # Temperature-dependent modulus factor (modulates linear and nonlinear strain terms)
    # Polynomial in temperature up to cubic order, weighted by parameters 2,5,7 respectively,
    # plus intercept-like offset from param 0 for baseline stiffness scaling.
    
    temp_modulus = (
        1.0 
        + 0.01*params[2]*x1 
        + 0.001*params[5]*x1**2 
        + 0.0001*params[7]*x1**3
    )
    
    # Base polynomial terms without direct temp-strain interactions here,
    # since those are captured separately below
    
    base_poly = (
        params[0]
        + params[2] * x1                      # linear in temp alone
        + params[5] * x1**2                   # quadratic in temp alone
        + params[7] * x1**3                   # cubic in temp alone
        + params[10] * np.exp(-x1)            # exponential decay with temp 
        + params[11] * np.log(np.clip(x0+1e-6, 1e-6, None))  # log(strain), avoid log(0)
        + 0.05*params[11]/np.clip(x0+1e-6, 1e-6, None)     # inverse-strain correction term for singularity near zero strain
    )
    
    # Strain polynomial terms modulated by the temperature-dependent modulus
    
    strain_poly = (
        (params[1]*x0)                       # linear in strain 
        + (params[4]*x0**2)                  # quadratic in strain 
        + (params[6]*x0**3)                  # cubic in strain 
        + (params[8]*(x0**2)*x1)             # mixed nonlinear term 
        + (params[9]*x0*(x1**2))             # mixed nonlinear term 
        + (params[3]*x0*x1)                  # linear interaction term between strain and temp
    ) * temp_modulus
