def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1` with nonlinearities and physical constraints.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - x0: Strain (ε)
    - x1: Temperature (T)
    - y : Stress (σ)

    Parameters:
    - params: array-like coefficients [p0,...p11]

    Model form:
        σ = 
          + p1 * ε * exp(-p2 * T)               # thermal softening
          + p3 * ε^2                           # quadratic strain hardening
          + p4 * ε^3                           # cubic strain hardening
          + p5 * T                            # linear temp effect
          + p6 * T^2                          # quadratic temp effect
          + p10 * T^3                         # cubic temp effect
          + p7 * ε * T                       # linear interaction term
          + p8 * ε^2 * T                     # higher order interaction term
          + p9 / (1 + |p11|*|ε|)             # saturation effect at high strains
          + sign(p11)*sign(ε)                 # asymmetry/yield behavior

        Note:
        - No constant term to ensure σ=0 when ε=0.
        - Saturation denominator scaled by abs(p11), avoiding division by zero.
        - Asymmetry term captures yield or Bauschinger effects.
    """
    
    eps = x0
    temp = x1
    
    # Thermal softening: modulus decreases exponentially with temperature
    thermal_softening = params[1] * eps * np.exp(-params[2] * temp)
    
    # Nonlinear strain hardening terms (quadratic and cubic)
    nonlinear_strain = params[3] * eps**2 + params[4] * eps**3
    
    # Temperature polynomial terms including cubic for complex thermal effects
    temp_terms = params[5] * temp + params[6] * temp**2 + params[10] * temp**3
    
    # Interaction terms between strain and temperature including higher order cross term
    interaction_terms = params[7] * eps * temp + params[8] * eps**2 * temp
    
    # Saturation effect modeled as rational function; use absolute value of parameter for stability in denominator scaling 
    denom_scale = np.abs(params[11]) if np.abs(params[11]) > 1e-8 else 1e-8  # avoid division by zero or too small number
    
    saturation = params[9] / (1.0 + denom_scale*np.abs(eps))
    
    # Asymmetry or yield behavior captured by sign function of strain multiplied by parameter magnitude and sign of param 11 
    asymmetry = np.sign(params[11]) * np.sign(eps) if params[11] != 0 else 0.0
    
    return (
        thermal_softening +
        nonlinear_strain +
        temp_terms +
        interaction_terms +
        saturation +
        asymmetry
       )
