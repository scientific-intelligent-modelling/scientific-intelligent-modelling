def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements:
    - Use sigmoid instead of tanh for smooth yielding/saturation.
    - Add logarithmic strain hardening term.
    - Include inverse temperature term for Arrhenius-like effects.
    - Keep total parameters <= 12.

    Model structure:

    y = params[0]
      + (params[1] + params[2]*x1 + params[3]*x1**2) * x0                  # temp-dependent modulus * strain
      + params[4] * x0**abs(params[5])                                    # power-law strain hardening
      + params[6] * exp(params[7]*x1)                                     # exponential temp effect
      + params[8] / (1 + exp(-params[9]*(x0 - params[10])))                # sigmoid yielding/saturation
      + params[11] * x0 * x1**3                                           # higher order interaction
      + params_extra * log(strain)                                         # added logarithmic strain hardening

    Since MAX_NPARAMS=12, we will merge the log_strain term into one of the existing parameters or omit it if needed.

    Here we add log_strain using param index 12 if available; else omit.

    """

    safe_x0 = np.clip(x0, 1e-6, None)
    safe_x1 = np.clip(x1, 1e-6, None)

    temp_modulus = params[1] + params[2]*x1 + params[3]*(x1**2)

    power_law_strain = safe_x0 ** abs(params[5])

    exp_temp = params[6] * np.exp(params[7]*x1)

    sigmoid_yielding = params[8] / (1.0 + np.exp(-params[9]*(safe_x0 - params[10])))

    high_order_interaction = params[11] * safe_x0 * (x1 ** 3)

    # Optional logarithmic strain hardening if param available
    log_strain = 0.0
    if len(params) > 12:
        log_strain = params[12] * np.log(safe_x0)

    # Optional inverse temperature Arrhenius term if param available
    inv_temp_term = 0.0
    if len(params) > 13:
        inv_temp_term = params[13]/safe_x1

    return (
        params[0]
        + temp_modulus*safe_x0
        + params[4]*power_law_strain
        + exp_temp
        + sigmoid_yielding
        + high_order_interaction
        + log_strain
        + inv_temp_term
     )
