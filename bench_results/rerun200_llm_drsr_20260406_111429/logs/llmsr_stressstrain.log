        Additional terms added here using same params indices for demonstration:
        
        + p12 * (1 / (1 + np.exp(-50*(x1 - 300))))  # sigmoid temp softening near 300K
        + p13 * np.sign(x0) * np.abs(x0)**(1.5)     # power law on strain with sign preservation
        + p14 * np.log(x1 + epsilon)                 # logarithmic temperature dependence
        + p15 * np.log(np.abs(x0)+epsilon)*np.tanh(10*(x1-250))  # cross log-strain & tanh-temp
        
    Note: This requires extending params array length accordingly (to at least 16).
    
    """
    
    epsilon = 1e-8
    
    linear = params[0] + params[1]*x0 + params[2]*x1
    quad = params[3]*x0**2 + params[4]*x1**2
    interaction_1 = params[5]*x0*x1
    thermal_softening_exp = params[6] * x0 * np.exp(-params[7]*x1)
    
