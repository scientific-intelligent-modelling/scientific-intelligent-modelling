    # Inverse temperature term
    inv_temp = 1.0 / safe_x1
    
    # Logarithmic temperature term (log(x1))
    log_temp = np.log(safe_x1)
    
    # Exponential decay term with strain and temperature interaction
    # Use fixed decay rate alpha=0.5 for numerical stability (could be parameterized if desired)
    alpha = 0.5
    exp_decay = np.exp(-alpha * safe_x1)
    
    y = (
        p[0]
        + p[1] * x0
        + p[2] * x1
        + p[3] * x0 * x1
        + p[4] * x0**2
        + p[5] * x1**2
        + p[6] * x0**3
        + p[7] * inv_temp
        + p[8] * (x0**2) * x1
        + p[9] * x0 * (x1**2)
        + p[10] * x0 * log_temp
        + p[11] * x0 * exp_decay
    )
    
    return y
