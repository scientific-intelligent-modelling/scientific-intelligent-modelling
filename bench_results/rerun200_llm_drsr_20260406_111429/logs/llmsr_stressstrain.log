def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retains polynomial terms capturing linear and nonlinear elasticity and temperature effects.
    - Introduces a temperature-dependent modulus modifying strain terms multiplicatively.
    - Adds smooth saturation effects on strain using tanh to model yielding/softening.
    - Includes exponential decay modulated by temperature to capture thermal softening.
    - Adds logarithmic strain term for small strain singularity behavior.
    - Incorporates Gaussian weighting around room temperature to localize temp effects.
    - Adds inverse strain correction for steep changes near zero strain.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
      params[0]: intercept
      params[1]: linear strain coefficient
      params[2]: linear temperature coefficient
      params[3]: strain * temperature interaction
      params[4]: strain^2 term (nonlinear elasticity)
      params[5]: temperature^2 term (nonlinear temp effect)
      params[6]: strain^3 term (higher order nonlinearity)
      params[7]: temperature^3 term
      params[8]: strain^2 * temperature interaction
      params[9]: strain * temperature^2 interaction
      params[10]: exponential decay scale with temp 
      params[11]: log(strain) coefficient (small-strain behavior)

    Returns:
        Stress values as np.ndarray.
    """

    # Clip x0 to avoid log(0) or division by zero issues
    eps = 1e-6
    x0_safe = np.clip(x0, eps, None)

    # Polynomial base terms capturing linear and nonlinear elasticity & temp effects
    poly_terms = (
        params[0]
        + params[1] * x0                      # linear in strain
        + params[2] * x1                      # linear in temp
        + params[3] * x0 * x1                 # interaction term
        + params[4] * x0**2                   # quadratic in strain (nonlinear elasticity)
        + params[5] * x1**2                   # quadratic in temp (temp effect)
        + params[6] * x0**3                   # cubic in strain (higher order nonlinearity)
        + params[7] * x1**3                   # cubic in temp 
        + params[8] * (x0**2) * x1            # mixed nonlinear term 
        + params[9] * x0 * (x1**2)            # mixed nonlinear term 
    )

    # Temperature-dependent modulus modifier for the linear and nonlinear elastic terms,
    # modeled as a polynomial in temperature affecting the effective stiffness.
    
    modulus_temp_mod = 1.0 + 0.01*params[5]*x1 + 0.001*params[7]*x1**2  # small correction scaling
    
    elastic_terms = (
        modulus_temp_mod *
        (
            params[1]*x0 +
            params[4]*x0**2 +
            params[6]*x0**3 +
            params[8]*(x0**2)*x1 +
            params[9]*x0*(x1**2)
        )
     )

     # Saturation effect on high strains using tanh to model yielding/softening,
     # scaled by a parameter controlling onset sharpness
    
