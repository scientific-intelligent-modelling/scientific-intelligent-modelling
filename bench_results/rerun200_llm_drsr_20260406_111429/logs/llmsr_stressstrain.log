    x1 = np.asarray(x1)

    # Linear contributions from strain and temperature plus constant offset
    linear = params[0] + params[1]*x0 + params[2]*x1

    # Quadratic contributions from strain squared and temperature squared
    quad = params[3]*x0**2 + params[4]*x1**2

    # Interaction between strain and temperature linearly combined
    interaction = params[5]*x0*x1

    # Thermal softening modeled as an exponential decay with respect to temperature,
    # scaled by the amplitude parameter times the current strain value.
    thermal_softening = params[6] * x0 * np.exp(-params[7]*x1)

    # Logarithmic dependence on positive shifted strains to capture hardening behavior;
    # if any value is negative or zero after shift, set log_strain to zero safely.
    
    log_strain = np.zeros_like(x0)
    
    positive_mask = (x0 + epsilon) > 0
    
    if np.any(positive_mask):
        log_strain[positive_mask] = params[8] * np.log(x0[positive_mask] + epsilon)
