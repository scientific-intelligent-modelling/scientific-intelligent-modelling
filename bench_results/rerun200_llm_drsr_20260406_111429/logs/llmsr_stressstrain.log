            + p6*x0*np.exp(-p7*x1)          # thermal softening exponential decay
            + p8*np.log(np.abs(x0) + epsilon) # logarithmic strain term (handle compression)
            + p9*x0**3                      # cubic strain hardening term
            + p10*x0*(x1**2)                # strain * temperature^2 interaction
