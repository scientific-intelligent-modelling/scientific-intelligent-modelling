            p[2] : linear temperature coefficient
            p[3] : quadratic strain coefficient
            p[4] : quadratic temperature coefficient
            p[5] : strain-temperature interaction (linear)
            p[6] : cubic strain coefficient
            p[7] : exponential decay rate for temp effect on stiffness (positive)
            p[8] : coefficient for exp decay * strain term magnitude
            p[9] : quadratic interaction term coeff (strain * temp^2)
            p[10]: inverse temperature softening coefficient
            p[11]: logarithmic temperature effect coefficient

    Returns:
        y: predicted stress as numpy array same shape as inputs

    Notes:
        - To avoid log(<=0), use max(x1 + offset, small positive number).
        - To avoid division by zero in inverse temp term, add small epsilon to denominator.
        - Exponential decay uses abs(p7) to ensure positive decay rate.
    """

    p = params

    # Small constants for numerical stability
    epsilon = 1e-6          # to avoid division by zero in inverse temp term
    temp_log_offset = 1e-3  # offset inside log to avoid log(0) or negative argument

    # Ensure positive argument inside log; assume x1 can be negative if Celsius,
    # so shift by offset + max(0,x1)
    safe_temp_for_log = np.maximum(x1 + temp_log_offset, temp_log_offset)

    # Avoid division by zero in inverse temperature term; assume absolute scale is Kelvin,
    # if input is Celsius convert to Kelvin approx. here by adding 273.15,
    # else just add epsilon if already Kelvin scale. Here we assume Celsius input.
    
    safe_temp_for_inv = x1 + 273.15 + epsilon

    
    exp_decay_rate = np.abs(p[7])  # ensure positive decay rate
    
    return (
        p[0]
        + p[1]*x0
        + p[2]*x1
        + p[3]*x0**2
        + p[4]*x1**2
        + p[5]*x0*x1
        + p[6]*x0**3
        
        + p[8]*np.exp(-exp_decay_rate * x1)*x0
        
        + p[9]*x0*(x1**2)
        
        + (p[10]/safe_temp_for_inv)
        
        + p[11]*np.log(safe_temp_for_log)
       )
