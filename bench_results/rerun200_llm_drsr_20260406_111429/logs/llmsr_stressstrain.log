        y = p0 
            + p1 * x0 
            + p2 * x1 
            + p3 * x0 * x1 
            + p4 * x0**2 
            + p5 * x1**2
            + p6 * x0**2 * x1
            + p7 * x0 * x1**2
            + p8 * x0**3
            + p9  * x1**3
            + p10 * x0**3 * x1
