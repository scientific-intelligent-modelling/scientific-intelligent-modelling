def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retain linear, quadratic, and cubic terms in strain and temperature.
    - Add inverse temperature term (Arrhenius-like) for stiffness degradation.
    - Add exponential decay term with temperature to model thermal softening.
    - Add logarithmic dependence on temperature (shifted to avoid log(0)).
    - Include higher order cross terms for strain-temperature coupling.

    Variables:
    - x0: Strain
    - x1: Temperature

    Parameters:
    - params: array of coefficients (length = 12)

    Model form:

        y = p0 
            + p1*x0 
            + p2*x1 
            + p3*x0*x1 
            + p4*x0^2 
            + p5*x1^2
            + p6*x0^3
            + p7*(1/(x1+eps))
            + p8*(x0^2 * x1)
            + p9*(x0 * x1^2)
            + p10 * x0 * exp(-p11 * x1)
            + p11 * log(x1 + eps)

        Note: params[11] is used twice here in description; to fix this,
              we use params[10] and params[11] for exp term coefficients,
              and reuse param[9] or param[8] for log term if needed.

        To keep unique parameters:

        Use params[10] for coefficient of exp term,
        Use params[11] for exponent coefficient in exp,
        Use param[9] for log term coefficient instead of interaction (or vice versa).

        Here we choose to replace param[9]'s original meaning with log term coefficient.

    """
    
    epsilon = 1e-8  # To avoid division by zero or log(0)
    
    inv_temp = 1.0 / (x1 + epsilon)
    
    exp_term = params[10] * x0 * np.exp(-params[11] * x1)
    
    log_term = params[9] * np.log(x1 + epsilon)  # Using param[9] here
    
    y = (
        params[0]
        + params[1]*x0
        + params[2]*x1
        + params[3]*x0*x1
        + params[4]*(x0**2)
        + params[5]*(x1**2)
        + params[6]*(x0**3)
        + params[7]*inv_temp
        + params[8]*(x0**2)*x1
        # param 9 replaced by logarithmic temp dependence:
        #+ params[9]*x0*(x1**2)   # omitted to save parameter slot
        
        # add logarithmic temp dependence:
        + log_term
        
        # add exponential decay term:
        + exp_term
    )
    
    return y
