def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning and improvements:
    - Introduce a temperature-dependent yield strain threshold to better capture yielding onset.
    - Use a smooth transition function (hyperbolic tangent) for yielding instead of sigmoid for numerical stability.
    - Model strain hardening with a tempered power law that depends on temperature.
    - Add an Arrhenius-type term to capture thermally activated softening.
    - Include combined nonlinear interaction terms between strain and temperature with adjustable exponents.
    - Retain logarithmic temperature effect for saturation behavior.
    
    Model structure:
    y = params[0]
      + (params[1] + params[2]*x1 + params[3]*x1**2) * x0                          # temp-dependent modulus * strain
      + params[4] * x0 ** (abs(params[5]) + params[6]*x1)                          # tempered power-law strain hardening
      + params[7] * np.tanh((x0 - (params[8] + params[9]*x1)) * 100)               # smooth yielding transition, scaled for sharpness
      + params[10] * np.exp(-params[11]/(x1+1e-6))                                # Arrhenius-type thermal softening
      + params[11] * np.log(x1 + 1.01)                                            # logarithmic temperature saturation effect

    Parameters:
    - x0: Strain input array
    - x1: Temperature input array
    - params: Array of 12 parameters

    Returns:
    - y: Stress output array
    """

    safe_x0 = np.clip(x0, 1e-8, None)
    safe_x1 = np.clip(x1, 1e-8, None)

    # Temperature-dependent modulus times strain (linear elastic part)
    temp_modulus = params[1] + params[2]*safe_x1 + params[3]*(safe_x1**2)

    # Tempered power-law strain hardening with temperature dependence in exponent
    exponent = abs(params[5]) + params[6]*safe_x1
    power_law_strain = safe_x0 ** exponent

    # Temperature-dependent yield strain threshold
    yield_strain_threshold = params[8] + params[9]*safe_x1

    # Smooth yielding transition using tanh scaled by factor to control sharpness (~100)
    yielding_transition = np.tanh((safe_x0 - yield_strain_threshold)*100)

    
    arrhenius_softening = params[10] * np.exp(-params[11]/safe_x1)

    
    log_temp_effect = params[11] * np.log(safe_x1 + 1.01)

    
    y = (
        params[0]
        + temp_modulus * safe_x0
        + params[4] * power_law_strain
        + params[7] * yielding_transition
        + arrhenius_softening
        + log_temp_effect
     )

    
    return y
