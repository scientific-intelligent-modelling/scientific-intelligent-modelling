def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends primarily on strain with a modulus affected by temperature.
    - Nonlinear elasticity effects captured by polynomial terms in strain.
    - Temperature influences modulus and can cause nonlinear softening or hardening.
    - Interaction terms capture coupling between strain and temperature effects.
    - Added smooth nonlinearities (e.g., tanh) to model saturation or limiting behavior in stress-strain response at high strains or temperatures.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params: array of coefficients (length at least 12)
      params[0]: intercept
      params[1]: linear strain coefficient
      params[2]: linear temperature coefficient
      params[3]: strain * temperature interaction
      params[4]: strain^2 term (nonlinear elasticity)
      params[5]: temperature^2 term (nonlinear temp effect)
      params[6]: strain^3 term (higher order nonlinearity)
      params[7]: temperature^3 term
      params[8]: strain^2 * temperature interaction
      params[9]: strain * temperature^2 interaction
      params[10]: exponential decay with temp 
      params[11]: log(strain), avoid log(0)

    Returns:
        Stress values as np.ndarray.
    """
    
    # Base polynomial and interaction terms as before
    poly_terms = (
        params[0]
        + params[1] * x0                      # linear in strain
        + params[2] * x1                      # linear in temp
        + params[3] * x0 * x1                 # interaction term
        + params[4] * x0**2                   # quadratic in strain (nonlinear elasticity)
        + params[5] * x1**2                   # quadratic in temp (temp effect)
        + params[6] * x0**3                   # cubic in strain (higher order nonlinearity)
        + params[7] * x1**3                   # cubic in temp 
        + params[8] * (x0**2) * x1            # mixed nonlinear term 
        + params[9] * x0 * (x1**2)            # mixed nonlinear term 
        + params[10] * np.exp(-x1)            # possible exponential decay with temp 
        + params[11] * np.log(np.clip(x0+1e-6, 1e-6, None))  # log(strain), avoid log(0)
    )
    
    # Add smooth saturation effect using tanh to model limiting stress at high strains/temps,
    # weighted by parameters for flexibility.
    
    saturation = (
        0.5*params[4]*np.tanh(params[6]*x0)   # scaled tanh of strain capturing saturation/nonlinearity,
                                             # weighted by quadratic and cubic coeffs for physical meaning.
        - 0.3*params[5]*np.tanh(params[7]*x1)  # scaled tanh of temperature capturing softening/hardening effects,
                                              # weighted by quadratic and cubic temp coeffs.
    )
    
    return poly_terms + saturation
