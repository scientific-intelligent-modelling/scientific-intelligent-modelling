def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning and improvements over v1:
    - Enforce zero stress at zero strain (σ=0 when ε=0) by removing constant term.
    - Model temperature dependence as a modifier of the effective modulus (strain coefficient).
    - Use an exponential decay term to capture thermal softening more explicitly on strain terms.
    - Include nonlinear strain hardening terms modulated by temperature.
    - Avoid pure temperature-only terms that produce non-zero stress at zero strain.
    
    Model form:
        σ = (p0 + p1 * T + p2 * T^2) * ε 
            + (p3 + p4 * T) * ε^2 
            + p5 * ε^3 
            + p6 * ε * exp(-p7 * T)
            + p8 * ε^2 * exp(-p9 * T)
            + p10 * ε^3 * exp(-p11 * T)

    Parameters:
        params: array-like coefficients [p0,...,p11]

    Explanation:
        - The first group models a temperature-dependent linear modulus.
        - The second group models quadratic and cubic strain hardening with temperature modulation.
        - The exponential terms model thermal softening effects on different powers of strain.

    This form respects physical constraints and captures complex nonlinear interactions between strain and temperature.
    """
    
    eps = x0
    temp = x1
    
    # Linear term with quadratic temp dependence
    linear_modulus = params[0] + params[1]*temp + params[2]*temp**2
    
    # Quadratic strain term modulated linearly by temp
    quad_modulus = params[3] + params[4]*temp
    
    # Cubic strain coefficient (constant)
    cubic_modulus = params[5]
    
    # Exponential thermal softening terms for different powers of strain
    exp_soften_1 = np.exp(-params[7]*temp)
    exp_soften_2 = np.exp(-params[9]*temp)
    exp_soften_3 = np.exp(-params[11]*temp)
    
    stress = (
        linear_modulus*eps
        + quad_modulus*eps**2
        + cubic_modulus*eps**3
        + params[6]*eps*exp_soften_1
        + params[8]*eps**2*exp_soften_2
        + params[10]*eps**3*exp_soften_3
    )
    
    return stress
