def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain linearly and nonlinearly (strain hardening).
    - Temperature reduces stiffness exponentially.
    - Logarithmic strain term captures large-strain behavior.
    - Inverse temperature term models low-temperature effects.
    - Cross terms between strain powers and temperature powers capture complex interactions.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters (params[0] to params[11]):
      p0: constant offset
      p1: linear strain coefficient (modulus at ref temp)
      p2: linear temperature coefficient (offset)
      p3: quadratic strain coefficient
      p4: quadratic temperature coefficient
      p5: interaction linear term (strain * temp)
      p6: exponential decay rate for modulus with temp
      p7: cubic strain coefficient (strain hardening)
      p8: logarithmic strain coefficient
      p9: inverse temperature coefficient
      p10: interaction quadratic term (strain^2 * temp)
      p11: interaction cubic term (strain^3 * temp)
    """
    
    epsilon = 1e-8  # small number to avoid log(0) or division by zero
    
    # Safe inputs for log and division
    safe_x0 = np.maximum(x0, epsilon)
    safe_x1 = np.maximum(x1, epsilon)

    # Temperature-dependent modulus decay factor (exponential decay with temp)
    modulus_decay = np.exp(-params[6] * safe_x1)

    # Linear + quadratic + cubic strain terms modulated by modulus_decay
    strain_terms = (
        params[1] * safe_x0 +
        params[3] * safe_x0**2 +
        params[7] * safe_x0**3
    ) * modulus_decay

    # Temperature-only terms (offsets and quadratic)
    temp_terms = params[2]*safe_x1 + params[4]*safe_x1**2

    # Interaction terms between strain powers and temperature
    interaction_terms = (
        params[5]*safe_x0*safe_x1 +
        params[10]*safe_x0**2*safe_x1 +
        params[11]*safe_x0**3*safe_x1
    )

    
    # Logarithmic dependence on strain for large strains (> 0)
    log_strain_term = params[8] * np.log(safe_x0)

    
    # Inverse temperature effect capturing low-temp behavior safely 
    inv_temp_term = params[9] / safe_x1

    
    # Constant offset term
    offset = params[0]

    
    y = offset + strain_terms + temp_terms + interaction_terms + log_strain_term + inv_temp_term
    
  
    return y
