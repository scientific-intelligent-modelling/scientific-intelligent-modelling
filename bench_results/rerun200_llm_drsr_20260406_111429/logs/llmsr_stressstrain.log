    inv_temp_term = 0.0 if len(p) < 11 else p[10] / (x1 + epsilon)
    
    exp_term = 0.0 if len(p) < 12 else p[11] * np.exp(-decay_rate * np.abs(x0*x1))
    
    # Logarithmic temperature term, safe with epsilon
    log_temp_term = 0.0
    if np.all(x1 > -epsilon):  
        # Only compute where temp > ~zero to avoid complex numbers/log errors
        log_temp_term = np.log(x1 + epsilon)
    
    # Hyperbolic tangent saturation effect modeled as tanh(scaling_factor*(strain*temperature))
    # Use param[5] as scaling factor for tanh argument; if param[5]==0 fallback to 1.0
    
    scaling_factor = p[5] if abs(p[5]) > epsilon else 1.0
    
