def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Further enhancements:
    - Incorporate inverse temperature terms to capture Arrhenius-type relaxation effects.
    - Add strain-temperature interaction terms with nonlinear temperature dependence.
    - Include fractional powers of strain and combined exponential-strain terms to model complex plasticity/yielding.
    - Use a sigmoid function (logistic) instead of tanh for more flexible saturation modeling.
    - Add logarithmic temperature term to capture subtle thermal softening/hardening effects.

    Model structure:
    y = params[0]
        + (params[1] + params[2]*x1 + params[3]*x1**2) * x0                  # temp-dependent linear modulus
        + params[4] * (np.abs(x0)**params[5])                               # power-law strain nonlinearity (strain rate sensitivity)
        + params[6] / (1 + np.exp(-params[7]*(x0 - params[8])))             # sigmoid saturation/yielding
        + params[9] * np.log(np.clip(x0, 1e-6, None))                       # logarithmic strain hardening
        + params[10] * np.exp(params[11]*x1)                                # exponential temperature effect
        + params[12] / np.clip(x1, 1e-6, None)                              # inverse temperature term (Arrhenius)
        + params[13] * x0 * x1**3                                           # higher order strain-temp interaction
        + params[14] * (np.abs(x0)**(3/2))                                  # fractional power for plasticity-like behavior
        + params[15] * x0 * np.exp(params[16]*x1)                           # combined nonlinear strain-temp term
        + params[17] * np.log(np.clip(x1, 1e-6, None))                      # logarithmic temperature effect

    Notes:
    - This model uses up to 18 parameters; if fewer are available,
      some terms can be omitted or parameters fixed.
    - Clipping inputs where needed to avoid numerical issues.

    Since MAX_NPARAMS=12 in the original code,
    you may need to reduce or combine terms accordingly.
    
    Here we provide a full physically motivated skeleton;
    you can select subsets depending on parameter availability.
    
    """
    
    safe_x0 = np.clip(np.abs(x0), 1e-6, None)
    safe_x1 = np.clip(x1, 1e-6, None)
    
    temp_poly_modulus = params[1] + params[2]*x1 + params[3]*(x1**2)
    
    power_law_strain = params[4] * (safe_x0 ** params[5])
    
    sigmoid_saturation = params[6] / (1.0 + np.exp(-params[7]*(x0 - params[8])))
    
    log_strain = params[9] * np.log(safe_x0)
    
    exp_temp = params[10] * np.exp(params[11]*x1)
    
    inv_temp = 0 if len(params) <= 12 else params[12]/safe_x1
    
    high_order_interaction = 0 if len(params) <= 13 else params[13]*x0*(x1**3)
    
    frac_power_plasticity = 0 if len(params) <=14 else params[14]*(safe_x0**(3/2))
    
    exp_strain_temp = 0 if len(params) <=15 else params[15]*x0*np.exp(params[16]*x1)
    
    log_temp = 0 if len(params) <=17 else params[17]*np.log(safe_x1)

    
    return (
        params[0]
        + temp_poly_modulus*x0
        + power_law_strain
        + sigmoid_saturation
        + log_strain
        + exp_temp
        + inv_temp
        + high_order_interaction
        + frac_power_plasticity
        + exp_strain_temp
        + log_temp
     )
