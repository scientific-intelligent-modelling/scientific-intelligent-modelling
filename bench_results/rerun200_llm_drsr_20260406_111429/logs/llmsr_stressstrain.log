    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params: array of coefficients (length at least 16)
      params[0] to params[11]: same as in equation_v1
      params[12]: coefficient for |strain|
      params[13]: coefficient for |temperature|
      params[14]: coefficient for |strain| * temperature^2 interaction
      params[15]: coefficient for strain^2 * |temperature| interaction

    Returns:
        Stress values as np.ndarray.
    """

    # Base polynomial and interaction terms as in v1
    poly_terms = (
        params[0]
        + params[1] * x0                      # linear in strain
        + params[2] * x1                      # linear in temp
        + params[3] * x0 * x1                 # interaction term
        + params[4] * x0**2                   # quadratic in strain (nonlinear elasticity)
        + params[5] * x1**2                   # quadratic in temp (temp effect)
        + params[6] * x0**3                   # cubic in strain (higher order nonlinearity)
        + params[7] * x1**3                   # cubic in temp 
        + params[8] * (x0**2) * x1            # mixed nonlinear term 
        + params[9] * x0 * (x1**2)            # mixed nonlinear term 
        + params[10] * np.exp(-x1)            # possible exponential decay with temp 
        + params[11] * np.log(np.clip(x0+1e-6, 1e-6, None))  # log(strain), avoid log(0)
    )

    abs_x0 = np.abs(x0)
    abs_x1 = np.abs(x1)

    # Saturation terms from v1 capturing limiting behavior at high strains/temps,
    saturation = (
        0.5*params[4]*np.tanh(params[6]*x0)   # scaled tanh of strain capturing saturation/nonlinearity,
                                             # weighted by quadratic and cubic coeffs for physical meaning.
        - 0.3*params[5]*np.tanh(params[7]*x1)  # scaled tanh of temperature capturing softening/hardening effects,
                                              # weighted by quadratic and cubic temp coeffs.
        + 0.25*params[12]*np.tanh(abs_x0)     # new saturation on absolute strain to capture asymmetry/nonlinearity
        - 0.25*params[13]*np.tanh(abs_x1)     # new saturation on absolute temperature to capture asymmetry/nonlinearity
    )

    exp_modulation = (
        0.4*params[10]*np.exp(-params[6]*x0)*np.exp(-((x1-300)/50)**2)  
