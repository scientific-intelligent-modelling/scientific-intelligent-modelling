def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retain all terms from v1 to capture linear, nonlinear, and interaction effects.
    - Add additional nonlinear coupling terms involving inverse temperature and absolute strain.
    - Include a sigmoid function of temperature to model thermal activation or phase transition softening/hardening.
    - Use safe operations for log and division to avoid numerical issues.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params: array of coefficients (length at least 15)
      params[0] : intercept
      params[1] : linear strain coefficient
      params[2] : linear temperature coefficient
      params[3] : strain * temperature interaction
      params[4] : strain^2 term (nonlinear elasticity)
      params[5] : temperature^2 term (nonlinear temp effect)
      params[6] : strain^3 term (higher order nonlinearity)
      params[7] : temperature^3 term
      params[8] : strain^2 * temperature interaction
      params[9] : strain * temperature^2 interaction
      params[10]: exponential decay with temp 
      params[11]: log(strain), avoid log(0)
      params[12]: coefficient for inverse temp term 1/(temp + epsilon)
      params[13]: coefficient for abs(strain) term
      params[14]: coefficient for sigmoid(temp) softening/hardening

    Returns:
        Stress values as np.ndarray.
    """
    
    epsilon = 1e-6  # small number to avoid division by zero
    
    # Base polynomial + interaction terms (from v1)
    base = (
        params[0]
        + params[1] * x0                      # linear in strain
        + params[2] * x1                      # linear in temp
        + params[3] * x0 * x1                 # interaction term
        + params[4] * x0**2                   # quadratic in strain (nonlinear elasticity)
        + params[5] * x1**2                   # quadratic in temp (nonlinear temp effect)
        + params[6] * x0**3                   # cubic in strain (higher order nonlinearity)
        + params[7] * x1**3                   # cubic in temp 
        + params[8] * (x0**2) * x1            # mixed nonlinear term 
        + params[9] * x0 * (x1**2)            # mixed nonlinear term 
        + params[10] * np.exp(-x1)            # possible exponential decay with temp 
        + params[11] * np.log(np.clip(x0+epsilon, epsilon, None))  # log(strain), avoid log(0)
    )
    
    denom = 1.0 + np.abs(params[5])*(x1**2)  # ensure denominator positive and stable
    
    modulated_strain = (
          (params[1]*x0 
         + params[4]*x0**2 
         + params[6]*x0**3) / denom
     )
    
    exp_strain_term = np.exp(params[4]*x0) - 1.0  # zero at zero strain
    
    inv_temp_term = 0. if len(params)<13 else \
                    (params[12]/(x1+epsilon))   # inverse temperature effect
    
    abs_strain_term = 0. if len(params)<14 else \
                      (params[13]*np.abs(x0))   # asymmetric tension/compression
    
    sigmoid_temp = 0. if len(params)<15 else \
                   (params[14]/(1. + np.exp(-(x1 - 300)/20)))  
                   # sigmoid centered near room temp (~300K), width ~20K
    
    return base + modulated_strain + exp_strain_term*params[-1] \
           + inv_temp_term \
           + abs_strain_term \
           + sigmoid_temp
