def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain with a modulus that varies polynomially with temperature.
    - Introduce a temperature-dependent modulus modeled as a polynomial in temperature multiplying strain terms.
    - Include saturation effect for strain at high values using tanh to model yielding/softening.
    - Retain exponential decay term for temperature effects and logarithmic strain term for small strain behavior.
    - Modulate nonlinear strain terms by the temperature-dependent modulus to capture temp influence on nonlinearity.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params (length >= 12):
      params[0]: intercept
      params[1], params[2], params[5], params[7]: coefficients for temp polynomial modulus (linear, quadratic, cubic)
      params[3]: linear interaction term coefficient (strain*temp)
      params[4]: quadratic strain coefficient base
      params[6]: cubic strain coefficient base
      params[8], params[9]: mixed nonlinear interaction terms
      params[10]: exponential decay with temp coefficient
      params[11]: log(strain) coefficient

    Returns:
        Stress values as np.ndarray.
    """

    # Temperature-dependent modulus polynomial (up to cubic)
    mod_temp = (
        1.0  # baseline modulus factor (can be absorbed in other coeffs if desired)
        + params[2] * x1 
        + params[5] * x1**2 
        + params[7] * x1**3
    )

    # Saturation effect scale factor (fixed)
    saturation = 5.0  
    saturated_strain = np.tanh(saturation * x0)

    # Linear term modulated by temp-dependent modulus
    linear_term = params[1] * x0 * mod_temp

    # Nonlinear strain terms modulated by saturation and temp-dependent modulus
    quad_term = (params[4] * x0**2) * saturated_strain * mod_temp
    cubic_term = (params[6] * x0**3) * saturated_strain * mod_temp

    # Interaction terms not directly modulated by saturation but included as before
    interaction_terms = (
        params[3] * x0 * x1 
        + params[8] * (x0**2) * x1 
        + params[9] * x0 * (x1**2)
    )

    
    exp_decay_term = params[10] * np.exp(-x1)

    
    log_strain_term = 0.0
    # Avoid log(<= 0), only apply if strain > 0; else zero contribution or small epsilon inside log handled below.
    
    safe_x0 = np.clip(x0, 1e-6, None)
    
    log_strain_term = params[11] * np.log(safe_x0)

    
    stress = (
        params[0]
        + linear_term 
        + quad_term 
        + cubic_term 
        + interaction_terms 
        + exp_decay_term 
        + log_strain_term
     )
