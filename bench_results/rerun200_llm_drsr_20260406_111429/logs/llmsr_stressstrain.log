def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Further physical considerations:
    - Incorporate softplus function to model smooth yielding onset.
    - Use rational-exponential form for temperature-dependent modulus.
    - Include interaction terms between fractional powers of strain and temperature.
    - Retain logarithmic and inverse strain terms for low-strain nonlinearities.
    - Add Arrhenius-type inverse temperature squared term for activation energy effects.
    - Use separate sigmoid slopes for strain and temperature saturation effects.
    
    Model structure:
    y = params[0]
        + (params[1] + params[2]*x1 + params[3]*np.exp(params[4]*x1)) * x0
        + params[5] * x0**2
        + params[6] * np.log(np.clip(np.abs(x0), 1e-6, None))
        + params[7] / np.clip(np.abs(x0), 1e-6, None)
        + (params[8] * x1) / (params[9] + x1)
        + params[10] * np.tanh(params[11]*x0)
        + 0.05*params[5]*x1**2                                  # quadratic temp effect
        + 0.03*params[4]*(np.clip(np.abs(x0), 1e-6, None))**(2/3) # fractional power strain effect
        - 0.02*params[9]/(np.clip(x1, 1e-6, None)**2)           # inverse temp squared term
        + 0.5*params[10]/(1+np.exp(-params[6]*(x0-0.5)))         # sigmoid saturation in strain (softplus-like)
        - 0.3*params[3]/(1+np.exp(params[11]*(x1-np.median(x1))))# sigmoid saturation in temp
        + softplus(params[11]*(x0-0.02))                         # smooth yielding onset modeled by softplus

    Note:
    The softplus function is defined as softplus(z) = log(1+exp(z)), a smooth approximation of ReLU.

    """
    
    def softplus(z):
        return np.log1p(np.exp(-np.abs(z))) + np.maximum(z, 0)

