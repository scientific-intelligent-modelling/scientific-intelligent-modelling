def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Linear and quadratic strain terms to capture elastic and early plastic behavior.
    - Power-law strain term with fractional exponent for plasticity/yielding.
    - Temperature effects modeled via exponential, inverse, and logarithmic terms.
    - Interaction terms between strain and temperature to capture coupling.
    - Sigmoid function to model saturation/yielding behavior.
    
    Model structure (using up to 12 parameters):
    
    y = params[0]                                         # bias/intercept
        + (params[1] + params[2]*x1) * x0                 # temp-dependent linear modulus
        + params[3] * x0**2                                # quadratic strain term
        + params[4] * (np.abs(x0)**params[5])             # power-law strain nonlinearity
        + params[6] / (1.0 + np.exp(-params[7]*(x0 - params[8])))  # sigmoid saturation/yielding
        + params[9] * np.exp(params[10]*x1)                # exponential temperature effect
        + params[11] / (x1 + 1e-6)                         # inverse temperature effect (Arrhenius)
        + params[12] * x0 * np.log(np.clip(x1+1.01, 1e-6, None))   # interaction: strain * log(temperature)
    
    Notes:
    - To fit within MAX_NPARAMS=12, we combine or omit some terms from v1.
    - Use clipping to avoid numerical issues in log and division.
    
    Parameters:
    - x0: Strain input array
    - x1: Temperature input array
    - params: array of parameters with length at least 13
    
    Returns:
    - y: predicted stress array
    """
    
    safe_x0 = np.abs(x0) + 1e-8          # avoid zero for fractional powers/logs if needed
    safe_x1 = np.clip(x1, 1e-6, None)     # avoid zero or negative in logs/divisions
    
    linear_modulus = params[1] + params[2]*x1
    
    power_law_strain = params[4] * (safe_x0 ** params[5])
    
    sigmoid_saturation = params[6] / (1.0 + np.exp(-params[7]*(x0 - params[8])))
    
    exp_temp = params[9] * np.exp(params[10]*x1)
    
    inv_temp = params[11] / safe_x1
    
    log_temp_interaction = 0.0
    if len(params) > 12:
        log_temp_interaction = params[12] * x0 * np.log(safe_x1 + 1.01)
    
    return (
        params[0]
        + linear_modulus * x0
        + params[3] * x0**2
        + power_law_strain
        + sigmoid_saturation
        + exp_temp
        + inv_temp
        + log_temp_interaction
     )
