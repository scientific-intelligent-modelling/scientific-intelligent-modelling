    log_strain = np.log(abs_strain)

    exp_temp_decay = np.exp(-x1)

    # Combined nonlinear/log-exp interaction term controlled by param[11]
    nonlinear_interaction = (
          log_strain 
        + exp_temp_decay * x0 
        + log_strain * inv_temp
    )

    return (
          params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 * x1
        + params[4] * x0**2
        + params[5] * x1**2
        + params[6] * x0**3
        + params[7] * x1**3
        + params[8] * (x0**2) * x1
        + params[9] * x0 * (x1**2)
        + params[10] * inv_temp
        + params[11] * nonlinear_interaction
       )
