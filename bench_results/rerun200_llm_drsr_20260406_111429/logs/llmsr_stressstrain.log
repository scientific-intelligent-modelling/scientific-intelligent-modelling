def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain and temperature with polynomial terms up to cubic.
    - Include inverse temperature term for thermal activation effects.
    - Include exponential softening term with trainable decay rate depending on strain and temperature.
    - Add logarithmic temperature term to capture slow varying thermal effects at low temperatures.
    - Use all 12 parameters efficiently.

    Variables:
    - x0: Strain
    - x1: Temperature

    Parameters:
    - params: array of coefficients (length = 12)

    Model form:
        y = p0 
            + p1 * x0 
            + p2 * x1 
            + p3 * x0**2 
            + p4 * x1**2 
            + p5 * x0 * x1
            + p6 * x0**3
            + p7 * x1**3
            + p8 * (x0**2) * x1
            + p9 * x0 * (x1**2)
            + p10 / (x1 + epsilon)
            + exp_term

        where,
        exp_term = p11 * exp(-decay_rate_param * abs(x0*x1))

        decay_rate_param is taken as abs(p[10]) to keep it positive and trainable.

        Additionally add a logarithmic interaction term scaled by a fraction of param[0] for subtle effects:
        
        log_term = (p[0]/10) * x0 * log(1 + max(x1, 0))

        This adds complexity without increasing parameter count.

    """
    
    epsilon = 1e-6  # avoid division by zero or log domain errors
    
    p = params
    
    # Decay rate for exponential softening taken from param[10], ensure positive by abs()
    decay_rate_param = np.abs(p[10])
    
    inv_temp_term = 0.0
    exp_term = 0.0
    
    if len(p) >= 12:
        inv_temp_term = p[10] / (x1 + epsilon)
        exp_term = p[11] * np.exp(-decay_rate_param * np.abs(x0*x1))
    
    # Logarithmic interaction term; ensure argument > 0 inside log by max with zero
    log_arg = np.maximum(x1, 0.0) + 1.0
    
    return (
        p[0]
        + p[1] * x0
        + p[2] * x1
        + p[3] * x0**2
        + p[4] * x1**2
        + p[5] * x0 * x1
        + p[6] * x0**3
        + p[7] * x1**3
        + p[8] * (x0**2) * x1
        + p[9] * x0 * (x1**2)
        + inv_temp_term
        + exp_term
        +
        (p[0]/10.0) * x0 * np.log(log_arg)
       )
