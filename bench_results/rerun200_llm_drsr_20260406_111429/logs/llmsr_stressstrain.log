def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Builds on polynomial interaction terms from v1.
    - Adds an exponential decay term to model thermal softening more explicitly.
    - Adds a saturation effect via tanh to capture nonlinear coupling saturation.
    - Uses all 12 parameters (params[0] to params[11]) consistently.

    Variables:
    - x0: Strain (ε)
    - x1: Temperature (T)
    - y : Stress (σ)

    Parameters:
    - params: array-like coefficients [p0,...p11]

    Model form:
        σ = p0 
            + p1 * ε 
            + p2 * T 
            + p3 * ε * T 
            + p4 * ε^2 
            + p5 * T^2
            + p6 * ε^2 * T
            + p7 * ε * T^2
            + p8 * ε^3
            + p9 * exp(-p10 * T) * ε   # thermal softening exponential decay term
            + p11 * tanh(ε * T)        # saturation effect due to strain-temperature coupling

    Note:
        Since MAX_NPARAMS=12, params indices go from 0 to 11.
        We use param[10] inside the exponent for decay rate,
        param[9] as amplitude of exponential term,
        and param[11] as coefficient for tanh saturation term.
    """
    
    eps = x0
    temp = x1
    
    base_poly = (
        params[0]
        + params[1] * eps
        + params[2] * temp
        + params[3] * eps * temp
        + params[4] * eps**2
        + params[5] * temp**2
        + params[6] * eps**2 * temp
        + params[7] * eps * temp**2
        + params[8] * eps**3
    )
    
    exp_decay = params[9] * np.exp(-params[10] * temp) * eps
    
    saturation = params[11] * np.tanh(eps*temp)
    
    return base_poly + exp_decay + saturation
