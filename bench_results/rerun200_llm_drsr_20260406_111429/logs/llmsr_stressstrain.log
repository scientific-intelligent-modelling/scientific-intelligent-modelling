def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain linearly (Hooke's law) plus nonlinear terms for plasticity or large strains.
    - Temperature affects stiffness nonlinearly; higher order terms can capture softening or phase changes.
    - Interaction terms between strain and temperature can be nonlinear as well.
    
    Variables:
    - x0: Strain
    - x1: Temperature
    """
    return (params[0]  # intercept / offset stress
            + params[1] * x0  # linear strain term (modulus)
            + params[2] * x1  # linear temperature effect
            + params[3] * x0 * x1  # interaction term (temperature-dependent modulus)
            + params[4] * x0**2  # quadratic strain effect
            + params[5] * x1**2  # quadratic temperature effect
            + params[6] * x0**3  # cubic strain effect
            + params[7] * (x0**2) * x1)  # interaction between quadratic strain and temperature
