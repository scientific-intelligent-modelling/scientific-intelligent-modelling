def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain (x0) and temperature (x1).
    - Young's modulus decreases with increasing temperature (modeled by exponential decay).
    - Nonlinear elastic/plastic effects captured by polynomial terms in strain.
    - Temperature effects are nonlinear; inverse temperature term captures thermally activated processes.
    - Interaction terms between strain and temperature powers.
    - Logarithmic term of strain captures strain hardening behavior at low strains.
    
    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
        params[0]: intercept (baseline stress)
        params[1]: linear coefficient for strain (x0)
        params[2]: linear coefficient for temperature (x1)
        params[3]: interaction term coefficient (x0 * x1)
        params[4]: quadratic term for strain^2
        params[5]: quadratic term for temperature^2
        params[6]: cubic term for strain^3
        params[7]: cubic term for temperature^3
        params[8]: interaction term coefficient (x0^2 * x1)
        params[9]: interaction term coefficient (x0 * x1^2)
        params[10]: inverse temperature term coefficient (1 / x1)
        params[11]: logarithmic strain term coefficient (log(|x0| + ε))

    Returns:
        y: Predicted stress as numpy array
    """
    
    epsilon = 1e-8  # To avoid division by zero or log(0)

    inv_temp = 1.0 / (x1 + epsilon)

    log_strain = np.log(np.abs(x0) + epsilon)

    # Exponential decay factor modeling thermal softening of modulus,
    # modulating the linear and quadratic strain terms to reflect temp dependence.
    
    exp_temp_decay = np.exp(-params[5] * x1)  # Using param5 here as in v1; could be replaced if desired.

    # Compose stress prediction combining all effects:

    y = (
          params[0]                                # intercept
        + exp_temp_decay * (
              params[1] * x0                      # linear in strain modulated by temp softening
            + params[4] * x0**2                   # quadratic in strain modulated by temp softening
            + params[6] * x0**3                   # cubic in strain modulated by temp softening
          )
        + params[2] * x1                          # linear temp effect independent of strain modulation
        + params[3] * x0 * x1                     # interaction linear*linear
        + params[5] * x1**2                       # quadratic temp effect 
        + params[7] * x1**3                       # cubic temp effect 
        + params[8] * (x0**2) * x1                # higher order interaction 
        + params[9] * x0 * (x1**2)                # higher order interaction 
        + params[10] * inv_temp                    # inverse temp effect capturing thermally activated processes 
        + params[11] * log_strain                  # logarithmic dependence on strain capturing hardening at low strains 
      )

    return y
