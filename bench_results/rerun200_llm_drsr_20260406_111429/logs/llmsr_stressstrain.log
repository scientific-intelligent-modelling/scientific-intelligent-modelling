def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Model stress as a polynomial function of strain (x0) and temperature (x1),
      including linear, quadratic, cubic terms.
    - Include interaction terms between strain and temperature.
    - Include inverse temperature term to capture thermal activation effects.
    - Include cross term between strain and inverse temperature.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params: array of coefficients (length = 12)

    Model form:

        stress = p0 
                 + p1 * strain 
                 + p2 * temperature 
                 + p3 * strain * temperature 
                 + p4 * strain^2 
                 + p5 * temperature^2
                 + p6 * strain^2 * temperature
                 + p7 * strain * temperature^2
                 + p8 * strain^3
                 + p9 * temperature^3
                 + p10 / temperature  # inverse temp effect
                 + p11 * strain / temperature

    """
    
    # Avoid division by zero or very small temperatures by clipping minimum value
    epsilon = 1e-8
    safe_temp = np.clip(x1, epsilon, None)
    
    inv_temp = 1.0 / safe_temp
    
    p = params
    
    return (
        p[0]                          # constant offset stress term
        + p[1] * x0                   # linear in strain
        + p[2] * x1                   # linear in temp
        + p[3] * x0 * x1              # interaction linear*linear term
        + p[4] * x0**2                # quadratic in strain (nonlinear elasticity)
        + p[5] * x1**2                # quadratic in temp (thermal softening/hardening)
        + p[6] * (x0**2) * x1         # mixed nonlinear term: quadratic strain times temp
        + p[7] * x0 * (x1**2)         # mixed nonlinear term: strain times quadratic temp
        + p[8] * x0**3                # cubic nonlinear elasticity effect on stress-strain curve shape
        + p[9] * x1**3                # cubic thermal effect on stress behavior at high temps
        + p[10] * inv_temp            # inverse temp captures Arrhenius-type activation energy effects on flow stress etc.
        + p[11] * x0 * inv_temp       # cross-term coupling strain with inverse temp effect on stress
        
    )
