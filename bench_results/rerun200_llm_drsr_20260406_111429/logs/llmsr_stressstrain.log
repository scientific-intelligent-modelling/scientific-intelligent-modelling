def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Variables:
    - x0: Strain (ε)
    - x1: Temperature (T)
    - y : Stress (σ)

    Parameters:
    - params: array-like coefficients [p0,...p11]

    Model form:
        σ = p1 * ε 
            + p3 * ε * T 
            + p4 * ε^2 
            + p6 * ε^2 * T
            + p7 * ε * T^2
            + p8 * ε^3
            + p10 * ε^3 * T
            + p11 * ε * T^3

    Notes:
    - No constant or pure temperature terms to ensure σ=0 when ε=0.
    - This polynomial form captures nonlinear strain effects and temperature coupling.
    """
    
    eps = x0
    temp = x1
    
    return (
        params[1]  * eps
        + params[3]  * eps  * temp
        + params[4]  * eps**2
        + params[6]  * eps**2  * temp
        + params[7]  * eps  * temp**2
        + params[8]  * eps**3
        + params[10]  * eps**3  * temp
        + params[11]  * eps  * temp**3
    )
