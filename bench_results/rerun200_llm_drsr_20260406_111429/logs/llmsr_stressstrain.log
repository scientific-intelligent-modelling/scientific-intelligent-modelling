    term_exp = np.exp(-params[7] * x1)
    term_inv_temp = 1.0 / (x1 + epsilon)
    
    y = (
        params[0] +
        params[1] * x0 +
        params[2] * x1 +
        params[3] * x0 * x1 +
        params[4] * x0**2 +
        params[5] * x1**2 +
        params[6] * term_exp +
        params[8] * term_inv_temp
    )
    
    return y
