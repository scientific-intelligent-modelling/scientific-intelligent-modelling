def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` incorporating physically meaningful nonlinearities:
    
    Physical reasoning:
    - Stress (y) depends on Strain (x0) and Temperature (x1).
    - Young's modulus E typically decreases exponentially with increasing temperature.
      Model this as E = p1 * exp(-p2 * x1)
    - Stress is approximately E * strain for elastic regime.
    - Include quadratic strain term to capture nonlinearity in stress-strain curve.
    - Include linear temperature offset and interaction term to capture coupling effects.
    
    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress
    
    Parameters:
    params[0]: intercept (baseline stress)
    params[1]: modulus scale factor (E0)
    params[2]: temperature decay rate for modulus
    params[3]: linear coefficient for temperature offset
    params[4]: quadratic coefficient for strain^2
    params[5]: interaction coefficient (strain * temperature)
    
    Returns:
        y (np.ndarray): Predicted stress
    """
    
    E = params[1] * np.exp(-params[2] * x1)  # Temperature-dependent Young's modulus
    
    return (
        params[0]  # baseline stress offset
        + E * x0  # linear elastic term with temp-dependent modulus
