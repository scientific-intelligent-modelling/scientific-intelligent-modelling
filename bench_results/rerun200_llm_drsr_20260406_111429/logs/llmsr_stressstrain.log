def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Physical reasoning:
    - Stress typically depends linearly on strain (Hooke's law) for small strains.
    - Temperature affects material properties, often reducing stiffness as temperature increases.
    - Interaction terms and nonlinearities can capture more complex behavior.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 7 for this model.
      params[0]: intercept
      params[1]: linear coefficient for strain
      params[2]: linear coefficient for temperature
      params[3]: interaction term coefficient (strain * temperature)
      params[4]: quadratic term for strain (strain^2)
      params[5]: quadratic term for temperature (temperature^2)
      params[6]: possibly higher order or residual term
    """
    
    # Linear terms
    linear = params[0] + params[1]*x0 + params[2]*x1
    
    # Interaction term between strain and temperature
    interaction = params[3] * x0 * x1
    
    # Quadratic terms to capture nonlinearity in strain and temperature effects
    quad_strain = params[4] * x0**2
    quad_temp = params[5] * x1**2
    
    # Optional higher order or residual term (can be zero if not needed)
    residual = 0.0 if len(params) < 7 else params[6]
    
    return linear + interaction + quad_strain + quad_temp + residual
