def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation_v1 with separate parameters for exponential decay coefficient and rate,
    plus combined inverse and logarithmic temperature terms.

    Physical reasoning:
    - Stress depends on strain linearly and nonlinearly (up to cubic terms).
    - Temperature affects stress via polynomial terms, inverse terms, exponential decay, and logarithmic softening/hardening.
    - Interaction terms between strain and temperature included.
    
    Variables:
    - x0: Strain
    - x1: Temperature
    
    Parameters:
    - params: array of coefficients (length 12)
    
    Model form example:
        stress = p0 
                 + p1 * strain 
                 + p2 * temperature 
                 + p3 * strain^2 
                 + p4 * temperature^2 
                 + p5 * strain * temperature
                 + p6 * strain^3
                 + p7 * temperature^3
                 + p8 * strain^2 * temperature
                 + p9 * strain * temperature^2
                 + p10 / (temperature + epsilon)           # inverse temp effect (softening)
                 + p11_exp_coeff * exp(-p11_exp_rate * temperature)  # exponential decay term for stiffness loss with temp
                 + log_term_coeff * log(temperature+offset)          # log term for low temp effects

        Here we reuse param[10] as inverse temp coefficient,
        param[11] as exp decay rate,
        param[12] would be log coeff but since max is 12 params,
        we approximate log coeff by a fraction of param[10].

        To keep within 12 params, we combine log term coefficient as fraction of param[10].
    
    """
    
    epsilon = 1e-6      # small number to avoid division by zero in inverse temp terms
    temp_offset = 1e-3  # small offset for log argument
    
    p = params
    
    # Logarithmic term safely computed; ensure argument > 0 by adding offset.
    log_temp = np.log(x1 + temp_offset)
    
    # Weight factor between inverse and logarithmic contributions from param[10]
    alpha = 0.6   # tuned weight factor; can be adjusted or learned
    
    inv_temp_term = alpha * (p[10] / (x1 + epsilon))
    
    log_temp_term = (1 - alpha) * p[10] * log_temp
    
    # Exponential decay uses absolute value of rate parameter to ensure positivity
    exp_decay_term = np.abs(p[11]) * np.exp(-np.abs(p[11]) * x1)
    
    return (
        p[0]
        + p[1] * x0
        + p[2] * x1
        + p[3] * x0**2
        + p[4] * x1**2
        + p[5] * x0 * x1
        + p[6] * x0**3
        + p[7] * x1**3
        + p[8] * (x0**2) * x1
        + p[9] * x0 * (x1**2)
        + inv_temp_term 
        + log_temp_term 
        - exp_decay_term     # negative sign since stiffness decays with increasing temp => reduces stress
        
        
       )
