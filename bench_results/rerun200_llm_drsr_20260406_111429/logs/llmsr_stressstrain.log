      + params[4] * x0**abs(params[5])                                    # power-law strain hardening
      + params[6] * np.exp(params[7]*x1)                                 # exponential temperature effect
      + params[8] / (1 + np.exp(-params[9]*(x0 - params[10])))           # sigmoid yielding/saturation
      + params[11] * x0 * x1**3                                          # higher order strain-temp interaction
