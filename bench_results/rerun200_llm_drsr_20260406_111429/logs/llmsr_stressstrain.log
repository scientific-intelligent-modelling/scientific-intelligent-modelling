def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements over v1:
    - Separate sigmoid slope parameter for strain saturation (params[11]) instead of reusing params[6].
    - Add a temperature-squared term to capture nonlinear temperature effects.
    - Add a strain inverse term to capture possible strain softening or damage effects.
    - Add a cross term with logarithmic strain and temperature interaction.
    - Maintain all previous terms for rich modeling.

    Model structure:
    y = params[0]
        + params[1]*x0                          # linear strain
        + params[2]*x1                          # linear temperature
        + params[3]*x0*x1                      # linear interaction
        + params[4]*x0**2                      # quadratic strain
        + params[5]*np.exp(params[6]*x1)       # exponential temp effect
        + params[7]*x0**3                      # cubic strain
        + params[8]*np.log(np.clip(x1, 1e-6, None))  # log temp effect
        + params[9]/np.clip(x1, 1e-6, None)   # inverse temperature (Arrhenius-like)
        + params[10]*(x0 * x1**2)              # nonlinear interaction term
        + params[11] * (1 / (1 + np.exp(-params[11]*(x0 - 0.5))))  # sigmoid saturation in strain with separate slope param
        + params[12] * x1**2                   # quadratic temperature term (if MAX_NPARAMS increased)
        + params[13] / np.clip(x0, 1e-6, None) if len(params) > 13 else 0.0   # inverse strain term (optional)
        + params[14] * np.log(np.clip(x0, 1e-6, None)) * x1 if len(params) > 14 else 0.0   # log-strain * temp cross term

    Notes:
    - If MAX_NPARAMS remains at 12, only the first eleven terms plus sigmoid are used.
      To include the last three terms, increase MAX_NPARAMS accordingly.
    """

    safe_x1 = np.clip(x1, 1e-6, None)
    safe_x0 = np.clip(x0, 1e-6, None)

    sigmoid_strain = 1 / (1 + np.exp(-params[11] * (x0 - 0.5)))

    y = (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 * x1
        + params[4] * x0 ** 2
        + params[5] * np.exp(params[6] * x1)
        + params[7] * x0 ** 3
        + params[8] * np.log(safe_x1)
        + params[9] / safe_x1
        + params[10] * (x0 * x1 ** 2)
        + params[11] * sigmoid_strain
    )

    if len(params) > MAX_NPARAMS:
      raise ValueError(f"params length {len(params)} exceeds expected MAX_NPARAMS={MAX_NPARAMS}")

    return y
