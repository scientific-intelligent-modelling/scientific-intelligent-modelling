def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Physical reasoning:
    - Stress often depends linearly on strain (Hooke's law) for small strains.
    - Temperature can affect the modulus and cause thermal expansion effects.
    - Include interaction terms and nonlinearities to capture more complex behavior.

    Variables:
    - x0: Strain
    - x1: Temperature

    Parameters:
    - params: array of coefficients (length up to MAX_NPARAMS=12)
    
    Model form (example):
        stress = p0 
               + p1 * strain 
               + p2 * temperature 
               + p3 * strain^2 
               + p4 * temperature^2 
               + p5 * strain * temperature
               + p6 * exp(p7 * strain)
               + p8 * log(1 + abs(strain))
               + p9 * sin(p10 * temperature)
               + p11 * strain^3
               
    This skeleton allows capturing linear, quadratic, interaction, and some nonlinear effects.
    """
    
    # Unpack parameters for clarity
    p = params
    
    # To avoid domain errors in log, add a small epsilon inside log argument
    epsilon = 1e-8
    
    term_linear_strain = p[1] * x0
    term_linear_temp = p[2] * x1
    
    term_quad_strain = p[3] * x0**2
    term_quad_temp = p[4] * x1**2
    
    term_interaction = p[5] * x0 * x1
    
    # Exponential term with strain scaled by parameter (p7)
    term_exp_strain = p[6] * np.exp(p[7] * x0)
    
    # Logarithmic term of absolute strain plus epsilon to avoid log(0)
    term_log_strain = p[8] * np.log(np.abs(x0) + epsilon)
    
    # Sinusoidal modulation with temperature scaled by parameter (p10)
    term_sin_temp = p[9] * np.sin(p[10] * x1)
    
    # Cubic strain term for higher order nonlinearity
    term_cubic_strain = p[11] * x0**3
    
    y = (
        p[0]
        + term_linear_strain
        + term_linear_temp
        + term_quad_strain
        + term_quad_temp
        + term_interaction
        + term_exp_strain
        + term_log_strain
        + term_sin_temp
        + term_cubic_strain
     )
