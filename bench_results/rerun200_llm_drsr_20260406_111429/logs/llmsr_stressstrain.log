      params[7]: temperature^3 term
      params[8]: strain^2 * temperature interaction
      params[9]: strain * temperature^2 interaction
      params[10]: exponential decay coefficient with temp 
      params[11]: log(strain + epsilon) coefficient

    Returns:
        Stress values as np.ndarray.
    """
    
    eps = 1e-8  # small offset to avoid log(0)

    # Polynomial terms capturing nonlinear elasticity and temp effects:
    poly = (
