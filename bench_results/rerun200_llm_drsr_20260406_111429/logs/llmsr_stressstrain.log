def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain and temperature with nonlinear coupling.
    - Modulus decreases exponentially with temperature (Arrhenius-type).
    - Strain hardening captured by polynomial terms in strain.
    - Thermal softening captured by exponential decay and logarithmic terms in temperature.
    - Logistic function models smooth yield/saturation behavior near threshold strain.
    - Hysteresis/asymmetry modeled via signed power-law term on strain.
    - Additional cross terms for complex interactions.

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 14 for full model.

    Model form example:
        y = p0 
            + p1 * x0 * exp(-p2 * x1)               # thermal softening modulated strain (Arrhenius)
            + p3 * x0**2 
            + p4 * x0**3 
            + p5 * x1 
            + p6 * x1**2 
            + p7 * x0 * x1 
            + p8 * (x0**2) * x1
            + p9 / (1 + exp(-p10*(x0 - p11)))       # logistic saturation around threshold p11
            + p12 * sign(x0) * |x0|^p13              # hysteresis/asymmetry term
            + p14 * log(1+x1)                        # logarithmic temp softening (if params length >=15)
            + p15 * (x0**3)*x1                       # higher order cross term (if params length >=16)
            
        Terms beyond index 13 are optional depending on params length.
    """
    
    # Ensure minimum parameter count for base model
    n = len(params)
    
    # Clip parameters that appear in exponents or denominators to avoid numerical issues
    exp_decay = max(params[2], 1e-6)
    
    thermal_softening = params[1] * x0 * np.exp(-exp_decay * x1)
    
    nonlinear_strain = params[3] * x0**2 + params[4] * x0**3
    
    temp_terms = params[5] * x1 + params[6] * x1**2
    
    interaction_terms = params[7] * x0 * x1 + params[8] * (x0**2) * x1
    
    logistic_arg = -params[10]*(x0 - params[11])
    
    logistic_arg_clipped = np.clip(logistic_arg, -50, 50)
    
    saturation_logistic = params[9] / (1.0 + np.exp(logistic_arg_clipped))
    
    base = (params[0]
            + thermal_softening
            + nonlinear_strain
            + temp_terms
            + interaction_terms
            + saturation_logistic)
    
    if n >= 14:
        power_exp = max(params[13], 0.01)  # positive exponent
        
        hysteresis_term = params[12] * np.sign(x0) * (np.abs(x0)**power_exp)
        
        base += hysteresis_term
    
    if n >= 15:
        # Logarithmic temperature softening term: captures slow variation at high T
        base += params[14] * np.log(1.0 + np.maximum(x1, 0))
        
    if n >= 16:
        # Higher order cross term: cubic strain times linear temperature interaction
        base += params[15] * (x0**3) * x1
        
    return base
