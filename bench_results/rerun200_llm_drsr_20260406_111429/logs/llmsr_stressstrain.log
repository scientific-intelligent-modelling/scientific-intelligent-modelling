    nonlinear_interaction = params[11] * (x0**2) * x1
    
    tanh_saturation = params[12] * np.tanh(params[13] * x0)
    
    cubic_exp_temp_modulated = params[14] * (x0 ** 3) * np.exp(-params[8]*x1)

    
    return (
        linear 
        + interaction 
        + quad_strain 
        + quad_temp 
        + cubic_strain 
        + exp_temp 
        + log_temp 
        + inv_strain 
        + nonlinear_interaction
        + tanh_saturation
        + cubic_exp_temp_modulated
       )
