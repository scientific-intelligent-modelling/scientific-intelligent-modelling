        + params[7] * x1**3                   # cubic in temp 
        + params[8] * (x0**2) * x1            # mixed nonlinear term 
        + params[9] * x0 * (x1**2)            # mixed nonlinear term 
        + params[11] * np.log(np.clip(x0+eps, eps, None))  # log(strain)
    )
    
    # Exponential decay factor modeling thermal softening,
    exp_decay = np.exp(-params[10]*x1)
    
    poly_modulated = poly * exp_decay
    
    # Saturation amplitude and scale depend linearly on temperature,
    # both modulated by trainable parameters from the polynomial coefficients for flexibility:
    
    saturation_amplitude = max(params[4], 0.5) + 0.3*x1   # base amplitude from quadratic strain param plus temp effect
    
    saturation_scale = max(params[6], 1.0) + 0.05*x1       # base scale from cubic strain param plus temp effect
    
    saturation = saturation_amplitude * np.tanh(saturation_scale*x0)
    
    return poly_modulated + saturation
