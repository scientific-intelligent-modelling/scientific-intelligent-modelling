    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements:
    - Added temperature-modulated strain saturation term using tanh.
    - Added inverse temperature squared term for stronger thermal activation modeling.
    - Added logarithmic interaction between strain and temperature.
    
    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params: array of coefficients [p0,...p11]
      Structure:
        p0 : intercept
        p1 : linear strain coefficient
        p2 : linear temperature coefficient
        p3 : quadratic strain coefficient
        p4 : quadratic temperature coefficient
        p5 : strain * temperature interaction coefficient
        p6 : thermal softening amplitude (exponential decay)
        p7 : thermal softening decay rate (exponential decay)
        p8 : logarithmic strain coefficient
        p9 : cubic strain coefficient (strain hardening)
        p10: inverse temperature squared coefficient (new)
        p11: log(strain)*log(temperature) interaction coefficient (new)

    Model structure:

        y = p0 
            + p1*x0 
            + p2*x1 
            + p3*x0**2 
            + p4*x1**2 
            + p5*x0*x1 
            + p6*x0*np.exp(-p7*x1)          # thermal softening exponential decay
            + p8*np.log(x0 + epsilon)       # logarithmic strain term (for large strains)
            + p9*x0**3                      # cubic strain hardening term
            + 5.0*p9*np.tanh(20*(x0 - 0.05))# smooth saturation effect on strain
            + p10 / ((x1+epsilon)**2)       # inverse temp squared effect for strong thermal activation barrier modeling
            + p11 * np.log(x0+epsilon) * np.log(x1+epsilon)  # log-log interaction capturing complex coupling

    """
    
    epsilon = 1e-8  # small number to avoid log(0) or division by zero
    
    linear = params[0] + params[1]*x0 + params[2]*x1
    
    quad = params[3]*x0**2 + params[4]*x1**2
    
    interaction_1 = params[5]*x0*x1
    
    thermal_softening = params[6] * x0 * np.exp(-params[7]*x1)
    
    log_strain = np.zeros_like(x0)
    positive_strain_mask = (x0 + epsilon) > 0
    log_strain[positive_strain_mask] = params[8] * np.log(x0[positive_strain_mask] + epsilon)
    
    cubic_strain = params[9] * x0**3
    
    tanh_strain_sat = 5.0 * params[9] * np.tanh(20*(x0 - 0.05))
    
    inv_temp_sq = params[10] / ((x1 + epsilon)**2)
    
    log_temp = np.zeros_like(x1)
    
    positive_temp_mask = (x1 + epsilon) > 0
    
    # For the new log-log interaction term, only compute where both are positive:
    
    log_log_interaction = np.zeros_like(x0)
    
    valid_mask = positive_strain_mask & positive_temp_mask
    
    if np.any(valid_mask):
        log_log_interaction[valid_mask] = (
            params[11]
            * np.log(x0[valid_mask] + epsilon)
            * np.log(x1[valid_mask] + epsilon)
        )
        
    
    return (
        linear 
        + quad 
        + interaction_1 
        + thermal_softening 
        + log_strain 
        + cubic_strain 
        + tanh_strain_sat 
        + inv_temp_sq 
        + log_log_interaction
       )
