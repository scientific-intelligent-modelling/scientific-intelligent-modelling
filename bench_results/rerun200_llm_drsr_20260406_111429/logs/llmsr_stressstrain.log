def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Builds on v1 with additional nonlinearities and interaction terms.
    - Includes exponential strain softening/hardening term to capture complex strain effects.
    - Adds temperature-dependent exponential activation term for thermally activated processes.
    - Cross terms between log(strain) and inverse temperature capture combined effects at low strains and high temperatures.
    
    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters (params array length >= 15):
        params[0]: intercept (baseline stress)
        params[1]: linear coefficient for strain (x0)
        params[2]: linear coefficient for temperature (x1)
        params[3]: interaction term coefficient (x0 * x1)
        params[4]: quadratic term for strain^2
        params[5]: quadratic term for temperature^2
        params[6]: cubic term for strain^3
        params[7]: cubic term for temperature^3
        params[8]: interaction term coefficient (x0^2 * x1)
        params[9]: interaction term coefficient (x0 * x1^2)
        params[10]: inverse temperature term coefficient (1 / x1)
        params[11]: logarithmic strain term coefficient (log(|x0| + ε))
        params[12]: exponential decay rate wrt strain magnitude in exp(-param12 * |x0|)
        params[13]: amplitude of exponential strain softening/hardening term
        params[14]: amplitude of temp-dependent exponential activation exp(-param14 * x1)

    Returns:
        y: Predicted stress as numpy array
    """
    
    epsilon = 1e-8  # To avoid division by zero or log(0)

    # Safe operations on inputs
    abs_x0 = np.abs(x0) + epsilon
    safe_x1 = np.maximum(x1, epsilon)

    inv_temp = 1.0 / safe_x1

    log_strain = np.log(abs_x0)

    # Exponential decay factor modeling thermal softening of modulus,
    # modulating the polynomial strain terms to reflect temp dependence.
    
    exp_temp_decay = np.exp(-params[5] * safe_x1)  # using param5 as decay rate wrt temp

    # Exponential decay wrt absolute strain magnitude capturing softening/hardening effects beyond polynomials
    exp_strain_decay = np.exp(-params[12] * abs_x0)

    # Additional temp-dependent activation factor, e.g. Arrhenius-like behavior 
    exp_temp_activation = np.exp(-params[14] * safe_x1)

    
    y = (
          params[0]                                # intercept / baseline stress

          + exp_temp_decay * (
                params[1] * x0                      # linear in strain modulated by temp softening
              + params[4] * x0**2                   # quadratic in strain modulated by temp softening
              + params[6] * x0**3                   # cubic in strain modulated by temp softening
          )

          + params[2] * safe_x1                     # linear temp effect independent of modulation

          + params[3] * x0 * safe_x1                # linear*linear interaction

          + params[5] * safe_x1**2                   # quadratic temp effect 

          + params[7] * safe_x1**3                   # cubic temp effect 

          + params[8] * (x0**2) * safe_x1            # higher order interaction 

          + params[9] * x0 * (safe_x1**2)            # higher order interaction 

          + params[10] * inv_temp                     # inverse temperature effect capturing thermally activated processes 

          + params[11] * log_strain                   # logarithmic dependence on strain capturing hardening at low strains 

          + params[13] * exp_strain_decay             # exponential decay wrt |strain| capturing additional nonlinearities

          + exp_temp_activation                       # multiplicative factor modeling thermal activation dynamics

      )

    
    return y
