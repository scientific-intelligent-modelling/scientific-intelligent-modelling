def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain and temperature.
    - Modulus of elasticity decreases with increasing temperature, often exponentially or inversely.
    - Nonlinear strain terms capture strain hardening or softening.
    - Temperature effects can be nonlinear and coupled with strain in more complex ways.
    - Include exponential decay term to model thermal softening of modulus.
    - Include inverse temperature term to capture Arrhenius-type behavior if relevant.

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 12 for this model.
    
    Model form:
        y = p0 
            + p1*x0 
            + p2*x1 
            + p3*x0*x1 
            + p4*x0**2 
            + p5*x1**2 
            + p6*(x0**2)*x1 
            + p7*x0*(x1**2) 
            + p8*x0**3
            + p9 * x0 * np.exp(-p10 * x1)
            + p11 / (x1 + 273.15)  # inverse absolute temperature (K)
    
    where
        x0 = strain,
        x1 = temperature in Celsius,
        y = stress
    """
    
    # To avoid division by zero or negative Kelvin temperatures, add 273.15 to Celsius
    temp_K = x1 + 273.15
    
    linear = params[0] + params[1] * x0 + params[2] * x1
    interaction = params[3] * x0 * x1
    quad_strain = params[4] * x0**2
    quad_temp = params[5] * x1**2
    cross_quad_1 = params[6] * (x0**2) * x1
    cross_quad_2 = params[7] * x0 * (x1**2)
    cubic_strain = params[8] * x0**3
    
    # Exponential decay term modeling thermal softening of modulus with temperature
    exp_term = params[9] * x0 * np.exp(-params[10] * x1)
    
    # Inverse absolute temperature term capturing Arrhenius-like effects on stress or material properties
    inv_temp_term = params[11] / temp_K
    
    return (linear 
            + interaction 
            + quad_strain 
            + quad_temp 
            + cross_quad_1 
            + cross_quad_2 
            + cubic_strain 
            + exp_term 
            + inv_temp_term)
