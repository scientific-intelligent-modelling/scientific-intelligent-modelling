    # scaled down from constant offset param to keep magnitude reasonable.
    
    log_temp_term = (p[0] / 10.0) * x0 * np.log(1.0 + np.maximum(x1, 0))
    
    return (
        p[0]
        + p[1] * x0
        + p[2] * x1
        + p[3] * x0**2
        + p[4] * x1**2
