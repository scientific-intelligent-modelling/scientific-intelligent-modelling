def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retain all terms from v1 capturing linear, nonlinear, and interaction effects.
    - Add inverse temperature term to model thermal activation (Arrhenius-like).
    - Modulate exponential strain term by a rational function of temperature for better physical realism.
    - Include absolute strain * temperature interaction to capture asymmetric mechanical response affected by temp.
    - Use safe numerical operations (clipping) for log and division.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params: array of coefficients (length at least 14)
      params[0]: intercept
      params[1]: linear strain coefficient
      params[2]: linear temperature coefficient
      params[3]: strain * temperature interaction
      params[4]: strain^2 term (nonlinear elasticity)
      params[5]: temperature^2 term (nonlinear temp effect)
      params[6]: strain^3 term (higher order nonlinearity)
      params[7]: temperature^3 term
      params[8]: strain^2 * temperature interaction
      params[9]: strain * temperature^2 interaction
      params[10]: exponential decay with temp 
      params[11]: log(strain), avoid log(0)
      params[12]: inverse temperature coefficient (Arrhenius-like)
      params[13]: abs(strain) * temperature interaction

    Returns:
        Stress values as np.ndarray.
    """
    
    epsilon = 1e-6  # small number to avoid division by zero or log(0)

    # Base polynomial + interaction terms from v1
    base = (
        params[0]
        + params[1] * x0                      # linear in strain
        + params[2] * x1                      # linear in temp
        + params[3] * x0 * x1                 # interaction term
        + params[4] * x0**2                   # quadratic in strain (nonlinear elasticity)
        + params[5] * x1**2                   # quadratic in temp (nonlinear temp effect)
        + params[6] * x0**3                   # cubic in strain (higher order nonlinearity)
        + params[7] * x1**3                   # cubic in temp 
        + params[8] * (x0**2) * x1            # mixed nonlinear term 
        + params[9] * x0 * (x1**2)            # mixed nonlinear term 
        + params[10] * np.exp(-x1)            # possible exponential decay with temp 
        + params[11] * np.log(np.clip(x0+epsilon, epsilon, None))  # log(strain), avoid log(0)
    )
    
    # Rational modulation denominator for polynomial terms involving strain and temp squared,
    denom_poly = 1.0 + np.abs(params[5])*(x1**2)

    modulated_strain_poly = (
          (params[1]*x0 +
           params[4]*x0**2 +
           params[6]*x0**3) / denom_poly
       )
    
    # Exponential dependence on strain modulated by rational function of temperature,
    denom_exp = 1.0 + np.abs(params[5])*(x1**2)  # reuse same denominator structure
    
    exp_strain_term = ((np.exp(params[4]*x0) - 1.0) / denom_exp) 
    
    exp_modulated = exp_strain_term*params[-3]

    
    # Inverse Temperature Term for Arrhenius-like behavior,
    
    inv_temp_term = 0.0
    safe_x1 = np.clip(x1, epsilon, None)
    
    if len(params) > 12:
        inv_temp_term = params[-2]/safe_x1
