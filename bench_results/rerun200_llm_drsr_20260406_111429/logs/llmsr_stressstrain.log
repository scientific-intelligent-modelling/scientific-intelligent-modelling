def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain approximately linearly at small strains (Hooke's law).
    - Temperature reduces stiffness, often modeled as a decay or softening effect.
    - Nonlinearities include quadratic terms and interaction terms.
    - Additional nonlinear terms can capture strain hardening and thermal softening more flexibly.
    - Include inverse temperature dependence to model effects like thermal activation.
    - Use smooth nonlinear functions like tanh to model saturation effects in strain.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params: array of coefficients [p0,...p11]
      Using up to quadratic, interaction, exponential, logarithmic, inverse and hyperbolic tangent terms.
    
    Model structure:

        y = p0 
            + p1*x0 
            + p2*x1 
            + p3*x0**2 
            + p4*x1**2 
            + p5*x0*x1 
            + p6*x0*np.exp(-p7*x1)          # thermal softening exponential decay
            + p8*np.log(x0 + epsilon)        # logarithmic strain term (for large strains)
            + p9/(x1 + epsilon)              # inverse temperature term (thermal activation)
            + p10*np.tanh(p11 * x0)          # saturation effect in strain

    """
    
    epsilon = 1e-8  # small number to avoid division by zero or log(0)
    
    linear = params[0] + params[1]*x0 + params[2]*x1
    quad = params[3]*x0**2 + params[4]*x1**2
    interaction = params[5]*x0*x1
    thermal_softening = params[6] * x0 * np.exp(-params[7]*x1)
    
    # Logarithmic strain term only valid for positive strain values; else zero
    log_strain = np.zeros_like(x0)
    positive_mask = (x0 + epsilon) > 0
    log_strain[positive_mask] = params[8] * np.log(x0[positive_mask] + epsilon)
    
    inv_temp = params[9] / (x1 + epsilon)
    
    tanh_strain = params[10] * np.tanh(params[11] * x0)
    
    return linear + quad + interaction + thermal_softening + log_strain + inv_temp + tanh_strain
