    denom_eps = 1e-8  # avoid division by zero
    
    rational_term = 0.0
    if np.all(x0 >= 0):
        rational_term = (params[12] * x0) / (params[13] + x0 + denom_eps) + params[14]*x1
    
        result = (
            linear 
            + interaction 
            + quad_strain 
            + quad_temp 
            + cross_quad 
            + cross_quad_2 
            + cubic_strain 
            + exp_temp_effect 
            + log_strain 
            + rational_term
        )
        
        return result
    
    else:
