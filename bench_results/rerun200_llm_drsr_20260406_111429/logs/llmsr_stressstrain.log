    """
    """
    Improved version of `equation_v1` with richer nonlinearities and physically meaningful terms.

    Variables:
    - x0: Strain (ε)
    - x1: Temperature (T)
    - y : Stress (σ)

    Parameters:
    - params: array-like coefficients [p0,...p11]

    Model form:
        σ = 
          + p0 * ε * exp(-p1 * T)                        # thermal softening linear term
          + p2 * ε^2                                    # quadratic hardening
          + p3 * ε^3                                    # cubic hardening
          + p4 * T                                     # linear temperature-only term
          + p5 * T^2                                   # quadratic temperature-only term
          + p6 * T^3                                   # cubic temperature-only term
          + p7 * ε * T                                 # linear interaction
          + p8 * ε^2 * T                               # quadratic-strain & linear-temp interaction
          + p9 * ε * T^2                               # linear-strain & quadratic-temp interaction
          + p10* tanh(p11*|ε|)                          # saturation effect via tanh for smooth saturation
          + sign(ε)*|ε|^{power}                         # asymmetry/yield behavior with power-law exponent = fixed 1.5 here or param if desired
          + log(1+max(ε,0)) scaled by small factor     # logarithmic microstructure effect on positive strains

    Notes:
     - No constant offset to ensure σ=0 when ε=0.
     - The asymmetry power is fixed here as 1.5 for stability; can be made trainable if desired.
     - Saturation amplitude controlled by param[10], steepness by param[11].
     - Logarithmic microstructure effect scaled by fixed small factor 0.05.

    """
    
    eps = x0
    temp = x1
    
    abs_eps = np.abs(eps)
    
    # Thermal softening modulated linear term in strain
    thermal_softening = params[0] * eps * np.exp(-params[1] * temp)
    
    # Nonlinear hardening terms in strain only
    nonlinear_hardening = params[2] * eps**2 + params[3] * eps**3
    
    # Temperature polynomial terms only (no constant offset)
    temp_terms = params[4] * temp + params[5] * temp**2 + params[6] * temp**3
    
    # Interaction terms between strain and temperature powers
    interaction_terms = (
        params[7]  * eps      * temp +
        params[8]  * eps**2   * temp +
        params[9]  * eps      * temp**2 
    )
    
    # Saturation modeled as tanh function of absolute strain magnitude for smooth saturation,
    saturation = params[10] * np.tanh(params[11]*abs_eps)
    
    # Asymmetry or yield behavior modeled as sign(eps)*|eps|^{power}, fixed power=1.5 here for stability,
    
    asymmetry_power = 1.5
    
    asymmetry = np.sign(eps) * abs_eps**asymmetry_power
    
    # Logarithmic microstructural effect on positive strains only; zero otherwise; scaled by small fixed factor
    
    log_strain = np.where(eps > 0, np.log(1.0 + eps), 0.0)
    
  
    return (
        thermal_softening 
        + nonlinear_hardening 
        + temp_terms 
        + interaction_terms 
        + saturation 
        + asymmetry 
        + 0.05*log_strain
       )
