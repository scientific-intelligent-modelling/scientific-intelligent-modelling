    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation_v1 with physical constraints and richer nonlinearities.

    Variables:
    - x0: Strain (ε)
    - x1: Temperature (T)
    - y : Stress (σ)

    Parameters:
    - params: array-like coefficients [p0,...p11]

    Model form:
        σ = 
          + p0 * ε * exp(-p1 * T)                        # thermal softening linear term
          + p2 * ε^2                                    # quadratic hardening
          + p3 * ε^3                                    # cubic hardening
          + p4 * ε * T                                  # linear interaction
          + p5 * ε^2 * T                                # quadratic-strain & linear-temp interaction
          + p6 * ε * T^2                                # linear-strain & quadratic-temp interaction
          + p7 * |ε| / (1 + p8*|ε|)                     # saturation effect (rational)
          + p9  * sign(ε) * |ε|^{p10}                   # asymmetry/yield behavior with power-law exponent
          + p11 * log(1+max(ε,0))                        # logarithmic microstructure effect on positive strains

        Note:
        - No constant or pure temperature-only terms to ensure σ=0 when ε=0.
        - All terms vanish at zero strain except the log term which is zero at zero strain.

    """
    
    eps = x0
    temp = x1
    
    abs_eps = np.abs(eps)
    
    # Thermal softening modulated linear term in strain
    thermal_softening = params[0] * eps * np.exp(-params[1] * temp)
    
    # Nonlinear hardening terms in strain only
    nonlinear_hardening = params[2] * eps**2 + params[3] * eps**3
    
    # Interaction terms between strain and temperature powers
    interaction_terms = (
        params[4]  * eps      * temp +
        params[5]  * eps**2   * temp +
        params[6]  * eps      * temp**2
    )
    
    # Saturation modeled as rational function of absolute strain magnitude to limit stress growth at high strains
    saturation = params[7] * abs_eps / (1.0 + np.abs(params[8]) * abs_eps)
    
    # Asymmetry or yield behavior modeled as sign(eps)*|eps|^{power}, where power is trainable param constrained > 0 ideally,
    # here we just use param as exponent directly; for stability clip exponent >= 0.1 to avoid numerical issues if needed outside this function.
    
    asymmetry_power = max(params[10], 0.1)  # ensure positive exponent for numerical stability
    
    asymmetry = params[9] * np.sign(eps) * abs_eps**asymmetry_power
    
    # Logarithmic microstructural effect on positive strains only; zero otherwise; scaled by trainable parameter
    
    log_strain = np.where(eps > 0, np.log(1.0 + eps), 0.0)
    
    log_term = params[11] * log_strain
    
    return (
        thermal_softening 
        + nonlinear_hardening 
        + interaction_terms 
        + saturation 
        + asymmetry 
        + log_term
       )
