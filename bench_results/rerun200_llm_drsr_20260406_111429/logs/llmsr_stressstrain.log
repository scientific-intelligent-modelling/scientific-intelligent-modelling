def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends linearly on strain (Hooke's law) at small strains.
    - Temperature reduces stiffness, often modeled as exponential decay or inverse relation.
    - Nonlinear terms capture strain hardening and thermal softening.
    - Added cubic strain term to capture stronger nonlinear strain effects.
    - Added inverse temperature term to model softening at low temperatures.
    
    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params: array of coefficients [p0,...p11]
      Using linear, quadratic, cubic terms and interaction terms for nonlinearities.
      p0: constant offset
      p1: linear strain coefficient
      p2: linear temperature coefficient
      p3: quadratic strain coefficient
      p4: quadratic temperature coefficient
      p5: interaction (strain * temperature)
      p6: thermal softening exponential amplitude
      p7: thermal softening exponential rate
      p8: logarithmic strain coefficient
      p9: cubic strain coefficient
      p10: inverse temperature coefficient (1/x1)
      p11: interaction cubic term (x0^2 * x1)
    """
    
    epsilon = 1e-8  # small number to avoid log(0) or division by zero
    
    # Linear terms
    linear = params[0] + params[1]*x0 + params[2]*x1
    
    # Quadratic terms
    quad = params[3]*x0**2 + params[4]*x1**2
    
    # Interaction term (strain * temperature)
    interaction = params[5]*x0*x1
    
    # Thermal softening exponential decay with temperature
    thermal_softening = params[6] * x0 * np.exp(-params[7]*x1)
    
    # Logarithmic strain dependence for large strains (only if positive)
    log_strain = 0.0
    if np.all(x0 + epsilon > 0):
        log_strain = params[8] * np.log(x0 + epsilon)
    
    # Cubic strain term for stronger nonlinearities / hardening effects
    cubic_strain = params[9] * x0**3
    
    # Inverse temperature term to model effects at low temperatures safely 
    inv_temp = 0.0
    if np.all(x1 + epsilon > 0):
        inv_temp = params[10] / (x1 + epsilon)
    
    # Additional interaction cubic term (strain squared times temperature)
    interaction_cubic = params[11] * x0**2 * x1
    
  
    return linear + quad + interaction + thermal_softening + log_strain + cubic_strain + inv_temp + interaction_cubic
