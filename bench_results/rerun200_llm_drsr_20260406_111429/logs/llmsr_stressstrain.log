def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain and temperature.
    - At small strains, stress-strain is linear (Hooke's law).
    - Temperature reduces stiffness (modulus), often approximately linearly or exponentially.
    - Nonlinear strain terms capture strain hardening.
    - Interaction terms model temperature-dependent modulus and nonlinear coupling.
    - Include an exponential decay term to model thermal softening more realistically.
    
    Model form:
    y = p0 
        + p1 * x0 
        + p2 * x1 
        + p3 * x0 * x1 
        + p4 * x0**2 
        + p5 * x1**2 
        + p6 * (x0**2) * x1 
        + p7 * x0 * (x1**2) 
        + p8 * x0**3
        + p9  * np.exp(-p10*x1) * x0

    where
    - The last term models exponential decay of modulus with temperature,
      multiplied by strain to keep units consistent.

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 11 for this model.
    """
    
    linear = params[0] + params[1] * x0 + params[2] * x1
    interaction = params[3] * x0 * x1
    quad_strain = params[4] * x0**2
    quad_temp = params[5] * x1**2
    cross_quad_1 = params[6] * (x0**2) * x1
    cross_quad_2 = params[7] * x0 * (x1**2)
    cubic_strain = params[8] * x0**3
    
    # Exponential thermal softening term: modulus decreases exponentially with temperature,
    # scaled by strain to maintain physical meaning as stress ~ modulus*strain.
    exp_term = params[9] * np.exp(-params[10]*x1) * x0
    
    return linear + interaction + quad_strain + quad_temp + cross_quad_1 + cross_quad_2 + cubic_strain + exp_term
