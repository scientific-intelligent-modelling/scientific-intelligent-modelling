def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Builds on v1 by adding absolute value terms to capture asymmetric effects in strain and temperature.
    - Adds cubic interaction terms involving absolute values to model nonlinearities that depend on magnitude but not sign.
    - Retains polynomial, tanh saturation, exponential modulation, and inverse strain correction terms.
    - Introduces a small linear temperature * |strain| term to capture possible directional dependence of temperature effect on strain.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params: array of coefficients (length at least 12)
      params[0] to params[11]: same as in v1

    Returns:
        Stress values as np.ndarray.
    """

    p = params

    # Base polynomial and interaction terms (same as v1)
    poly_terms = (
        p[0]
        + p[1] * x0                      # linear in strain
        + p[2] * x1                      # linear in temp
        + p[3] * x0 * x1                 # interaction term
        + p[4] * x0**2                   # quadratic in strain (nonlinear elasticity)
        + p[5] * x1**2                   # quadratic in temp (temp effect)
        + p[6] * x0**3                   # cubic in strain (higher order nonlinearity)
        + p[7] * x1**3                   # cubic in temp 
        + p[8] * (x0**2) * x1            # mixed nonlinear term 
        + p[9] * x0 * (x1**2)            # mixed nonlinear term 
        + p[10] * np.exp(-x1)            # possible exponential decay with temp 
        + p[11] * np.log(np.clip(x0+1e-6, 1e-6, None))  # log(strain), avoid log(0)
    )

    saturation = (
        0.5*p[4]*np.tanh(p[6]*x0)   
        - 0.3*p[5]*np.tanh(p[7]*x1)  
    )

    exp_modulation = (
        0.4*p[10]*np.exp(-p[6]*x0)*np.exp(-((x1-300)/50)**2)  
    )

    inv_strain_correction = (
        0.05*p[11]/np.clip(x0+1e-6, 1e-6, None)  
    )

    
    abs_terms = (
          0.15*p[3]*np.abs(x0)*x1               # linear temp times abs(strain), asymmetric effect
        + 0.10*p[8]*np.abs(x0)**3               # cubic abs(strain), captures magnitude-based nonlinearity ignoring sign
        - 0.10*p[9]*x0*np.abs(x1)**2             # strain times squared abs(temp), capturing asymmetric temp effects
    )
    
    return poly_terms + saturation + exp_modulation + inv_strain_correction + abs_terms
