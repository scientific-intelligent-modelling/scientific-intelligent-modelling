def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements:
    - Added strain^2 * temperature interaction term (p12)
    - Modulated cubic strain hardening by temperature (p9 * x0^3 * exp(-p7*x1))
    - Added inverse temperature exponential softening term (p10 * x0 * exp(-p11 / (x1 + epsilon)))
    - Separate tanh saturation on strain and temperature plus combined effect
    - Retain logarithmic terms for both strain and temperature

    Parameters:
    - params: array of coefficients [p0,...,p11]
      p0 : constant offset
      p1 : linear strain coefficient
      p2 : linear temperature coefficient
      p3 : quadratic strain coefficient
      p4 : quadratic temperature coefficient
      p5 : linear strain * temperature interaction
      p6 : thermal softening exponential scale (strain * exp(-p7*temperature))
      p7 : thermal softening exponential rate
      p8 : logarithmic strain coefficient (log(strain + epsilon))
      p9 : cubic strain hardening coefficient modulated by exp(-p7*temperature)
      p10: inverse temp exponential softening scale (strain * exp(-p11 / temp))
      p11: inverse temp exponential softening rate denominator parameter
      # Note: To keep 12 params total, we merge some effects into existing params
      
    Model structure:

        y = p0 
            + p1*x0 
            + p2*x1 
            + p3*x0**2 
            + p4*x1**2 
            + p5*x0*x1 
            + p6*x0*np.exp(-p7*x1)          # thermal softening exponential decay with T
            + p8*np.log(x0 + epsilon)        # logarithmic strain term (for large strains)
            + p9*(x0**3)*np.exp(-p7*x1)     # cubic hardening modulated by T softening
            + p10*x0*np.exp(-p11/(x1+epsilon))  # inverse temp exponential softening at low T
            + tanh_saturation_strain_temp     # combined smooth saturation effects on x0,x1
            
    """
    
    epsilon = 1e-8
    
    # Linear terms
    linear = params[0] + params[1]*x0 + params[2]*x1
    
    # Quadratic terms
    quad = params[3]*x0**2 + params[4]*x1**2
    
    # Interaction term: linear in x0 and x1 (strain*temp)
    interaction_1 = params[5]*x0*x1
    
    # Thermal softening exponential decay with temp in exponent (-p7 * T)
    thermal_soften_exp = params[6] * x0 * np.exp(-params[7]*x1)
    
    # Logarithmic dependence on positive strains only
    log_strain = np.zeros_like(x0)
    positive_mask_strain = (x0 + epsilon) > 0
    log_strain[positive_mask_strain] = params[8] * np.log(x0[positive_mask_strain] + epsilon)
    
    # Cubic hardening modulated by thermal softening factor exp(-p7*T)
    cubic_hardening_modulated = params[9] * (x0**3) * np.exp(-params[7]*x1)
    
    # Inverse-temperature dependent exponential softening at low temperatures:
    inv_temp_soften_exp = params[10] * x0 * np.exp(-params[11]/(x1+epsilon))
    
    # Smooth saturation effects using tanh functions:
    
    tanh_strain = np.tanh(15*(x0 - 0.05))          # saturates near yield strain ~5%
    
    tanh_temp = np.tanh(10*(x1 - 300))             # saturates near room temp ~300K
    
    tanh_saturation_combined = tanh_strain * tanh_temp
    
    tanh_saturation_effect = 5.0 * params[9] * tanh_saturation_combined
