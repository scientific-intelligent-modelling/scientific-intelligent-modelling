def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain (x0) and temperature (x1).
    - Young's modulus decreases with increasing temperature (modeled by exponential decay).
    - Nonlinear elastic/plastic effects captured by polynomial terms in strain.
    - Temperature effects are nonlinear; inverse temperature term captures thermally activated processes.
    - Interaction terms between strain and temperature powers.
    - Logarithmic term of strain captures strain hardening behavior at low strains.
    - Sigmoid-like function models saturation or phase transformation effects near a critical temp (~300K).
    
    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters (length >= 12):
        params[0]: intercept (baseline stress)
        params[1]: linear coefficient for strain modulated by exp decay
        params[2]: linear coefficient for temperature
        params[3]: interaction term coefficient (strain * temperature)
        params[4]: quadratic term for strain^2 modulated by exp decay
        params[5]: quadratic term for temperature^2
        params[6]: cubic term for strain^3 
        params[7]: cubic term for temperature^3 
        params[8]: interaction term (strain^2 * temperature)
        params[9]: interaction term (strain * temperature^2)
        params[10]: exponential decay rate with temp in modulus-like term
        params[11]: amplitude scaling the exponential decay effect

    Returns:
        y: predicted stress as numpy array
    """
    
    epsilon = 1e-8  # To avoid division by zero or log(0)

    # Exponential decay factor modeling thermal softening of modulus,
    # modulating the linear and quadratic strain terms to reflect temp dependence.
    
    exp_decay = np.exp(-params[10] * x1)

    # Sigmoid-like function to model saturation or phase change effects around some temp threshold (~300K):
    
    sigmoid = 1 / (1 + np.exp(-0.05 * (x1 - 300)))

    inv_temp = 1.0 / (x1 + epsilon)

    log_strain = np.log(np.abs(x0) + epsilon)

    y = (
          params[0]                                                      # intercept baseline stress
        + exp_decay * (
              params[1] * x0                                            # linear in strain modulated by temp softening
            + params[4] * x0**2                                         # quadratic in strain modulated by temp softening
          )
        + params[6] * x0**3                                             # cubic in strain independent of modulation
        + params[2] * x1                                                # linear temp effect independent of modulation
        + params[5] * x1**2                                             # quadratic temp effect 
        + params[7] * x1**3                                             # cubic temp effect 
        + params[3] * x0 * x1                                           # interaction linear*linear 
        + params[8] * (x0**2) * x1                                      # higher order interaction 
        + params[9] * x0 * (x1**2)                                      # higher order interaction 
        + inv_temp * (-10.0)                                            # fixed negative inverse temp effect capturing thermally activated softening; can be parameterized if desired
        + 20.0 * log_strain                                             # scaled logarithmic dependence on strain capturing hardening at low strains; can be parameterized if desired
        + sigmoid * 50.0                                                # sigmoid saturation/phase transition effect scaled arbitrarily here; can be parameterized if needed.
        + exp_decay * params[11]                                        # offset modulated by exponential decay scaling amplitude param11 
      )

    return y
