def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation_v1 with additional nonlinear coupling terms
    and smooth asymmetry modeling.

    Variables:
    - x0: Strain (ε)
    - x1: Temperature (T)
    - y : Stress (σ)

    Parameters:
    - params: array-like coefficients [p0,...p11]

    Model form:
        σ = p0 
            + p1 * ε * exp(-p2 * T)                      # thermal softening
            + p3 * ε^2 + p4 * ε^3                        # nonlinear strain hardening
            + p5 * T + p6 * T^2 + p10 * T^3              # polynomial temp dependence
            + p7 * ε * T + p8 * ε^2 * T                  # interaction terms
            + p9 / (1 + |p10*ε|)                         # saturation effect
            + p11 * tanh(k*ε)                            # smooth asymmetry/yield behavior replacing sign(ε)
            + 0.05*log(1+ε) if ε>0 else 0                # logarithmic microstructure effect
            + extra coupling term: e.g. params[...]*ε^2*T^2

    Note:
        Here k is chosen as 5 for sharp but smooth transition near zero.

    """
    
    eps = x0
    temp = x1
    
    k = 5.0  # sharpness parameter for tanh
    
    thermal_softening = params[1] * eps * np.exp(-params[2] * temp)
    
    nonlinear_strain = params[3] * eps**2 + params[4] * eps**3
    
    temp_poly = params[5] * temp + params[6] * temp**2 + params[10] * temp**3
    
    interaction_terms = params[7] * eps * temp + params[8] * eps**2 * temp
    
    saturation = params[9] / (1.0 + np.abs(params[10]*eps))
    
    asymmetry_smooth = params[11] * np.tanh(k*eps)
    
    log_strain = np.where(eps > 0, np.log(1+eps), 0.0)
    
    # Additional coupling term between squared strain and squared temperature for richer modeling,
    # reusing param index 0 as coefficient for this term plus constant offset.
    
    extra_coupling = params[0] + 0.5*params[0]*eps**2*temp**2
    
    return (
        extra_coupling
        + thermal_softening
        + nonlinear_strain
        + temp_poly
        + interaction_terms
        + saturation
        + asymmetry_smooth
        + 0.05*log_strain
     )
