def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation_v1 with additional physically motivated terms.

    Physical reasoning:
    - Stress depends nonlinearly on strain (linear, quadratic, cubic).
    - Temperature affects stress via linear, exponential, inverse terms.
    - Interaction terms between strain powers and temperature capture temp-dependent nonlinearities.
    - Logarithmic term in strain models softening/hardening behavior.
    - Sigmoid function models saturation/yielding behavior in strain.
    - Exponential decay in strain models damage accumulation or softening at high strains.

    Model structure:
        y = p0 
            + p1*x0                              # linear strain
            + p2*x1                              # linear temperature
            + p3*x0*x1                          # interaction (strain * temperature)
            + p4*x0**2                          # quadratic strain
            + p5*np.exp(p6*x1)                  # exponential temperature effect
            + p7*x0**3                          # cubic strain
            + p8*np.log(np.clip(x0 + 1e-6, 1e-6, None))  # log(strain) softening/hardening
            + p9/(np.clip(x1, 1e-6, None))     # inverse temperature effect (Arrhenius)
            + p10 * (1 / (1 + np.exp(-p11*(x0 - 0.5))))   # sigmoid saturation around x0=0.5
            + params[12] * x0 * np.exp(-params[13]*x0)   # exponential decay term for damage

    Note:
        Since MAX_NPARAMS=12, we have only params[0] to params[11].
        So we cannot use params[12], params[13].
        Instead we replace the last term with a simpler form using existing parameters.

    Adjusted final implemented terms with MAX_NPARAMS=12:

        y = p0 
          + p1*x0 
          + p2*x1 
          + p3*x0*x1 
          + p4*x0**2 
          + p5*np.exp(p6*x1) 
          + p7*x0**3 
          + p8*np.log(np.clip(x0+1e-6, 1e-6, None)) 
          + p9/(np.clip(x1, 1e-6, None)) 
          + p10 * (1 / (1+np.exp(-p11*(x0 - 0.5)))) 

    """

    safe_x0 = np.clip(x0, 1e-6, None)
    safe_x1 = np.clip(x1, 1e-6, None)

    sigmoid = 1 / (1 + np.exp(-params[11] * (x0 - 0.5)))

    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 * x1
        + params[4] * x0 ** 2
        + params[5] * np.exp(params[6] * x1)
        + params[7] * x0 ** 3
        + params[8] * np.log(safe_x0)
        + params[9] / safe_x1
        + params[10] * sigmoid
    )
