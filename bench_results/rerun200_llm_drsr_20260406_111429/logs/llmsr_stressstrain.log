def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Temperature-dependent elastic modulus modeled as quadratic in temperature.
    - Power-law strain hardening with exponent as absolute value of a parameter.
    - Exponential temperature effect to capture softening or hardening.
    - Sigmoid function to model yielding or saturation behavior.
    - Logarithmic temperature term for diminishing returns/saturation effects.
    - Interaction terms between strain and higher powers of temperature for complex coupling.
    - Use safe clipping to avoid numerical issues (log(0), division by zero).
    
    Model structure:
        y = params[0]
          + (params[1] + params[2]*x1 + params[3]*x1**2) * x0                  # temp-dependent modulus * strain
          + params[4] * x0**abs(params[5])                                    # power-law strain hardening
          + params[6] * exp(params[7]*x1)                                     # exponential temp effect
          + params[8] / (1 + exp(-params[9]*(x0 - params[10])))                # sigmoid yielding/saturation
          + alpha*params[11]*x0*x1**3                                         # high order interaction term
          + (1-alpha)*params[11]*log(x1)                                      # logarithmic temp effect

    Parameters:
        x0: Strain input array
        x1: Temperature input array
        params: Array of 12 parameters

    Returns:
        y: Stress output array
    """
    
    safe_x0 = np.clip(x0, 1e-6, None)
    safe_x1 = np.clip(x1, 1e-6, None)

    alpha = 0.7  # weight split for param 11 between interaction and log term

    temp_modulus = params[1] + params[2]*safe_x1 + params[3]*(safe_x1**2)
    
    power_law_strain = safe_x0 ** abs(params[5])
    
    exp_temp_effect = params[6] * np.exp(params[7]*safe_x1)
    
    sigmoid_yielding = params[8] / (1.0 + np.exp(-params[9]*(safe_x0 - params[10])))
    
    high_order_interaction = alpha * params[11] * safe_x0 * (safe_x1 ** 3)
    
    log_temp_effect = (1 - alpha) * params[11] * np.log(safe_x1)

    y = (
        params[0]
        + temp_modulus * safe_x0
        + params[4] * power_law_strain
        + exp_temp_effect
        + sigmoid_yielding
        + high_order_interaction
        + log_temp_effect
     )
    
    return y
