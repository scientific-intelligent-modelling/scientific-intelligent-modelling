    temp = x1
    
    # Polynomial terms (up to cubic and interactions)
    poly_terms = (
        params[0]
        + params[1] * eps
        + params[2] * temp
        + params[3] * eps * temp
        + params[4] * eps**2
        + params[5] * temp**2
        + params[6] * eps**2 * temp
        + params[7] * eps * temp**2
        + params[8] * eps**3
        + params[9]  * temp**3
        + params[10]  * eps**3  * temp
        + params[11]  * eps  * temp**3
    )
    
    # Exponential thermal softening term (modulus decays exponentially with temperature)
    exp_term = params[12] * np.exp(-params[13]*temp) * eps
    
    # Logarithmic strain effect (to capture nonlinearities at low strains)
    log_term = params[14] * np.log(1.0 + np.abs(eps))
    
    return poly_terms + exp_term + log_term
