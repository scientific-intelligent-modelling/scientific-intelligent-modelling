def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved stress-strain-temperature model.

    Physical reasoning enhancements:
    - Temperature-dependent modulus as cubic polynomial in temperature.
    - Softplus function for smooth yield/saturation effect on strain.
    - Logarithmic terms for both strain and temperature.
    - Inverse temperature term to capture Arrhenius-like thermal activation.
    - Additional interaction terms including sinusoids to capture complex nonlinearities.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params: array of coefficients [p0,...p11]
      Using linear, quadratic, cubic, interaction, exponential decay,
      logarithmic, softplus nonlinearities.

    Model structure:

        y = p0 
            + p1*x0 
            + p2*x1 
            + p3*x0**2 
            + p4*x1**2 
            + p5*x0*x1 
            + p6*x0*np.exp(-p7*x1)          # thermal softening exponential decay
            + p8*np.log(x0 + epsilon)        # logarithmic strain term
            + p9*x0**3                      # cubic strain hardening term
            + p10 * softplus(50*(x0-0.05))  # smooth saturation effect (softplus)
            + p11 * np.sin(5 * x1)          # sinusoidal temp effect capturing oscillations

        where softplus(z) = log(1+exp(z))
    
    """
    
    epsilon = 1e-8  # small number to avoid log(0)
    
    def softplus(z):
        return np.log1p(np.exp(z))
    
    linear = params[0] + params[1]*x0 + params[2]*x1
    quad = params[3]*x0**2 + params[4]*x1**2
    interaction_1 = params[5]*x0*x1
    thermal_softening = params[6] * x0 * np.exp(-params[7]*x1)
    
    log_strain = np.zeros_like(x0)
    positive_mask_strain = (x0 + epsilon) > 0
    log_strain[positive_mask_strain] = params[8] * np.log(x0[positive_mask_strain] + epsilon)
    
    cubic_strain = params[9] * x0**3
    
    softplus_sat = params[10] * softplus(50*(x0 - 0.05))
    
    sinusoid_temp = params[11] * np.sin(5 * x1)
    
    return linear + quad + interaction_1 + thermal_softening + log_strain + cubic_strain + softplus_sat + sinusoid_temp
