    safe_x0 = np.where(np.abs(x0) < 1e-6, 1e-6, x0)  # avoid division by zero in reciprocal
    
    base_poly = (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[6] * np.exp(params[7] * x1)
        + params[8] * x0**3 
