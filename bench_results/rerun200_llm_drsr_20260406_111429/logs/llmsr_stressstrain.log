def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation_v1.

    Physical reasoning:
    - Stress depends on polynomial terms in strain and temperature up to cubic order.
    - Interaction terms between strain and temperature included.
    - Temperature effects include inverse temp softening, logarithmic softening at low temps,
      and exponential decay capturing stiffness loss.
    - Logarithmic term replaces cubic temperature term due to limited parameters.

    Variables:
    - x0: Strain
    - x1: Temperature

    Parameters:
    - params: array of length 12
      [p0,...p11]
      
      Mapping:
      0: constant
      1: linear strain
      2: linear temp
      3: quadratic strain
      4: quadratic temp
      5: strain*temp interaction
      6: cubic strain
      7: log(temp + offset) coeff (replaces previous cubic temp)
      8: strain^2 * temp interaction
      9: strain * temp^2 interaction
      10: inverse temp coeff (softening)
      11: exp decay rate param (positive via abs)
    
    """
    
    epsilon = 1e-6       # To avoid division by zero in inverse term
    temp_offset = 1e-3   # To avoid log(0)
    
    p = params
    
    inv_temp_term = p[10] / (x1 + epsilon)
    
    log_temp_term = p[7] * np.log(x1 + temp_offset)
    
    exp_decay_term = np.sign(p[11]) * np.exp(-np.abs(p[11]) * x1)   # sign allows positive or negative amplitude
    
    return (
        p[0]
        + p[1]*x0
        + p[2]*x1
        + p[3]*x0**2
        + p[4]*x1**2
        + p[5]*x0*x1
        + p[6]*x0**3
        + log_temp_term               # replaces previous cubic x1^3 term for better physical meaning at low T 
        + p[8]*(x0**2)*x1 
        + p[9]*x0*(x1**2)
        + inv_temp_term 
        + exp_decay_term*x0          # multiply exp_decay by x0 since it modulates stiffness affecting stress-strain relation 
                                    # (stiffness times strain gives stress contribution)
        
    )
