          + p3 * softplus(100*(x0-0.03))                          # smooth yield/strain hardening onset
          + p4 * x0**2                                            # quadratic strain hardening
          + p5 * x0 * np.exp(-p6 / (x1 + epsilon))                # Arrhenius-like thermal softening (activation energy)
          + p7 * np.sin(20*x0)                                    # oscillatory microstructure effect on strain
          + p8 * np.log(x0 + epsilon)                             # logarithmic strain term (strain softening/hardening)
          + p9 * np.tanh(5*(x1-300))                              # temperature saturation near 300K phase transition
          + p10 * x0 / (x1 + epsilon)                             # interaction term strain/inverse temp
          + p11 * softplus(-50*(x0-0.07))                         # smooth saturation at higher strains

