def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Further improved version of the nonlinear harmonic oscillator acceleration model.

    Enhancements over equation_v1:
    - Added quartic nonlinearities in position and velocity
    - Added mixed quadratic velocity * position term
    - Added additional trigonometric modulations with phase shifts
    - Included interaction terms between polynomial nonlinearities and trig functions for richer dynamics

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of 12 parameters

    Returns:
        y: predicted acceleration array
    """
    
    p = params
    
    # Base linear and polynomial nonlinear terms (same as v1)
    base = (
        p[0]                    # constant offset term
        + p[1] * x0             # linear time dependence (parametric modulation)
        + p[2] * x1             # linear restoring force (-omega^2 * x)
        + p[3] * x2             # linear damping (-c * v)
        + p[4] * (x1 ** 3)      # cubic stiffness nonlinearity
        + p[5] * (x2 ** 3)      # cubic damping nonlinearity (nonlinear damping)
        + p[6] * (x1 ** 2)      # quadratic stiffness nonlinearity
        + p[7] * (x2 ** 2)      # quadratic damping nonlinearity
        + p[8] * (x1 * x2)      # cross term between position and velocity
        + p[11] * ((x1 ** 2) * x2)  # higher order mixed nonlinearity coupling pos^2 with vel
    )
    
    # Add quartic nonlinearities using existing parameters by reusing/modulating them:
    quartic_pos = p[4] * (x1 ** 4) * np.cos(6*x0)   # modulated quartic stiffness term
    
    quartic_vel = p[5] * (x2 ** 4) * np.sin(7*x0)   # modulated quartic damping term
    
    mixed_quad_vel_pos = p[7] * ((x2 ** 2) * x1)     # mixed quadratic velocity squared times position
    
    # Trigonometric forcing / parametric excitation terms from v1 plus phase shifts:
    
    trig_basic = (
        p[9]  * np.sin(x0)
        + p[10] * np.cos(x0)
    )
    
    trig_phase_shifted = (
        p[9]  * np.sin(x0 + np.pi/4)
        + p[10] * np.cos(x0 - np.pi/3)
    )
    
    trig_higher_freqs = (
        p[9]*np.sin(3*x0)*np.cos(2*x0)
       -p[10]*np.cos(4*x0)*np.sin(5*x0)
    )
    
    return base \
           + quartic_pos \
           + quartic_vel \
           + mixed_quad_vel_pos \
           + trig_basic \
           + trig_phase_shifted \
           + trig_higher_freqs
