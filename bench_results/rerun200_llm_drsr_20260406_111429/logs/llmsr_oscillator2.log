def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator as a function of time (x0),
    position (x1), and velocity (x2).

    Extends previous versions by including additional nonlinear interaction terms involving time,
    and separates quartic terms in position and velocity.

    Parameters:
    - params: array-like with at least 12 elements:
        params[0]: constant offset term
        params[1]: linear term in time t
        params[2]: linear term in position x
        params[3]: linear term in velocity v
        params[4]: quadratic term in position x^2
        params[5]: quadratic term in velocity v^2
        params[6]: cross term x*v
        params[7]: cubic term in position x^3
        params[8]: cubic term in velocity v^3
        params[9]: cross cubic term x^2 * v
        params[10]: cross cubic term x * v^2
        params[11]: quartic combined interaction or higher order nonlinearities

    Returns:
    - acceleration y as numpy array.
    """

    # Define quartic terms separately for clarity:
    quartic_pos = x1 ** 4          # quartic position
    quartic_vel = x2 ** 4          # quartic velocity
    quartic_cross = (x1 ** 2) * (x2 ** 2)  # mixed quartic

    # Additional nonlinear time-dependent interactions:
    time_sq_pos = (x0 ** 2) * x1   # quadratic time times position
    time_sq_vel = (x0 ** 2) * x2   # quadratic time times velocity

    return (
        params[0] +                     # constant offset
        params[1] * x0 +                # linear time t 
        params[2] * x1 +                # linear position 
        params[3] * x2 +                # linear velocity 
        params[4] * (x1 ** 2) +         # quadratic position 
