    mixed_pos_velsq = p[10] * (x1 * (x2 ** 2))
    
    # Param index 11 modulates trigonometric forcing / parametric excitation at multiple harmonics
    
    trig_forcing = (
        p[11] * np.sin(3*x0)   # higher harmonic sinusoidal forcing or parametric excitation 
