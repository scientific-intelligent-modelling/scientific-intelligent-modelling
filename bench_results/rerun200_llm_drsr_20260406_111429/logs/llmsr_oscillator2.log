        params[4] * (x1 ** 2) +         # nonlinear stiffness quadratic 
        params[5] * (x1 ** 3) +         # nonlinear stiffness cubic 
        params[6] * (x1 ** 4) +         # higher order stiffness
        
        params[7] * x2 +                # linear damping ~ -c*v 
        params[8] * (x2 ** 2) +         # nonlinear damping
        
        params[9] * (x1 * x2) +         # coupling between position and velocity
        
        params[10] * ((x1 ** 2) * x2) + # higher order coupling
        
        params[11] * quartic_mixed      # quartic mixed interaction terms for complex nonlinearity
    )
