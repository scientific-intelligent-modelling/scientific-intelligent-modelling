def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved version of the nonlinear harmonic oscillator acceleration model.

    Enhancements over equation_v1:
    - Adds modulation of nonlinear terms by sinusoids of time (parametric excitation)
    - Includes mixed quadratic and cubic cross terms between position and velocity
    - Incorporates higher harmonics in time modulation (e.g., sin(2x0), cos(3x0))
    - Keeps parameter count at MAX_NPARAMS=12

    Parameters:
        x0 (np.ndarray): time array
        x1 (np.ndarray): position array at time t
        x2 (np.ndarray): velocity array at time t
        params (np.ndarray): array of 12 parameters

    Returns:
        y (np.ndarray): predicted acceleration array
    """

    p = params

    # Base linear and nonlinear terms similar to equation_v1
    base = (
        p[0]                              # constant offset term
        + p[1] * x0                      # linear time dependence (parametric modulation)
        + p[2] * x1                      # linear restoring force term (-omega^2 * x)
        + p[3] * x2                      # linear damping term (-c * v)
        + p[4] * (x1 ** 3)               # cubic stiffness nonlinearity
        + p[5] * (x2 ** 3)               # cubic velocity nonlinearity (nonlinear damping)
        + p[6] * (x1 ** 2)               # quadratic stiffness nonlinearity
        + p[7] * (x2 ** 2)               # quadratic velocity nonlinearity
        + p[8] * (x1 * x2)               # cross term between position and velocity
    )

    # Trigonometric forcing / parametric excitation terms with higher harmonics:
    trig_terms = (
          p[9]  * np.sin(x0)             # fundamental sinusoidal forcing in time
        + p[10] * np.cos(x0)             # fundamental cosine forcing in time
        + p[11] * ((x1 ** 2) * x2)      # higher order mixed nonlinearity coupling position squared with velocity 
                                        # also acts as a nonlinear damping/stiffness cross term 
                                        # can be interpreted as a modulation of damping by position squared.
    )

    ### Additional modulated nonlinear interaction terms ###
    
    # Modulate cubic stiffness by sin(2*time):
    mod_cubic_stiffness = p[4] * (x1 ** 3) * np.sin(2*x0)

    # Modulate cubic damping by cos(3*time):
    mod_cubic_damping = p[5] * (x2 ** 3) * np.cos(3*x0)

    # Quadratic cross term modulated by sin(3*time):
    mod_quad_cross = p[8] * (x1**2)*x2*np.sin(3*x0)

    
    return base + trig_terms + mod_cubic_stiffness + mod_cubic_damping + mod_quad_cross
