    acc = (
        params[0]                          # constant offset / bias force
        + params[1] * x0                  # explicit linear time-dependent forcing
        + params[11] * np.sin(x0)         # sinusoidal driving force 
        + params[2] * x1                  # linear restoring force (-omega^2 * x)
        + params[3] * x2                  # linear damping (-beta * v)
    )
    
    # Nonlinear restoring forces (odd powers for potential energy symmetry)
    acc += (
        params[4] * (x1 ** 3)             # cubic restoring force (-alpha * x^3)
        + params[8] * (x1 ** 5)           # quintic restoring force (-gamma * x^5)
    )
    
    # Nonlinear damping / velocity dependent terms
    acc += (
        params[5] * (x2 ** 2)             # quadratic velocity term 
        + params[6] * (x2 ** 3)           # cubic velocity term 
    )
    
    # Cross coupling nonlinear terms between position and velocity
    acc += (
        params[7] * x1 * x2               # cross term coupling position and velocity nonlinearly 
        + params[9] * (x1 ** 2) * x2      # mixed nonlinear coupling: position squared times velocity 
        + params[10] * x1 * (x2 ** 2)     # mixed nonlinear coupling: position times velocity squared 
    )
    
    return acc
