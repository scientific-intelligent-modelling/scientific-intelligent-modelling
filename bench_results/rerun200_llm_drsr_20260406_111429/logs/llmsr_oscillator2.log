def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved version of the equation to calculate acceleration in a nonlinear harmonic oscillator.
    
    This version includes:
    - constant forcing term
    - linear time dependence (e.g., external forcing or drift)
    - linear and cubic stiffness terms (restoring force)
    - linear damping term proportional to velocity
    - quadratic velocity term to capture possible nonlinear damping effects
    
    Mathematical form:
        y = p0 + p1 * t + p2 * x + p3 * x^3 + p4 * v + p5 * v^2
    
    Parameters:
        x0 (np.ndarray): time array
        x1 (np.ndarray): position array at time t
        x2 (np.ndarray): velocity array at time t
        params (np.ndarray): parameters array with at least 6 elements
    
    Returns:
        np.ndarray: calculated acceleration values
    """
    
    return (
        params[0]                # constant offset / forcing
        + params[1] * x0         # linear time dependence
        + params[2] * x1         # linear stiffness term (-k*x)
        + params[3] * (x1 ** 3)  # nonlinear cubic stiffness term (-k3*x^3)
        + params[4] * x2         # linear damping term (-c*v)
        + params[5] * (x2 ** 2)  # nonlinear damping or velocity squared effect
    )
