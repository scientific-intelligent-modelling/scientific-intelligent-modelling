def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Models acceleration as a nonlinear function of position and velocity:
    a = p0 + p1*t + p2*x + p3*v + p4*x^3 + p5*x^2*v + p6*x*v^2 + p7*v^3

    Parameters:
    - params: array-like coefficients [p0,...p7]
    """
    # Unpack parameters for clarity
    p = params
    
    # Terms:
    # constant term
    term_const = p[0]
    
    # linear terms in time, position and velocity
    term_t = p[1] * x0
    term_x = p[2] * x1
    term_v = p[3] * x2
    
    # cubic nonlinearity in position (typical Duffing oscillator nonlinearity)
    term_x3 = p[4] * (x1 ** 3)
    
    # mixed nonlinear terms involving powers of position and velocity to capture more complex dynamics
    term_x2v = p[5] * (x1 ** 2) * x2
    term_xv2 = p[6] * x1 * (x2 ** 2)
    
    # cubic nonlinearity in velocity (less common but possible damping or forcing effect)
    term_v3 = p[7] * (x2 ** 3)

    return (
        term_const +
        term_t +
        term_x +
        term_v +
        term_x3 +
        term_x2v +
        term_xv2 +
        term_v3
    )
