def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` modeling acceleration in a nonlinear harmonic oscillator.

    Parameters:
        - x0: time
        - x1: position at time t
        - x2: velocity at time t
        - params: array-like with length 12

    Returns:
        - y: acceleration at time t
    """

    # Unpack parameters for clarity (optional)
    c0 = params[0]   # constant offset term
    c_time = params[1]   # linear dependence on time (could model drift)
    
    k1 = params[2]   # linear spring constant term (-k * x)
    k3 = params[3]   # cubic spring nonlinearity (-k3 * x^3)
    
    d1 = params[4]   # linear damping coefficient (-d * v)
    d2 = params[5]   # quadratic damping or friction effect
    
    cross = params[6]  # cross term between position and velocity
    
    f_sin_amp = params[7]
    f_cos_amp = params[8]
    
    asym_pos = params[9]  # asymmetry via abs(position)
    
    friction_sign = params[10]  # friction-like effect via sign(velocity)
    
    k2 = params[11]  # quadratic spring nonlinearity (-k2 * x^2)

    return (
        c0 
        + c_time * x0 
        - k1 * x1 
        - k3 * (x1 ** 3) 
        - d1 * x2 
        - d2 * (x2 ** 2) 
        + cross * x1 * x2 
        + f_sin_amp * np.sin(x0) 
        + f_cos_amp * np.cos(x0) 
        + asym_pos * np.abs(x1) 
        - friction_sign * np.sign(x2) 
        - k2 * (x1 ** 2)
    )
