        params[9] * ((x1 ** 2) * x2) +   # cross cubic pos^2*vel 
        params[10] * (x1 * (x2 ** 2)) +   # cross cubic pos*vel^2 
        
        # Use param11 to weight combined quartic and additional nonlinear interactions:
        
        params[11] * (
            quartic_pos +
            quartic_vel +
            quartic_cross +
            time_sq_pos +
            time_sq_vel
         )
    )
