    quartic_and_mixed = (
          (x1 ** 4)                  # quartic position 
        + (x2 ** 4)                  # quartic velocity 
        + (x1 ** 2) * (x2 ** 2)     # mixed quartic interaction between pos & vel 
        + (x0 ** 3)                 # cubic time to capture nonlinear temporal effects 
        + (x0 ** 2) * x1            # cross quadratic time & linear pos 
        + (x0 ** 2) * x2            # cross quadratic time & linear vel 
