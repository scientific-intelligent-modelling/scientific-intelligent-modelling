def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Models acceleration as:
    y = p0 + p1*x0 + p2*x1 + p3*x1^3 + p4*x2 + p5*x2^2 + p6*x1*x2 + ...

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    # Unpack parameters for clarity
    p = params
    
    # Construct nonlinear terms
    term_const = p[0]
    term_time = p[1] * x0
    term_pos_linear = p[2] * x1
    term_pos_cubic = p[3] * (x1 ** 3)
    term_vel_linear = p[4] * x2
    term_vel_quadratic = p[5] * (x2 ** 2)
    term_pos_vel_cross = p[6] * (x1 * x2)
    
    # Additional polynomial terms if desired
    term_pos_squared = p[7] * (x1 ** 2)
    term_time_squared = p[8] * (x0 ** 2)
    
    # Higher order cross terms could be added similarly
    
    return (
        term_const +
        term_time +
        term_pos_linear +
        term_pos_cubic +
        term_vel_linear +
        term_vel_quadratic +
        term_pos_vel_cross +
        term_pos_squared +
        term_time_squared
        # Add more if needed up to params length
    )
