def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved nonlinear harmonic oscillator acceleration model.

    Model structure:
    y = acceleration =
        p0                                # constant offset
        + p1 * x0                        # linear time dependence (drift or slow variation)
        - |p2| * x1                     # linear restoring force (-k*x)
        - |p3| * x2                     # linear damping (-c*v)
        + p4 * (x1 ** 3)                # cubic stiffness nonlinearity
        + p5 * (x2 ** 3)                # cubic nonlinear damping
        + p6 * (x1 ** 2)                # quadratic stiffness nonlinearity
        + p7 * (x2 ** 2)                # quadratic nonlinear damping
        + p8 * (x1 * x2)                # cross term coupling position & velocity
        + p9 * sin(x0)                  # sinusoidal forcing term (sin component)
        + p10* cos(x0)                  # sinusoidal forcing term (cos component)
        + p11* ((x1 ** 2) * x2)         # higher order cross nonlinearity

      + additional modulated nonlinear interaction terms:
      
        + sign(p4)*|p4|*(x1**3)*sin(x0)          # cubic stiffness modulated by sin(time)
        + sign(p5)*|p5|*(x2**3)*cos(x0)          # cubic damping modulated by cos(time)
        + sign(p8)*|p8|*(x1*x2)*sin(2*x0)        # cross product modulated by sin(2*time)
        + sign(p6)*|p6|*(x1**2)*cos(3*x0)         # quadratic stiffness modulated by cos(3*time)

      + new interaction terms:
      
        - |p7|*(x2**2)*sin(2*x0)                  # quadratic damping modulated by sin(2*time), negative sign to reflect dissipative effect
        - |p11|*((x1**2)*x2)*cos(3*x0)            # higher order cross nonlinearity modulated by cos(3*time), negative sign for physical plausibility

    Parameters:
    - x0: time array
    - x1: position array at time t
    - x2: velocity array at time t
    - params: array-like of length 12

    Returns:
    - y: predicted acceleration as numpy array
    """
    
    p = params
    
    base = (
          p[0]
        + p[1]   * x0
        - abs(p[2])   * x1      # restoring force negative sign enforced (-k*x)
        - abs(p[3])   * x2      # damping negative sign enforced (-c*v)
        + p[4]   * (x1 ** 3)
        + p[5]   * (x2 ** 3)
        + p[6]   * (x1 ** 2)
        + p[7]   * (x2 ** 2)
        + p[8]   * (x1 * x2)
        + p[9]   * np.sin(x0)
        + p[10]  * np.cos(x0)
        + p[11]  *((x1 ** 2)* x2)
