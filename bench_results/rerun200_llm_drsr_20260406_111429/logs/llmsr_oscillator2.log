def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Calculates acceleration as a nonlinear function of time (x0), position (x1),
    and velocity (x2). Includes polynomial terms up to cubic order plus nonlinear damping
    and parametric forcing.

    Parameters:
    - params: array of length 12 coefficients

    Returns:
    - acceleration array
    """
    # Unpack parameters for clarity
    c = params[0]       # constant offset
    k_t = params[1]     # linear time term coefficient
    k_x = params[2]     # linear position term coefficient (restoring force)
    b = params[3]       # linear velocity term coefficient (damping)
    
    k_x2 = params[4]     # quadratic position term
    b_v2 = params[5]     # quadratic velocity term
    
    k_xv = params[6]     # cross product quadratic term
    
    k_x3 = params[7]     # cubic position term (nonlinear restoring force)
    
    b_v3 = params[8]     # cubic velocity term (nonlinear damping)
    
    mixed1 = params[9]   # mixed cubic term x1^2 * x2
    
    mixed2 = params[10]  # mixed cubic term x1 * x2^2
    
    f_sin = params[11]   # amplitude of sinusoidal forcing depending on time

    
    y = (
        c 
        + k_t * x0 
        + k_x * x1 
        + b * x2 
        + k_x2 * x1**2 
        + b_v2 * x2**2 
        + k_xv * x1 * x2 
        + k_x3 * x1**3 
        + b_v3 * x2**3 
        + mixed1 * (x1**2) * x2 
        + mixed2 * x1 * (x2**2) 
        + f_sin * np.sin(x0)
        
        # Additional physically meaningful nonlinear damping proportional to |velocity|*velocity
        + 0.0  # placeholder for possible extra terms if needed
        
        # For example, adding a nonlinear damping proportional to |v|*v:
        # d_nl_damping_coeff * |x2|*x2 could be added if we extend parameters.
        
        )
    
    return y
