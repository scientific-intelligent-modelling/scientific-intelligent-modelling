def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator with:
    - constant term
    - linear terms in time (x0), position (x1), velocity (x2)
    - cubic nonlinearity in position (x1^3)
    - quadratic term in velocity (x2^2)
    - cross term between position and velocity (x1 * x2)
    - periodic forcing terms sin(x0), cos(x0)
    - absolute value and sign functions for asymmetric/friction effects
    - quadratic term in position for softening/hardening spring effect

    Parameters:
        params: array-like with length 12

    Returns:
        y: acceleration
    """
    
    # Unpack parameters for clarity
    c0 = params[0]   # constant offset
    c_t = params[1]  # linear time dependence
    c_x = params[2]  # linear position dependence (restoring force)
    c_v = params[3]  # linear velocity dependence (damping)
    
    c_x3 = params[4]   # cubic nonlinearity in position
    c_v2 = params[5]   # quadratic velocity term
    c_xv = params[6]   # cross term between position and velocity
    
    c_sin = params[7]  # sinusoidal forcing by time
    c_cos = params[8]  # cosinusoidal forcing by time
    
    c_absx = params[9]   # absolute value of position for asymmetry effects
    c_signv = params[10] # sign of velocity for friction-like effect
    
    c_x2 = params[11]     # quadratic term in position for softening/hardening spring effect

    
    return (
        c0 
        + c_t * x0 
        + c_x * x1 
        + c_v * x2 
        + c_x3 * x1**3 
        + c_v2 * x2**2 
        + c_xv * x1 * x2 
        + c_sin * np.sin(x0) 
        + c_cos * np.cos(x0) 
        + c_absx * np.abs(x1) 
        + c_signv * np.sign(x2) 
        + c_x2 * x1**2
     )
