def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version adds higher order nonlinear terms and cross terms between time,
    position, and velocity to better capture complex dynamics of a nonlinear harmonic oscillator.

    Mathematical form:

        y = p0
            + p1 * x0
            + p2 * x1
            + p3 * x1**2
            + p4 * x1**3
            + p5 * x2
            + p6 * x2**2
            + p7 * x2**3
            + p8 * x1 * x2
            + p9 * (x0 ** 2)
            + p10 * (x0 * x1)
            + p11 * (x0 * x2)

    where:
        - p0: constant offset / forcing term
        - p1: linear time-dependent forcing coefficient
        - p2: linear stiffness coefficient (restoring force)
        - p3: quadratic stiffness coefficient (softening/hardening effect)
        - p4: cubic stiffness coefficient (nonlinear restoring force)
        - p5: linear damping coefficient (velocity dependent dissipation)
        - p6: quadratic damping coefficient (nonlinear damping)
        - p7: cubic damping coefficient (higher order nonlinear damping)
        - p8: cross term between position and velocity capturing coupling effects
        - p9: quadratic time-dependent forcing term capturing possible parametric excitation effects
        - p10: cross term between time and position capturing time-varying stiffness or forcing modulation 
        - p11: cross term between time and velocity capturing time-varying damping or forcing modulation

    Parameters:
        x0 (np.ndarray): time array (independent variable)
        x1 (np.ndarray): position at time t
        x2 (np.ndarray): velocity at time t
        params (np.ndarray): parameters array with at least 12 elements

    Returns:
        np.ndarray: calculated acceleration values for the nonlinear harmonic oscillator.
    """
    
    return (
          params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * np.power(x1, 2)
        + params[4] * np.power(x1, 3)
        + params[5] * x2
        + params[6] * np.power(x2, 2)
        + params[7] * np.power(x2, 3)
        + params[8] * x1 * x2
        + params[9] * np.power(x0, 2)
        + params[10] * x0 * x1
        + params[11] * x0 * x2 
    )
