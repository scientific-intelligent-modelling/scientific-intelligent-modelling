def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator as a function of time (x0),
    position (x1), and velocity (x2).

    Parameters:
    - params: array-like with exactly 12 elements:
        params[0]: constant offset
        params[1]: linear time t
        params[2]: cubic time t^3
        params[3]: linear position x
        params[4]: quintic position x^5
        params[5]: septic position x^7
        params[6]: linear velocity v (damping)
        params[7]: quintic velocity v^5 (nonlinear damping)
        params[8]: cross term x*v
        params[9]: cross quartic term x^3 * v
        params[10]: cross quartic term x * v^3
        params[11]: mixed higher order term e.g. x^5 * v + x * v^5

    Returns:
    - acceleration y as numpy array.
    """
    
    mixed_high_order = (x1 ** 5) * x2 + x1 * (x2 ** 5)
    
    return (
        params[0] +
        
        # Time dependent terms capturing possible parametric forcing or slow modulation.
        params[1] * x0 +
        params[2] * (x0 ** 3) +
        
        # Restoring force terms - typically negative coefficients expected here physically,
        # but signs are learned during fitting.
        params[3] * x1 +
        params[4] * (x1 ** 5) +
        params[5] * (x1 ** 7) +
        
        # Damping terms - usually opposing motion direction,
        # so negative coefficients expected for physical damping.
        params[6] * x2 +
        params[7] * (x2 ** 5) +
        
         # Cross interaction terms capturing coupling effects between position and velocity.
         # These allow modeling nonlinear damping/restoring force interactions.
         #
         # Note: powers chosen to keep total polynomial degree manageable while capturing complexity.
         #
         # For example:
         #   - param8 multiplies linear cross term,
         #   - param9 multiplies cubic in position times linear in velocity,
         #   - param10 multiplies linear in position times cubic in velocity,
         #
         # These can model asymmetric or amplitude-dependent damping/restoring forces.
         
         +params[8] * (x1 * x2) \
         +params[9] * ((x1 ** 3) * x2) \
         +params[10] * (x1 * (x2 ** 3)) \
         
         +params[11] * mixed_high_order  
    )
