    sign = np.sign
    
    base = (
          p[0]
        + p[1]   * x0
        - abs(p[2])   * x1      # restoring force negative sign enforced
        - abs(p[3])   * x2      # damping negative sign enforced
        + p[4]   * (x1 ** 3)
        + p[5]   * (x2 ** 3)
        + p[6]   * (x1 ** 2)
