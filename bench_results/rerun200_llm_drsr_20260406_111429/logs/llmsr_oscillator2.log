def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Mathematical form:

        y = p0 
            + p1 * x0 
            + p2 * x1 
            + p3 * x1**3 
            + p4 * x1**4
            + p5 * x2 
            + p6 * x2**2 
            + p7 * (x1 * x2)
            + p8 * (x0 * x1)
            + p9 * (x0 * x2)
            + p10 * np.sin(x0)  # periodic forcing term
            + p11 * np.cos(x0)
            
        # Additional nonlinear terms:
        + p12 * (x1 ** 5)          # higher order position nonlinearity
        + p13 * (x2 ** 3)          # cubic velocity nonlinearity (damping/forcing)
        + p14 * (x1 ** 2) * x2     # mixed quadratic position and linear velocity
        + p15 * x1 * (x2 ** 2)     # mixed linear position and quadratic velocity

    Parameters:
        - x0: time array
        - x1: position at time t
        - x2: velocity at time t
        - params: array of parameters (length 16)

    Returns:
        - acceleration array y corresponding to inputs.
    """
    return (
        params[0]
        + params[1]  * x0
        + params[2]  * x1
        + params[3]  * np.power(x1, 3)
        + params[4]  * np.power(x1, 4)
        + params[5]  * x2
        + params[6]  * np.power(x2, 2)
        + params[7]  * (x1   * x2)
        + params[8]  * (x0   * x1)
        + params[9]  * (x0   * x2)
        + params[10] * np.sin(x0)
        + params[11] * np.cos(x0)
        
        # Additional nonlinear terms beyond v1:
        
        + params[12]   * np.power(x1,5)       # quintic nonlinearity in position
        + params[13]   * np.power(x2,3)       # cubic nonlinearity in velocity
        + params[14]   *(np.power(x1,2)*x2)   # quadratic position times linear velocity term
        + params[15]   *(x1*np.power(x2,2))   # linear position times quadratic velocity term
    )
