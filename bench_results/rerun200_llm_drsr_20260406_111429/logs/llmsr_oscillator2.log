def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator with:
    - constant offset term
    - linear time dependence (e.g., slow drift or external modulation)
    - linear restoring force proportional to position (Hooke's law)
    - linear damping proportional to velocity
    - quadratic and cubic nonlinearities in position for softening/hardening spring effects
    - quadratic velocity term representing nonlinear damping or drag
    - cross term between position and velocity capturing coupling effects
    - periodic forcing terms dependent on time (sinusoidal forcing)
    - absolute value of position for asymmetric potential effects
    - sign of velocity for friction-like effects

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array-like with length 12 representing coefficients

            params[0] : constant offset acceleration term
            params[1] : coefficient for linear time dependence (x0)
            params[2] : linear stiffness coefficient (-k)
            params[3] : linear damping coefficient (-c)
            params[4] : cubic stiffness nonlinearity coefficient (-k3)
            params[5] : quadratic velocity term coefficient (nonlinear damping/drag)
            params[6] : cross term coefficient between position and velocity
            params[7] : amplitude of sinusoidal forcing sin(x0)
            params[8] : amplitude of sinusoidal forcing cos(x0)
            params[9] : coefficient for absolute value of position |x1|
            params[10]: coefficient for sign of velocity sign(x2) (friction-like effect)
            params[11]: quadratic stiffness nonlinearity coefficient (-k2)

    Returns:
        y: acceleration array corresponding to input arrays.
    """
    
    return (
        params[0]
        + params[1]*x0
        + params[2]*x1               # linear restoring force ~ -k*x1 
        + params[3]*x2               # linear damping ~ -c*x2 
        + params[4]*x1**3           # cubic nonlinearity in position ~ -k3*x1^3 
        + params[5]*x2**2           # nonlinear damping / drag ~ v^2 
        + params[6]*x1*x2           # cross coupling between position and velocity 
        + params[7]*np.sin(x0)      # sinusoidal forcing component 1 
        + params[8]*np.cos(x0)      # sinusoidal forcing component 2 
        + params[9]*np.abs(x1)      # asymmetric potential effect 
        + params[10]*np.sign(x2)     # friction-like effect depending on direction of motion 
        + params[11]*(x1**2)         # quadratic stiffness nonlinearity ~ softening/hardening spring effect 
    )
