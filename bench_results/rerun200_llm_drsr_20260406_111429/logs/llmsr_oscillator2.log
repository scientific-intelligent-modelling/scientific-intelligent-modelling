        params[0]                      # constant offset / bias force
        + params[1] * x0              # explicit time-dependent forcing
        + params[2] * x1              # linear restoring force (-omega^2 * x)
        + params[3] * x2              # linear damping (-beta * v)
        + params[4] * (x1 ** 3)       # cubic restoring force (-alpha * x^3)
        + params[5] * (x2 ** 2)       # quadratic velocity nonlinearity (e.g., nonlinear damping)
        + params[6] * x1 * x2         # cross term coupling position and velocity nonlinearly
        + params[7] * (x1 ** 2)       # quadratic position anharmonicity effect
        + params[8] * (x2 ** 3)       # cubic velocity nonlinearity for higher order effects
        + params[9] * (x1 ** 2) * x2   # quadratic position times velocity cross-term 
        + params[10] * x1 * (x2 ** 2)  # mixed cubic terms involving both variables nonlinearly 
        + params[11] * x0 * x1         # time-position interaction term representing parametric forcing or modulation
    )
