def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Background:
    Calculate Acceleration in Nonlinear Harmonic Oscillator given Time (t), Position (x), and Velocity (v).

    Variables:
    - Independents: 
        x0 = t (time)
        x1 = x (position)
        x2 = v (velocity)
    - Dependent:
        y = acceleration

    Equation form:
    y = p0 
        + p1 * t 
        + p2 * x 
        + p3 * v 
        + p4 * (x ** 3)            # nonlinear stiffness
        + p5 * (v ** 2)            # nonlinear damping-like term
        + p6 * (x ** 2)            # quadratic stiffness term
        + p7 * (x * v)             # linear damping term
        + p8 * (x ** 2 * v)        # nonlinear damping cross term
        + p9 * (x * v ** 2)        # another nonlinear cross term
        + p10 * sin(t)             # periodic forcing term
        + p11 * cos(t)             # another periodic forcing term
        + p12 * v**3               # cubic velocity damping/nonlinearity
        + p13 * sin(t)*x           # modulated forcing by position
        + p14 * cos(t)*v           # modulated forcing by velocity
        + p15 * t*v                # time-velocity interaction

    Parameters:
    - params: array-like with at least 16 parameters.
    """
    
    return (
          params[0]
        + params[1]  * x0                      # linear time dependence
        + params[2]  * x1                      # linear position dependence
        + params[3]  * x2                      # linear velocity dependence
        + params[4]  * (x1 ** 3)               # cubic stiffness nonlinearity
        + params[5]  * (x2 ** 2)               # quadratic velocity nonlinearity / damping-like effect
        + params[6]  * (x1 ** 2)               # quadratic stiffness term
        + params[7]  * (x1 * x2)               # linear damping cross-term
        + params[8]  * (x1 ** 2 * x2)          # nonlinear cross-term between position squared and velocity 
        + params[9]  * (x1 * x2 ** 2)          # another nonlinear cross-term between position and squared velocity 
        + params[10] * np.sin(x0)              # sinusoidal forcing component with time only 
        + params[11] * np.cos(x0)              # cosine forcing component with time only 
        + params[12] * (x2 **3 )               # cubic velocity nonlinearity/damping effect  
        + params[13] * np.sin(x0)*x1           # sinusoidal forcing modulated by position  
        + params[14] * np.cos(x0)*x2           # cosine forcing modulated by velocity  
      	+ params[15]  	* x0*x2               	# interaction between time and velocity  
    )
