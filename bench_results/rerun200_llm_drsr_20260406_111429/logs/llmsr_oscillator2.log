        + params[1]*x0               # linear time-dependent forcing term
        + params[2]*x1               # linear restoring force (Hooke's law)
        + params[3]*x2               # linear damping proportional to velocity
        + params[4]*(x1**3)          # cubic nonlinearity in position (Duffing term)
        + params[5]*(x1**2)          # quadratic nonlinearity in position
        + params[6]*(x2**2)          # nonlinear damping term (velocity squared)
        + params[7]*x0*x1            # coupling between time and position
        + params[8]*x0*x2            # coupling between time and velocity
        + params[9]*x1*x2            # coupling between position and velocity (nonlinear damping/restoring)
        + params[10]*(x1**4)         # quartic nonlinearity in position (higher order stiffness)
