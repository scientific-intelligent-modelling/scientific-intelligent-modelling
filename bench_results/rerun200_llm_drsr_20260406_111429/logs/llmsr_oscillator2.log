def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator with:
    - constant offset term
    - linear time dependence (e.g., slow drift or external influence)
    - linear restoring force (-k * x1)
    - linear damping (-c * x2)
    - cubic nonlinearity in position (Duffing-type nonlinearity)
    - quadratic velocity term (nonlinear damping or drag)
    - cross term between position and velocity (coupling effects)
    - periodic forcing terms depending on time (sin and cos components)
    - absolute value of position for asymmetry effects
    - sign of velocity for friction-like effect
    - quadratic term in position for softening/hardening spring effect

    Parameters:
        x0: time array or scalar
        x1: position array or scalar at time t
        x2: velocity array or scalar at time t
        params: array-like with length 12 containing coefficients

            params[0]: constant offset acceleration
            params[1]: coefficient for linear time dependence (x0)
            params[2]: coefficient for linear position dependence (restoring force)
            params[3]: coefficient for linear velocity dependence (damping)
            params[4]: coefficient for cubic nonlinearity in position (x1^3)
            params[5]: coefficient for quadratic velocity term (x2^2)
            params[6]: coefficient for cross term between position and velocity (x1*x2)
            params[7]: amplitude of sin(time) forcing component
            params[8]: amplitude of cos(time) forcing component
            params[9]: coefficient multiplying abs(position) |x1|
            params[10]: coefficient multiplying sign(velocity) sign(x2), friction-like effect
            params[11]: coefficient multiplying quadratic position term x1^2

    Returns:
        y: acceleration as numpy array or scalar matching input shape.
    """
    
    return (
        params[0]  # constant offset acceleration
        + params[1] * x0  # linear time-dependent forcing/drift
        
        # Note the restoring force is usually negative k*x, so if we want to model that,
        # the parameter can be negative.
        + params[2] * x1  # linear restoring force
        
        + params[3] * x2  # linear damping
        
        + params[4] * x1**3  # cubic nonlinearity in restoring force
        
        + params[5] * x2**2  # nonlinear damping / drag
        
        + params[6] * x1 * x2  # coupling between displacement and velocity
        
        + params[7] * np.sin(x0)  # periodic forcing component sin(ωt), ω=1 here
        
        + params[8] * np.cos(x0)  # periodic forcing component cos(ωt), ω=1 here
        
        + params[9] * np.abs(x1)   # asymmetry effects due to absolute displacement
        
        + params[10] * np.sign(x2)  # friction-like effect depending on direction of motion
        
        + params[11] * x1**2     # quadratic stiffness nonlinearity / softening/hardening spring effect
    )
