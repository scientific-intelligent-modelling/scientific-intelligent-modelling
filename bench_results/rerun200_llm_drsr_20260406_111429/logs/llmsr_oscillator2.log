    sign_p5 = np.sign(p[5])
    sign_p6 = np.sign(p[6])
    sign_p7 = np.sign(p[7])
    sign_p8 = np.sign(p[8])
    sign_p11= np.sign(p[11])
    
    mod_cubic_stiffness =     abs(p[4])     *(x1**3)*np.sin(x0)*sign_p4
    mod_cubic_damping =       abs(p[5])     *(x2**3)*np.cos(x0)*sign_p5
    mod_cross_term =          abs(p[8])     *(x1*x2)*np.sin(2*x0)*sign_p8
    mod_quad_stiffness =      abs(p[6])     *(x1**2)*np.cos(3*x0)*sign_p6
    
    mod_quad_damping =       -abs(p[7])     *(x2**2)*np.sin(2*x0)*sign_p7
