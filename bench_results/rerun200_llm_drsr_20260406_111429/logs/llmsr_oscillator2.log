def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator with:
    - constant offset
    - linear and quadratic time dependence
    - sinusoidal forcing with frequency modulation (sin and cos with param frequency)
    - linear, quadratic and cubic nonlinearities in position (restoring forces)
    - linear, quadratic and cubic nonlinearities in velocity (damping effects)
    - cross terms between position and velocity for complex interactions
    - absolute value and sign functions for asymmetry/friction effects

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array-like with length 12

    Returns:
        y: acceleration array
    """
    
    omega = params[3]  # frequency parameter for sinusoidal forcing
    
    return (
        params[0]  # constant offset
        + params[1] * x0  # linear time dependence
        + params[11] * x0**2  # quadratic time dependence
        
        + params[2] * x1  # linear position restoring force
        + params[4] * x1**3  # cubic Duffing-type nonlinearity in position
        + params[9] * x1**2  # quadratic position term
        
        + params[6] * x2  # linear damping term (velocity)
        + params[5] * x2**2  # quadratic velocity term (nonlinear damping or forcing)
        + params[11-1] * x2**3 if len(params) > 11 else 0.0   # cubic velocity term if available
        
        + params[7] * np.sin(omega * x0)  # sinusoidal forcing with frequency modulation (sin)
        + params[8] * np.cos(omega * x0)  # sinusoidal forcing with frequency modulation (cos)
        
