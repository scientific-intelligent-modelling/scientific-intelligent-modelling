def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Background:
    Calculate Acceleration in Nonlinear Harmonic Oscillator given Time (x0), Position (x1), and Velocity (x2).

    Mathematical form:

        y = p0 
            + p1 * x0 
            - |p2| * x1                 # linear restoring force (negative)
            - |p3| * x1**3             # cubic restoring force (negative)
            - |p4| * x1**5             # quintic restoring force (negative)
            - |p5| * x2                # linear damping (negative)
            + p6 * x2**3               # nonlinear damping or velocity effect
            + p7 * x1 * x2             # coupling term
            + p8 * x0**2               # quadratic time forcing
            + p9 * x0 * x1             # parametric excitation term
            + p10 * x0 * x2            # time-velocity coupling
            + p11 * (x1**2) * x2       # nonlinear cross term

    Explanation:
    - Negative signs on odd powers of position reflect restoring forces.
    - Negative sign on linear velocity term models damping.
    - Higher order terms allow capturing complex nonlinearities.
    - Cross terms model coupling between variables and parametric effects.

    Parameters:
        - params: array with 12 parameters [p0,...p11]

    Returns:
        - acceleration values as np.ndarray
    """

    return (
          params[0]
        + params[1] * x0
        - abs(params[2]) * x1
        - abs(params[3]) * np.power(x1, 3)
        - abs(params[4]) * np.power(x1, 5)
        - abs(params[5]) * x2
        + params[6] * np.power(x2, 3)
        + params[7] * (x1 * x2)
        + params[8] * np.power(x0, 2)
        + params[9] * (x0 * x1)
        + params[10] * (x0 * x2)
        + params[11] * ((x1 ** 2) * x2)
    )
