def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version models acceleration in a nonlinear harmonic oscillator with:
    - linear and nonlinear restoring forces (position terms)
    - linear and nonlinear damping (velocity terms)
    - coupling terms between position and velocity
    - time-dependent forcing (sinusoidal)
    - possible slow drift or ramp in time

    Parameters:
    - params: array of length 12 coefficients

    Returns:
    - acceleration array
    """
    # Extract parameters for clarity
    c0 = params[0]   # constant offset
    c1 = params[1]   # linear time dependence (drift/ramp)
    c2 = params[2]   # linear restoring force coefficient (-k)
    c3 = params[3]   # linear damping coefficient (-b)
    
    c4 = params[4]   # quadratic position nonlinearity
    c5 = params[5]   # quadratic velocity nonlinearity
    c6 = params[6]   # coupling term position*velocity
    
    c7 = params[7]   # cubic position nonlinearity (Duffing term)
    c8 = params[8]   # cubic velocity nonlinearity
    
    c9  = params[9]  # mixed cubic term (x1^2 * x2)
    c10 = params[10] # mixed cubic term (x1 * x2^2)
    
    c11 = params[11] # sinusoidal forcing amplitude

    
    acceleration = (
        c0 
        + c1 * x0 
        + c2 * x1 
        + c3 * x2 
        + c4 * x1**2 
        + c5 * x2**2 
        + c6 * x1 * x2 
        + c7 * x1**3 
        + c8 * x2**3 
        + c9  * (x1**2) * x2 
        + c10 * x1 * (x2**2) 
        + c11 * np.sin(x0)
    )
    
    return acceleration
