def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version extends the nonlinear harmonic oscillator acceleration model by including
    higher-order nonlinear terms and additional cross terms between time, position,
    and velocity to better capture complex system dynamics.

    Model form:
        a = p0 
            + p1*t 
            + p2*x 
            + p3*v 
            + p4*x^3 
            + p5*x^2*v 
            + p6*x*v^2 
            + p7*v^3
            + p8*t^2
            + p9*t*x
            + p10*t*v
            + p11*x*v

    Parameters:
        - x0 (np.ndarray): time (t)
        - x1 (np.ndarray): position at time t (x)
        - x2 (np.ndarray): velocity at time t (v)
        - params (np.ndarray): array-like coefficients [p0,...p11]

    Returns:
        - np.ndarray: calculated acceleration values
    """
    
    # Unpack parameters for clarity
    p = params
    
    # Linear and constant terms
    term_const = p[0]
    term_t = p[1] * x0
    term_x = p[2] * x1
    term_v = p[3] * x2
    
    # Nonlinear stiffness terms (cubic in position)
    term_x3 = p[4] * (x1 ** 3)
    
    # Nonlinear damping / mixed terms involving position and velocity powers
    term_x2v = p[5] * (x1 ** 2) * x2
    term_xv2 = p[6] * x1 * (x2 ** 2)
    
    # Cubic velocity nonlinearity / damping or forcing effect
    term_v3 = p[7] * (x2 ** 3)
    
    # Quadratic and cross terms involving time to capture parametric effects or forcing modulation
    term_t2 = p[8] * (x0 ** 2)
    
    term_tx = p[9] * x0 * x1
    
    term_tv = p[10] * x0 * x2
    
    # Cross product of position and velocity capturing coupling effects or nonlinear damping/forcing interactions
    term_xv = p[11] * x1 * x2

    
    return (
        term_const +
        term_t +
        term_x +
        term_v +
        term_x3 +
        term_x2v +
        term_xv2 +
        term_v3 +
        term_t2 +
        term_tx +
        term_tv +
        term_xv
     )
