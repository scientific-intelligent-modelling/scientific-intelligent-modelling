def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Calculates acceleration as a nonlinear function of time (x0), position (x1),
    and velocity (x2). Includes polynomial terms up to cubic order,
    plus sinusoidal forcing and interaction terms reflecting physical oscillator behavior.

    Parameters:
    - params: array of length 12 coefficients

    Returns:
    - acceleration array
    """
    # Unpack parameters for clarity
    c0 = params[0]   # constant offset
    c1 = params[1]   # linear time term
    c2 = params[2]   # linear position term (restoring force)
    c3 = params[3]   # linear velocity term (damping)
    
    c4 = params[4]   # quadratic position term
    c5 = params[5]   # quadratic velocity term
    c6 = params[6]   # cross quadratic term
    
    c7 = params[7]   # cubic position term (nonlinear restoring force)
    c8 = params[8]   # cubic velocity term (nonlinear damping)
    
    c9  = params[9]  # mixed cubic term x1^2 * x2
    c10 = params[10] # mixed cubic term x1 * x2^2
    
    c11 = params[11] # sinusoidal forcing dependent on time

    return (
        c0 
        + c1 * x0 
        + c2 * x1 
        + c3 * x2 
        + c4 * x1**2 
        + c5 * x2**2 
        + c6 * x1 * x2 
        + c7 * x1**3 
        + c8 * x2**3 
        + c9  * (x1**2) * x2 
        + c10 * x1 * (x2**2) 
        + c11 * np.sin(x0)
    )
