def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Model acceleration of a nonlinear harmonic oscillator with:
    - constant offset (params[0])
    - linear time dependence (params[1] * t)
    - sinusoidal forcing term with frequency scaling (params[2] * sin(params[3]*t))
    - linear position restoring force (params[4] * x)
    - cubic position nonlinearity (Duffing term) (params[5] * x^3)
    - linear velocity damping term (params[6] * v)
    - quadratic velocity term for nonlinear damping or forcing effects (params[7] * v^2)
    - mixed nonlinear coupling between position and velocity (params[8] * x*v)

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of parameters [p0,...p8]

    Returns:
        acceleration array y
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * np.sin(params[3] * x0)
        + params[4] * x1
        + params[5] * np.power(x1, 3)
        + params[6] * x2
        + params[7] * np.power(x2, 2)
        + params[8] * x1 * x2
    )
