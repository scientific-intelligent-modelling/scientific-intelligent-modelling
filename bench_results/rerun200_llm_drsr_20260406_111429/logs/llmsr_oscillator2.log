def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version models acceleration in a nonlinear harmonic oscillator with physically meaningful terms:
    - Constant offset (params[0])
    - Linear time dependence (params[1] * x0)
    - Linear position term (restoring force) (params[2] * x1)
    - Linear velocity term (damping) (params[3] * x2)
    - Cubic position nonlinearity (Duffing-type nonlinearity) (params[4] * x1**3)
    - Quadratic velocity nonlinearity (nonlinear damping) (params[5] * x2**2)
    - Cubic velocity nonlinearity (higher order damping) (params[6] * x2**3)
    - Cross term position*velocity coupling (params[7] * x1 * x2)
    - Quartic position term for stronger restoring force nonlinearity (params[8] * x1**4)
    - Quadratic position times velocity coupling (params[9] * x1**2 * x2)
    - Quadratic time-position interaction term to capture possible parametric excitation or time-dependent stiffness modulation (params[10] * x0**2 * x1)
    - Cubic time-velocity interaction term to capture time-dependent damping effects or forcing on velocity terms (params[11] * x0**3 * x2)

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of 12 coefficients

    Returns:
        Acceleration array.
    """
    
    y = (
        params[0]
        + params[1]*x0
        + params[2]*x1
        + params[3]*x2
        + params[4]*(x1**3)
        + params[5]*(x2**2)
        + params[6]*(x2**3)
        + params[7]*x1*x2
        + params[8]*(x1**4)
        + params[9]*(x1**2)*x2
        + params[10]*(x0**2)*x1
        + params[11]*(x0**3)*x2
    )
    
    return y
