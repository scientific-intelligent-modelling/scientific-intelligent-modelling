def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version refines the nonlinear harmonic oscillator acceleration model by:
    - Retaining polynomial terms up to cubic order in position and velocity,
    - Including cross terms to capture nonlinear coupling,
    - Adding a sinusoidal forcing term representing external periodic driving,
    - Explicitly modeling physical intuition: 
      * params[2] corresponds roughly to negative stiffness (-k),
      * params[3] corresponds roughly to negative damping (-b),
      * higher order terms capture nonlinear restoring and damping effects.

    Parameters:
    - x0: time array
    - x1: position array at time t
    - x2: velocity array at time t
    - params: array of 12 coefficients

    Returns:
    - acceleration array as nonlinear function of inputs and parameters
    """
    
    # Unpack parameters for clarity (optional)
    c0 = params[0]   # constant offset (e.g., bias acceleration)
    c1 = params[1]   # linear time dependence (slow drift or ramp)
    
    k_lin = params[2]  # linear restoring force coefficient (~-k)
    b_lin = params[3]  # linear damping coefficient (~-b)
    
    k_quad_pos = params[4]  # quadratic position nonlinearity
    b_quad_vel = params[5]  # quadratic velocity nonlinearity
    
    cross_quad = params[6]  # coupling between position and velocity
    
    k_cubic_pos = params[7]  # cubic restoring force nonlinearity (Duffing term)
    b_cubic_vel = params[8]  # cubic damping nonlinearity
    
    mixed_term1 = params[9]   # mixed cubic term (x1^2 * x2)
    mixed_term2 = params[10]  # mixed cubic term (x1 * x2^2)
    
    forcing_amp = params[11]  # amplitude of sinusoidal forcing
    
    return (
        c0
        + c1 * x0
        + k_lin * x1
        + b_lin * x2
        + k_quad_pos * x1**2
        + b_quad_vel * x2**2
        + cross_quad * x1 * x2
        + k_cubic_pos * x1**3
        + b_cubic_vel * x2**3
        + mixed_term1 * (x1**2) * x2
        + mixed_term2 * x1 * (x2**2)
        + forcing_amp * np.sin(x0)
     )
