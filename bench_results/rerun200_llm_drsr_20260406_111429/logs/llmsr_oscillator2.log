        + |p7|*(x2**2)*sin(2*x0)*sign(p7)          # quadratic velocity modulation by sin(2*time)
        - |p11|*(x1**3)*cos(2*x0)*sign(p11)       # cubic position modulation by cos(2*time), negative sign to add flexibility

