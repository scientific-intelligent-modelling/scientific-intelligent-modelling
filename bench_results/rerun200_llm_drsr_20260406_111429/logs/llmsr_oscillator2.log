def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    This version balances physical interpretability with nonlinear complexity,
    including:
    - linear terms in time, position, velocity
    - cubic and quartic nonlinearities in position (Duffing oscillator style)
    - cubic and quartic nonlinearities in velocity (nonlinear damping)
    - parametric forcing via quadratic and cubic time dependence
    - cross coupling terms between time-position, position-velocity, time-position-velocity

    Parameters:
        x0 : np.ndarray
            Time variable(s)
        x1 : np.ndarray
            Position variable(s)
        x2 : np.ndarray
            Velocity variable(s)
        params : np.ndarray
            Array of 12 parameters controlling each term

    Returns:
        y : np.ndarray
            Computed acceleration at given inputs
    """

    return (
          params[0]                       # constant offset / bias

        + params[1] * x0                 # linear in time (forcing/drift)

        + params[2] * x1                 # linear restoring force (-k*x)

        + params[3] * x2                 # linear damping (-c*v)

        + params[4] * (x1 ** 3)          # Duffing-type cubic stiffness nonlinearity

        + params[5] * (x0 ** 2)          # parametric forcing via quadratic in time

        + params[6] * (x2 ** 3)          # nonlinear damping cubic in velocity

        + params[7] * x0 * x1            # coupling between time and position

        + params[8] * x1 * (x2 ** 2)     # mixed nonlinear damping-position term

        + params[9] * (x1 ** 4)          # quartic stiffness nonlinearity

        + params[10] * (x0 ** 3) * x1     # higher order parametric forcing term

        + params[11] * x0 * x1 * x2       # three-way nonlinear coupling term involving all variables 
    )
