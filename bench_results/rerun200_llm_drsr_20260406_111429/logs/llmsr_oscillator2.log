def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Models acceleration of a nonlinear harmonic oscillator as a function of time (x0),
    position (x1), and velocity (x2).

    Uses polynomial terms up to cubic nonlinearity in position and velocity.
    
    Parameters:
    - params: array-like with at least 6 elements:
        params[0]: constant offset term
        params[1]: linear term in time t
        params[2]: linear term in position x
        params[3]: linear term in velocity v
        params[4]: cubic term in position x^3
        params[5]: cubic term in velocity v^3
    
    Returns:
    - acceleration y as numpy array.
    """
    
    return (
        params[0] +
        params[1] * x0 +
        params[2] * x1 +
        params[3] * x2 +
        params[4] * np.power(x1, 3) +
        params[5] * np.power(x2, 3)
    )
