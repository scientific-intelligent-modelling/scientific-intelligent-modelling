def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration as a nonlinear harmonic oscillator with time-dependent forcing and nonlinear damping terms:

        y = p0 
            + p1 * x1                 # linear restoring force term
            + p2 * (x1 ** 3)          # cubic nonlinearity in position (Duffing-type)
            + p3 * (x1 ** 5)          # quintic nonlinearity in position
            + p4 * x2                 # linear damping term
            + p5 * (x2 ** 3)          # nonlinear damping term (cubic velocity)
            + p6 * (x2 ** 2)          # quadratic velocity term for asymmetric damping
            + p7 * (x1 ** 2)          # quadratic position term for asymmetry
            + p8 * np.sin(x0)         # periodic forcing - sine component
            + p9 * np.cos(x0)         # periodic forcing - cosine component
            + p10 * (x1 * x2)         # coupling between position and velocity
            + p11 * (x0 * x2)         # time-dependent modulation of velocity

    Parameters:
        - params: array of 12 coefficients [p0 ... p11]

    Variables:
        - x0 : time t
        - x1 : position at time t
        - x2 : velocity at time t

    Returns:
        y : acceleration at time t
    """
    return (
        params[0]
        + params[1] * x1
        + params[2] * (x1 ** 3)
        + params[3] * (x1 ** 5)
        + params[4] * x2
        + params[5] * (x2 ** 3)
        + params[6] * (x2 ** 2)
        + params[7] * (x1 ** 2)
        + params[8] * np.sin(x0)
        + params[9] * np.cos(x0)
        + params[10] * (x1 * x2)
        + params[11] * (x0 * x2)
    )
