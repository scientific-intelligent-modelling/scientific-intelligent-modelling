def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Extends the nonlinear harmonic oscillator acceleration model by adding:
    - Nonlinear cross terms combining position and velocity with trigonometric modulation
    - Quadratic and cubic nonlinearities modulated by time-dependent sine/cosine functions
    - Interaction terms that reflect physical damping/stiffness coupling effects

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of 12 parameters

    Returns:
        y: predicted acceleration array
    """
    
    p = params
    
    # Base linear and nonlinear terms
    term0 = p[0]                   # Constant offset
    
    term1 = p[1] * x0              # Linear in time (could represent slow drift or parametric effect)
    
    term2 = p[2] * x1              # Linear stiffness term (-k*x)
    
    term3 = p[3] * x2              # Linear damping term (-c*v)
    
    term4 = p[4] * (x1 ** 3)       # Cubic stiffness nonlinearity
    
    term5 = p[5] * (x2 ** 3)       # Cubic damping nonlinearity
    
    term6 = p[6] * (x1 ** 2)       # Quadratic stiffness nonlinearity
    
    term7 = p[7] * (x2 ** 2)       # Quadratic damping nonlinearity
    
    term8  = p[8]  * (x1 * x2)     # Cross product position-velocity coupling
    
    term9  = p[9]  * ((x1 ** 2) * x2)   # Higher order cross product
    
    term10 = p[10] * np.sin(x0)          # Sinusoidal forcing / parametric excitation
    
    term11 = p[11] * np.cos(x0)          # Cosine forcing / parametric excitation
    
    
    ### Additional enhanced nonlinear interaction terms ###
    
    # Modulate cubic stiffness by sin(time)
    mod_cubic_stiffness = p[4] * (x1 ** 3) * np.sin(x0)
    
    # Modulate cubic damping by cos(time)
    mod_cubic_damping   = p[5] * (x2 ** 3) * np.cos(x0)
    
    # Modulate cross product by sin(2*time)
    mod_cross_term      = p[8] * (x1 * x2) * np.sin(2*x0)
    
    # Modulate quadratic stiffness by cos(3*time)
    mod_quad_stiffness  = p[6] * (x1 ** 2) * np.cos(3*x0)

    
        
    
    return (
        term0 + 
        term1 + 
        term2 + 
        term3 + 
        term4 + 
        term5 + 
        term6 + 
        term7 + 
        term8 + 
        term9 +
        term10 +
        term11 +
        
