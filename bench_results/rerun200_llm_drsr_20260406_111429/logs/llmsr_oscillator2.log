def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration y as a function of time x0, position x1, velocity x2 with:
    - constant offset
    - linear and quadratic time dependence
    - sinusoidal forcing with frequency parameter
    - linear and cubic position restoring forces
    - linear, quadratic, cubic velocity damping/nonlinear damping
    - cross terms between position and velocity up to cubic order
    - parametric excitation term modulated by cosine(time)
    - additional nonlinear mixed terms for richer dynamics

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of parameters [p0,...p11]

    Returns:
        acceleration array y
    """
    
    return (
        params[0]                              # constant offset
        + params[1] * x0                      # linear time dependence
        + params[2] * x0**2                   # quadratic time dependence
        
        + params[3] * np.sin(params[4] * x0) # sinusoidal forcing
        
        + params[5] * x1                      # linear position restoring force
        + params[6] * x1**3                   # cubic Duffing nonlinearity
        
        + params[7] * x2                      # linear velocity damping
        + params[8] * x2**2                   # quadratic velocity term (nonlinear damping/forcing)
        + params[9] * x2**3                   # cubic velocity term
        
        + params[10] * x1 * x2                # cross term between position and velocity
        
        + params[11] * np.cos(params[4]*x0) * x1  # parametric excitation modulated by cosine(time)*position 
    )
