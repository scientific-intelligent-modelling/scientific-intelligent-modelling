def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0` that includes nonlinear terms for modeling 
    acceleration of nonlinear harmonic oscillator.
    
    Parameters:
    - params (np.ndarray): array of length up to MAX_NPARAMS=12
    
    Returns:
    - y (np.ndarray): predicted acceleration
    """
    # Unpack parameters for clarity
    p = params
    # Constant term
    term0 = p[0]
    
    # Linear terms
    term1 = p[1] * x0      # time dependence (usually zero or small)
    term2 = p[2] * x1      # linear position term (-omega^2 * x)
    term3 = p[3] * x2      # linear velocity term (damping)
    
    # Quadratic / cubic nonlinearities:
    term4 = p[4] * (x1 ** 2)
    term5 = p[5] * (x1 ** 3)
    
    term6 = p[6] * (x2 ** 2)
    term7 = p[7] * (x2 ** 3)
    
    # Cross terms:
    term8  = p[8]  * (x1 * x2)
    term9  = p[9]  * (x1 ** 2 * x2)
    term10 = p[10] * (x1 * x2 ** 2)
    
    # Possibly include time cross terms if desired:
    term11 = p[11] * (x0 * x1)

    return (
        term0 + term1 + term2 + term3 +
        term4 + term5 +
        term6 + term7 +
        term8 + term9 + term10 +
        term11
     )
