def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Calculates acceleration for a nonlinear harmonic oscillator with cubic nonlinearity and damping.

    Parameters:
    - x0: time (not necessarily used explicitly)
    - x1: position at time t
    - x2: velocity at time t
    - params: array of parameters [c0, c1, c2, c3] where
        c0 = constant offset (optional)
        c1 = linear stiffness coefficient (-ω²)
        c2 = cubic stiffness coefficient (-α)
        c3 = damping coefficient (-β)

    Returns:
    - acceleration y as numpy array
    """
    
    # unpack parameters for clarity
    c0 = params[0]  # constant offset term
    c1 = params[1]  # linear term coefficient for position
    c2 = params[2]  # cubic term coefficient for position^3
    c3 = params[3]  # linear damping term coefficient for velocity

    return c0 + c1 * x1 + c2 * (x1 ** 3) + c3 * x2
