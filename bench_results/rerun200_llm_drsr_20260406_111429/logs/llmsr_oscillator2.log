def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` for nonlinear harmonic oscillator acceleration.

    Background:
    Calculate Acceleration in Nonlinear Harmonic Oscillator given Time (x0), Position at time t (x1),
    and Velocity at time t (x2).

    Variables:
    - Independents: x0 (time), x1 (position), x2 (velocity)
    - Dependent: y (acceleration)

    Parameters:
    - params (np.ndarray): array of length up to MAX_NPARAMS=12

    Returns:
    - y (np.ndarray): predicted acceleration
    """

    p = params

    # Constant term
    term0 = p[0]

    # Linear terms
    term1 = p[1] * x0          # time dependence
    term2 = p[2] * x1          # linear position term (-omega^2 * x)
    term3 = p[3] * x2          # linear velocity term (damping)

    # Nonlinear terms on position and velocity
    term4 = p[4] * (x1 ** 3)   # cubic position nonlinearity
    term5 = p[5] * (x2 ** 3)   # cubic velocity nonlinearity

    term6 = p[6] * (x1 ** 2)   # quadratic position nonlinearity
    term7 = p[7] * (x2 ** 2)   # quadratic velocity nonlinearity

    
    # Cross terms between position and velocity
    term8  = p[8]  * (x1 * x2)

    
    # Time-dependent trigonometric forcing/modulation terms
    term9  = p[9]  * np.sin(x0)
    
    term10 = p[10] * np.cos(x0)

    
    # Higher order cross nonlinearities involving powers of position and velocity
    term11 = p[11] * ((x1 ** 2) * x2)

    
    return (
        term0 +
        term1 +
        term2 +
        term3 +
        term4 +
        term5 +
        term6 +
        term7 +
        term8 +
        term9 +
        term10 +
        term11
     )
