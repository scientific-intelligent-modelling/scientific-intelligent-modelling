        + params[8] * (x0 ** 2)       # quadratic forcing in time 
        + params[9] * x0 * x1         # mixed term between time and position 
        + params[10] * x0 * x2         # mixed term between time and velocity 
        + params[11] * (x1 ** 2) * x2  # higher order coupling: position squared times velocity
    )
