def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1` with additional physically meaningful nonlinear terms.

    Background:
    Calculate Acceleration in Nonlinear Harmonic Oscillator given Position (x0) and Velocity (x1).

    Variables:
    - Independents: x0 (position), x1 (velocity)
    - Dependent: y (acceleration)

    Parameters:
    - params (np.ndarray): Array of 12 trainable coefficients.

    Returns:
    - y (np.ndarray): Calculated acceleration.
    
    Model rationale:
    - Linear restoring force ~ x0
    - Linear damping ~ x1
    - Cubic stiffness nonlinearity ~ x0^3
    - Nonlinear damping ~ x1^3
    - Cross coupling terms between position and velocity
    - Pendulum-like nonlinearities via sin(x0), cos(x0)
    - Higher order coupling terms involving powers of position and velocity
    """
    
    return (
        params[0]                          # constant offset term, often zero in physical systems
        + params[1] * x0                  # linear restoring force (-k*x)
        + params[2] * x1                  # linear damping (-c*v)
        + params[3] * x0 ** 3             # cubic stiffness nonlinearity (-k3*x^3)
        + params[4] * x1 ** 3             # nonlinear damping term
        + params[5] * x0 * x1             # cross term coupling position and velocity
        + params[6] * np.sin(x0)          # pendulum-like restoring force component
        + params[7] * (x0 ** 2) * x1      # higher order coupling term between position squared and velocity
        + params[8] * np.cos(x0)          # additional positional nonlinearity component
        + params[9] * np.power(x1, 2)     # quadratic velocity term for nonlinear damping effects
        + params[10] * np.power(x0, 2)     # quadratic position term for softening/hardening spring effect 
        + params[11] * np.sin(2*x0)       # second harmonic pendulum-like nonlinearity 
    )
