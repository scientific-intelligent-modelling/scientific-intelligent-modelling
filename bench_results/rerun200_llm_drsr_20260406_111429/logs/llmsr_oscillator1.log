def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration as a polynomial function of position (x0) and velocity (x1),
    including nonlinear terms typical for a nonlinear harmonic oscillator,
    plus oscillatory nonlinearities from sine and cosine functions to capture
    more complex physical behaviors such as parametric excitation or nonlinear resonance.

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of parameters [p0, p1, ..., p11] representing coefficients for each term

    Returns:
    - y: Acceleration at time t
    """

    p = params

    # Constant term (external forcing)
    y = p[0]

    # Linear terms (stiffness and damping)
    y += p[1] * x0       # linear restoring force ~ position
    y += p[2] * x1       # linear damping ~ velocity

    # Quadratic terms capturing basic nonlinearities
    y += p[3] * x0**2
    y += p[4] * x1**2

    # Cubic terms for stronger nonlinear effects in stiffness/damping/coupling
    y += p[5] * x0**3
    y += p[6] * x1**3

    # Cross terms combining position and velocity powers
    y += p[7] * (x0 * x1)
    y += p[8] * (x0**2) * x1
    y += p[9] * x0 * (x1**2)

    
    # Higher order cross cubic terms for complex interactions
    y += p[10] * (x0**3) * x1
    y += p[11] * x0 * (x1**3)
