def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Further extends the nonlinear harmonic oscillator acceleration model by:
    - Including fractional power terms in position and velocity to capture subtle nonlinearities.
    - Adding asymmetric damping/friction terms using sign functions.
    - Retaining all previous polynomial and mixed terms for generality.

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.

    Returns:
    - y (np.ndarray): Calculated acceleration.
    """
    
    return (
        params[0]  # constant offset
        + params[1] * x0  # linear in position (restoring force)
        + params[2] * x1  # linear in velocity (linear damping)
        + params[3] * x0**2  # quadratic in position (nonlinear stiffness)
        + params[4] * x1**2  # quadratic in velocity (nonlinear damping)
        + params[5] * x0**3  # cubic nonlinearity in position
        + params[6] * x0 * x1  # cross term between position and velocity
        + params[7] * x1**3  # cubic nonlinearity in velocity (nonlinear damping)
        + params[8] * x0**4  # quartic nonlinearity in position (higher order stiffness)
        + params[9] * (x0**2) * x1  # mixed quadratic position times linear velocity
        + params[10] * x0 * (x1**2)  # mixed linear position times quadratic velocity
        + params[11] * np.sign(x1) * np.abs(x1)**(3/2)  # fractional power asymmetric damping term
        + params[12-12 if len(params)>12 else -1]*np.sign(x0)*np.abs(x0)**(3/2) if len(params)>12 else 0   # fractional power asymmetric stiffness term, optional if param available
    )
