def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Further extends the nonlinear oscillator model by:
    - Including quartic terms in position and velocity to capture stronger nonlinearities.
    - Adding asymmetric mixed terms to model complex interactions between position and velocity.
    - Retaining lower order terms for linear restoring force and damping.

    Physical reasoning:
    - Restoring force includes linear, cubic, quartic terms in position.
    - Damping includes linear, cubic, quartic terms in velocity.
    - Mixed terms capture nonlinear coupling effects between position and velocity.

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Array of 12 trainable coefficients

    Returns:
        np.ndarray: Acceleration y as a function of position, velocity, and parameters.
    """
    
    return (
        params[0]                              # constant forcing term
        + params[1] * x0                      # linear restoring force ~ -k*x0
        + params[2] * x1                      # linear damping ~ -c*x1
        + params[3] * (x0 ** 3)               # cubic stiffness nonlinearity (Duffing)
        + params[4] * (x1 ** 3)               # cubic damping nonlinearity
        + params[5] * (x0 ** 4)               # quartic stiffness nonlinearity
        + params[6] * (x1 ** 4)               # quartic damping or higher order effect
        + params[7] * (x0 * x1)               # bilinear coupling term
        + params[8] * (x0 ** 2 * x1)          # quadratic-cubic mixed term
        + params[9] * (x0 * x1 ** 2)          # cubic-quadratic mixed term
        + params[10] * (x0 ** 3 * x1)         # higher order mixed term emphasizing strong coupling effects
        + params[11] * (x0 ** 2 * x1 ** 2)     # quartic cross term capturing complex interactions
    )
