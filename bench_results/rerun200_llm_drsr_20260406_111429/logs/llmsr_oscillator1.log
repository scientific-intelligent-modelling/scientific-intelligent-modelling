def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculate acceleration for a nonlinear harmonic oscillator given position and velocity.

    Model includes:
    - constant offset term
    - linear restoring force (proportional to position)
    - linear damping term (proportional to velocity)
    - cubic and quintic stiffness nonlinearities in position
    - quadratic and cubic damping nonlinearities in velocity
    - cross terms between position and velocity capturing coupling effects
    - dry friction modeled by sign(velocity)
    - higher order mixed nonlinear interaction terms

    Parameters:
        x0: Position at time t (np.ndarray)
        x1: Velocity at time t (np.ndarray)
        params: array of parameters [p0,...p11] (np.ndarray)

    Returns:
        Acceleration y as numpy array.
    """
    
    return (
        params[0]  # constant offset term
        + params[1] * x0  # linear restoring force (-ω^2 * x)
        + params[2] * x1  # linear damping (-c * v)
        + params[3] * x0**3  # cubic stiffness nonlinearity (Duffing term)
        + params[4] * x0**5  # quintic stiffness nonlinearity (higher order restoring force)
        + params[5] * x1**2  # quadratic damping nonlinearity
        + params[6] * x1**3  # cubic damping nonlinearity
        + params[7] * x0 * x1  # coupling between position and velocity
        + params[8] * (x0**2) * x1  # higher order mixed term: quadratic position times linear velocity
        + params[9] * x0 * (x1**2)  # higher order mixed term: linear position times quadratic velocity
        + params[10] * np.sign(x1)  # dry friction / Coulomb friction effect modeled by sign of velocity
        + params[11] * ((x0**3) * (x1**2))  # higher order mixed nonlinearity capturing complex dynamics
    )
