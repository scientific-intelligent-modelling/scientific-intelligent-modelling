def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Extends the model by including higher-order mixed nonlinearities,
    nonlinear damping depending on velocity magnitude, and coupling terms
    to better capture complex oscillator dynamics.

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length at least 12.

    Returns:
        Acceleration y as a function of position x0 and velocity x1.
    """
    # To keep parameter indexing consistent with previous versions,
    # we reuse params[0] to params[11].
    
    # Base polynomial terms (up to quartic)
    base = (
        params[0]                      # constant term
        + params[1] * x0              # linear stiffness term
        + params[2] * x1              # linear damping term
        + params[3] * (x0 ** 2)       # quadratic stiffness nonlinearity
        + params[4] * (x1 ** 2)       # quadratic damping nonlinearity
        + params[5] * (x0 ** 3)       # cubic stiffness nonlinearity
        + params[6] * (x1 ** 3)       # cubic damping nonlinearity
        + params[7] * (x0 * x1)       # coupling linear term
        + params[8] * (x0 ** 2 * x1)  # mixed quadratic-cubic term
        + params[9] * (x0 * x1 ** 2)  # mixed cubic-quadratic term
        + params[10] * (x0 ** 4)      # quartic stiffness term
        + params[11] * (x1 ** 4)      # quartic damping or velocity effect term
    )
    
    # Additional nonlinear damping proportional to |velocity|*velocity,
    # which is common in some physical systems with drag-like forces.
    nonlinear_damping = -params[12]*np.abs(x1)*x1 if len(params) > 12 else 0.0
    
    return base + nonlinear_damping
