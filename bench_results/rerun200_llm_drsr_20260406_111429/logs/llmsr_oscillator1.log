def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical interpretation:
    Acceleration in a nonlinear harmonic oscillator with:
    - linear and cubic stiffness terms,
    - linear, cubic, and quadratic damping,
    - sinusoidal forcing terms,
    - higher order polynomial nonlinearities,
    - mixed nonlinear coupling terms,
    - additional nonlinear damping proportional to |x1|*x1 (common in friction/damping models),
    - and combined trigonometric interaction terms.

    params mapping (length >= 12):
      0: linear restoring force coefficient (-x0)
      1: cubic restoring force coefficient (-x0^3)
      2: linear damping coefficient (-x1)
      3: cubic damping coefficient (-x1^3)
      4: sinusoidal restoring/forcing term sin(x0)
      5: velocity-dependent forcing cos(x1)
      6: mixed nonlinear term (x0^2)*x1
      7: mixed nonlinear term x0*(x1^2)
      8: quartic stiffness nonlinearity (x0^4)
      9: quartic damping nonlinearity (x1^4)
     10: mixed sinusoidal term sin(x0*x1)
     11: mixed sinusoidal term cos(x0*x1)

     Additional extensions included here:
     - params[12]: quadratic velocity damping term proportional to x1 * |x1|
     - params[13]: quintic stiffness nonlinearity (x0^5)
     - params[14]: quintic damping nonlinearity (x1^5)

    Note:
        If fewer than 15 parameters are provided, the extra terms default to zero.

    Returns:
        np.ndarray : acceleration values computed from the nonlinear oscillator model.
    """
    
    # Safely handle extra parameters if provided
    p = np.zeros(15)
    length = min(len(params), 15)
    p[:length] = params[:length]

    # Compute acceleration y according to the extended model
    y = (
        -p[0] * x0 
        -p[1] * x0 ** 3 
        -p[2] * x1 
        -p[3] * x1 ** 3 
        +p[4] * np.sin(x0) 
        +p[5] * np.cos(x1) 
        +p[6] * (x0 ** 2) * x1 
        +p[7] * x0 * (x1 ** 2) 
        +p[8] * x0 ** 4 
        +p[9] * x1 ** 4 
        +p[10]*np.sin(x0*x1) 
        +p[11]*np.cos(x0*x1) 
        
        # Additional nonlinear damping proportional to |velocity|*velocity
        - p[12] * np.abs(x1) * x1
        
        # Higher order stiffness and damping terms
        - p[13] * x0 ** 5
        - p[14] * x1 ** 5
    )
    
    return y
