def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Extends the previous model by including:
    - nonlinear damping terms involving |velocity|*velocity (quadratic damping)
    - terms involving sign of velocity to model dry friction-like effects
    - higher order mixed nonlinearities between position and velocity
    - asymmetric effects via sign functions

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.

    Returns:
    - y (np.ndarray): Calculated acceleration.
    """
    
    p = params
    
    # Sign functions for asymmetric/friction-like effects
    sign_x0 = np.sign(x0)
    sign_x1 = np.sign(x1)
    
    return (
        p[0]  # constant offset
        + p[1] * x0  # linear stiffness term
        + p[2] * x1  # linear damping term
        + p[3] * x0**2  # quadratic stiffness nonlinearity
        + p[4] * x1**2  # quadratic velocity term (nonlinear damping)
        + p[5] * x0**3  # cubic stiffness nonlinearity (Duffing-type)
        + p[6] * x0 * x1  # cross term linear in both variables
        + p[7] * x1**3  # cubic velocity nonlinearity (nonlinear damping)
        + p[8] * x0**4  # quartic stiffness nonlinearity (higher order restoring force)
        + p[9] * (x0**2) * x1  # mixed quadratic position & linear velocity term
        + p[10] * x0 * (x1**2)  # mixed linear position & quadratic velocity term
        + p[11] * sign_x1 * np.abs(x1)  # friction-like effect proportional to |v|*sign(v), i.e. v*|v|
    )
