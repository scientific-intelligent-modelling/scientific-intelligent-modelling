def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration as a nonlinear function of position and velocity including:
    - constant offset
    - linear terms in position (restoring force) and velocity (damping)
    - quadratic terms in position and velocity
    - cubic term in position (nonlinear stiffness)
    - quartic term in position (higher order stiffness)
    - cross terms between powers of position and velocity

    Physically motivated terms:
        a = p0 
            + p1*x0 
            + p2*x1 
            + p3*x0**2 
            + p4*x1**2 
            + p5*x0*x1 
            + p6*x0**3
            + p7*x0**4
            + p8*(x0**2)*x1
            + p9*x0*(x1**2)

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Coefficients array with length >= 10

    Returns:
        np.ndarray: Acceleration at time t
    """
    
    return (
          params[0]  # constant offset
        + params[1] * x0  # linear restoring force term
        + params[2] * x1  # linear damping term
        + params[3] * x0**2  # quadratic stiffness term
        + params[4] * x1**2  # quadratic damping term
        + params[5] * x0 * x1  # cross term between position and velocity
        + params[6] * x0**3  # cubic nonlinear stiffness term
        + params[7] * x0**4  # quartic nonlinear stiffness term (higher order)
        + params[8] * (x0**2) * x1  # mixed cubic term: quadratic pos times vel (nonlinear damping effect)
        + params[9] * x0 * (x1**2)   # mixed cubic term: pos times quadratic vel (nonlinear damping effect)
    )
