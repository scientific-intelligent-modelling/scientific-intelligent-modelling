def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Models acceleration as a polynomial function of position (x0) and velocity (x1),
    including nonlinear terms typical for a nonlinear harmonic oscillator.

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of parameters [p0, p1, ..., p11] representing coefficients for each term

    Returns:
    - y: Acceleration at time t
    """
    
    # Unpack parameters for clarity (up to 12 parameters)
    p = params
    
    # Constant term
    y = p[0]
    
    # Linear terms
    y += p[1] * x0       # linear stiffness term ~ position
    y += p[2] * x1       # linear damping term ~ velocity
    
    # Quadratic terms
    y += p[3] * x0**2
    y += p[4] * x0 * x1
    y += p[5] * x1**2
    
    # Cubic terms
    y += p[6] * x0**3   # nonlinear stiffness cubic term
    y += p[7] * (x0**2) * x1 
    y += p[8] * x0 * (x1**2)
    y += p[9] * x1**3
    
    # Optional higher order or cross terms if needed:
    
    # For completeness using all 12 params:
    
    # Mixed cubic/quartic-like terms or additional nonlinearities:
    
    y += p[10] * (x0**3) * x1   # e.g. cubic position times velocity term
    y += p[11] * x0 * (x1**3)   # e.g. position times cubic velocity term
    
    return y
