def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration as a polynomial function of position (x0) and velocity (x1),
    including nonlinear terms typical for a nonlinear harmonic oscillator,
    plus nonlinear oscillatory effects via sine and cosine functions.

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of 12 parameters [p0,...,p11] representing coefficients for each term

    Returns:
    - y: Acceleration at time t
    """

    p = params

    # Constant term (could represent constant external forcing)
    y = p[0]

    # Linear terms (stiffness and damping)
    y += p[1] * x0       # linear stiffness ~ position
    y += p[2] * x1       # linear damping ~ velocity

    # Quadratic terms capturing nonlinearities and coupling
    y += p[3] * x0**2
    y += p[4] * x0 * x1
    y += p[5] * x1**2

    # Cubic terms for stronger nonlinear effects
    y += p[6] * x0**3
    y += p[7] * (x0**2) * x1 
    y += p[8] * x0 * (x1**2)
    y += p[9] * x1**3

    
    # Additional cubic cross-terms to capture complex interactions
    y += p[10] * (x0**3) * x1   
    y += p[11] * x0 * (x1**3)

    
    # Optionally add oscillatory nonlinearities if desired:
    
#     Since we have only 12 parameters total, 
#     if you want to include sine/cosine terms,
#     you can replace some polynomial coefficients or extend params array.
#     For example:
#     if len(p) > 12:
#         y += p[12] * np.sin(x0)
#         y += p[13] * np.cos(x1)

    
#     Return the computed acceleration value(s)
    
    return y
