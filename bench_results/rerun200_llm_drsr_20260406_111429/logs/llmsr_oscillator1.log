def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Extends the nonlinear harmonic oscillator acceleration model by including
    quartic order polynomial terms and additional cross terms to better capture
    complex nonlinear dynamics.

    Physically motivated terms include:
    - constant offset
    - linear, quadratic, cubic, and quartic terms in position and velocity
    - mixed cross terms up to quartic order (degree 4)

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Coefficients array with length >= 12

    Returns:
        np.ndarray: Acceleration at time t
    """
    
    # Base polynomial terms up to cubic order + some cross terms from v1:
    base = (
          params[0]                      # constant offset term
        + params[1] * x0                # linear position term (restoring force)
        + params[2] * x1                # linear velocity term (damping)
        + params[3] * x0**2             # quadratic position term
        + params[4] * x1**2             # quadratic velocity term
        + params[5] * x0**3             # cubic position term (nonlinear stiffness)
        + params[6] * x1**3             # cubic velocity term (nonlinear damping)
        + params[7] * x0 * x1           # cross linear term between position and velocity
        + params[8] * (x0**2) * x1      # quadratic position times linear velocity
        + params[9] * x0 * (x1**2)      # linear position times quadratic velocity
        + params[10] * (x0**3) * x1     # cubic position times linear velocity
        + params[11] * x0 * (x1**3)     # linear position times cubic velocity
    )
    
    # If more parameters are available beyond index 11, add quartic order terms.
    if len(params) > 12:
        p = params  # alias for brevity
        
        quartic_terms = 0.0
        
        if len(p) > 12:
            quartic_terms += p[12] * x0**4              # quartic in position (higher-order stiffness)
        
        if len(p) > 13:
            quartic_terms += p[13] * x1**4              # quartic in velocity (higher-order damping)
        
        if len(p) > 14:
            quartic_terms += p[14] * (x0**3)*x1         # cubic pos times linear vel
        
        if len(p) > 15:
            quartic_terms += p[15] * x0*(x1**3)         # linear pos times cubic vel
        
        if len(p) > 16:
            quartic_terms += p[16] * (x0**2)*(x1**2)     # quadratic pos times quadratic vel
        
        if len(p) > 17:
            quartic_terms += p[17] * (x0)*(x1)**3       # repeated but could be different coefficient
        
        base += quartic_terms
    
    return base
