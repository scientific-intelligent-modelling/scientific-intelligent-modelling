def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Adds higher-order nonlinear cross terms (quartic order) to better capture
    complex nonlinear dynamics in the oscillator.

    Physical reasoning:
    - The acceleration depends on restoring force (linear and nonlinear stiffness),
      damping force (linear and nonlinear velocity dependence),
      and mixed higher-order terms representing coupling between position and velocity.
    - Including quartic terms allows modeling subtle effects like amplitude-dependent damping
      or stiffness beyond cubic nonlinearity.
    
    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of coefficients (length >= 12)
    
    Returns:
    - y: Acceleration at time t
    """
    p = params
    return (
        p[0]  # constant offset (usually zero)
        + p[1] * x0  # linear stiffness term (restoring force)
        + p[2] * x1  # linear damping term
        + p[3] * (x0 ** 2)  # quadratic stiffness nonlinearity
        + p[4] * (x1 ** 2)  # quadratic velocity nonlinearity (nonlinear damping)
        + p[5] * (x0 ** 3)  # cubic stiffness nonlinearity
        + p[6] * (x1 ** 3)  # cubic velocity nonlinearity
        + p[7] * (x0 * x1)  # cross term linear*velocity
        + p[8] * (x0 ** 2 * x1)  # mixed quadratic position & linear velocity
        + p[9] * (x0 * x1 ** 2)  # mixed linear position & quadratic velocity
        + p[10] * ((x0 ** 3) * x1)   # cubic position times linear velocity
        + p[11] * (x0 * (x1 ** 3))   # linear position times cubic velocity

        # Additional quartic order terms for richer dynamics:
        + params[12-12 if len(params)>12 else -1]*((x0**4)) if len(params)>12 else 0   # quartic stiffness nonlinearity, if param available

        + params[13-12 if len(params)>13 else -1]*((x1**4)) if len(params)>13 else 0   # quartic velocity nonlinearity

        + params[14-12 if len(params)>14 else -1]*(x0**3*x1**2) if len(params)>14 else 0   # mixed cubic position & quadratic velocity

        + params[15-12 if len(params)>15 else -1]*(x0**2*x1**3) if len(params)>15 else 0   # mixed quadratic position & cubic velocity

    )
