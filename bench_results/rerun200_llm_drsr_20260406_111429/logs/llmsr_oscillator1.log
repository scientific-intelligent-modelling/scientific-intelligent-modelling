def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Nonlinear harmonic oscillator acceleration model including:
    - constant offset term
    - linear, cubic, quintic position terms (restoring force + nonlinear stiffness)
    - linear, quadratic, cubic velocity terms (damping effects)
    - cross terms between position and velocity up to cubic order
    - additional higher order cross terms

    Parameters:
    - params: array-like with at least 12 elements

    Returns:
        y: acceleration values as np.ndarray
    """
    return (
        params[0] +                    # constant offset / bias term
        params[1] * x0 +               # linear restoring force
        params[2] * (x0 ** 3) +        # cubic stiffness nonlinearity (Duffing)
        params[3] * (x0 ** 5) +        # quintic stiffness nonlinearity
        params[4] * x1 +               # linear damping
        params[5] * (x1 ** 2) +        # quadratic velocity damping
        params[6] * (x1 ** 3) +        # cubic velocity damping
        params[7] * (x0 * x1) +        # cross term position*velocity
        params[8] * (x0 ** 2 * x1) +   # higher order cross term pos^2*vel
        params[9] * (x0 * x1 ** 2) +   # higher order cross term pos*vel^2
        params[10] * (x0 ** 3 * x1) +  # even higher order pos^3*vel term
        params[11] * (x0 * x1 ** 3)    # even higher order pos*vel^3 term
    )
