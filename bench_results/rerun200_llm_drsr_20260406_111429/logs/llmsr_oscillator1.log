        + p[7] * np.power(x1, 3)
        + p[8] * np.power(x0, 2) * x1
        + p[9] * x0 * np.power(x1, 2)
        # Optionally include remaining params as higher order or interaction terms if needed.
        # For now ignore params[10], params[11]
    )
