def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    This version incorporates physically meaningful nonlinear terms commonly found in 
    nonlinear oscillators, including polynomial and trigonometric terms representing 
    restoring forces, damping (linear and nonlinear), and coupling between position 
    and velocity.

    Parameters:
    - params (np.ndarray): Array of 12 trainable coefficients.

    Returns:
    - y (np.ndarray): Calculated acceleration.
    """
    
    p = params
    
    return (
        p[0]                               # constant offset (usually zero)
        + p[1] * x0                       # linear restoring force (-k*x)
        + p[2] * x1                       # linear damping (-c*v)
        + p[3] * x0**2                   # quadratic stiffness nonlinearity
        + p[4] * x1**2                   # quadratic velocity nonlinearity (nonlinear damping)
        + p[5] * x0 * x1                 # cross term coupling position and velocity
        + p[6] * x0**3                   # cubic stiffness nonlinearity
        + p[7] * x1**3                   # cubic velocity nonlinearity (nonlinear damping)
        + p[8] * (x0**2) * x1            # higher order coupling term
        + p[9] * x0 * (x1**2)            # another higher order coupling term
        + p[10] * np.sin(x0)             # pendulum-like restoring force component
        + p[11] * np.exp(-x1**2)         # velocity-dependent nonlinear damping saturation
    )
