def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical interpretation:
    Acceleration in a nonlinear harmonic oscillator with:
    - linear and higher-order stiffness terms,
    - linear, quadratic, cubic, quartic, quintic damping,
    - sinusoidal forcing and mixed trigonometric coupling,
    - nonlinear velocity-dependent damping proportional to |x1|*x1,
    - mixed polynomial-trigonometric coupling terms,
    - parametric excitation terms (e.g., sin(ω t) replaced by sin(k*x0), cos(k*x1)),
    - cross-coupling between position and velocity powers.

    params mapping (length >= 20):
      0: linear restoring force coefficient (-x0)
      1: cubic restoring force coefficient (-x0^3)
      2: linear damping coefficient (-x1)
      3: cubic damping coefficient (-x1^3)
      4: sinusoidal restoring/forcing term sin(x0)
      5: velocity-dependent forcing cos(x1)
      6: mixed nonlinear term (x0^2)*x1
      7: mixed nonlinear term x0*(x1^2)
      8: quartic stiffness nonlinearity (x0^4)
      9: quartic damping nonlinearity (x1^4)
     10: mixed sinusoidal term sin(x0*x1)
     11: mixed sinusoidal term cos(x0*x1)
     12: quadratic velocity damping term proportional to x1 * |x1|
     13: quintic stiffness nonlinearity (x0^5)
     14: quintic damping nonlinearity (x1^5)

     Additional new terms:
     15: parametric forcing sin(2 * x0 * x1) 
     16: parametric forcing cos(2 * x0 * x1) 
     17: cross polynomial-trig term sin(x0) * x1**2
     18: cross polynomial-trig term cos(x0) * x1**3
     19: higher order mixed polynomial term (x0**3)*(x1**2)

    Note:
        If fewer than 20 parameters are provided, the extra terms default to zero.

    Returns:
        np.ndarray : acceleration values computed from the nonlinear oscillator model.
    """
    
    # Safely handle extra parameters if provided
    p = np.zeros(20)
    length = min(len(params), 20)
    p[:length] = params[:length]

    y = (
        # Restoring forces
        -p[0] * x0 
        -p[1] * x0 ** 3 
        + p[8] * x0 **4 \
        - p[13] * x0 **5

        # Damping forces
        -p[2] * x1 
        -p[3] * x1 **3 
        + p[9] * x1 **4 \
        - p[14] * x1 **5 \
        - p[12] * np.abs(x1) * x1

        # Sinusoidal forcing / restoring effects
        +p[4] * np.sin(x0) 
        +p[5] * np.cos(x1) 

        # Mixed trigonometric coupling
        +p[10]*np.sin(x0*x1) 
        +p[11]*np.cos(x0*x1)

        # Nonlinear coupling between position and velocity powers
        +p[6]*(x0**2)*x1 
        +p[7]*x0*(x1**2)

        # Additional parametric forcing / interaction terms
        +p[15]*np.sin(2*x0*x1) 
        +p[16]*np.cos(2*x0*x1)

        # Cross polynomial-trig interaction terms involving velocity powers
        +p[17]*np.sin(x0)*(x1**2) 
        +p[18]*np.cos(x0)*(x1**3)

         # Higher order mixed polynomial coupling between position and velocity powers
         +p[19]*(x0**3)*(x1**2)
        
    )
    
    return y
