def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Extends the model by including additional mixed nonlinearities,
    velocity-dependent damping terms (including sign/absolute value),
    and higher-order coupling terms to better capture complex oscillator dynamics.

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length at least 12.

    Returns:
        Acceleration y as a function of position x0 and velocity x1.
    """
    # To keep parameter indexing consistent with MAX_NPARAMS=12,
    # we reuse params[0]..params[11] but redefine their roles slightly.
    
    # Extract parameters for clarity
    c0 = params[0]   # constant offset
    c1 = params[1]   # linear stiffness (position)
    c2 = params[2]   # linear damping (velocity)
    
    c3 = params[3]   # quadratic stiffness term (x0^2)
    c4 = params[4]   # quadratic damping term (x1^2)
    
    c5 = params[5]   # cubic stiffness term (x0^3)
    c6 = params[6]   # cubic damping term (x1^3)
    
    c7 = params[7]   # cross term linear*linear (x0*x1)
    
    c8 = params[8]   # mixed cubic term (x0^2 * x1)
    
    c9 = params[9]   # mixed cubic term (x0 * x1^2)
    
    c10 = params[10]  # quartic stiffness term (x0^4)
    
    c11 = params[11]  # quartic velocity effect or nonlinear damping (x1^4)

    abs_x1 = np.abs(x1)

    return (
        c0
        + c1 * x0
        + c2 * x1
        + c3 * x0**2
        + c4 * x1**2
        + c5 * x0**3
        + c6 * x1**3
        + c7 * x0 * x1
        + c8 * x0**2 * x1
        + c9 * x0 * x1**2
        + c10 * x0**4
        + c11 * abs_x1 * x1  # nonlinear damping proportional to |v|*v, common in fluid drag etc.
    )
