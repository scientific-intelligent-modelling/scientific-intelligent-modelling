def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration as a nonlinear function of position (x0) and velocity (x1),
    including cross terms to capture coupling effects between position and velocity.

    a = p0 
        + p1*x0 
        + p2*x1 
        + p3*x0**2 
        + p4*x1**2 
        + p5*x0**3 
        + p6*x1**3
        + p7*x0*x1
        + p8*(x0**2)*x1
        + p9*x0*(x1**2)
        + p10*np.sin(x0)
        + p11*np.cos(x1)

    This form captures:
    - linear and nonlinear restoring forces (powers of x0)
    - linear and nonlinear damping (powers of x1)
    - interaction terms between position and velocity
    - possible periodic nonlinearities via sine and cosine terms

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 12.
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 ** 2
        + params[4] * x1 ** 2
        + params[5] * x0 ** 3
        + params[6] * x1 ** 3
        + params[7] * x0 * x1
        + params[8] * (x0 ** 2) * x1
        + params[9] * x0 * (x1 ** 2)
        + params[10] * np.sin(x0)
        + params[11] * np.cos(x1)
    )
