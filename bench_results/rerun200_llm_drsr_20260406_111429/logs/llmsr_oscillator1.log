    # Base polynomial terms (up to quartic)
    base = (
        params[0]                      # constant term
        + params[1] * x0              # linear stiffness term
        + params[2] * x1              # linear damping term
        + params[3] * (x0 ** 2)       # quadratic stiffness nonlinearity
        + params[4] * (x1 ** 2)       # quadratic damping nonlinearity
        + params[5] * (x0 ** 3)       # cubic stiffness nonlinearity
        + params[6] * (x1 ** 3)       # cubic damping nonlinearity
        + params[7] * (x0 * x1)       # coupling linear term
        + params[8] * (x0 ** 2 * x1)  # mixed quadratic-cubic term
