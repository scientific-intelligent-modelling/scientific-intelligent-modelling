def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Includes linear, quadratic, and cubic terms of position (x0) and velocity (x1)
    to capture nonlinear restoring force and damping effects.
    
    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients
    
    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    # Unpack parameters for clarity
    p = params
    
    # Construct polynomial terms up to cubic order
    y = (
        p[0] +                # constant term
        p[1] * x0 +           # linear position term
        p[2] * x1 +           # linear velocity term
        p[3] * x0**2 +        # quadratic position term
        p[4] * x1**2 +        # quadratic velocity term
        p[5] * x0 * x1 +      # cross term position*velocity
        p[6] * x0**3 +        # cubic position term (nonlinear restoring force)
        p[7] * x1**3 +        # cubic velocity term (nonlinear damping)
        p[8] * (x0**2) * x1 + # mixed nonlinear term
        p[9] * x0 * (x1**2)   # another mixed nonlinear term
    )
    
    return y
