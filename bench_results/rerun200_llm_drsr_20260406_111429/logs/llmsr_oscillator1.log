def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration y as a nonlinear function of position (x0) and velocity (x1),
    including odd-powered restoring forces (linear, cubic, quintic),
    linear and nonlinear damping with sign-preserving fractional powers,
    and cross terms capturing coupling effects.

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of coefficients [p0 ... p11] for each term

    Returns:
    - y: Acceleration at time t
    """
    
    def signed_power(v, power):
        return np.sign(v) * (np.abs(v) ** power)
    
    p = params
    
    y = (
        p[0] * x0                      # linear restoring force
        + p[1] * (x0 ** 3)            # cubic stiffness nonlinearity (Duffing)
        + p[2] * (x0 ** 5)            # quintic stiffness nonlinearity
        + p[3] * x1                   # linear damping
        + p[4] * signed_power(x1, 2)  # quadratic velocity damping with sign preservation
        + p[5] * signed_power(x1, 3)  # cubic velocity damping with sign preservation
        + p[6] * (x0 * x1)            # cross term position*velocity
        + p[7] * (x0 ** 2 * x1)       # higher order cross term
        + p[8] * (x0 * x1 ** 2)       # another higher order cross term
        + p[9] * signed_power(x1, 4/3)# fractional power nonlinear damping term for flexibility
        + p[10]* signed_power(x1, 5/3)# additional fractional power nonlinear damping term 
        + p[11]* signed_power(x1, 7/3)# higher order fractional power nonlinear damping term 
    )
    
    return y
