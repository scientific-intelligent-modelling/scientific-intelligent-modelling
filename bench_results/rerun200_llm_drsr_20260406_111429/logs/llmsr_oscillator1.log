def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Background:
    Calculate Acceleration in Nonlinear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0 (position), x1 (velocity)
    - Dependent: y (acceleration)

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.

    Model structure includes:
        - constant offset
        - linear restoring force and damping
        - quadratic, cubic, quartic stiffness/damping nonlinearities
        - cross-terms coupling position and velocity nonlinearities
        - sinusoidal potential term to model pendulum-like effects
        - cosine term for additional periodic forcing effects
        - higher order mixed terms to capture complex interactions
    """
    
    p = params
    
    return (
          p[0]                               # constant offset / bias acceleration
        + p[1] * x0                         # linear restoring force ~ position
        + p[2] * x1                         # linear damping ~ velocity
        
        + p[3] * x0**2                     # quadratic stiffness nonlinearity (softening/hardening)
        + p[4] * x1**2                     # quadratic damping nonlinearity
        
        + p[5] * x0 * x1                   # bilinear coupling term
        
        + p[6] * x0**3                     # cubic stiffness nonlinearity
        + p[7] * x1**3                     # cubic damping nonlinearity
        
        + p[8] * (x0**2) * x1              # cross-term nonlinear coupling 1
        
        + p[9] * x0 * (x1**2)              # cross-term nonlinear coupling 2
        
        + p[10] * np.sin(x0)               # sinusoidal potential effect (e.g., pendulum-like)
        
        + p[11] * np.power(x0, 4)          # quartic stiffness nonlinearity for stronger anharmonicity
        
        # Note: cosine term from v1 replaced by quartic term here to keep param count fixed.
    )
