def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration as a polynomial function of position (x0) and velocity (x1),
    including nonlinear terms typical for a nonlinear harmonic oscillator,
    plus oscillatory nonlinearities from sine and cosine functions,
    and additional mixed trigonometric-polynomial terms to capture complex dynamics.

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of parameters [p0, p1, ..., p11] representing coefficients for each term

    Returns:
    - y: Acceleration at time t
    """

    p = params

    # Constant term (could represent external constant forcing)
    y = p[0]

    # Linear terms (stiffness and damping)
    y += p[1] * x0       # linear stiffness ~ position restoring force
    y += p[2] * x1       # linear damping ~ velocity dependent dissipation

    # Quadratic terms capturing basic nonlinearities and coupling effects
    y += p[3] * x0**2
    y += p[4] * x0 * x1
    y += p[5] * x1**2

    
    # Cubic terms for stronger nonlinear effects in stiffness/damping/coupling
    y += p[6] * x0**3           # cubic stiffness nonlinearity
    y += p[7] * (x0**2) * x1   # mixed cubic term position^2*velocity (nonlinear damping)
    y += p[8] * x0 * (x1**2)   # mixed cubic term position*velocity^2 
    y += p[9] * x1**3           # cubic velocity nonlinearity (nonlinear damping)

    
    # Additional higher order cross terms capturing more complex interactions:
    
    y += p[10] * np.sin(x0)     # nonlinear oscillatory restoring force component from position
    
    y += p[11] * np.cos(x1)     # nonlinear oscillatory damping or forcing component from velocity
