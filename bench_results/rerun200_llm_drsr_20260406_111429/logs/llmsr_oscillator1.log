def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration y as a nonlinear function of position (x0) and velocity (x1),
    including polynomial nonlinearities up to cubic order and nonlinear damping terms,
    reflecting physical principles of a nonlinear harmonic oscillator with velocity-dependent damping.

    Physical reasoning:
    - Restoring force expanded as polynomial in position (including cubic stiffness).
    - Damping includes linear and nonlinear velocity dependence.
    - Cross terms model coupling between position and velocity.
    - Nonlinear damping term proportional to v*|v| to capture quadratic velocity effects.

    Parameters:
    - params (np.ndarray): array of parameters with length >= 12

    Returns:
    - y (np.ndarray): computed acceleration values
    """
    
    abs_x1 = np.abs(x1)
    
    return (
        params[0] +                      # constant offset term
        params[1] * x0 +                # linear restoring force term ~ position
        params[2] * x1 +                # linear damping term ~ velocity
        params[3] * x0**2 +             # quadratic stiffness nonlinearity
        params[4] * x1**2 +             # quadratic velocity effect (nonlinear damping)
        params[5] * x0**3 +             # cubic stiffness nonlinearity
        params[6] * x1**3 +             # cubic velocity effect (nonlinear damping)
        params[7] * x0 * x1 +           # cross term coupling position and velocity linearly
        params[8] * (x0**2) * x1 +      # mixed higher order coupling term
        params[9] * x0 * (x1**2) +      # another mixed higher order coupling term
        params[10] * (x0**3) * x1 +     # cubic position with linear velocity cross-term
        params[11] * abs_x1 * x1         # nonlinear damping ~ v*|v|
    )
