    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Calculates acceleration for a nonlinear harmonic oscillator given position (x0)
    and velocity (x1), using polynomial terms up to quartic order with trainable parameters,
    including sign-dependent dry friction term.

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of coefficients (length == 12)

    Returns:
    - y: Acceleration at time t
    """
    
    return (
        params[0]  # constant offset term
        + params[1] * x0  # linear stiffness (-k*x)
        + params[2] * x1  # linear damping (-c*v)
        + params[3] * x0**2  # quadratic stiffness nonlinearity
        + params[4] * x1**2  # quadratic velocity nonlinearity (nonlinear damping)
        + params[5] * x0 * x1  # cross term between position and velocity
        + params[6] * x0**3  # cubic stiffness nonlinearity
        + params[7] * x1**3  # cubic velocity nonlinearity (nonlinear damping)
        + params[8] * x0**4  # quartic stiffness nonlinearity (higher order)
        + params[9] * (x0**2) * x1  # mixed quadratic position & linear velocity term
        + params[10] * x0 * (x1**2)  # mixed linear position & quadratic velocity term
        + params[11] * np.sign(x1)   # sign-dependent dry friction effect
    )
