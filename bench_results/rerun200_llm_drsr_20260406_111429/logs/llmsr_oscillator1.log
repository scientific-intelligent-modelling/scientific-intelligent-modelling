def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical interpretation:
    Acceleration in a nonlinear harmonic oscillator with:
    - Linear and cubic stiffness (restoring force)
    - Linear and cubic damping
    - Higher order polynomial stiffness/damping terms (quartic)
    - Sinusoidal forcing terms depending on position and velocity
    - Mixed nonlinear coupling terms (polynomial and trigonometric)
    
    Parameters:
        params (np.ndarray): Array of 12 trainable coefficients.

    Returns:
        y (np.ndarray): Calculated acceleration.
    """
    
    # Linear restoring force and damping
    linear_restoring = -params[0] * x0
    linear_damping = -params[2] * x1
    
    # Cubic stiffness and damping nonlinearities
    cubic_stiffness = -params[1] * x0 ** 3
    cubic_damping = -params[3] * x1 ** 3
    
    # Sinusoidal forcing components depending on position and velocity
    sin_pos = params[4] * np.sin(x0)
    cos_vel = params[5] * np.cos(x1)
    
    # Mixed polynomial coupling terms between position and velocity
    mixed_poly_1 = params[6] * (x0 ** 2) * x1
    mixed_poly_2 = params[7] * x0 * (x1 ** 2)
    
    # Higher order polynomial stiffness/damping terms (quartic)
    quartic_stiffness = params[8] * x0 ** 4
    quartic_damping = params[9] * x1 ** 4
    
    # Nonlinear mixed sinusoidal coupling terms between position and velocity
    sin_mixed = params[10] * np.sin(x0 * x1)
    
    cos_mixed = params[11] * np.cos(x0 * x1)

    
    y = (
        linear_restoring 
        + cubic_stiffness 
        + linear_damping 
        + cubic_damping 
        + sin_pos 
        + cos_vel 
        + mixed_poly_1 
        + mixed_poly_2 
        + quartic_stiffness 
        + quartic_damping 
        + sin_mixed 
        + cos_mixed
     )
    
    return y
