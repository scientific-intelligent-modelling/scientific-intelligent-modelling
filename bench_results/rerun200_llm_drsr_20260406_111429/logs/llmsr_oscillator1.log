def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration y as a nonlinear function of position (x0) and velocity (x1),
    including linear, quadratic, cubic, cross terms, and nonlinear damping effects.

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of coefficients [p0 ... p11] for each term

    Returns:
    - y: Acceleration at time t
    """
    p = params

    # Terms:
    # p[0]: constant offset
    # p[1]*x0 + p[2]*x1 : linear restoring force and linear damping
    # p[3]*x0^2 + p[4]*x1^2 + p[5]*x0*x1 : quadratic nonlinearities and coupling
    # p[6]*x0^3 + p[7]*x1^3 + p[8]*(x0^2)*x1 + p[9]*x0*(x1^2) : cubic nonlinearities including mixed terms
    # p[10]*(sign(x1)*|x1|^2) : nonlinear damping term proportional to velocity squared with sign preserving directionality
    # p[11]*(sign(x1)*|x1|^3) : higher order nonlinear damping term

    # To implement sign-preserving powers for velocity-based damping:
    
    def signed_power(v, power):
        return np.sign(v) * (np.abs(v)**power)

    y = (
        p[0]
        + p[1] * x0
        + p[2] * x1
        + p[3] * x0**2
        + p[4] * x1**2
        + p[5] * x0 * x1
        + p[6] * x0**3
        + p[7] * signed_power(x1, 3)
        + p[8] * (x0**2) * x1
        + p[9] * x0 * (x1**2)
        + p[10] * signed_power(x1, 2)
        + p[11] * signed_power(x1, 4/3)  # fractional power for more flexible nonlinearity; can be adjusted if needed.
    )

    return y
