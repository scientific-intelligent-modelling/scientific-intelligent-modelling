def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Includes linear, nonlinear (quadratic & cubic), cross terms between position and velocity,
    trigonometric nonlinearities reflecting pendulum-like restoring forces,
    and fractional power damping-like nonlinearities in velocity.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Coefficients array with 12 elements

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    return (
        params[0]  # constant term
        + params[1] * x0  # linear position term (restoring force)
        + params[2] * x1  # linear velocity term (damping)
        + params[3] * (x0 ** 2)  # quadratic position nonlinearity
        + params[4] * (x1 ** 2)  # quadratic velocity nonlinearity
        + params[5] * (x0 ** 3)  # cubic position nonlinearity
        + params[6] * (x1 ** 3)  # cubic velocity nonlinearity
        + params[7] * (x0 * x1)  # cross term linear*linear
        + params[8] * (x0 ** 2 * x1)  # cross term quadratic*linear
        + params[9] * (x0 * x1 ** 2)  # cross term linear*quadratic
        + params[10] * np.sin(x0)   # trigonometric nonlinearity from position 
        + params[11] * np.sign(x1) * np.abs(x1)**(3/2)   # fractional power damping-like nonlinearity in velocity 
    )
