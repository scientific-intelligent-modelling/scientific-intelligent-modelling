def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Models acceleration y as a polynomial function of position (x0) and velocity (x1),
    including linear, quadratic, cubic, and cross terms to capture nonlinear effects.

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of coefficients [p0 ... p11] for each term

    Returns:
    - y: Acceleration at time t
    """
    # Unpack parameters for clarity
    p = params

    # Construct polynomial terms:
    # p[0]: constant term
    # p[1]*x0 + p[2]*x1 : linear terms
    # p[3]*x0^2 + p[4]*x1^2 + p[5]*x0*x1 : quadratic terms
    # p[6]*x0^3 + p[7]*x1^3 + p[8]*(x0^2)*x1 + p[9]*x0*(x1^2) : cubic terms
    # Additional cross or higher order if needed:
    # For completeness up to 12 params:
    # p[10]*(some 4th order or mixed term), p[11]*(another mixed term)

    y = (
        p[0]
        + p[1] * x0
        + p[2] * x1
        + p[3] * x0**2
        + p[4] * x1**2
        + p[5] * x0 * x1
        + p[6] * x0**3
        + p[7] * x1**3
        + p[8] * (x0**2) * x1
        + p[9] * x0 * (x1**2)
        + p[10] * (x0**4 if hasattr(x0, "__pow__") else 0)
        + p[11] * (x1**4 if hasattr(x1, "__pow__") else 0)
    )
    
    return y
