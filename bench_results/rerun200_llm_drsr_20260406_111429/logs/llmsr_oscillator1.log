def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical interpretation:
    Acceleration in a nonlinear harmonic oscillator with:
      - linear and cubic stiffness restoring forces,
      - linear and cubic damping,
      - quartic stiffness and damping nonlinearities,
      - quadratic and cubic cross coupling between position and velocity,
      - sinusoidal forcing terms depending on position, velocity, and their product,
      - cosine forcing depending on velocity and product of position & velocity,
      - higher order mixed polynomial-sinusoidal interaction terms.

    Functional form:

        y = 
          - params[0] * x0                     # linear restoring force (Hooke's law)
          - params[1] * x0**3                  # cubic stiffness nonlinearity
          - params[2] * x1                     # linear damping
          - params[3] * x1**3                  # cubic damping nonlinearity
          + params[4] * np.sin(x0)             # sinusoidal potential forcing (position)
          + params[5] * np.cos(x1)             # velocity-dependent periodic forcing
          + params[6] * (x0**2)*x1             # quadratic position times velocity coupling
          + params[7] * x0*(x1**2)             # position times quadratic velocity coupling
          + params[8] * (x0**4)                 # quartic stiffness nonlinearity
          + params[9] * (x1**4)                 # quartic damping nonlinearity
          + params[10]*np.sin(x0*x1)            # mixed sinusoidal term capturing interaction effects
          + params[11]*np.cos(x0*x1)            # complementary mixed cosine term for asymmetry

        + additional new terms:
          + params[12]*x0**3*x1                 # cubic position times velocity cross term
          + params[13]*x0*x1**3                 # position times cubic velocity cross term
          + params[14]*np.sin(x1*x1)            # sinusoidal of squared velocity (nonlinear periodic damping)
          + params[15]*np.cos(x0+x1)             # cosine of sum capturing combined phase effects

    Parameters:
    - x0: Position at time t (np.ndarray)
    - x1: Velocity at time t (np.ndarray)
    - params: Trainable coefficients array of length 16

    Returns:
    - y: Acceleration at time t (np.ndarray)
    """
    
    return (
        -params[0] * x0 
        -params[1] * x0 ** 3 
        -params[2] * x1 
        -params[3] * x1 ** 3 
        +params[4] * np.sin(x0)
        +params[5] * np.cos(x1)
        +params[6] * (x0 ** 2)*x1 
        +params[7] * x0*(x1 ** 2)
        +params[8] * (x0 ** 4)
        +params[9] * (x1 ** 4)
        +params[10]*np.sin(x0*x1)
        +params[11]*np.cos(x0*x1)

        +params[12]*(x0 ** 3)*x1
        +params[13]*x0*(x1 ** 3)

        +params[14]*np.sin(x1**2)
        +params[15]*np.cos(x0+x1)
    )
