def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator as a polynomial function of position (x0)
    and velocity (x1), including linear, nonlinear, and cross terms up to cubic order.

    Parameters:
    - x0 (np.ndarray): Position at time t.
    - x1 (np.ndarray): Velocity at time t.
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length at least 12.

    Returns:
    - y (np.ndarray): Calculated acceleration.

    Physical motivation:
    The acceleration in a nonlinear oscillator typically depends on restoring forces proportional to position,
    damping proportional to velocity, and nonlinear corrections such as cubic stiffness or velocity-dependent terms.

    This model includes:
      - constant offset
      - linear terms in position and velocity
      - quadratic terms in position and velocity
      - cubic terms in position and velocity
      - cross terms between position and velocity up to quadratic order
      - mixed cubic term x0^2 * x1 for richer nonlinear coupling
      - smooth approximations of sign(velocity) and abs(position) for better numerical behavior
    """
    
    # Smooth approximation parameters
    epsilon = 1e-4
    
    # Smooth sign approximation: tanh scaled by large factor ~ sign(x)
