def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Adds nonlinear damping with absolute value velocity dependence,
    higher order cross terms, and mixed trig-polynomial terms.

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 15.

      params mapping:
      0: constant term
      1: linear in position (x0)
      2: linear in velocity (x1)
      3: quadratic in position (x0^2)
      4: quadratic in velocity (x1^2)
      5: cross term x0 * x1
      6: cubic in position (x0^3)
      7: cubic in velocity (x1^3)
      8: cross term x0^2 * x1
      9: cross term x0 * x1^2
     10: sin(x0) nonlinear restoring force
     11: cos(x1) nonlinear velocity modulation
     12: nonlinear damping proportional to |x1|*x1
     13: sin(x0)*x1 coupling term (velocity modulated by position nonlinearity)
     14: cos(x0)*x1^2 coupling term

    Returns:
        np.ndarray : acceleration values computed from the nonlinear oscillator model.
    """
    y = (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 ** 2
        + params[4] * x1 ** 2
        + params[5] * x0 * x1
        + params[6] * x0 ** 3
        + params[7] * x1 ** 3
        + params[8] * (x0 ** 2) * x1
        + params[9] * x0 * (x1 ** 2)
        + params[10] * np.sin(x0)
        + params[11] * np.cos(x1)
        + params[12] * np.abs(x1) * x1           # nonlinear damping with drag/friction effect 
        + params[13] * np.sin(x0) * x1           # coupling between position nonlinearity and velocity 
        + params[14] * np.cos(x0) * (x1 ** 2)    # another mixed trig-polynomial coupling term 
    )
    
    return y
