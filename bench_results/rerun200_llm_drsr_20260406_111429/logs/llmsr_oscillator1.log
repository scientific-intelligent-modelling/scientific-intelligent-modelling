    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Nonlinear harmonic oscillator acceleration model including:
    - Linear restoring force (-k * x0)
    - Linear damping (-c * x1)
    - Cubic stiffness (Duffing term)
    - Nonlinear damping and mixed polynomial terms

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of 12 coefficients [p0 ... p11]

    Returns:
    - y: Acceleration at time t
    """
    
    p = params
    
    # Constant offset term (could represent external forcing)
    constant = p[0]
    
    # Linear terms
    linear_pos = p[1] * x0          # typically negative for restoring force
    linear_vel = p[2] * x1          # typically negative for damping
    
    # Quadratic terms
    quad_pos = p[3] * (x0 ** 2)
    quad_vel = p[4] * (x1 ** 2)
    quad_cross = p[5] * (x0 * x1)
    
    # Cubic terms
    cubic_pos = p[6] * (x0 ** 3)       # Duffing nonlinearity
    cubic_vel = p[7] * (x1 ** 3)       # nonlinear damping or forcing in velocity
    
    cubic_mixed1 = p[8] * ((x0 ** 2) * x1)
    cubic_mixed2 = p[9] * (x0 * (x1 ** 2))
    
    # Quartic or higher order mixed terms to capture subtle nonlinearities
    quartic_pos = p[10] * (x0 ** 4)
    
    quartic_vel = p[11] * (x1 ** 4)

    
    y = (
        constant 
        + linear_pos 
        + linear_vel 
        + quad_pos 
        + quad_vel 
        + quad_cross 
        + cubic_pos 
        + cubic_vel 
        + cubic_mixed1 
        + cubic_mixed2 
        + quartic_pos 
        + quartic_vel
     )
