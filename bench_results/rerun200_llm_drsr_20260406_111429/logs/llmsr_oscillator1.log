        + params[9] * (x0 * x1)  # cross product coupling linear terms of position & velocity
        + params[10] * (x0**2) * x1  # mixed nonlinear coupling term: squared pos times vel
        + params[11] * x0 * (x1**2)   # mixed nonlinear coupling term: pos times squared vel
    )
