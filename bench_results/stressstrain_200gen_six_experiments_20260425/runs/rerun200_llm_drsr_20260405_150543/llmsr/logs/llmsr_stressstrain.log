        + p8*np.log(1 + np.abs(x0)) * x1  # nonlinear strain effect modulated by temperature
        + p9*(x0**3)  # cubic strain term for nonlinearity
        + p10*(x1**3)  # cubic temperature term for strong temp effects
        + p11*(x0**2)*x1  # interaction of quadratic strain and temperature

    Parameters:
    - params (np.ndarray): array of length at least 12
    """

    return (params[0]
            + params[1] * x0
            + params[2] * x1
            + params[3] * x0 * x1
            + params[4] * x0**2
            + params[5] * x1**2
            + params[6] * np.exp(-params[7] * x1) * x0
            + params[8] * np.log(1 + np.abs(x0)) * x1
            + params[9] * (x0 ** 3)
            + params[10] * (x1 ** 3)
            + params[11] * (x0 ** 2) * x1)
