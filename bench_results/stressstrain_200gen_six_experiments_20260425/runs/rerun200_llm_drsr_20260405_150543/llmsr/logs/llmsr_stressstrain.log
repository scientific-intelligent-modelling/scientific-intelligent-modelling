def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain linearly and nonlinearly.
    - Temperature affects the modulus and can induce thermal stress.
    - Include higher order nonlinear terms and combined exponential effects to capture complex temperature-strain interactions.
    - Add logarithmic or reciprocal terms to model softening/hardening effects at certain temperature ranges.

    Variables:
    - x0: Strain
    - x1: Temperature

    Parameters:
    - params: array of coefficients (length up to MAX_NPARAMS=12)

    Model form example:
        stress = p0
               + p1 * strain
               + p2 * temperature
               + p3 * strain * temperature
               + p4 * strain^2
               + p5 * temperature^2
               + p6 * strain^2 * temperature
               + p7 * strain * temperature^2
               + p8 * strain * exp(-p9*temperature)
               + p10 * log(1 + abs(temperature))  # smooth log term for temp effect
               + p11 / (1 + exp(-strain))         # sigmoid-like saturation effect in strain

    This skeleton captures linear, quadratic, interaction, exponential decay, logarithmic and saturation nonlinearities.
    """

    p = params

    # Clip or shift temperature to avoid domain errors in log and overflow in exp
    temp_clip = np.clip(x1, a_min=-1000, a_max=1000)

    # To avoid log(0), add small epsilon inside log argument
    eps = 1e-8

    # Compute terms step by step for clarity

    linear = p[0] + p[1]*x0 + p[2]*x1
    interaction = p[3]*x0*x1
    quad = p[4]*x0**2 + p[5]*x1**2
    higher_order_interactions = p[6]*(x0**2)*x1 + p[7]*x0*(x1**2)

    exp_decay = p[8] * x0 * np.exp(-p[9]*temp_clip)

    log_temp = p[10] * np.log(np.abs(temp_clip) + 1.0 + eps)  # shifted log to avoid issues

    sigmoid_strain = 1. / (1. + np.exp(-x0))

    saturation_effect = p[11] * sigmoid_strain

    y = (
        linear
        + interaction
        + quad
        + higher_order_interactions
        + exp_decay
        + log_temp
        + saturation_effect
       )

    return y
