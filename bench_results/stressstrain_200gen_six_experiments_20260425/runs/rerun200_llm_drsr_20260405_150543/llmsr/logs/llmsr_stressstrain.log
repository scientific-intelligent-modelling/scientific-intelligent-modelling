def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain and temperature with linear, nonlinear, and interaction terms.
    - Added logarithmic terms to capture slow variation or saturation effects.
    - Added reciprocal terms to model stiffening/softening at low strain/temperature.
    - Exponential decay terms model softening with increasing strain or temperature.

    Variables:
    - x0: Strain (assumed >= 0)
    - x1: Temperature (assumed > 0)

    Parameters:
    - params: array of coefficients (length up to MAX_NPARAMS=12)

    Model form example:
        stress = p0
               + p1 * strain
               + p2 * temperature
               + p3 * strain * temperature
               + p4 * strain^2
               + p5 * temperature^2
               + p6 * strain^2 * temperature
               + p7 * strain * temperature^2
               + p8 * strain^3
               + p9 * temperature^3
               + p10 * exp(-strain)
               + p11 * exp(-temperature)

             + p12 * log(1+strain)
             + p13 / (1+strain)
             + p14 * log(1+temperature)
             + p15 / (1+temperature)

    Note: This requires params length >= 16. If fewer parameters are available,
          omit the last four terms accordingly.
    """

    # To avoid index errors, check length of params and set missing parameters to zero.
    # This allows flexible use with fewer parameters if needed.

    def safe_log(arr):
        return np.log(np.clip(arr, a_min=1e-8, a_max=None))

    # Unpack parameters safely with default zero if not provided
    def get_param(i):
        return params[i] if i < len(params) else 0.0

    p = [get_param(i) for i in range(16)]

    # Basic polynomial and interaction terms from v1:
    y = (
        p[0]
        + p[1]  * x0                      # linear strain
        + p[2]  * x1                      # linear temp
        + p[3]  * x0   * x1               # interaction term
        + p[4]  * x0**2                   # quadratic strain
        + p[5]  * x1**2                   # quadratic temp
        + p[6]  * (x0**2)   * x1          # quadratic strain times temp
        + p[7]  * x0       *(x1**2)       # strain times quadratic temp
        + p[8]  * x0**3                   # cubic strain
        + p[9]  * x1**3                   # cubic temp
        + p[10] * np.exp(-x0)             # exp decay w.r.t. strain
        + p[11] * np.exp(-x1)             # exp decay w.r.t. temp

      # Additional nonlinear/saturation/softening terms:
      )

    y += (
          p[12]  * safe_log(1+x0)         # log(1+strain), slow growth/saturation effect
          +p[13] / (1+x0)                 # reciprocal term for low-strain stiffening/softening

          +p[14]  * safe_log(1+x1)         # log(1+temp), slow growth/saturation effect
          +p[15] / (1+x1)                 # reciprocal term for low-temp stiffening/softening
      )

    return y
