def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Physical reasoning:
    - Stress often depends linearly on strain (Hooke's law) for small strains.
    - Temperature can affect the modulus of elasticity and cause thermal stress.
    - Interaction terms between strain and temperature can capture coupling effects.
    - Nonlinear terms may capture material nonlinearities or temperature effects.

    Variables:
    - x0: Strain
    - x1: Temperature

    Parameters:
    - params: array of coefficients (length up to MAX_NPARAMS=12)

    Model form (example):
        y = p0 + p1*x0 + p2*x1 + p3*x0*x1 + p4*x0^2 + p5*x1^2 + p6*exp(p7 * x1) * x0

    This includes linear, quadratic, interaction, and an exponential temperature effect modulating strain.
    """

    # Unpack parameters for clarity
    p = params
    # Linear terms
    linear = p[0] + p[1]*x0 + p[2]*x1

    # Interaction term
    interaction = p[3]*x0*x1

    # Quadratic terms
    quad = p[4]*x0**2 + p[5]*x1**2

    # Exponential temperature effect modulating strain (to capture e.g. thermal softening/hardening)
    exp_temp_effect = np.exp(p[7] * x1) * x0 * p[6]

    y = linear + interaction + quad + exp_temp_effect

    return y
