        y = p0
            + p1 * x0
            + p2 * x1
            + p3 * x0 * x1
            + p4 * x0**2
            + p5 * x1**2
            + p6 * x0**3
            + p7 * exp(-p8 * x1**2) * x0
            + p9 * log(1 + abs(x0))
