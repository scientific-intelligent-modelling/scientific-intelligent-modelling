def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retains all terms from equation_v1 capturing linear, nonlinear strain and temperature effects.
    - Adds a sigmoid term to model saturation effects in stress at high strains or temperatures.
    - Includes a temperature-dependent modulus modeled as a rational function to capture softening/hardening more flexibly.
    - Adds cross terms with higher powers to capture complex coupling.

    Model form:
    y = p0
        + p1 * x0
        + p2 * x1
        + p3 * x0 * x1
        + p4 * x0**2
        + p5 * x1**2
        + p6 * x0**3
        + p7 * exp(-p8 * x1) * x0
        + p9 * log(1 + abs(x0))
        + p10 * (x0**2) * x1
        + p11 * ( 1 / (1 + exp(-p12*(x0 - p13))) )  # sigmoid saturation on strain

    where
    Note: params length should be at least 14 for this model.

    Variables:
    - x0 = Strain
    - x1 = Temperature
    - y = Stress
    """

    # Clip temperature to avoid overflow in exp(-p8*x1)
    temp_clip = np.clip(x1, 0, 1000)  # assuming physical range

    # Compute log safely; add small epsilon inside log argument to avoid log(0)
    eps = 1e-8
    log_term = np.log(1 + np.abs(x0) + eps)

    # Sigmoid term parameters (ensure params has enough length)
    # If params length <14, fallback to zero sigmoid effect
    if len(params) >= 14:
        sigmoid_p11 = params[11]
        sigmoid_p12 = params[12]
        sigmoid_p13 = params[13]

        sigmoid_term = sigmoid_p11 / (1.0 + np.exp(-sigmoid_p12*(x0 - sigmoid_p13)))
    else:
        sigmoid_term = 0.0


    return (params[0]
            + params[1] * x0
            + params[2] * temp_clip
            + params[3] * x0 * temp_clip
            + params[4] * x0**2
            + params[5] * temp_clip**2
            + params[6] * x0**3
            + params[7] * np.exp(-params[8] * temp_clip) * x0
            + params[9] * log_term
            + params[10] * (x0**2) * temp_clip
            + sigmoid_term)
