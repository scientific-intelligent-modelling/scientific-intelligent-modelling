def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Physical reasoning:
    - Stress generally depends linearly on strain (Hooke's law) for small strains.
    - Temperature affects material properties, often reducing stiffness as temperature increases.
    - Interaction terms between strain and temperature can capture temperature-dependent modulus changes.
    - Nonlinear terms can capture some nonlinear elastic or plastic behavior.

    Variables:
    - x0: Strain
    - x1: Temperature

    Parameters:
    - params: array of coefficients (length up to MAX_NPARAMS=12)

    Model form (example):
        stress = p0
               + p1 * strain
               + p2 * temperature
               + p3 * strain * temperature
               + p4 * strain^2
               + p5 * temperature^2
               + p6 * strain^2 * temperature
               + p7 * strain * temperature^2
               + p8 * strain^3
               + p9 * temperature^3
               + p10 * exp(-strain)
               + p11 * exp(-temperature)

    This skeleton allows capturing linear, nonlinear, and interaction effects.
    """

    # Unpack parameters for clarity (optional)
    p = params

    term_linear_strain = p[1] * x0
    term_linear_temp = p[2] * x1

    term_interaction = p[3] * x0 * x1

    term_quad_strain = p[4] * x0**2
    term_quad_temp = p[5] * x1**2

    term_quad_strain_temp = p[6] * (x0**2) * x1
    term_quad_temp_strain = p[7] * x0 * (x1**2)

    term_cubic_strain = p[8] * x0**3
    term_cubic_temp = p[9]  * x1**3

    # To avoid overflow in exp, clip inputs if necessary or use safe exponentials.

    term_exp_neg_strain = p[10]  * np.exp(-x0)

    term_exp_neg_temp   = p[11]  * np.exp(-x1)

    y = (
        p[0]
        + term_linear_strain
        + term_linear_temp
        + term_interaction
        + term_quad_strain
        + term_quad_temp
        + term_quad_strain_temp
        + term_quad_temp_strain
        + term_cubic_strain
        + term_cubic_temp
        + term_exp_neg_strain
        + term_exp_neg_temp
     )

    return y
