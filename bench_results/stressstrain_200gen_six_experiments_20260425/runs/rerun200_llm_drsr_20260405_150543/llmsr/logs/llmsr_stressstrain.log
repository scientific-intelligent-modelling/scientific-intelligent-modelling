def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retain all terms from v1 to capture linear, nonlinear, and interaction effects.
    - Add strain-rate-like effect by including a term with strain derivative (if available).
      Since only x0 and x1 are given, approximate strain-rate effect by including a fractional power of strain.
    - Include temperature-dependent stiffness modeled as a rational function to capture saturation effects.
    - Add cross terms involving powers of strain and inverse temperature to model complex thermal softening.
    - Include an additional hyperbolic sine term for asymmetric response in strain-temperature coupling.

    Model structure (using up to 24 parameters):
        y = p0
            + p1 * x0                          # linear strain
            + p2 * x1                          # linear temperature
            + p3 * x0 * x1                    # interaction term
            + p4 * x0**2                      # quadratic strain
            + p5 * x1**2                      # quadratic temperature
            + p6 * exp(-p7 * x1) * x0         # exp decay with temp modulated by strain (softening)
            + p8 * x0**3                      # cubic strain nonlinearity
            + p9 / (x1 + eps)                 # inverse temperature effect
            + p10 * log(x1.clip(min=eps))     # logarithmic temp effect
            + p11 * x0**4                     # quartic strain term for higher order nonlinearity
            + p12 * exp(-p13*x1) * (x0**2)   # exp decay modulated by quadratic strain
            + p14 / ((x1+eps)**2)             # inverse temperature squared effect (stronger softening)
            + p15 * (log(x1.clip(min=eps)))**2  # log(temp)^2 effect for moderate temp influence
            + p16 * tanh(p17*x0*x1)           # saturation effect of strain-temperature product

            + p18 * np.power(np.abs(x0), 2.5)  # fractional power capturing nonlinear elasticity

            + (p19 + p20*x0)/(p21 + x1+eps)   # rational function modeling temp-dependent stiffness

            + p22*(x0**2)/(safe_x1**3)         # cross term with higher inverse temp power

            + p23*np.sinh(p17*x0*x1)           # hyperbolic sine for asymmetric coupling

    Parameters:
        params: array-like with length >= 24

    Notes:
        eps is a small number to avoid division by zero or log(0).
        If fewer than 24 parameters are provided, missing terms default to zero.
    """

    eps = 1e-6

    def get_param(i):
        return params[i] if i < len(params) else 0.0

    safe_x1 = x1.clip(min=eps)

    y = (
        get_param(0)
        + get_param(1)*x0
        + get_param(2)*x1
        + get_param(3)*x0*x1
        + get_param(4)*x0**2
        + get_param(5)*x1**2
        + get_param(6)*np.exp(-get_param(7)*x1)*x0
        + get_param(8)*x0**3
        + get_param(9)/safe_x1
        + get_param(10)*np.log(safe_x1)
        + get_param(11)*x0**4

        +

        get_param(12)*np.exp(-get_param(13)*x1)*(x0**2)

        +

        get_param(14)/(safe_x1**2)

        +

        get_param(15)*(np.log(safe_x1)**2)

        +

        get_param(16)*np.tanh(get_param(17)*x0*x1)

        +

        get_param(18)*(np.abs(x0)**2.5)

        +

       (get_param(19)+get_param(20)*x0)/(get_param(21)+safe_x1)

       +

       get_param(22)*(x0**2)/(safe_x1**3)

       +

       get_param(23)*np.sinh(get_param(17)*x0*x1)

    )

