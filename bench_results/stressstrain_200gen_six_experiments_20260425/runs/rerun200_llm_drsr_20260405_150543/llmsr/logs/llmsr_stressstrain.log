def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Polynomial terms up to cubic in strain and quadratic in temperature capture elastic and nonlinear elastic behavior.
    - Interaction terms between strain powers and temperature powers capture coupling effects.
    - Exponential decay term models thermal softening or activation-like behavior.
    - Inverse temperature and logarithmic temperature terms model thermal activation/softening effects.
    - Hyperbolic tangent models saturation/nonlinear strain response with trainable scaling.

    Variables:
        x0: Strain (can be negative or positive)
        x1: Temperature (Kelvin, positive)
        params: array of length 12 with coefficients

    Returns:
        y: Stress
    """

    eps = 1e-8

    # Polynomial terms including interactions
    poly_terms = (
        params[0]  # intercept / baseline stress
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 * x1
        + params[4] * (x0 ** 2)
        + params[5] * (x1 ** 2)
        + params[6] * (x0 ** 2) * x1
        + params[7] * x0 * (x1 ** 2)
        + params[8] * (x0 ** 3)
    )

    # Exponential decay term modeling thermal softening or activation-like behavior,
    # negative exponent for decay; clip for numerical stability
    exp_arg = np.clip(-params[9] * x1, a_min=-50, a_max=50)
    exp_term = params[10] * np.exp(exp_arg) * x0

    # Inverse temperature term modeling thermal activation/softening
    inv_temp_term = params[11] / (x1 + eps)

    # Logarithmic temperature term capturing slow varying thermal effects,
    # reuse param[9], scaled by small factor to avoid dominance if desired
    log_temp_term = 0.05 * params[9] * np.log(x1 + eps)

    # Saturation effect modeled by tanh of scaled strain,
    # trainable scale factor controls nonlinearity strength/saturation threshold
    tanh_scale_param = 5.0  # fixed scale factor for tanh argument base

    tanh_arg = tanh_scale_param * params[11 % len(params)] * x0

    tanh_term = np.tanh(tanh_arg)


    y = poly_terms + exp_term + inv_temp_term + log_temp_term + tanh_term

    return y
