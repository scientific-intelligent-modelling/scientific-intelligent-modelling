            + p4 * x0**2
            + p5 * x1**2
            + p6 * exp(-p7 * x1) * x0
            + p8 * x0**3
            + p9 * exp(-p10 * x1) * (x0**2)
            + p11 * log(1 + x1)
            + sigmoid_term_coefficient * x0 / (1 + exp(-k*(x1 - c)))

    Parameters:
        params: array-like with length == 12,
                where params[11] is coefficient for logarithmic temp,
                sigmoid midpoint c and slope k are fixed constants.
    """

    # Unpack parameters for clarity
    p = params

    # Fixed sigmoid parameters for smooth transition in material behavior around temperature c [K]
    c = 300.0   # midpoint of sigmoid, e.g., room temperature in Kelvin
    k = 0.05    # slope controlling sharpness of transition

    # Compute sigmoid modulation factor safely to avoid overflow:
    # Clip input to reasonable range to prevent overflow in exp()
    arg = k*(x1 - c)
    arg_clipped = np.clip(arg, -50, 50)

    sigmoid = 1 / (1 + np.exp(-arg_clipped))

    # Compute logarithmic temperature safely; add small epsilon inside log to avoid log(0)
    log_temp = np.log(1.00001 + x1)

    y = (
        p[0]
        + p[1]   * x0
        + p[2]   * x1
        + p[3]   * x0*x1
        + p[4]   * (x0**2)
        + p[5]   * (x1**2)
