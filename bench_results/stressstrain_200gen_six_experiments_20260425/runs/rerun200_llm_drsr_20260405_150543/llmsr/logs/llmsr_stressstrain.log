def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends on strain and temperature.
    - Temperature reduces stiffness (modulus), so a negative linear term in temperature.
    - Interaction term captures temperature-dependent modulus changes.
    - Quadratic terms capture nonlinear elastic/plastic behavior.
    - Adding a cubic strain term to better capture nonlinearities at higher strains.
    - Adding an inverse temperature term to model possible Arrhenius-type effects or thermal activation.

    Model structure:
    y = p0
        + p1*x0
        + p2*x1
        + p3*x0*x1
        + p4*x0**2
        + p5*x1**2
        + p6*x0**3
        + p7*(1/(x1+273.15))  # inverse absolute temperature (K)

    Variables:
    - x0: Strain (dimensionless)
    - x1: Temperature (°C)

    Note:
    We add 273.15 to convert Celsius to Kelvin for physical meaningfulness in inverse T term.

    Parameters:
    - params: array-like of length at least 8
    """

    # Avoid division by zero or negative Kelvin temperatures by adding 273.15
    T_kelvin = x1 + 273.15

    return (params[0]
            + params[1] * x0
            + params[2] * x1
            + params[3] * x0 * x1
            + params[4] * x0**2
            + params[5] * x1**2
            + params[6] * x0**3
            + params[7] / T_kelvin)
