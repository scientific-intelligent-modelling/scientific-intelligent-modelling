def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Nonlinear strain terms (quadratic and cubic) to capture complex elasticity.
    - Temperature effects modeled via linear, quadratic, exponential decay/growth.
    - Use inverse absolute temperature in Kelvin to model thermally activated processes.
    - Logarithmic strain terms to capture plasticity or rate-dependent behavior.
    - Interaction terms between strain and temperature for coupling effects.
    - Rational term to model saturation or softening at high strains or temperatures.
    - Hyperbolic tangent term for saturation effect on strain.

    Model structure:
        y = p0
            + p1*x0                          # linear strain
            + p2*x1                          # linear temperature
            + p3*x0**2                      # quadratic strain
            + p4*x1**2                      # quadratic temperature
            + p5*x0*x1                      # interaction term
            + p6*np.exp(-p7 * x1) * x0     # temp-dependent stiffness decay (exponential decay)
            + p8*np.tanh(p9 * x0)          # saturation effect in strain
            + p10 * x0**3                   # cubic strain nonlinearity
            + p11 * x0 * np.log(np.abs(x0)+1e-6) / (x1+273.15)  # combined nonlinear rational term

    Parameters:
        params: array of length 12

    Returns:
        y: predicted stress values as numpy array
    """

    abs_x0 = np.abs(x0) + 1e-6         # avoid log(0)
    abs_x1_kelvin = x1 + 273.15        # convert Celsius to Kelvin

    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[6] * np.exp(-params[7] * x1) * x0   # temp-dependent stiffness decay
        + params[8] * np.tanh(params[9] * x0)         # saturation effect in strain
        + params[10] * x0**3                           # cubic strain nonlinearity
        + params[11] * (x0 * np.log(abs_x0)) / abs_x1_kelvin  # nonlinear rational term combining strain & temp
    )
