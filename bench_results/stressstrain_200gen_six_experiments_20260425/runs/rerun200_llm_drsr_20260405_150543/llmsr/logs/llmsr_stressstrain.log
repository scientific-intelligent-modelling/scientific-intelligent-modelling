def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retains linear, quadratic, cubic terms in strain and temperature.
    - Includes exponential temperature dependence to model thermal activation.
    - Adds logarithmic strain term for microstructural effects at low strains.
    - Includes inverse absolute temperature term (Kelvin scale).
    - Adds hyperbolic tangent saturation effect on strain.
    - Includes mixed interaction terms such as sqrt(strain)*temperature.

    Model structure:
    y = params[0]
        + params[1]*x0
        + params[2]*x1
        + params[3]*x0**2
        + params[4]*x1**2
        + params[5]*x0*x1
        + params[6]*np.exp(params[7]*x1)
        + params[8]*np.log(np.clip(x0, 1e-8, None))
        + params[9]/(x1+273.15)
        + params[10]*np.tanh(params[11] * x0)

    Note:
    - The cubic term from v1 is replaced by a tanh saturation term with parameter p11 controlling saturation rate,
      to keep parameter count at 12.

    Parameters:
    - x0: Strain (independent variable)
    - x1: Temperature in Celsius (independent variable)
    - params: array of length 12

    Returns:
    - y: Stress prediction as numpy array
    """

    safe_x0 = np.clip(x0, 1e-8, None)  # avoid log(0) or negative inside log

    temp_K = x1 + 273.15               # convert Celsius to Kelvin for inverse temp

    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[6] * np.exp(params[7] * x1)
        + params[8] * np.log(safe_x0)
        + params[9] / temp_K
        + params[10] * np.tanh(params[11] * x0)
    )
