def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retain polynomial terms up to cubic in strain and quadratic in temperature.
    - Include interaction terms between strain and temperature.
    - Model temperature softening with an exponential decay term with a trainable decay rate (params[12]).
    - Add logarithmic and inverse terms for mild nonlinearities and asymptotic behavior.
    - Use tanh(strain) to capture saturation/yielding effects.
    - Add an additional term with inverse strain (to capture possible singular behavior near zero strain).
    - Add a Gaussian-like term centered at some strain value (params[13]) to model localized phenomena like phase transitions or damage initiation.

    Parameters (length at least 14):
      params[0]: intercept
      params[1]: linear strain coefficient
      params[2]: linear temperature coefficient
      params[3]: strain^2 coefficient
      params[4]: temperature^2 coefficient
      params[5]: strain * temperature interaction term
      params[6]: exp(-decay_rate * temperature) coefficient
      params[7]: strain * exp(-decay_rate * temperature) interaction term
      params[8]: log(1 + |strain|) coefficient
      params[9]: 1 / (1 + temperature) coefficient
      params[10]: strain^3 coefficient
      params[11]: tanh(strain) coefficient
      params[12]: decay rate for exponential terms inside exp()
      params[13]: center of Gaussian term in strain

    Inputs:
        x0: Strain (np.ndarray)
        x1: Temperature (np.ndarray)
        params: coefficients array

    Output:
        y: Stress (np.ndarray)
    """

    epsilon = 1e-8

    # Polynomial terms in strain and temperature including interactions
    poly_terms = (
        params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[10] * x0**3
    )

    # Exponential decay with trainable decay rate for temp softening effects
    exp_term = np.exp(-params[12] * x1)

    exp_terms = (
        params[6] * exp_term
        + params[7] * x0 * exp_term
    )

    # Logarithmic mild nonlinearity in strain, abs to avoid domain errors for negative strains
    log_term = np.log(1 + np.abs(x0) + epsilon)

    # Inverse temperature effect term, avoid division by zero by adding epsilon
    inv_temp_term = 1 / (1 + x1 + epsilon)

    # Saturation or yielding modeled by tanh(strain), smooth bounded function capturing plateauing stress at large strains
    tanh_term = np.tanh(x0)

    # Inverse strain term to capture possible singular behavior near zero strain, regularized by epsilon to avoid div by zero.
    inv_strain_term = 1 / (x0 + epsilon)

    # Gaussian-like localized effect centered at param center param (params[13]) with fixed width sigma=0.05,
    # modeling localized phenomena such as phase transitions or damage initiation.

    sigma = 0.05

    gauss_term = np.exp(-((x0 - params[13]) ** 2) / (2 * sigma ** 2))
