    where
    x0 = Strain
    x1 = Temperature
    y = Stress

    Note: params length should be at least 15 for this model.
    """

    # Clip temperature to avoid overflow in exp(-p8*x1)
    temp_clip = np.clip(x1, 0, 1000)  # physical range

    eps = 1e-8
    log_term = np.log(1 + np.abs(x0) + eps)

    # Sigmoid function parameters from params[13], params[14]
    # To avoid overflow in exp inside sigmoid, clip argument as well
    sigmoid_arg = np.clip(params[13] * (temp_clip - params[14]), -500, 500)

    sigmoid_temp_effect = 1 / (1 + np.exp(-sigmoid_arg))
