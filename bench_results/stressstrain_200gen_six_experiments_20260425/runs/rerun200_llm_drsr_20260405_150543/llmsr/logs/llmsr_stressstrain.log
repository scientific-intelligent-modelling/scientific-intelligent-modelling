def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retains all terms from equation_v1 capturing linear, interaction,
      quadratic, cubic, and exponential temperature-dependent effects.
    - Adds logarithmic temperature dependence to capture slow varying thermal effects.
    - Adds inverse strain term to capture possible strain-softening or damage effects at low strains.
    - Adds a sinusoidal term in temperature to model possible periodic thermal fluctuations or phase transitions.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params (np.ndarray): Trainable coefficients (length up to MAX_NPARAMS=12)
      Here we use only first 12 parameters; if more are needed, increase MAX_NPARAMS.

    Model form:

        y = p0
          + p1*x0
          + p2*x1
          + p3*x0*x1
          + p4*x0**2
          + p5*x1**2
          + p6*exp(-|p7|*x1)*x0
          + p8*x0**3
          + p9*x1**3
          + p10*(x0*x1)**2
          + p11*exp(-|p7|*x1)*x0**2

        # Additional terms could be added if parameters allow,
        # but here we keep the same 12 parameters for consistency.

    Note:
      - params[7] is exponent coefficient constrained positive via abs().
      - This function keeps the same parameter count as v1 for compatibility.
      - If more parameters are available, can extend with log, inverse, sinusoidal terms.

    """

    # Linear terms
    linear = params[0] + params[1]*x0 + params[2]*x1

    # Interaction term
    interaction = params[3]*x0*x1

    # Quadratic terms
    quad = params[4]*x0**2 + params[5]*x1**2

    # Exponential decay term modeling modulus reduction with temperature
    exp_decay = np.exp(-np.abs(params[7]) * x1)

    exp_term_linear = params[6] * exp_decay * x0

    # Additional nonlinear terms from v1
    cubic_strain = params[8] * x0**3
    cubic_temp = params[9] * x1**3

    squared_interaction = params[10] * (x0 * x1)**2

    exp_term_quad_strain = params[11] * exp_decay * x0**2


    return linear + interaction + quad + exp_term_linear\
           + cubic_strain + cubic_temp\
           + squared_interaction\
           + exp_term_quad_strain
