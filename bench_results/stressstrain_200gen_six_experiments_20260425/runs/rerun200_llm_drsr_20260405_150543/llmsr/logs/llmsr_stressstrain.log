def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculate Stress given Strain (x0) and Temperature (x1).

    Model structure:
        y = p0
            + p1 * x0
            + p2 * x1
            + p3 * x0 * x1
            + p4 * x0**2
            + p5 * x1**2
            + p6 * exp(-p7 * x1) * x0
            + p8 * x0**3
            + p9 * exp(-p10 * x1) * (x0**2)
            + p11 * x0 * sigmoid(x1)

    where sigmoid(x) = 1 / (1 + exp(-(x - c))) with fixed c.

    Parameters:
        params: array-like with length == 12

    Returns:
        y: predicted stress values as numpy array.
    """

    # Fixed sigmoid midpoint c; choose physically meaningful value or zero if normalized inputs
    c = 25.0  # e.g., room temperature in Celsius; adjust based on data scaling

    # Compute sigmoid term safely to avoid overflow
    temp_shifted = x1 - c
    # Clip input to avoid overflow in exp for large negative/positive values
    temp_shifted_clipped = np.clip(temp_shifted, -50, 50)
    sigmoid = 1 / (1 + np.exp(-temp_shifted_clipped))

    y = (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 * x1
        + params[4] * x0**2
        + params[5] * x1**2
        + params[6] * np.exp(-params[7] * x1) * x0
        + params[8] * x0**3
        + params[9] * np.exp(-params[10] * x1) * (x0**2)
        + params[11] * x0 * sigmoid   # coefficient times strain times sigmoid(temperature)
    )

    return y
