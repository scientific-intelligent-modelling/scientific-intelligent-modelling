def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning enhancements:
    - Retain nonlinear strain and temperature terms.
    - Include logarithmic temperature terms to capture slow thermal effects.
    - Include strain * log(temperature) interaction term.
    - Include hyperbolic tangent term of strain for saturation/yielding behavior.
    - Use exponential decay term to model thermal softening/hardening.
    - Use inverse temperature terms for Arrhenius-type behavior.
    - Keep constant offset.

    Variables:
    - x0: Strain
    - x1: Temperature

    Parameters:
    - params: array of coefficients (length up to MAX_NPARAMS=12)

    Model form:

        y = p0
          + p1*x0
          + p2*x1
          + p3*x0*x1
          + p4*x0**2
          + p5*x1**2
          + p6*np.exp(-p7 * x1) * x0
          + p8*x0**3
          + p9/(x1+eps)
          + p10*x0/(x1+eps)
          + p11*np.log(x1+eps)
          + p12*x0*np.log(x1+eps)
          + p13*np.tanh(5.0 * x0)

    Since MAX_NPARAMS=12, we must combine or omit some terms. Here we prioritize:

        y = (p[0]
             + p[1]*x0
             + p[2]*x1
             + p[3]*x0*x1
             + p[4]*x0**2
             + p[5]*x1**2
             + p[6]*np.exp(-p[7] * x1) * x0
             + p[8]*x0**3
             + p[9]/(x1+eps)
             + p[10]*x0/(x1+eps)
            ) \
            + params[-2] * np.log(x1+eps) \
            + params[-1] * x0 * np.log(x1+eps) \
            # Note: tanh term omitted due to param limit; could be added if param count increased

    """

    eps = 1e-6  # small number to avoid division by zero

    # Clip temperature to avoid invalid values in log and division
    temp_clip = np.clip(x1, a_min=eps, a_max=None)

    p = params

    linear = (
        p[0]
        + p[1] * x0
        + p[2] * temp_clip
        )

    interaction = (
        p[3] * x0 * temp_clip
        )

    quad = (
        p[4] * x0 ** 2
        + p[5] * temp_clip ** 2
        )

    exp_term = (
        p[6] * np.exp(-p[7] * temp_clip) * x0
        )

    cubic_strain = (
        p[8] * x0 ** 3
        )

    inv_temp_terms = (
        (p[9]) / temp_clip +
        (p[10]) * x0 / temp_clip
        )

    log_temp_terms = (
        (p[-2]) * np.log(temp_clip) +
        (p[-1]) * x0 * np.log(temp_clip)
        )

    y = linear \
      + interaction \
      + quad \
      + exp_term \
      + cubic_strain \
      + inv_temp_terms \
      + log_temp_terms

    return y
