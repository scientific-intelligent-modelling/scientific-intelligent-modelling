    inv_temp = 1.0 / (x1 + epsilon)

    log_strain = np.log(np.abs(x0) + epsilon)

    # Combine logarithmic strain and its interaction with inverse temperature using param[11]
    log_term = params[11] * (log_strain + inv_temp * log_strain)

    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 * x1
        + params[4] * x0**2
        + params[5] * x1**2
        + params[6] * inv_temp
        + params[7] * x0**3
        + params[8] * (x0**2) * x1
        # Arrhenius type exponential decay with activation energy param[10]
        + params[9] * np.exp(-params[10] * inv_temp)
        # Combined logarithmic strain and its interaction with inverse temperature term
        + log_term
    )
