    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements:
    - Modulate strain linear term by an exponential decay in temperature to model temperature-dependent modulus.
    - Add interaction terms involving tanh of strain and temperature to capture saturation effects influenced by temperature.
    - Include squared tanh(strain) term for sharper saturation behavior.
    - Retain polynomial, logarithmic, inverse, and exponential terms from v1 for flexibility.

    Parameters (length 12):
      params[0]: intercept
      params[1]: base linear strain coefficient
      params[2]: linear temperature coefficient
      params[3]: strain^2 coefficient
      params[4]: temperature^2 coefficient
      params[5]: strain * temperature interaction term
      params[6]: exp(-temperature) coefficient (temperature softening)
      params[7]: strain * exp(-temperature) interaction term
      params[8]: log(1 + |strain|) coefficient
      params[9]: 1 / (1 + temperature) coefficient
      params[10]: strain^3 coefficient
      params[11]: tanh(strain) coefficient (saturation)

    Args:
        x0: Strain (np.ndarray)
        x1: Temperature in Kelvin (np.ndarray)
        params: array of length 12

    Returns:
        y: Stress (np.ndarray)
    """

    epsilon = 1e-8

    # Exponential decay with temp for modulus modulation
    exp_neg_temp = np.exp(-x1)

    # Linear strain term modulated by temp softening effect
    modulated_strain = x0 * (params[1] + params[7] * exp_neg_temp)

    # Polynomial terms including quadratic and cubic nonlinearities and temp effects
    poly_terms = (
        modulated_strain
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[10] * x0**3
    )

    # Exponential terms capturing pure temp softening effects independent of strain
    exp_terms = (
        params[6] * exp_neg_temp
    )

    # Logarithmic mild nonlinearity in strain magnitude to capture subtle effects near zero strain
    log_term = np.log(1 + np.abs(x0) + epsilon)

    # Inverse temperature effect for asymptotic behavior at high temperatures
    inv_temp_term = 1 / (1 + x1 + epsilon)

    # Saturation modeled by tanh(strain), plus squared tanh for sharper saturation curve,
    # also include interaction with temperature via multiplication with tanh(x1/1000) scaled down to reasonable range.

    tanh_strain = np.tanh(x0)

    # Smooth function of temp scaled down to ~ [0, 1], assuming typical temps ~300K; adjust divisor if needed.
    tanh_temp_scaled = np.tanh(x1 / 1000.0)

    saturation_terms = (
        params[11] * tanh_strain
        + 0.5 * params[11] * (tanh_strain ** 2) * tanh_temp_scaled
        # The factor 0.5 is arbitrary scaling; can be absorbed into param during fitting.

