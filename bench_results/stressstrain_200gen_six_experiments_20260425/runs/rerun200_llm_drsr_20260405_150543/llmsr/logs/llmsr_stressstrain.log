        + params[2] * x1
        + params[3] * x0 * x1
        + params[4] * x0**2
        + params[5] * x1**2
        + params[6] * (x0**2) * x1
        + params[7] * x0 * (x1**2)
        + params[8] * np.exp(-params[9] * x1) * x0

        # Saturation terms split from param 10:
