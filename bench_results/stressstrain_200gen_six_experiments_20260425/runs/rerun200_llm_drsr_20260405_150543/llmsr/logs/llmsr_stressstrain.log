def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retain polynomial terms in strain (x0) and temperature (x1).
    - Keep exponential temperature dependence modulating strain.
    - Use logarithmic term of (strain + 1) to model strain hardening saturation,
      allowing for small negative strains.
    - Include inverse absolute temperature term to capture Arrhenius-type effects.
    - Add hyperbolic tangent saturation on strain.
    - Add interaction terms between strain and temperature including mixed powers.
    - Add cubic term in strain to capture nonlinear hardening at higher strains.
    - Add a term with inverse strain + offset to capture softening or damage effects at low strains.

    Model structure:
    y = params[0]
        + params[1]*x0
        + params[2]*x1
        + params[3]*x0**2
        + params[4]*x1**2
        + params[5]*x0*x1
        + params[6]*np.exp(params[7]*x1)*x0
        + params[8]*np.log(np.clip(x0+1, 1e-8, None))
        + params[9]/(x1+273.15)
        + params[10]*np.tanh(params[11] * x0)
        + params[12]*(x0**3 if len(params)>12 else 0)
        + (params[13]/(np.clip(x0, 1e-4, None)) if len(params)>13 else 0)

    Parameters:
    - x0: Strain (independent variable)
    - x1: Temperature in Celsius (independent variable)
    - params: array of length >=12

    Returns:
    - y: Stress prediction as numpy array
    """

    safe_x0_log = np.clip(x0 + 1, 1e-8, None)   # ensure argument > 0 for log

    temp_K = x1 + 273.15                        # convert Celsius to Kelvin

    # For compatibility with given MAX_NPARAMS=12,
    # we will not add extra terms beyond index 11 here,
    # but the comment shows how one might extend the model.

    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[6] * np.exp(params[7] * x1) * x0
        + params[8] * np.log(safe_x0_log)
        + params[9] / temp_K
        + params[10] * np.tanh(params[11] * x0)
    )
