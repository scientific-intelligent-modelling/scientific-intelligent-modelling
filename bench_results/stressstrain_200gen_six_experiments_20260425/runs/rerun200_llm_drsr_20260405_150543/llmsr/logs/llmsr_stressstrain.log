def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning enhancements:
    - Retain nonlinear strain and temperature terms from v1.
    - Add logarithmic temperature terms to capture slow thermal effects.
    - Include strain * log(temperature) interaction term.
    - Keep hyperbolic tangent term for strain saturation/yielding behavior.
    - Use exponential decay term with negative exponent to model thermal softening.
    - Use inverse temperature terms for Arrhenius-type behavior.
    - Maintain constant offset.

    Variables:
    - x0: Strain
    - x1: Temperature

    Parameters:
    - params: array of coefficients (length up to MAX_NPARAMS=12)

    Model form:

        y = p0
          + p1*x0
          + p2*x1
          + p3*x0*x1
          + p4*x0**2
          + p5*x1**2
          + p6 * x0 * exp(-p7 * x1)
          + p8 * x0**3
          + p9 / (x1+eps)
          + p10 * x0 / (x1+eps)
          + p11 * log(x1+eps)
          + p12 * x0 * log(x1+eps)
          + p13 * tanh(5.0 * x0)

    Since MAX_NPARAMS=12, we have only 12 parameters (p[0]..p[11]).

    To fit into 12 parameters, we combine or omit some terms:

        y = (
            p[0]
            + p[1]*x0
            + p[2]*x1
            + p[3]*x0*x1
            + p[4]*x0**2
            + p[5]*x1**2
            + p[6]*x0*np.exp(-p[7]*x1)
            + p[8]*x0**3
            + p[9]/(x1+eps)
            + p[10]*x0/(x1+eps)
            # Use last param for combined log and tanh effects:
            #   split param into two parts by fixed ratio or just use one effect prioritizing log term,
            #   here we prioritize both by scaling tanh with a fixed factor and using param for log term,
            #   or alternatively use param for tanh and fix coefficient for log term.
        )
        +
        # Add both terms scaled by the last parameter split in half each or just add both with fixed scale factors:
        # Here, we add both with fixed scale factors and last param split equally:

        0.5*p[11] * np.log(x1+eps) \
        +
        0.5*p[11] * np.tanh(5.0*x0)

    """

    eps = 1e-6

    # Clip temperature to avoid invalid values in log and division
    temp_clip = np.clip(x1, a_min=eps, a_max=None)

    p = params

    linear = (
        p[0]
        + p[1] * x0
        + p[2] * temp_clip
        + p[3] * x0 * temp_clip
        + p[4] * x0 ** 2
        + p[5] * temp_clip ** 2
    )

    exp_term = p[6] * x0 * np.exp(-p[7] * temp_clip)

    cubic_strain = p[8] * x0 ** 3

    inv_temp_terms = (
        (p[9]) / temp_clip +
        (p[10]) * x0 / temp_clip
    )


    # Split last parameter between log and tanh terms equally:

    if len(p) >= 12:
        half_param = 0.5*p[11]
        log_term = half_param * np.log(temp_clip)
        tanh_term = half_param * np.tanh(5.0*x0)

        y = linear + exp_term + cubic_strain \
            + inv_temp_terms \
            + log_term \
            + tanh_term

    else:
        # If fewer than 12 params provided, omit last two nonlinear terms gracefully.
        y = linear + exp_term \
            + cubic_strain \
            + inv_temp_terms

    return y
