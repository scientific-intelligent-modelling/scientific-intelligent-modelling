    sigmoid_temp = params[13] / (1.0 + np.exp(params[14] * (x1 - params[15])))

    combined_log_inv_temp = params[16] * (np.log(x1 + epsilon) / (x1 + epsilon))

    return (
          params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 * x1
        + params[4] * x0**2
        + params[5] * x1**2
        + params[6] / (x1 + epsilon)
