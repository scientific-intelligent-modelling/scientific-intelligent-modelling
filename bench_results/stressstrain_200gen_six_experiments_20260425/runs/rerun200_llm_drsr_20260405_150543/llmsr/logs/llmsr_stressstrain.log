        y = p0
            + p1 * x0
            + p2 * x1
            + p3 * x0 * x1
            + p4 * x0**2
            + p5 * x1**2
            + p6 * np.exp(-p7 * x1) * x0
            + p8 * np.tanh(p9 * x0)
            + p10 * np.log(1 + abs(x1))
            + p11

    This form captures linear, quadratic, interaction, exponential temperature dependence,
    saturation effects via tanh, and logarithmic temperature effects.
    """

    # To avoid domain errors in log and exp, ensure inputs are valid or add small epsilons if needed
    eps = 1e-8

    term_exp = np.exp(-params[7] * x1)
    term_tanh = np.tanh(params[9] * x0)

    # Use absolute value inside log to avoid domain error; add eps for stability
    term_log = np.log(1 + np.abs(x1) + eps)

    y = (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0 * x1
        + params[4] * (x0 ** 2)
        + params[5] * (x1 ** 2)
        + params[6] * term_exp * x0
        + params[8] * term_tanh
        + params[10] * term_log
        + params[11]
    )

    return y
