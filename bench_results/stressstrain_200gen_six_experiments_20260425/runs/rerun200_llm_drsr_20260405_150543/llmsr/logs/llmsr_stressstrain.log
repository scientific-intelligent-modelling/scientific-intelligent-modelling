def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends linearly on strain (Hooke's law) for small strains.
    - Temperature reduces stiffness, so include a negative linear term in temperature.
    - Interaction terms capture coupling between strain and temperature.
    - Quadratic terms allow nonlinearity in strain and temperature effects.
    - Include cubic term in strain to capture some material nonlinearities at higher strains.
    - Include inverse temperature term to model possible nonlinear thermal softening effects.

    Model form:
    y = p0
        + p1*x0
        + p2*x1
        + p3*x0*x1
        + p4*x0**2
        + p5*x1**2
        + p6*x0**3
        + p7/(x1 + c)  # To avoid division by zero, add a small constant c

    where
    x0 = Strain
    x1 = Temperature
    y = Stress

    Parameters:
    - params: array-like with at least 8 parameters [p0,...,p7]

    Note:
      We add a small constant (e.g., 1e-6) inside denominator to avoid division by zero.
      This term models nonlinear thermal softening or strengthening effects that are inversely proportional to temperature.
    """

    c = 1e-6  # small constant to avoid division by zero

    return (params[0]
            + params[1] * x0
            + params[2] * x1
            + params[3] * x0 * x1
            + params[4] * x0**2
            + params[5] * x1**2
            + params[6] * x0**3
            + params[7] / (x1 + c))
