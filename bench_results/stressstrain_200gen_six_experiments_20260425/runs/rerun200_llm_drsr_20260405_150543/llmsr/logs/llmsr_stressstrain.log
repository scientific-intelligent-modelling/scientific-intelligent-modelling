     - tanh(x0) models strain saturation/nonlinearity.

    """

    # Clip temperature to avoid overflow in exp(-p8*x1)
    temp_clip = np.clip(x1, 0, 1000)  # physical range

    eps = 1e-8  # small epsilon for numerical stability

    log_term = np.log(1.0 + np.abs(x0) + eps)

    return (params[0]
            + params[1] * x0
            + params[2] * temp_clip
            + params[3] * x0 * temp_clip
            + params[4] * x0 ** 2
            + params[5] * temp_clip ** 2
            + params[6] * x0 ** 3
            + params[7] * np.exp(-params[8] * temp_clip) * x0
            + params[9] * log_term
