def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements:
    - Smooth yield onset modeled by softplus function on strain.
    - Temperature-dependent stiffness modeled by exp decay.
    - Cubic term in strain for asymmetric hardening/softening.
    - Interaction terms combining nonlinear strain and temperature effects.
    - Log(1 + |x1|) for stable logarithmic temperature effect.
    """
    # Softplus function: smooth approximation to ReLU (max(0,x))
    def softplus(z):
        return np.log1p(np.exp(z))

    # Parameters unpacking for clarity (optional)
    p = params

    # Terms
    linear_strain = p[0] + p[1] * x0
    linear_temp = p[2] * x1

    quadratic_terms = p[3] * x0**2 + p[4] * x1**2 + p[5] * x0 * x1

    exp_temp_decay = p[6] * np.exp(-p[7] * x1)  # temp reduces stiffness/yield

    saturation_strain = p[8] * np.tanh(p[9] * x0)

    cubic_strain = p[10] * x0**3  # asymmetric hardening/softening

    log_temp = p[11] * np.log1p(np.abs(x1))  # stable log temp effect

    soft_yield = softplus(p[9]*x0 - 1.0)  # shifted softplus to model yield threshold

    reciprocal_strain_temp = (p[11]) / (np.abs(x0) + 1e-6) / (np.abs(x1)+1e-6)


    y = (
        linear_strain
        + linear_temp
        + quadratic_terms
        + exp_temp_decay
        + saturation_strain
        + cubic_strain
        + log_temp
        + reciprocal_strain_temp
        # optionally add soft_yield multiplied by a parameter if you want:
        #+ p[some_index]*soft_yield
        # but we have only 12 params total, so reuse existing ones or omit this term here
     )

    return y
