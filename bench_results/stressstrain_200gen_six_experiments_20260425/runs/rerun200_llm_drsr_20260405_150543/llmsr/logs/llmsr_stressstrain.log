def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Incorporate strain rate effects implicitly via nonlinear strain terms.
    - Use temperature in Kelvin for physical consistency.
    - Model softening/hardening with exponential decay/growth terms dependent on temperature.
    - Include interaction terms between strain and temperature to capture coupling effects.
    - Add rational function term to model saturation or limiting behavior at high strains.
    - Use smooth nonlinear functions (tanh, log) to capture complex material responses.

    Model structure:
    y = params[0]
        + params[1]*x0                              # linear strain
        + params[2]*x1                              # linear temperature (Celsius)
        + params[3]*x0**2                           # quadratic strain
        + params[4]*(x1+273.15)**(-1)               # inverse absolute temperature (Kelvin)
        + params[5]*x0*x1                           # interaction term
        + params[6]*np.exp(-params[7]*x1)           # exponential temp-dependent softening/hardening
        + params[8]*np.log(np.abs(x0)+1e-6)         # logarithmic strain effect
        + params[9]*(x0**3)/(1+params[10]*np.abs(x0))  # rational cubic strain term for saturation
        + params[11]*np.tanh(x0 * (x1+273.15))      # nonlinear saturation interaction with absolute temp

    Parameters:
    - x0: Strain (independent variable)
    - x1: Temperature in Celsius (independent variable)
    - params: array of length 12 trainable parameters

    Returns:
    - y: Stress (dependent variable)
    """

    abs_x0 = np.abs(x0) + 1e-6          # avoid log(0)
    abs_x1_kelvin = x1 + 273.15         # convert Celsius to Kelvin

    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] / abs_x1_kelvin
        + params[5] * x0 * x1
        + params[6] * np.exp(-params[7] * x1)
        + params[8] * np.log(abs_x0)
        + (params[9] * (x0 ** 3)) / (1.0 + params[10] * abs_x0)
        + params[11] * np.tanh(x0 * abs_x1_kelvin)
    )
