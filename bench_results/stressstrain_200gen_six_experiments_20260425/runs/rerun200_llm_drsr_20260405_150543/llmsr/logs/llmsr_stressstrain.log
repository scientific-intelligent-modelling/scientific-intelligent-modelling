def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends linearly on strain (Hooke's law) at small strains.
    - Temperature reduces stiffness, modeled as an exponential decay term multiplying strain.
    - Nonlinear strain terms capture material nonlinearities beyond elastic regime.
    - Interaction terms capture coupling between strain and temperature.
    - Including inverse temperature term to model Arrhenius-type or thermally activated effects.
    - Added logarithmic temperature term to capture slow varying thermal softening/hardening effects.

    Model form:
    y = p0
        + p1 * x0 * exp(-p2 * x1)          # linear strain modulated by temperature
        + p3 * x0**2
        + p4 * x0**3
        + p5 * x0**2 * x1                  # nonlinear interaction term
        + p6 * x1
        + p7 / (x1 + eps)                  # inverse temperature effect
        + p8 * np.log(x1 + eps)            # logarithmic temperature effect
        + p9 * x0 * x1                     # linear interaction term
        + p10 * x1**2                     # quadratic temperature effect
        + p11                            # constant offset

    Where:
    - x0: Strain
    - x1: Temperature

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length is 12.
    """

    eps = 1e-6  # small number to avoid division by zero and log(0)

    return (params[11]
            + params[1] * x0 * np.exp(-params[2] * x1)
            + params[3] * x0**2
            + params[4] * x0**3
            + params[5] * (x0**2) * x1
            + params[6] * x1
            + params[7] / (x1 + eps)
            + params[8] * np.log(x1 + eps)
            + params[9] * x0 * x1
            + params[10] * (x1**2)
            )
