def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Retains all terms from v1 for linear, quadratic, cubic strain and temperature effects.
    - Adds a saturating nonlinear term via tanh to model yielding/softening at high strain*temp.
    - Adds an exponential decay term modulated by strain squared to capture temperature-induced modulus degradation.
    - Adds a quartic strain term for higher-order nonlinear elasticity.
    - Adds a logarithmic temperature dependence to capture slow growth or saturation effects at high temperature.
    - Uses 12 parameters total.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params (np.ndarray): Trainable coefficients (length=12)

    Model form:

        y = p0
          + p1*x0
          + p2*x1
          + p3*x0*x1
          + p4*x0**2
          + p5*x1**2
          + p6*exp(-|p7| * x1 * (1 + p8 * x0**2)) * x0
          + p9*x0**4
          + p10*log(1+x1)
          + p11*tanh(p11 * x0 * x1)

    Notes:
      - The exp decay term now includes modulation by strain squared inside the exponent,
        allowing coupling between strain and temperature effects on modulus degradation.
      - The tanh term uses param[11] both as amplitude and argument scaling,
        modeling smooth saturation/yielding behavior dependent on strain and temperature.
      - Logarithmic temp term captures slow growth or saturation at high temperatures.

    """

    abs_p7 = np.abs(params[7])

    # Exponential decay modulated by temp and strain squared interaction
    exp_decay = np.exp(-abs_p7 * x1 * (1.0 + params[8] * x0**2))

    # Saturating nonlinear term modeling yielding/softening behavior
    tanh_arg = params[11] * x0 * x1
    saturating_term = params[11] * np.tanh(tanh_arg)

    y = (
        params[0]                          # intercept
        + params[1]*x0                    # linear strain
        + params[2]*x1                    # linear temp
        + params[3]*x0*x1                 # interaction linear-linear
        + params[4]*x0**2                 # quadratic strain
        + params[5]*x1**2                 # quadratic temp

        + params[6]*exp_decay * x0         # exp decay modulated linear strain with strain^2-temp coupling

        + params[9]*x0**4                  # quartic strain

        + params[10]*np.log(1.0+x1)       # logarithmic temp

        + saturating_term                  # saturating nonlinear correction term

       )

    return y
