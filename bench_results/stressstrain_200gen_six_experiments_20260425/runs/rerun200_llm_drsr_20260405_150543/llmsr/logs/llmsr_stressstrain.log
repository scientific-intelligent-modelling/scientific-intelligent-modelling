def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation_v1 with enhanced physical modeling.

    Physical reasoning:
    - Linear, quadratic, cubic polynomial terms in strain (x0) capture elastic & nonlinear elastic behavior.
    - Linear and quadratic terms in temperature (x1) capture thermal softening/hardening.
    - Interaction terms between strain powers and temperature powers model coupling effects.
    - Exponential term models thermally activated processes modulated by strain magnitude.
    - Saturation effect modeled by tanh of scaled strain modulated by exponential decay with temperature.
    - Inverse temperature term models thermal activation or softening at high temperatures.
    - Logarithmic terms in both strain magnitude and temperature capture mild nonlinearities.

    Parameters:
        x0: Strain (can be negative or positive)
        x1: Temperature (Kelvin, positive)
        params: array of length 12 with coefficients

    Returns:
        y: Stress
    """

    eps = 1e-8

    # Polynomial terms in strain and temp including interaction up to cubic order in strain
    poly = (
        params[0]               # intercept / baseline stress
        + params[1] * x0        # linear strain term
        + params[2] * x1        # linear temp term
        + params[3] * x0 * x1   # interaction linear*linear
        + params[4] * (x0 ** 2) # quadratic strain term
        + params[5] * (x1 ** 2) # quadratic temp term
        + params[6] * (x0 ** 2) * x1   # interaction quadratic*linear temp
        + params[7] * x0 * (x1 ** 2)   # interaction linear*quadratic temp
        + params[8] * (x0 ** 3)         # cubic strain nonlinearity
    )

    # Exponential decay/growth modulated by absolute strain magnitude to model thermally activated processes,
    # clip exponent argument for numerical stability (-50 to 50)
    exp_arg = np.clip(-params[9] * x1 * (1 + np.abs(x0)), a_min=-50, a_max=50)

    exp_term = np.exp(exp_arg)

    exp_effect = params[10] * exp_term

    # Saturation effect modeled as tanh of scaled strain modulated by exponential decay with temp,
    # representing reduced saturation at higher temperatures or high strains

    tanh_arg = params[11] * x0 * np.exp(-x1)

    sat_term = np.tanh(tanh_arg)

    # Mild nonlinearities via logarithmic terms on |strain|+eps and on temperature+eps

    log_strain = np.log(1 + np.abs(x0) + eps)

    log_temp = np.log(x1 + eps)

    log_effects = 0.5*(log_strain + log_temp)  # average effect; can be weighted if desired

    y = poly + exp_effect + sat_term + log_effects

    return y
