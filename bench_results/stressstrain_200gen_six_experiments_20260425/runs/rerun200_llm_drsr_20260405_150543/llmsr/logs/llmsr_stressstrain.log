def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Physical reasoning:
    - Stress typically depends linearly on strain (Hooke's law) for small strains.
    - Temperature affects material properties, often reducing stiffness as temperature increases.
    - Interaction terms between strain and temperature can capture temperature-dependent modulus.
    - Nonlinear terms (e.g., quadratic strain) can capture some nonlinear elasticity or plasticity onset.

    Variables:
    - x0: Strain
    - x1: Temperature

    Parameters:
    - params: array of coefficients (length up to MAX_NPARAMS=12)
      params[0]: intercept (baseline stress)
      params[1]: linear coefficient for strain
      params[2]: linear coefficient for temperature
      params[3]: interaction term strain*temperature
      params[4]: quadratic term strain^2
      params[5]: quadratic term temperature^2
      ... others can be zero or used later if needed.
    """

    # Unpack parameters for clarity
    p0 = params[0]
    p1 = params[1]
    p2 = params[2]
    p3 = params[3]
    p4 = params[4]
    p5 = params[5]

    # Compute stress with linear, interaction and quadratic terms
    y = (
        p0
        + p1 * x0                  # linear in strain
        + p2 * x1                  # linear in temperature
        + p3 * x0 * x1             # interaction term (strain*temperature)
        + p4 * x0**2               # nonlinear strain effect
        + p5 * x1**2               # nonlinear temperature effect
    )

    return y
