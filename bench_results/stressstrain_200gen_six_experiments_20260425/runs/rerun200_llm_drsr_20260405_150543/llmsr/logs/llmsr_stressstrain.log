def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physical reasoning:
    - Stress depends linearly on strain (Hooke's law) for small strains.
    - Temperature affects material stiffness, often reducing it as temperature increases.
    - Interaction terms capture how temperature modifies strain response.
    - Nonlinear terms model nonlinear elastic or thermal effects.
    - Exponential term models possible exponential temperature effects (e.g., thermal activation).
    - Tanh term models saturation or yielding behavior at large strains.

    Variables:
    - x0: Strain
    - x1: Temperature
    - y: Stress

    Parameters:
    - params (np.ndarray): Trainable coefficients (length up to MAX_NPARAMS=12)

    Model form:
        y = p0
            + p1 * x0
            + p2 * x1
            + p3 * x0 * x1
            + p4 * x0**2
            + p5 * x1**2
            + p6 * (x0**2) * x1
            + p7 * x0 * (x1**2)
            + p8 * exp(p9 * x1)
            + p10 * tanh(p11 * x0)
    """

    # Unpack parameters for readability
    p = params

    # Compute each term explicitly for clarity
    linear_strain = p[1] * x0
    linear_temp = p[2] * x1
    interaction = p[3] * x0 * x1

    quad_strain = p[4] * (x0 ** 2)
    quad_temp = p[5] * (x1 ** 2)

    higher_order_interaction_1 = p[6] * (x0 ** 2) * x1
    higher_order_interaction_2 = p[7] * x0 * (x1 ** 2)

    exp_temp_effect = p[8] * np.exp(p[9] * x1)

    tanh_strain_saturation = p[10] * np.tanh(p[11] * x0)

    y = (
        p[0]
        + linear_strain
        + linear_temp
        + interaction
        + quad_strain
        + quad_temp
        + higher_order_interaction_1
        + higher_order_interaction_2
        + exp_temp_effect
        + tanh_strain_saturation
    )

    return y
