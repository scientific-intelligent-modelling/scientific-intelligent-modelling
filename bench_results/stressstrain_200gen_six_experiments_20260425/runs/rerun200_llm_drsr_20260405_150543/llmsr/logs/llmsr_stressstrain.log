def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Stress given Strain and Temperature

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Enhancements:
    - Introduce sharper saturation effect on strain via tanh(10 * strain).
    - Add cross term: (strain^2) * exp(-temperature) to capture nonlinear temp-strain interaction.
    - Include inverse temperature squared term for stronger asymptotic behavior.
    - Maintain polynomial, exponential, logarithmic, inverse, and tanh terms from v1.

    Parameters:
        x0: Strain (can be positive or negative)
        x1: Temperature (Kelvin)
        params: array of length 12

    Returns:
        y: Stress
    """

    epsilon = 1e-8

    # Polynomial terms
    poly_terms = (
        params[1] * x0
        + params[2] * x1
        + params[3] * x0**2
        + params[4] * x1**2
        + params[5] * x0 * x1
        + params[10] * x0**3
    )

    # Exponential decay terms for temperature softening effects
    exp_term = np.exp(-x1)

    exp_terms = (
        params[6] * exp_term
        + params[7] * x0 * exp_term
        + # New nonlinear interaction term:
        params[8] * (x0**2) * exp_term
    )

    # Logarithmic mild nonlinearity in strain; abs to avoid domain errors for negative strains
    log_term = np.log(1 + np.abs(x0) + epsilon)

    # Inverse temperature effects; add inverse squared temp term for stronger asymptotic behavior
    inv_temp_term = 1 / (1 + x1 + epsilon)

    inv_temp_sq_term = 1 / ((1 + x1)**2 + epsilon)

    # Saturation or yielding modeled by sharper tanh(strain), smooth bounded function capturing plateauing stress at large strains
    tanh_term = np.tanh(10.0 * x0)


    y = (
        params[0]
        + poly_terms
        + exp_terms[:-1].sum() if isinstance(exp_terms, tuple) else exp_terms  # sum all exponential terms except the new one handled separately below
        + params[8] * log_term   # Note: param index reused here; will fix below to avoid conflict.
        + params[9] * inv_temp_term
        + params[-2] * inv_temp_sq_term if len(params) > 11 else 0.0   # If param available for inverse squared temp term; else zero.
        + params[11] * tanh_term
     )

    return y
