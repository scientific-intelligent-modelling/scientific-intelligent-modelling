def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Includes:
    - Constant offset
    - Linear stiffness term (x0)
    - Cubic stiffness term (x0^3)
    - Damping term (x1)
    - Optional quadratic stiffness term (x0^2) for more flexibility
    - Optional velocity squared term (x1^2) to capture nonlinear damping effects

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 6.
    
    This version balances physical interpretability and model flexibility,
    allowing to capture slightly more complex nonlinear oscillator dynamics.
    """
    return (
        params[0]                  # constant offset
        + params[1] * x0          # linear stiffness
        + params[2] * x0**3       # cubic nonlinearity
        + params[3] * x1          # linear damping
        + params[4] * x0**2       # quadratic position term (optional)
        + params[5] * x1**2       # nonlinear damping term (optional)
    )
