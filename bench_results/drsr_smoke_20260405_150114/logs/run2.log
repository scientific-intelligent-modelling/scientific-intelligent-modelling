def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Includes:
    - Constant offset (params[0])
    - Linear position term (params[1] * x0)
    - Cubic position term (params[2] * x0**3) to capture anharmonicity/nonlinearity
    - Linear velocity term (params[3] * x1) to capture damping effects

    This skeleton balances physical interpretability and expressiveness for a nonlinear oscillator.
    """
    return params[0] + params[1] * x0 + params[2] * x0**3 + params[3] * x1
