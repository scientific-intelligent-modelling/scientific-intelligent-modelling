def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Includes:
    - Constant offset
    - Linear position term
    - Cubic position term for nonlinearity
    - Linear velocity term for damping

    Parameters:
    - params (np.ndarray): Trainable coefficients [p0, p1, p2, p3]
    
    Returns:
    - y (np.ndarray): Acceleration values
    """
    return params[0] + params[1] * x0 + params[2] * x1 + params[3] * (x0 ** 3)
