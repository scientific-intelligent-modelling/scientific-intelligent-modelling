def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Includes:
    - Constant offset
    - Linear stiffness term (x0)
    - Cubic stiffness term (x0^3)
    - Damping term (x1)
    - Optional quadratic velocity term (x1^2) to capture nonlinear damping effects

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 5.
    """
    return params[0] + params[1] * x0 + params[2] * x0**3 + params[3] * x1 + params[4] * x1**2
