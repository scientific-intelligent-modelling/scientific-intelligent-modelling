def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Calculates acceleration y for a nonlinear harmonic oscillator with damping.

    y = offset + linear_position + cubic_position + linear_velocity_damping

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Coefficients [offset, k_linear, k_cubic, c_damping, ...]

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    return (
        params[0]               # constant offset
        + params[1] * x0       # linear restoring force term
        + params[2] * x0**3    # cubic nonlinear restoring force term
        + params[3] * x1       # velocity-dependent damping term
    )
