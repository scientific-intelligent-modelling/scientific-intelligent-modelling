def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Includes linear and cubic terms in position (x0) to capture nonlinear restoring force,
    and a linear damping term in velocity (x1).

    y represents acceleration in a nonlinear damped harmonic oscillator:
        y = a + b*x0 + c*x0^3 + d*x1

    Parameters:
    - params (np.ndarray): Trainable coefficients [a, b, c, d, ...]
    """
    # Ensure params has at least 4 elements
    assert len(params) >= 4, "params must have at least 4 elements"

    return params[0] + params[1] * x0 + params[2] * x0**3 + params[3] * x1
