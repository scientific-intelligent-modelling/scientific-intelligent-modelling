def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    This function models acceleration y in a nonlinear harmonic oscillator,
    incorporating:
    - linear stiffness term (proportional to position x0),
    - cubic stiffness term (nonlinear restoring force from x0^3),
    - linear damping term (proportional to velocity x1),
    - cubic damping term (nonlinear damping from x1^3),
    - and a constant offset.

    Parameters:
    - params (np.ndarray): Trainable coefficients with length at least 6
        params[0]: constant offset
        params[1]: linear stiffness coefficient (x0)
        params[2]: cubic stiffness coefficient (x0^3)
        params[3]: linear damping coefficient (x1)
        params[4]: cubic damping coefficient (x1^3)
        params[5]: optional higher order or cross terms if needed

    Returns:
    - y (np.ndarray): acceleration values
    """
    
    # Extract parameters for clarity
    c = params[0]       # constant offset
    k1 = params[1]      # linear stiffness coefficient
    k3 = params[2]      # cubic stiffness coefficient
    d1 = params[3]      # linear damping coefficient
    d3 = params[4]      # cubic damping coefficient
    
    # Compute nonlinear terms
    y = (
        c 
        + k1 * x0           # linear restoring force ~ position
        + k3 * x0**3       # nonlinear restoring force ~ position cubed
        + d1 * x1           # linear damping ~ velocity
        + d3 * x1**3       # nonlinear damping ~ velocity cubed
    )
    
    return y
