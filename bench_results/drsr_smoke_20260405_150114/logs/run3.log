"""
Find the mathematical function skeleton that represents oscillator1.

Background:
Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

Variables:
- Independents: x0, x1
- Dependent: y
"""

import numpy as np

# Initialize parameters
MAX_NPARAMS = 10
params = [1.0]*MAX_NPARAMS

def equation_v0(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    return params[0] + params[1] * x0 + params[2] * x1


