def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Includes:
    - Constant offset (params[0])
    - Linear position term (params[1] * x0)
    - Cubic position term (params[2] * x0**3) to capture nonlinear stiffness
    - Linear velocity term (params[3] * x1) to capture linear damping
    - Cubic velocity term (params[4] * x1**3) to capture nonlinear damping effects

    This skeleton captures essential nonlinear oscillator physics while keeping parameters trainable.
    
    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    
    Returns:
    - y (np.ndarray): Calculated acceleration values.
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x0**3
        + params[3] * x1
        + params[4] * x1**3
    )
