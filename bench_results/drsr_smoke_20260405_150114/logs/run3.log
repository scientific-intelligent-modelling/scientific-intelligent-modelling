def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Calculates acceleration y for a nonlinear harmonic oscillator given position (x0)
    and velocity (x1), including linear and cubic nonlinear terms.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Trainable coefficients [p0,...p5]

      params[0]: constant bias term
      params[1]: linear coefficient for position x0
      params[2]: linear coefficient for velocity x1 (damping)
      params[3]: cubic coefficient for position x0^3
      params[4]: cubic coefficient for velocity x1^3 (optional nonlinear damping)
      params[5]: optional extra linear or nonlinear term if needed

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * np.power(x0, 3)
        + params[4] * np.power(x1, 3)
        # optionally add more terms if desired, e.g. quadratic or cross terms,
        # but omitted here to keep model simple as per instructions.
    )
