def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Models acceleration y as a nonlinear function of position (x0) and velocity (x1):
    y = p0 + p1*x0 + p2*x0^3 + p3*x1 + p4*x1^3

    Parameters:
    - params (np.ndarray): array of at least 5 parameters [p0, p1, p2, p3, p4]
    """
    return (
        params[0]  # constant offset
        + params[1] * x0  # linear position term
        + params[2] * x0**3  # cubic position term (nonlinear stiffness)
        + params[3] * x1  # linear velocity term (damping)
        + params[4] * x1**3  # cubic velocity term (nonlinear damping)
    )
