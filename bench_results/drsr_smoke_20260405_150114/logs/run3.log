def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Models acceleration y as a nonlinear harmonic oscillator with damping.

    y = p0 + p1*x0 + p2*x0^3 + p3*x1 + p4*x1^3

    Parameters:
    - params (np.ndarray): array of at least 5 trainable coefficients [p0, p1, p2, p3, p4]

    Returns:
    - y (np.ndarray): acceleration values
    """
    return (
        params[0]                  # constant offset
        + params[1] * x0           # linear stiffness term (restoring force)
        + params[2] * x0**3        # cubic stiffness term (nonlinear restoring force)
        + params[3] * x1           # linear damping term
        + params[4] * x1**3        # nonlinear damping term
    )
