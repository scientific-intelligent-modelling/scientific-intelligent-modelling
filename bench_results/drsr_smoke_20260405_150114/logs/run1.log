def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator with damping,
    including constant, linear, cubic terms and velocity damping,
    plus optional quadratic term for more flexibility.

    y = params[0] 
        + params[1]*x0 
        + params[2]*x0**2 
        + params[3]*x0**3 
        + params[4]*x1

    where:
    - params[0]: constant offset (optional)
    - params[1]: linear stiffness coefficient (expected negative)
    - params[2]: quadratic stiffness coefficient (optional)
    - params[3]: nonlinear stiffness coefficient (cubic term)
    - params[4]: damping coefficient (expected negative)
    
    Parameters:
    - x0 (np.ndarray): position at time t
    - x1 (np.ndarray): velocity at time t
    - params (np.ndarray): trainable coefficients used by the equation skeleton.
    
    Returns:
    - y (np.ndarray): acceleration at time t
    """
    
    return (
        params[0]
        + params[1] * x0
        + params[2] * x0**2
        + params[3] * x0**3
        + params[4] * x1
    )
