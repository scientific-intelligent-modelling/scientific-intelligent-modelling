def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    This function represents the acceleration y in a nonlinear harmonic oscillator,
    incorporating:
      - a constant offset (params[0])
      - linear stiffness term proportional to position x0 (params[1] * x0)
      - cubic nonlinear stiffness term proportional to x0^3 (params[2] * x0**3)
      - damping term proportional to velocity x1 (params[3] * x1)

    Variables:
    - Independents:
        - x0: position at time t
        - x1: velocity at time t
    - Dependent:
        - y: acceleration at time t

    Parameters:
    - params (np.ndarray): Trainable coefficients [offset, linear stiffness, cubic stiffness, damping]
    """
    return params[0] + params[1] * x0 + params[2] * (x0 ** 3) + params[3] * x1
