def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Extends the nonlinear oscillator model by including:
    - constant offset (params[0])
    - linear stiffness term in position x0 (params[1] * x0)
    - cubic stiffness term in position x0 (params[2] * x0**3)
    - damping term proportional to velocity x1 (params[3] * x1)
    - optional quadratic stiffness term in position x0 (params[4] * x0**2)
    - optional velocity squared term for nonlinear damping effects (params[5] * x1**2)

    This structure allows capturing more complex nonlinear behaviors while keeping physical interpretability.
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x0**3
        + params[3] * x1
        + params[4] * x0**2
        + params[5] * x1**2
    )
