def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Includes nonlinear terms for position and velocity to capture non-linear harmonic oscillator behavior.
    """
    # Linear terms
    y = params[0]  # constant term
    y += params[1] * x0  # linear in position
    y += params[2] * x1  # linear in velocity

    # Nonlinear terms (up to cubic)
    y += params[3] * (x0 ** 2)
    y += params[4] * (x1 ** 2)
    y += params[5] * (x0 ** 3)
    y += params[6] * (x1 ** 3)

    # Cross terms
    y += params[7] * (x0 * x1)
    y += params[8] * (x0 ** 2 * x1)
    y += params[9] * (x0 * x1 ** 2)

    return y
