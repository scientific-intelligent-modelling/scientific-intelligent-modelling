def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Calculates acceleration for a nonlinear harmonic oscillator given position (x0) 
    and velocity (x1) at time t, using polynomial terms up to cubic order.

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Array of 12 coefficients

    Returns:
        np.ndarray: Acceleration values
    """
    return (
        params[0]  # constant offset (usually zero)
        + params[1] * x0  # linear restoring force (-k*x)
        + params[2] * x1  # linear damping (-c*v)
        + params[3] * (x0 ** 3)  # cubic stiffness nonlinearity (-alpha*x^3)
        + params[4] * (x1 ** 3)  # cubic nonlinear damping term (-beta*v^3)
        + params[5] * (x0 ** 2)  # quadratic stiffness term
        + params[6] * (x1 ** 2)  # quadratic damping term
        + params[7] * (x0 * x1)   # coupling between position and velocity
        + params[8] * ((x0 ** 2) * x1)   # higher order coupling term
        + params[9] * (x0 * (x1 ** 2))   # higher order coupling term
        + params[10] * ((x0 ** 3) * x1)   # even higher order coupling term
        + params[11] * (x0 * (x1 ** 3))   # even higher order coupling term
    )
