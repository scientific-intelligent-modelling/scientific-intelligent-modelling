    # Linear terms
    y += p[1] * x0          # linear position term (restoring force)
    y += p[2] * x1          # linear velocity term (damping)

    # Quadratic terms
    y += p[3] * (x0 ** 2)
    y += p[4] * (x1 ** 2)
    
    # Cubic terms
    y += p[5] * (x0 ** 3)
    y += p[6] * (x1 ** 3)

    # Cross terms cubic order
    y += p[7] * (x0 * x1)
    y += p[8] * ((x0 ** 2) * x1)
    y += p[9] * (x0 * (x1 ** 2))

    # Quartic / higher order cross terms for more flexibility
    if len(p) > 10:
        y += p[10] * (x0 ** 4)           # quartic position nonlinearity
        y += p[11] * ((x0 ** 3) * x1)   # mixed quartic term

        # Optionally, if you want to add more parameters beyond MAX_NPARAMS=12,
        # you could add more high-order or mixed terms here.

    return y
