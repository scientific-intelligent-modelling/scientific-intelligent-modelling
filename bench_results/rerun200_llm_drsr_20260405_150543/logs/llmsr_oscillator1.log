    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This function models acceleration in a nonlinear harmonic oscillator including:
    - constant offset,
    - linear, quadratic, and cubic terms in position and velocity,
    - mixed polynomial interaction terms,
    - periodic nonlinearities (sin and cos),
    - higher order nonlinearities (quartic terms),
    - cross terms involving powers of position and velocity.

    Parameters:
    - x0 (np.ndarray): position at time t
    - x1 (np.ndarray): velocity at time t
    - params (np.ndarray): array of length at least 12 containing coefficients

    Returns:
    - y (np.ndarray): acceleration values
    """
    
    p = params
    
    # Base terms from v1
    y = (
        p[0] +                    # constant offset term
        p[1] * x0 +               # linear position term (restoring force)
        p[2] * x1 +               # linear velocity term (damping)
        p[3] * (x0 ** 2) +        # quadratic position term
        p[4] * (x1 ** 2) +        # quadratic velocity term
        p[5] * (x0 * x1) +        # cross product term
        p[6] * (x0 ** 3) +        # cubic position nonlinearity
        p[7] * (x1 ** 3) +        # cubic velocity nonlinearity
        p[8] * ((x0 ** 2) * x1) + # mixed cubic term: quadratic pos times vel
        p[9] * (x0 * (x1 ** 2)) + # mixed cubic term: pos times quadratic vel
        p[10]* np.sin(x0) +       # periodic nonlinearity in position 
        p[11]* np.cos(x1)         # periodic nonlinearity in velocity 
    )
    
    # Add quartic nonlinearities and additional cross terms if parameters allow more than 12 elements.
    
    if len(p) > 12:
        y += (
            p[12] * (x0 ** 4) +          # quartic position nonlinearity
            p[13] * (x1 ** 4) +          # quartic velocity nonlinearity
            p[14] * ((x0 ** 3)* x1) +   # quartic mixed term: cubic pos times vel
            p[15] * (x0* (x1 **3))      # quartic mixed term: pos times cubic vel 
            if len(p) > 15 else 0.0      # safe check for length before accessing index 15 
        )
    
    return y
