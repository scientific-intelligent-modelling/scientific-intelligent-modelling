def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This function models acceleration in a nonlinear harmonic oscillator with:
    - linear and higher-order stiffness terms,
    - linear and nonlinear damping terms,
    - mixed polynomial coupling terms,
    - multiple periodic nonlinearities to capture complex oscillatory behavior.

    Parameters:
    - x0 (np.ndarray): position at time t
    - x1 (np.ndarray): velocity at time t
    - params (np.ndarray): array of length at least 12 containing coefficients

    Returns:
    - y (np.ndarray): acceleration values
    """
    
    p = params
    
    # Nonlinear damping terms with physical sign consistency:
    # quadratic velocity damping (~ v * |v|) ensures correct sign for energy dissipation.
    nonlinear_damping_quad = p[4] * x1 * np.abs(x1)
    
    y = (
        p[0] +                     # constant offset term (usually zero)
        p[1] * x0 +                # linear restoring force (-k*x)
        p[2] * x1 +                # linear damping (-c*v)
        p[3] * (x0 ** 3) +         # cubic stiffness nonlinearity (-alpha*x^3)
        nonlinear_damping_quad +   # quadratic velocity damping term (~v*|v|)
        p[7] * (x1 ** 3) +         # cubic velocity nonlinearity (~v^3)
        p[5] * (x0 * x1) +         # cross term coupling position & velocity
        p[6] * ((x0 ** 2) * x1) +  # mixed cubic polynomial term coupling position^2 & velocity
        p[8] * (x0 ** 4) +         # quartic stiffness nonlinearity (-beta*x^4)
        p[9] * np.sin(x0) +        # periodic restoring force term in position
        p[10]* np.cos(x0) +        # additional periodic term in position
        p[11]* np.sin(x1)          # periodic nonlinearity in velocity
    )
    
    return y
