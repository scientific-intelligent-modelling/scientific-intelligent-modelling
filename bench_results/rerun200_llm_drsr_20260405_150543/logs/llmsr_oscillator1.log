def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version extends the nonlinear harmonic oscillator acceleration model by including
    quintic stiffness nonlinearity, additional mixed nonlinear terms,
    and refined smooth friction-like damping effects with tunable sharpness.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Array of parameters with length 12

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    p = params
    
    # Tunable sharpness for smooth friction effect; use p[11] as amplitude, p[10] as sharpness
    friction_sharpness = 10.0 if abs(p[10]) < 1e-6 else abs(p[10])
    
    friction_effect = p[11] * np.tanh(friction_sharpness * x1)
    
    return (
        p[0]                          # constant offset term
        
        + p[1] * x0                  # linear stiffness term (-k*x)
        + p[2] * x1                  # linear damping term (-c*v)
        
        + p[3] * x0**2               # quadratic stiffness nonlinearity
        + p[4] * x1**2               # quadratic damping nonlinearity
        
        + p[5] * x0**3               # cubic stiffness nonlinearity (Duffing)
        
        + p[6] * x0 * x1             # cross term coupling position and velocity
        
        + p[7] * x1**3               # cubic damping nonlinearity
        
        + p[8] * (x0**2) * x1        # mixed cubic term: position^2 * velocity
        
        + p[9] * x0 * (x1**2)        # mixed cubic term: position * velocity^2
        
        + (p[10]/10.0) * (x0**4)     # quartic stiffness nonlinearity scaled down to keep magnitude reasonable
        
        + 0.5*p[11]*x0**5            # quintic pure stiffness nonlinearity added here using param 11 scaled down
        
        + friction_effect            # smooth friction-like effect replacing sign(x1)
    )
