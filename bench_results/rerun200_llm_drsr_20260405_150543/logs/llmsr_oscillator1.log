def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Parameters:
    - params (np.ndarray): array of length at least 12
    
    Returns:
    - y (np.ndarray): acceleration values
    """
    p = params
    
    y = (
        p[0]                      # constant offset (usually zero)
        + p[1] * x0               # linear restoring force (-k*x)
        + p[2] * x1               # linear damping (-c*v)
        + p[3] * (x0 ** 3)        # cubic stiffness nonlinearity (-alpha*x^3)
        + p[4] * (x1 ** 2)        # quadratic velocity damping term
        + p[5] * (x1 ** 3)        # cubic velocity damping term
        + p[6] * (x0 * x1)        # cross term coupling position & velocity
        + p[7] * ((x0 ** 2) * x1) # mixed cubic term
        + p[8] * ((x0 ** 3) * x1) # quartic mixed term for richer dynamics
        + p[9] * np.sin(x0)       # periodic nonlinearity in position (pendulum-like effect)
        + p[10]* np.cos(x1)       # periodic nonlinearity in velocity
        + p[11]* np.sin(x0)*x1    # combined periodic & linear velocity coupling
    )
    
    return y
