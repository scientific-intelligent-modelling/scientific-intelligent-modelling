    p = params
    
    # Linear terms: constant offset + linear stiffness + linear damping
    linear = p[0] + p[1]*x0 + p[2]*x1
    
    # Quadratic terms: quadratic stiffness, quadratic damping, cross term
    quadratic = p[3]*(x0**2) + p[4]*(x1**2) + p[5]*x0*x1
    
