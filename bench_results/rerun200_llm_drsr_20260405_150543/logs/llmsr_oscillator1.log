def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physically motivated nonlinear oscillator acceleration model with:
    - linear restoring force (-k*x)
    - linear damping (-c*v)
    - cubic stiffness nonlinearity (-alpha*x^3)
    - quadratic and cubic velocity nonlinearities (nonlinear damping)
    - mixed polynomial coupling terms
    - periodic nonlinearities in position and velocity
    - includes both sine and cosine terms for richer periodic effects

    Parameters:
    - x0 (np.ndarray): position at time t
    - x1 (np.ndarray): velocity at time t
    - params (np.ndarray): array of length at least 12 containing coefficients
    
    Returns:
    - y (np.ndarray): acceleration values
    """
    
    p = params
    
    y = (
        p[0] +                    # constant offset term (ideally zero)
        p[1] * x0 +               # linear restoring force term (-k*x)
        p[2] * x1 +               # linear damping term (-c*v)
        p[3] * (x0 ** 3) +        # cubic stiffness nonlinearity (-alpha*x^3)
        p[4] * (x1 ** 2) +        # quadratic velocity nonlinearity
        p[5] * (x0 * x1) +        # cross product term coupling position & velocity
        p[6] * ((x0 ** 2) * x1) + # mixed cubic polynomial term
        p[7] * (x1 ** 3) +        # cubic velocity nonlinearity
        p[8] * np.sin(x0) +       # periodic nonlinearity in position (sine)
        p[9] * np.cos(x0) +       # periodic nonlinearity in position (cosine)
        p[10]* np.sin(x1) +       # periodic nonlinearity in velocity (sine)
        p[11]* np.cos(x1)         # periodic nonlinearity in velocity (cosine)
    )
    
    return y
