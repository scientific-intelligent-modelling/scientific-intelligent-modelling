        + p[6]*x0**3
        + p[7]*(x0**2)*x1
        + p[8]*x0*(x1**2)
        + p[9]*x1**3
        + p[10]*np.abs(x1)*x1   # quadratic velocity damping term (like drag)
        + p[11]*sign_x1         # Coulomb friction-like term (velocity direction dependent)
    )
    
    return y
