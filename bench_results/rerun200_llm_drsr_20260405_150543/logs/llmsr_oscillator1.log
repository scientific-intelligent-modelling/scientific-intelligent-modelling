def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration as a nonlinear function of position and velocity including:
    - constant term
    - linear restoring force (-k*x)
    - linear damping (-c*v)
    - cubic stiffness nonlinearity (x0**3)
    - quadratic velocity damping (x1**2)
    - quadratic stiffness nonlinearity (x0**2)
    - cross linear coupling between position and velocity (x0*x1)
    - cubic velocity damping (x1**3)
    - mixed cubic-quadratic cross terms ((x0**2)*x1 and x0*(x1**2))
    - quartic stiffness nonlinearity (x0**4)
    - quartic velocity nonlinearity (x1**4)

    Parameters:
        params: array-like with length 12

    Returns:
        y: acceleration array
    """
    
    # Unpack parameters for readability
    c0 = params[0]   # constant offset acceleration
    c1 = params[1]   # linear position coefficient (-k)
    c2 = params[2]   # linear velocity coefficient (-c)
    
    c3 = params[3]   # cubic position coefficient
    c4 = params[4]   # quadratic velocity coefficient
    
    c5 = params[5]   # quadratic position coefficient
    
    c6 = params[6]   # cross linear term: position * velocity
    
    c7 = params[7]   # cubic velocity coefficient
    
    c8 = params[8]   # mixed term: (position squared) * velocity
    
    c9  = params[9]  # mixed term: position * (velocity squared)
    
    c10 = params[10] # quartic position coefficient
    
    c11 = params[11] # quartic velocity coefficient

    
    y = (
        c0 +
        c1 * x0 +
        c2 * x1 +
        c3 * x0 ** 3 +
        c4 * x1 ** 2 +
        c5 * x0 ** 2 +
        c6 * x0 * x1 +
        c7 * x1 ** 3 +
        c8 * (x0 ** 2) * x1 +
        c9 * x0 * (x1 ** 2) +
        c10 * (x0 ** 4) +
        c11 * (x1 ** 4)
     )
    
    return y
