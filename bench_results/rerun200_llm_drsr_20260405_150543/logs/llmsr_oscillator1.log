def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Background:
    Calculate Acceleration in Non-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Physical considerations:
    - The acceleration in a nonlinear oscillator typically depends on restoring forces (position terms),
      damping or velocity-dependent forces (velocity terms), and nonlinear coupling terms.
    - Common nonlinearities include cubic stiffness (x0^3) and velocity-dependent damping (x1, x1^3).
    - Cross terms between position and velocity can represent more complex interactions.

    Model form:
    y = p0 
        + p1*x0 + p2*x1 
        + p3*x0**2 + p4*x0*x1 + p5*x1**2 
        + p6*x0**3 + p7*(x0**2)*x1 + p8*x0*(x1**2) + p9*x1**3
        + p10*np.sin(p11 * x0)

    Parameters:
    - params: array of length at least 12

    Returns:
    - y: acceleration values as numpy array
    """
    
    p = params
    
    # Linear and polynomial terms
    y_poly = (
        p[0] 
        + p[1]*x0 
        + p[2]*x1 
        + p[3]*x0**2 
        + p[4]*x0*x1 
        + p[5]*x1**2 
        + p[6]*x0**3 
        + p[7]*(x0**2)*x1 
        + p[8]*x0*(x1**2) 
        + p[9]*x1**3
    )
    
    # Add a sinusoidal term to capture possible nonlinear periodic effects
    y_sin = p[10] * np.sin(p[11] * x0)
    
    return y_poly + y_sin
