def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Physically meaningful nonlinear oscillator acceleration model.

    Model:
        y = params[0]                  # constant forcing term (could be zero)
          + params[1]*x0               # linear restoring force (-k*x)
          + params[2]*x1               # linear damping (-c*v)
          + params[3]*(x0**3)          # cubic stiffness nonlinearity (Duffing)
          + params[4]*(x1**2 * x0)     # nonlinear velocity squared times position coupling
          + params[5]*(x1**3)          # cubic velocity damping nonlinearity

    Parameters:
        - x0: Position at time t (numpy array)
        - x1: Velocity at time t (numpy array)
        - params: Coefficients for each term (length 6 numpy array)

    Returns:
        Acceleration y as numpy array.
    """
    return (
        params[0]
        + params[1]*x0
        + params[2]*x1
        + params[3]*(x0**3)
        + params[4]*(x0 * (x1**2))
        + params[5]*(x1**3)
    )
