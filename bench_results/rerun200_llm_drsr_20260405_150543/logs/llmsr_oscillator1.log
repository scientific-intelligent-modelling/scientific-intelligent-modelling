def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Further improved version of the nonlinear harmonic oscillator acceleration model.

    This version explicitly separates:
    - constant forcing terms,
    - linear and nonlinear stiffness (restoring force) terms,
    - linear and nonlinear damping terms,
    - mixed coupling terms between position and velocity,
    - higher order polynomial nonlinearities up to quartic order.

    Parameters:
    - x0 (np.ndarray): Position at time t.
    - x1 (np.ndarray): Velocity at time t.
    - params (np.ndarray): Array of 12 coefficients:
        params[0]: constant offset / external forcing term
        params[1]: linear stiffness coefficient (-k)
        params[2]: cubic stiffness coefficient (-beta)
        params[3]: quartic stiffness coefficient (-delta)
        params[4]: linear damping coefficient (-c)
        params[5]: quadratic velocity damping coefficient
        params[6]: cubic velocity damping coefficient
        params[7]: quadratic position nonlinearity coefficient
        params[8]: cross term coefficient (x0 * x1)
        params[9]: mixed nonlinear coupling term (x0^2 * x1)
        params[10]: mixed nonlinear coupling term (x0 * x1^2)
        params[11]: additional constant or bias if needed

    Returns:
    - y (np.ndarray): acceleration values at given positions and velocities.
    
    Physical interpretation example:
      y = external_force 
          + restoring_force_terms 
          + damping_terms 
          + mixed_nonlinear_terms
          + bias_term
          
      where restoring_force_terms include linear, cubic, quartic in position,
      damping_terms include linear and nonlinear in velocity,
      mixed_nonlinear_terms couple position and velocity nonlinearly.
    """
    
    # Unpack parameters for clarity
    F_ext = params[0]       # constant external force / offset
    k_lin = params[1]       # linear stiffness (-k)
    k_cubic = params[2]     # cubic stiffness (-beta)
    k_quartic = params[3]   # quartic stiffness (-delta)
    
    c_lin = params[4]       # linear damping (-c)
    c_quad_v = params[5]     # quadratic velocity damping
    c_cubic_v = params[6]   # cubic velocity damping
    
    q_pos = params[7]       # quadratic position nonlinearity
    
    cross_term = params[8]  # cross term x0*x1
    
    mix_x02_v1 = params[9]  # mixed nonlinear coupling x0^2 * x1
    mix_x01_v2 = params[10]  # mixed nonlinear coupling x0 * x1^2
    
    bias = params[11]       # additional constant/bias if needed

    
    y = (
          F_ext + bias 
          + k_lin * x0 
          + k_cubic * (x0 ** 3) 
          + k_quartic * (x0 ** 4) 
          + q_pos * (x0 ** 2) 
          
          + c_lin * x1 
          + c_quad_v * (x1 ** 2) 
          + c_cubic_v * (x1 ** 3) 
          
          + cross_term * x0 * x1 
          
          + mix_x02_v1 * ((x0 ** 2) * x1) 
          + mix_x01_v2 * (x0 * (x1 ** 2))
      )
    
    return y
