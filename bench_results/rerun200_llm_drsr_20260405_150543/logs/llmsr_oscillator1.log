def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further refines the nonlinear harmonic oscillator acceleration model by:
    - explicitly separating linear and nonlinear damping terms,
    - including cubic stiffness and quartic stiffness terms,
    - adding mixed nonlinear coupling terms between position and velocity,
    - allowing for a constant offset term.

    Parameters:
    - params (np.ndarray): array of coefficients with length at least 12:
        params[0]: constant offset (usually zero)
        params[1]: linear stiffness coefficient (-alpha)
        params[2]: cubic stiffness coefficient (-beta)
        params[3]: linear damping coefficient (-gamma)
        params[4]: quadratic position term coefficient
        params[5]: quadratic velocity term coefficient
        params[6]: cross term coefficient (x0 * x1)
        params[7]: quartic position term coefficient (x0^4)
        params[8]: cubic velocity term coefficient (x1^3)
        params[9]: mixed nonlinear coupling term (x0^2 * x1)
        params[10]: mixed nonlinear coupling term (x0 * x1^2)
        params[11]: higher order constant or bias if needed

    Returns:
    - y (np.ndarray): acceleration values.
    """
    
    c = params[0]       # constant offset
    k1 = params[1]      # linear stiffness
    k3 = params[2]      # cubic stiffness
    d = params[3]       # linear damping
    qx = params[4]      # quadratic position
    qv = params[5]      # quadratic velocity
    cross = params[6]   # cross term x0*x1
    k4 = params[7]      # quartic position nonlinearity
    v3 = params[8]      # cubic velocity nonlinearity
    mix1 = params[9]     # mixed nonlinear coupling x0^2 * x1
    mix2 = params[10]     # mixed nonlinear coupling x0 * x1^2
    c_extra = params[11]  # extra constant or bias
    
    return (
          c + c_extra 
        + k1 * x0 
        + k3 * x0**3 
        + k4 * x0**4 
        + d * x1 
        + qx * x0**2 
        + qv * x1**2 
        + v3 * x1**3 
        + cross * x0 * x1 
        + mix1 * (x0**2) * x1 
        + mix2 * x0 * (x1**2)
    )
