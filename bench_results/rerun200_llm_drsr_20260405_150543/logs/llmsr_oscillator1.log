def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1` with extended nonlinearities and mixed terms.

    Parameters:
    - x0 (np.ndarray): position at time t
    - x1 (np.ndarray): velocity at time t
    - params (np.ndarray): array of length at least 12 containing coefficients

    Returns:
    - y (np.ndarray): acceleration values
    """
    p = params
    
    # Base linear + polynomial + periodic terms from v1
    y = (
        p[0] +                  # constant offset acceleration term (usually zero)
        p[1] * x0 +             # linear restoring force term (-k*x)
        p[2] * x1 +             # linear damping term (-c*v)
        p[3] * x0**2 +          # quadratic stiffness nonlinearity
        p[4] * x1**2 +          # quadratic damping nonlinearity
        p[5] * x0 * x1 +        # cross term coupling position and velocity
        p[6] * x0**3 +          # cubic stiffness nonlinearity
        p[7] * x1**3 +          # cubic damping nonlinearity
        p[8] * (x0**2) * x1 +   # mixed cubic term: quadratic position times velocity
        p[9] * x0 * (x1**2) +   # mixed cubic term: position times quadratic velocity
        p[10]* np.sin(x0) +     # periodic nonlinearity in position (e.g., pendulum effect)
        p[11]* np.cos(x1)       # periodic nonlinearity in velocity 
    )
    
    return y
