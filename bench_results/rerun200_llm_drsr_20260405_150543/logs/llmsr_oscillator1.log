def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This function models the acceleration y given position x0 and velocity x1,
    incorporating physically meaningful nonlinear stiffness and damping terms,
    smooth approximations for friction-like effects, asymmetric potential bias,
    higher-order cross terms, and refined nonlinear damping.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Array of 12 parameters controlling each term

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    p = params
    
    # Smooth sign approximations to avoid discontinuities in optimization
    sign_x0 = np.tanh(10 * x0)   # approx sign(x0)
    sign_x1 = np.tanh(10 * x1)   # approx sign(x1)
    
    abs_x1 = np.abs(x1)
    
    # Additional nonlinear terms for richer dynamics
    y = (
        p[0]                          # constant offset / external forcing
        
        - p[1] * x0                  # linear restoring force (-k*x), negative for restoring
        
        - p[2] * x1                  # linear damping force (-c*v), negative for dissipation
        
        + p[3] * (x0 ** 2)          # quadratic stiffness nonlinearity
        
        + p[4] * (x1 ** 2)          # quadratic velocity nonlinearity (nonlinear damping)
        
        - p[5] * (x0 ** 3)          # cubic stiffness nonlinearity (Duffing type), negative to keep restoring nature
        
