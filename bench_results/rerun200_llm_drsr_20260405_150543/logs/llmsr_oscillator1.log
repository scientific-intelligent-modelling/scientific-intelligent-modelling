def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration as a nonlinear function of position and velocity including:
    - constant term
    - linear terms in position and velocity (restoring force and damping)
    - cubic position term (Duffing-type nonlinearity)
    - quadratic terms in position and velocity
    - cross terms between position and velocity
    - cubic velocity term to capture nonlinear damping effects
    - mixed higher order cross terms

    y = params[0] 
        + params[1]*x0 
        + params[2]*x1 
        + params[3]*x0**3 
        + params[4]*x1**2 
        + params[5]*x0**2 
        + params[6]*x0*x1
        + params[7]*x1**3
        + params[8]*(x0**2)*x1
        + params[9]*x0*(x1**2)

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 10.
    """
    
    constant = params[0]
    
    linear_pos = params[1] * x0          # linear restoring force ~ -k*x
    linear_vel = params[2] * x1          # linear damping ~ -c*v
    
    cubic_pos = params[3] * (x0 ** 3)   # Duffing nonlinearity
    
    quad_vel = params[4] * (x1 ** 2)     # quadratic velocity term (nonlinear damping)
    
    quad_pos = params[5] * (x0 ** 2)     # quadratic position term
    
    cross_linear = params[6] * (x0 * x1) # cross term between position and velocity
    
    cubic_vel = params[7] * (x1 ** 3)   # cubic velocity term
    
    cross_quad_pos_vel = params[8] * ((x0 ** 2) * x1)  # higher order mixed term
    
    cross_pos_quad_vel = params[9] * (x0 * (x1 ** 2)) # another higher order mixed term

    
    return (
        constant +
        linear_pos +
        linear_vel +
        cubic_pos +
        quad_vel +
        quad_pos +
        cross_linear +
        cubic_vel +
        cross_quad_pos_vel +
        cross_pos_quad_vel
       )
