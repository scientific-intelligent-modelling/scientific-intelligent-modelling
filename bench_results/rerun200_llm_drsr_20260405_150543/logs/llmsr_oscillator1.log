        params (np.ndarray): Array of 12 parameters [p0,...p11]

    Returns:
        np.ndarray: Acceleration at time t
    """

    # Unpack parameters for clarity
    # Note: Negative signs for restoring force and damping are applied here explicitly,
    # assuming params represent positive coefficients.
    
    k1 = params[0]   # linear stiffness coefficient
    c1 = params[1]   # linear damping coefficient
    
    k2 = params[2]   # quadratic stiffness coefficient
