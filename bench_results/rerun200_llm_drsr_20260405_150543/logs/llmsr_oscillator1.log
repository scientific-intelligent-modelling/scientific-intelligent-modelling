def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further extends the nonlinear harmonic oscillator acceleration model by adding:
    - quintic position stiffness term (x0**5)
    - quartic velocity damping term (x1**4)
    - mixed quintic position-velocity coupling ((x0**4)*x1)
    - mixed cubic position * quadratic velocity coupling ((x0**3)*(x1**2))
    - absolute velocity linear damping term (|x1|)
    
    Parameters:
    - x0: Position at time t (np.ndarray)
    - x1: Velocity at time t (np.ndarray)
    - params: Array of coefficients (length >= 19)

    Returns:
    - y: Acceleration at time t as numpy array
    """
    
    # Ensure params has enough length; pad with zeros if necessary
    if len(params) < 19:
        params = np.pad(params, (0, 19 - len(params)), 'constant')
    
    p = params
    
    sign_x1 = np.sign(x1)
    
    y = (
          p[0]                      # constant term
        + p[1] * x0               # linear position restoring force (-k*x)
        + p[2] * x1               # linear velocity damping (-c*v)
        + p[3] * (x0 ** 2)        # quadratic position nonlinearity
        + p[4] * (x1 ** 2)        # quadratic velocity nonlinearity
        + p[5] * (x0 * x1)        # cross term position*velocity coupling
        + p[6] * (x0 ** 3)        # cubic position nonlinearity (Duffing-type)
        + p[7] * (x1 ** 3)        # cubic velocity nonlinearity
        + p[8] * ((x0 ** 2) * x1) # mixed higher order term
        + p[9] * (x0 * (x1 ** 2)) # another mixed higher order term
        + p[10]* np.abs(x1)*x1     # quadratic velocity damping / drag-like term
        + p[11]* sign_x1           # Coulomb friction-like term 
        + p[12]* (x0 ** 4)         # quartic stiffness nonlinearity 
        + p[13]* ((x0 ** 3)* x1)   # cubic position times linear velocity coupling 
      
      # New terms added in v2:
        + p[14]* (np.abs(x1))       # absolute value of velocity linear damping/forcing 
        + p[15]* (x0 ** 5)          # quintic stiffness nonlinearity 
        + p[16]* (x1 ** 4)          # quartic velocity nonlinearity/damping 
        + p[17]* ((x0 ** 4)* x1)   # quartic position times linear velocity coupling 
        + p[18]* ((x0 **3)*(x1**2))# cubic position times quadratic velocity coupling 
    )
    
    return y
