def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0` representing acceleration in a nonlinear harmonic oscillator.
    
    Model:
        y = params[0] 
          + params[1] * x0 
          + params[2] * x1 
          + params[3] * x0**2 
          + params[4] * x1**2 
          + params[5] * (x0**3)
    
    Physically meaningful terms include linear and cubic position terms and linear velocity term.
    
    Parameters:
        - x0: Position at time t
        - x1: Velocity at time t
        - params: Coefficients for each term
    
    Returns:
        Acceleration y as numpy array.
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * (x0 ** 2)
        + params[4] * (x1 ** 2)
        + params[5] * (x0 ** 3)
    )
