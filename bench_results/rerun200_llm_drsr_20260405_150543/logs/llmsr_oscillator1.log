def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculate acceleration y in a nonlinear harmonic oscillator given position x0 and velocity x1.

    Model:
        y = -params[0] * x0                 # Linear restoring force (spring)
          - params[1] * x1                 # Linear damping proportional to velocity
          - params[2] * (x0 ** 3)          # Cubic stiffness nonlinearity
          - params[3] * (x1 ** 3)          # Cubic damping nonlinearity
          + params[4] * (x0 ** 2)          # Quadratic position term (nonlinear stiffness)
          + params[5] * x0 * x1            # Cross term between position and velocity
          + params[6] * (x1 ** 2)          # Quadratic velocity term (nonlinear damping)
          + params[7]                       # Constant offset term / external forcing bias
          + params[8] * np.sin(x0)         # Periodic restoring force component
          + params[9] * np.cos(x1)         # Periodic damping/forcing component
          + params[10]* (x0 ** 5)           # Quintic stiffness term for stronger nonlinearity in restoring force
          + params[11]* ((x0 **3) *(x1**2))# Mixed higher order nonlinear interaction
          + params[12]* ((x0**4)*x1)       # Quartic position times linear velocity cross-term 
          + params[13]* ((x1**4))           # Quartic velocity term for strong nonlinear damping 
          + params[14]* np.sin(2*x0)        # Second harmonic of periodic restoring force 
          + params[15]* np.cos(2*x1)        # Second harmonic of periodic forcing/damping

    Parameters:
        - x0: Position at time t (np.ndarray)
        - x1: Velocity at time t (np.ndarray)
        - params: Coefficients array of length 16

    Returns:
        Acceleration y as numpy array.
    """
    
    return (
        -params[0] * x0 
        - params[1] * x1 
        - params[2] * (x0 ** 3)
        - params[3] * (x1 ** 3)
        + params[4] * (x0 ** 2)
        + params[5] * x0 * x1 
        + params[6] * (x1 ** 2)
        + params[7]
        + params[8] * np.sin(x0)
        + params[9] * np.cos(x1)
        + params[10]* (x0 ** 5)
        + params[11]* ((x0 **3) *(x1**2))
        + params[12]* ((x0**4)*x1)
        + params[13]* ((x1**4))
        + params[14]* np.sin(2*x0)
        + params[15]* np.cos(2*x1)
    )
