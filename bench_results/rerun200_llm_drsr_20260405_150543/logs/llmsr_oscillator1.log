def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version includes:
    - Constant offset term
    - Linear terms in position and velocity (restoring force and damping)
    - Quadratic terms in position, velocity, and their cross product
    - Cubic terms in position and velocity
    - Mixed cubic cross terms coupling position and velocity powers
    - Quartic stiffness term in position
    - Quartic mixed term coupling cubic position with velocity
    - Additional quartic mixed term coupling squared position with squared velocity

    Physically:
    - Linear terms model basic harmonic oscillator restoring force (-k*x) and linear damping (-c*v)
    - Quadratic and cubic terms model Duffing-type nonlinearities and nonlinear damping effects
    - Quartic terms capture stronger anharmonicity effects or higher order nonlinear interactions

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Array of 13 coefficients

            params[0]: constant offset / bias term
            params[1]: linear stiffness coefficient (~ restoring force)
            params[2]: linear damping coefficient (~ velocity dependent force)
            params[3]: quadratic position nonlinearity coefficient
            params[4]: quadratic velocity nonlinearity coefficient
            params[5]: quadratic cross term coefficient (x0 * x1)
            params[6]: cubic stiffness nonlinearity coefficient (x0^3)
            params[7]: cubic velocity nonlinearity coefficient (x1^3)
            params[8]: mixed cubic term coefficient ((x0^2)*x1)
            params[9]: mixed cubic term coefficient (x0*(x1^2))
            params[10]: quartic stiffness nonlinearity coefficient (x0^4)
            params[11]: quartic mixed term ((x0^3)*x1)
            params[12]: quartic mixed cross term ((x0^2)*(x1^2))

    Returns:
        np.ndarray: Acceleration y at time t.
    """
    
    return (
          params[0]                      # constant offset / bias term
        + params[1] * x0                # linear stiffness ~ restoring force (-k*x)
        + params[2] * x1                # linear damping ~ velocity dependent force (-c*v)
        + params[3] * (x0 ** 2)         # quadratic position nonlinearity 
        + params[4] * (x1 ** 2)         # quadratic velocity nonlinearity 
        + params[5] * (x0 * x1)         # quadratic cross coupling between position & velocity 
        + params[6] * (x0 ** 3)         # cubic stiffness nonlinearity (Duffing type)
        + params[7] * (x1 ** 3)         # cubic velocity nonlinearity 
        + params[8] * ((x0 ** 2) * x1)  # mixed cubic coupling squared position with velocity 
        + params[9] * (x0 * (x1 ** 2))  # mixed cubic coupling position with squared velocity 
        + params[10] * (x0 ** 4)         # quartic stiffness nonlinearity for stronger anharmonicity 
        + params[11] * ((x0 ** 3) * x1)   # quartic mixed coupling cubic position with velocity 
        + params[12] * ((x0 ** 2) * (x1 ** 2))   # quartic mixed cross coupling squared pos & squared vel 
