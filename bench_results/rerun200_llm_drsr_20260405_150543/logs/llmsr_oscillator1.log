def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved version of `equation_v1` with higher-order nonlinear and cross terms.

    Models acceleration y as a function of position x0 and velocity x1:

    y = c0
        - k1 * x0
        - c_damp * x1
        - k2 * x0^2
        - c_damp_nl * x1^2
        - k3 * x0^3
        - c_damp_cubic * x1^3
        - cross_lin * (x0 * x1)
        - cross_quad_pos_vel * (x0^2 * x1)
        - cross_quad_vel_pos * (x0 * x1^2)
        - cross_cubic_pos_vel * (x0^3 * x1)
        - mixed_quad_term * (x0^2 * x1^2)
        - k4 * (x0^4)
        - c_damp_quartic_vel * (x1^4)
        - cross_quartic_pos_vel_cubic_vel * (x0^4 * x1)
        - cross_cubic_pos_quartic_vel  * (x0^3  * x1^4)
        - k5  *(x0**5)

    Parameters:
    -----------
    x0 : np.ndarray
        Position at time t.
    x1 : np.ndarray
        Velocity at time t.
    params : np.ndarray
        Array of 12 parameters:
            params[0]  = c0                     # constant offset
            params[1]  = k1                     # linear stiffness coefficient
            params[2]  = c_damp                 # linear damping coefficient
            params[3]  = k2                     # quadratic stiffness coefficient
            params[4]  = c_damp_nl              # quadratic damping coefficient
            params[5]  = k3                     # cubic stiffness coefficient
            params[6]  = c_damp_cubic           # cubic damping coefficient
            params[7]  = cross_lin              # linear cross term coeff. (x0*x1)
            params[8]  = cross_quad_pos_vel     # quadratic pos-vel term coeff. (x0²*x1)
            params[9]  = cross_quad_vel_pos     # quadratic vel-pos term coeff. (x0*x1²)
            params[10] = mixed_quad_term         # quartic mixed term coeff. (x0²*x1²)
            params[11] = k4                      # quartic stiffness coefficient for position

    Note:
      Since we have only MAX_NPARAMS=12 parameters, some higher order terms are combined or omitted.
      You can extend the parameter vector if needed.

    Returns:
    --------
    y : np.ndarray
       Calculated acceleration.
    """

    c0               = params[0]
    k1               = params[1]
    c_damp           = params[2]
    k2               = params[3]
    c_damp_nl        = params[4]
    k3               = params[5]
    
    c_damp_cubic     = params[6]
    
    cross_lin          = params[7]
    
    cross_quad_pos_vel   = params[8]
    
    cross_quad_vel_pos   = params[9]

    mixed_quad_term     = params[10]

    k4                  = params[11]

    
    return (
          c0 
        - k1                 * x0 
        - c_damp             * x1 
        - k2                 * (x0 ** 2) 
        - c_damp_nl          * (x1 ** 2) 
        - k3                 * (x0 ** 3) 
        - c_damp_cubic       * (x1 ** 3) 
        - cross_lin          * (x0      *   x1) 
        - cross_quad_pos_vel   *((x0 ** 2)   *(x1)) 
        - cross_quad_vel_pos   *((x0)       *(x1 ** 2)) 
         # Quartic mixed term capturing interaction between squared position and squared velocity:
         - mixed_quad_term     *((x0 ** 2)   *(x1 ** 2))  
         # Quartic stiffness in position:
         - k4                  *(x0 **4 )
        
       )
