        # Quartic / higher order mixed cross terms
        + params[9] * ((x0 ** 3) * x1)
        + params[10] * (x0 * (x1 ** 3))
        
        # Additional quartic term: e.g., pure quartic stiffness or damping term 
        + params[11] * ((x0 ** 4) if np.all(np.isfinite(x0)) else 0)  
