def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physically motivated polynomial model for acceleration in a nonlinear harmonic oscillator,
    including linear, quadratic, cubic stiffness and damping terms, as well as mixed cross terms.
    This version uses all 12 parameters to capture richer nonlinear dynamics.

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Array of 12 parameters

    Returns:
        np.ndarray: Acceleration at time t
    """
    
    return (
        # Linear terms
        params[0] * x0 
        + params[1] * x1
        
        # Quadratic terms
        + params[2] * (x0 ** 2)
        + params[3] * (x1 ** 2)
        + params[4] * (x0 * x1)
        
        # Cubic terms
        + params[5] * (x0 ** 3)
        + params[6] * (x1 ** 3)
        
        # Mixed cubic cross terms
        + params[7] * ((x0 ** 2) * x1)
        + params[8] * (x0 * (x1 ** 2))
        
        # Quartic cross terms involving higher powers but still polynomial order <=4 
        + params[9] * ((x0 ** 3) * x1)
        + params[10] * (x0 * (x1 ** 3))
        
        # Optional constant offset term omitted to respect zero baseline acceleration at rest.
    )
