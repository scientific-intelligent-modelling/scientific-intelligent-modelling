    # Basic polynomial terms
    y = (
        c[0] +
        c[1] * x0 +
        c[2] * x1 +
        c[3] * (x0 ** 2) +
        c[4] * (x0 ** 3) +
        c[5] * (x1 ** 2) +
        c[6] * (x1 ** 3) +
        c[7] * (x0 * x1) +
