def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration y in a nonlinear harmonic oscillator given position (x0) and velocity (x1).
    Includes linear restoring force, damping, nonlinear stiffness (cubic), and nonlinear damping terms.

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of coefficients (length >= 12)

    Returns:
    - y: Acceleration at time t
    """
    p = params

    # Constant term (usually zero in physical oscillators)
    y = p[0]

    # Linear restoring force term (-k*x)
    y += p[1] * x0

    # Linear damping term (-c*v)
    y += p[2] * x1

    # Quadratic nonlinear stiffness terms
    y += p[3] * (x0 ** 2)

    # Quadratic nonlinear damping or velocity squared effect
    y += p[4] * (x1 ** 2)

    # Cubic nonlinear stiffness term (Duffing oscillator type nonlinearity)
    y += p[5] * (x0 ** 3)

    # Cubic velocity term for higher order damping or forcing effects
    y += p[6] * (x1 ** 3)

    # Cross terms capturing coupling between position and velocity
    y += p[7] * (x0 * x1)
    
    # Higher order mixed terms for more complex dynamics
    y += p[8] * ((x0 ** 2) * x1)
    
    y += p[9] * (x0 * (x1 ** 2))

    # Additional higher order cubic cross terms to increase model flexibility
    y += p[10] * ((x0 ** 3) * x1)
    
    y += p[11] * (x0 * (x1 ** 3))

    
    return y
