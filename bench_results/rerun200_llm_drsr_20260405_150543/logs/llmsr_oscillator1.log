def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration as a nonlinear function of position and velocity including:
    - linear, quadratic, cubic position terms (restoring forces)
    - linear, quadratic, cubic velocity terms (damping)
    - cross terms between position and velocity
    - no constant term to maintain physical equilibrium at zero state

    Equation form:

        y = params[0]*x0 
            + params[1]*x0**2 
            + params[2]*x0**3 
            + params[3]*x1 
            + params[4]*x1**2 
            + params[5]*x1**3 
            + params[6]*x0*x1
            + params[7]*(x0**2)*x1
            + params[8]*x0*(x1**2)

    Parameters:
    - x0 (np.ndarray): Position at time t.
    - x1 (np.ndarray): Velocity at time t.
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 9.

    Returns:
    - y (np.ndarray): Calculated acceleration.
    """
    
    pos_linear = params[0] * x0
    pos_quad = params[1] * (x0 ** 2)
    pos_cubic = params[2] * (x0 ** 3)

    vel_linear = params[3] * x1
    vel_quad = params[4] * (x1 ** 2)
    vel_cubic = params[5] * (x1 ** 3)

    cross_linear = params[6] * x0 * x1
    cross_quad_1 = params[7] * ((x0 ** 2) * x1)
    cross_quad_2 = params[8] * (x0 * (x1 ** 2))

    return (
        pos_linear +
        pos_quad +
        pos_cubic +
        vel_linear +
        vel_quad +
        vel_cubic +
        cross_linear +
        cross_quad_1 +
        cross_quad_2
     )
