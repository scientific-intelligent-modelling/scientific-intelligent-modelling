def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This model represents the acceleration of a nonlinear harmonic oscillator as a function of position (x0)
    and velocity (x1), including linear and nonlinear restoring forces, damping effects,
    friction-like effects, and higher-order coupling terms.

    Model form:
        y = p0
            + p1*x0 + p2*x1
            + p3*x0**2 + p4*x0*x1 + p5*x1**2
            + p6*x0**3 + p7*(x0**2)*x1 + p8*x0*(x1**2) + p9*x1**3
            + p10*|x1|*x1           # quadratic velocity damping (drag-like)
            + p11*sign(x1)          # Coulomb friction-like term
            + p12*(x0**4)           # quartic stiffness term (higher order restoring force)
            + p13*(x0**3)*x1        # cubic position * linear velocity coupling
            + p14*(x0**2)*(x1**2)   # quadratic position * quadratic velocity coupling
            + p15*x0*(x1**3)        # linear position * cubic velocity coupling
            + p16*(x1**4)           # quartic velocity damping term (strong nonlinear drag)
            + p17*np.exp(-abs(x0))  # exponential decay with position (e.g., softening effect)
            + p18*np.tanh(x1)       # smooth saturation effect on velocity

    Parameters:
    - x0: position at time t (np.ndarray)
    - x1: velocity at time t (np.ndarray)
    - params: array-like with length >= 19

    Returns:
    - y: acceleration at time t as numpy array
    """

    if len(params) < 19:
        params = np.pad(params, (0, 19 - len(params)), 'constant')

    p = params

    sign_x1 = np.sign(x1)

    y = (
          p[0]
        + p[1]*x0 
        + p[2]*x1 
        + p[3]*x0**2 
        + p[4]*x0*x1 
        + p[5]*x1**2 
        + p[6]*x0**3 
        + p[7]*(x0**2)*x1 
        + p[8]*x0*(x1**2) 
        + p[9]*x1**3 
        + p[10]*np.abs(x1)*x1       # quadratic damping term (drag-like)
        + p[11]*sign_x1             # Coulomb friction-like term
        + p[12]*(x0**4)             # quartic stiffness term (higher order restoring force)
        + p[13]*(x0**3)* x1         # cubic position * linear velocity coupling
        + p[14]*( x0 ** 2 ) * ( x1 ** 2 )   # quadratic position * quadratic velocity coupling
        + p[15] * x0 * ( x1 ** 3 )  # linear position * cubic velocity coupling
        + p[16] * ( x1 ** 4 )       # quartic velocity damping term (strong nonlinear drag)
        + p[17] * np.exp(-np.abs(x0))   # softening or saturation effect in restoring force with large displacement
        + p[18] * np.tanh(x1)           # smooth saturation effect on velocity-related forces/damping
    )

    return y
