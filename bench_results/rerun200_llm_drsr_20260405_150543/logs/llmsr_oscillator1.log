def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version extends the nonlinear harmonic oscillator acceleration model by combining:
    - Polynomial nonlinearities up to quartic order in position and velocity,
    - Mixed coupling terms,
    - Non-smooth terms like sign and absolute value functions to model friction-like effects.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Array of parameters with length 12

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    p = params
    
    # Polynomial and mixed terms (from v1)
    poly_terms = (
        p[0] +                    # constant offset
        p[1] * x0 +               # linear stiffness term (-k*x)
        p[2] * x1 +               # linear damping term (-c*v)
        p[3] * x0**2 +            # quadratic position nonlinearity
        p[4] * x1**2 +            # quadratic velocity nonlinearity
        p[5] * x0**3 +            # cubic stiffness nonlinearity (-alpha*x^3)
        p[6] * x0 * x1 +          # cross term position*velocity
        p[7] * x1**3 +            # cubic velocity nonlinearity (higher order damping)
        p[8] * (x0**2) * x1 +     # mixed quadratic position & linear velocity
        p[9] * x0 * (x1**2) +     # mixed linear position & quadratic velocity
        p[10]* x0**4 +            # quartic stiffness nonlinearity
        p[11]* x1**4              # quartic velocity nonlinearity (strong damping)
    )
    
    # Add nonsmooth/friction-like effects using sign and abs functions on velocity and position.
    #
    # Since we have only 12 parameters total, we can replace some polynomial terms with these if desired.
    #
    # Alternatively, if we want to keep all polynomial terms, we can add a few nonsmooth effects weighted by 
    # some of the parameters. Here I propose replacing constant offset with friction-like terms,
    # or you can add them as small corrections if you want.
    
    friction_like = (
        0.5*p[0]*np.sign(x1)      # dry friction proportional to sign of velocity scaled by param 0/2 
      - 0.3*p[3]*np.abs(x1)       # viscous-like damping proportional to abs(velocity), scaled by param 3/3.33 
      + 0.2*p[6]*np.sign(x0)      # piecewise effect depending on sign of position scaled by param 6/5 
      # These coefficients are arbitrary fractions of existing params for demonstration;
      # In practice, you'd assign dedicated parameters for these effects.
      #
      # If you want fully independent parameters for these nonsmooth effects,
      # you'd need more than MAX_NPARAMS=12.
      
      )
    
    return poly_terms + friction_like
