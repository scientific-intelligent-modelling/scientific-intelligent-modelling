def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Models acceleration of a nonlinear harmonic oscillator as:
        y = params[0] + params[1]*x0 + params[2]*x0**3 + params[3]*x1

    where:
        - params[0]: constant offset (can be zero)
        - params[1]: linear stiffness coefficient (negative for restoring force)
        - params[2]: cubic stiffness coefficient (nonlinear term)
        - params[3]: damping coefficient (usually negative)

    Parameters:
    - x0: position at time t
    - x1: velocity at time t
    - params: array of parameters

    Returns:
    - y: acceleration at time t
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * np.power(x0, 3)
        + params[3] * x1
    )
