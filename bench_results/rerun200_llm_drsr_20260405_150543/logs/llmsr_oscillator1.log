def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further extends the nonlinear harmonic oscillator acceleration model by including:
    - Higher order pure stiffness nonlinearities (quartic and quintic)
    - Additional mixed nonlinear terms coupling position and velocity
    - Refined friction-like damping effects using smooth approximations
    - Physically consistent signs for restoring and damping forces

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Array of parameters with length 12

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    p = params
    
    # Smooth approximations for sign functions to avoid discontinuities in optimization
    sign_x0 = np.tanh(10 * x0)   # approx sign(x0)
    sign_x1 = np.tanh(10 * x1)   # approx sign(x1)
    
    abs_x1 = np.abs(x1)
    
    y = (
        p[0]                          # constant offset term
        
        - p[1] * x0                  # linear restoring force (-k*x), negative sign physically correct
        
        - p[2] * x1                  # linear damping force (-c*v), negative sign physically correct
        
        + p[3] * x0**2              # quadratic stiffness nonlinearity
        
        + p[4] * x1**2              # quadratic velocity nonlinearity (nonlinear damping)
        
        - p[5] * x0**3              # cubic stiffness nonlinearity (Duffing type), negative to keep restoring nature
        
        + p[6] * x0 * x1            # cross term coupling position and velocity
        
        + p[7] * x0**2 * x1         # higher order mixed term
        
        + p[8] * x0 * x1**2         # mixed term
        
        - p[9] * sign_x1            # friction-like effect opposing motion, negative to oppose velocity direction
        
        - p[10]* abs_x1             # absolute value velocity effect as additional nonlinear damping, negative to dissipate energy
        
        + p[11]* sign_x0            # piecewise effect depending on position side, can represent asymmetric potential or bias
    )
    
    return y
