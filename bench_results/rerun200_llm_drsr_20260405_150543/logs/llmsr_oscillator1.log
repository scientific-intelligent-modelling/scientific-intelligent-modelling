    # Extended nonlinear oscillator acceleration model:
    # Includes all terms from v1 plus additional mixed nonlinearities and higher harmonics.
    
    y = (
        p[0] +                    # constant offset (ideally zero)
        p[1] * x0 +               # linear restoring force (-k*x)
        p[2] * x1 +               # linear damping (-c*v)
        p[3] * (x0 ** 3) +        # cubic stiffness nonlinearity (-alpha*x^3)
        p[4] * (x1 ** 2) +        # quadratic velocity term (nonlinear damping effect)
        p[5] * (x0 * x1) +        # cross term coupling position & velocity
        p[6] * ((x0 ** 2) * x1) + # mixed cubic term
        p[7] * (x0 ** 4) +        # quartic stiffness nonlinearity
        p[8] * (x1 ** 3) +        # cubic velocity nonlinearity
