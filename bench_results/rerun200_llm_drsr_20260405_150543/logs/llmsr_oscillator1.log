def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration as a nonlinear function of position and velocity with additional cross and higher order mixed terms:
    y = params[0] 
        + params[1]*x0 
        + params[2]*x1 
        + params[3]*x0**3 
        + params[4]*x0**2 
        + params[5]*x1*x0**2 
        + params[6]*x1**3
        + params[7]*x1*x0          # new cross term
        + params[8]*(x1**2)*x0     # new quadratic velocity * linear pos
        + params[9]*(x1**2)*(x0**2) # new quadratic vel * quadratic pos
        + params[10]*x1*(x0**3)    # new cubic mixed term

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 11.
    """
    constant = params[0]
    linear_pos = params[1] * x0
    damping = params[2] * x1
    cubic_pos = params[3] * (x0 ** 3)
    quadratic_pos = params[4] * (x0 ** 2)
    nonlinear_damping = params[5] * x1 * (x0 ** 2)
    cubic_damping = params[6] * (x1 ** 3)

    cross_term = params[7] * (x1 * x0)
    quad_vel_linear_pos = params[8] * ((x1 ** 2) * x0)
    quad_vel_quad_pos = params[9] * ((x1 ** 2) * (x0 ** 2))
    cubic_mixed_term = params[10] * (x1 * (x0 ** 3))

    return (
        constant +
        linear_pos +
        damping +
        cubic_pos +
        quadratic_pos +
        nonlinear_damping +
        cubic_damping +
        cross_term +
        quad_vel_linear_pos +
        quad_vel_quad_pos +
        cubic_mixed_term
    )
