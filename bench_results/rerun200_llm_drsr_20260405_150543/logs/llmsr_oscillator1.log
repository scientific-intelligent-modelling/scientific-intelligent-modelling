def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version adds nonsmooth nonlinearities (sign and absolute value terms)
    to better capture friction-like effects and piecewise nonlinearities,
    while keeping the total number of parameters at 12.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Array of parameters with length 12

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    p0 = params[0]   # constant offset term (usually zero)
    p1 = params[1]   # linear position coefficient (-k)
    p2 = params[2]   # linear velocity coefficient (-c)
    p3 = params[3]   # quadratic position coefficient
    p4 = params[4]   # quadratic velocity coefficient
    p5 = params[5]   # cubic position coefficient (-alpha)
    p6 = params[6]   # cross term: position * velocity
    p7 = params[7]   # cubic velocity coefficient (higher order damping)
    
    # Use remaining parameters for nonlinear mixed terms and nonsmooth effects:
    
    p8 = params[8]   # mixed quadratic term: position^2 * velocity
    p9 = params[9]   # mixed quadratic term: position * velocity^2
    
    p10 = params[10]  # friction-like effect proportional to sign(velocity)
    
    p11 = params[11]  # piecewise effect proportional to sign(position)

    
    return (
        p0 +
        p1 * x0 +
        p2 * x1 +
        p3 * x0**2 +
        p4 * x1**2 +
        p5 * x0**3 +
        p6 * x0 * x1 +
        p7 * x1**3 +
        p8 * (x0**2) * x1 +
        p9 * x0 * (x1**2) +
        p10 * np.sign(x1) +       # models dry friction or Coulomb friction effect
        p11 * np.sign(x0)         # models piecewise stiffness or asymmetric restoring force
     )
