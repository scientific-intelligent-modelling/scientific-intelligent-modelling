def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version adds quartic nonlinearities in position and mixed quartic terms,
    capturing more complex nonlinear oscillator dynamics including Duffing and damping effects.

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of coefficients (length >= 12)

    Returns:
    - y: Acceleration at time t
    """
    p = params

    return (
        p[0]                          # constant term
        + p[1] * x0                   # linear restoring force (-k*x)
        + p[2] * x1                   # linear damping (-c*v)
        + p[3] * (x0 ** 2)            # quadratic position nonlinearity
        + p[4] * (x1 ** 2)            # quadratic velocity nonlinearity
        + p[5] * (x0 * x1)            # cross term position*velocity
        + p[6] * (x0 ** 3)            # cubic position nonlinearity (Duffing-type)
        + p[7] * (x1 ** 3)            # cubic velocity nonlinearity
        + p[8] * ((x0 ** 2) * x1)     # mixed cubic term with squared position and linear velocity
        + p[9] * (x0 * (x1 ** 2))     # mixed cubic term with linear position and squared velocity
        + p[10] * ((x0 ** 2) * (x1 ** 2))   # mixed quartic term with squared position and squared velocity
        + p[11] * (x1 ** 4)           # quartic velocity nonlinearity for stronger anharmonic damping effects
        + (p[12] if len(p)>12 else 0.0) * (x0 ** 4)   # quartic position nonlinearity for stronger anharmonic restoring force effects 
    )
