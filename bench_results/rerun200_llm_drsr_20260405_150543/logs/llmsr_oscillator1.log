def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator as a polynomial function of position (x0)
    and velocity (x1), including linear, quadratic, cubic terms and cross terms to capture nonlinear
    restoring forces and damping effects. Additionally includes trigonometric nonlinearities,
    smooth approximations of sign and absolute value functions to model piecewise damping/friction,
    and velocity-dependent damping modulated by position.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Coefficients array with length 12

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    # Smooth approximation of sign function using tanh for differentiability
    smooth_sign_x1 = np.tanh(10 * x1)
    
    # Smooth approximation of absolute value using sqrt(x^2 + epsilon)
    epsilon = 1e-6
    smooth_abs_x1 = np.sqrt(x1**2 + epsilon)
    
    return (
        params[0]  # constant offset term
        + params[1] * x0  # linear position term (restoring force)
        + params[2] * x1  # linear velocity term (damping)
        + params[3] * x0**2  # quadratic position term
        + params[4] * x1**2  # quadratic velocity term
        + params[5] * x0**3  # cubic position term (nonlinear restoring force)
        + params[6] * x1**3  # cubic velocity term (nonlinear damping)
        + params[7] * x0 * x1  # cross term between position and velocity
        + params[8] * x0**2 * x1  # mixed quadratic-cubic cross term
        + params[9] * x0 * x1**2  # mixed quadratic-cubic cross term
        + params[10] * np.sin(x0)  # periodic nonlinearity in restoring force
        + params[11] * smooth_sign_x1 * smooth_abs_x1  # smooth friction-like damping proportional to |velocity| with directionality 
    )
