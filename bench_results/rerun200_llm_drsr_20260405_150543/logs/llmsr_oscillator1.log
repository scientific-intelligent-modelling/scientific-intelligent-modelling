        + p[8] * ((x0 ** 2) * x1)   # mixed cubic term
        + p[9] * ((x0 ** 3) * (x1 ** 2))  # higher order mixed polynomial term
        + p[10]* np.sin(x0)          # periodic nonlinearity in position
        + p[11]* np.cos(x1)          # periodic nonlinearity in velocity
    )
    
    return y
