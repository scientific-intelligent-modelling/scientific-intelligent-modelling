        + p12*(x0**4)                  # quartic stiffness nonlinearity
        + p13*(x0**3)*x1               # quartic coupling term
        + p14*(x0**2)*(x1**2)          # quartic coupling term
        + p15*x0*(x1**3)               # quartic coupling term
        + p16*(x1**4)                  # quartic velocity damping

    Parameters:
    - x0: position at time t (np.ndarray)
    - x1: velocity at time t (np.ndarray)
    - params: array-like with length >= 17

    Returns:
    - y: acceleration at time t as numpy array
    """

    if len(params) < 17:
        params = np.pad(params, (0, 17 - len(params)), 'constant')

    p = params

    sign_x1 = np.sign(x1)

    y = (
          p[0]
        + p[1]*x0 
        + p[2]*x1 
        + p[3]*x0**2 
        + p[4]*x0*x1 
        + p[5]*x1**2 
        + p[6]*x0**3 
        + p[7]*(x0**2)*x1 
        + p[8]*x0*(x1**2) 
        + p[9]*x1**3 
        + p[10]*np.abs(x1)*x1       # quadratic drag-like damping term
        + p[11]*sign_x1             # Coulomb friction-like term
        + p[12]*(x0**4)             # quartic stiffness nonlinearity
        + p[13]*(x0**3)*x1          # quartic position-velocity coupling term
        + p[14]*(x0**2)*(x1**2)     # quartic position-velocity coupling term
        + p[15]* x0 * ( x1 ** 3 )   # quartic position-velocity coupling term
        + p[16]*( x1 ** 4 )         # quartic velocity damping nonlinearity
    )

    return y
