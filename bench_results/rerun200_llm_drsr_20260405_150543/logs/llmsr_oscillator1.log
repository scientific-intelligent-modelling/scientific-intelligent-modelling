def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Physically motivated polynomial model for acceleration in a nonlinear harmonic oscillator,
    including linear, quadratic, cubic stiffness and damping terms,
    as well as cross coupling terms between position and velocity up to cubic order.

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: array of 12 parameters controlling each term

    Returns:
    - y: Acceleration at time t
    """

    # Unpack parameters for clarity
    # Stiffness (restoring force) coefficients (negative sign because force opposes displacement)
    k1 = params[0]   # linear stiffness coefficient (-k * x)
    k2 = params[1]   # quadratic stiffness coefficient (-k2 * x^2)
    k3 = params[2]   # cubic stiffness coefficient (-k3 * x^3)

    # Damping coefficients (negative sign because force opposes velocity)
    c1 = params[3]   # linear damping coefficient (-c * v)
    c2 = params[4]   # quadratic damping coefficient (-c2 * v^2)
    c3 = params[5]   # cubic damping coefficient (-c3 * v^3)

    # Cross coupling terms between position and velocity (all with negative sign)
    cross_11 = params[6]     # linear in position and velocity (-a * x * v)
    
    cross_21 = params[7]     # quadratic in position, linear in velocity (-b * x^2 * v)
    
    cross_12 = params[8]     # linear in position, quadratic in velocity (-d * x * v^2)

    cross_31 = params[9]     # cubic in position, linear in velocity (-e * x^3 * v)

    cross_13 = params[10]     # linear in position, cubic in velocity (-f * x * v^3)

    cross_22 = params[11]     # quadratic in both position and velocity (-g * x^2 * v^2)

    
    return (
        - k1 * x0 
        - k2 * (x0 ** 2) 
        - k3 * (x0 ** 3) 
        - c1 * x1 
        - c2 * (x1 ** 2) 
        - c3 * (x1 ** 3) 
        - cross_11 * (x0 * x1) 
        - cross_21 * ((x0 ** 2) * x1) 
        - cross_12 * (x0 * (x1 ** 2)) 
        - cross_31 * ((x0 ** 3) * x1) 
        - cross_13 * (x0 * (x1 ** 3))
        - cross_22* ((x0 ** 2)*(x1 ** 2))
       )
