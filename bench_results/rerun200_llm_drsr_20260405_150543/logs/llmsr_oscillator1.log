def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further extends the nonlinear harmonic oscillator acceleration model by including:
    - quartic and quintic pure stiffness nonlinearities,
    - additional mixed nonlinear terms coupling position and velocity,
    - refined friction-like damping effects combining sign and magnitude of velocity,
    - explicit physical signs for restoring (-k*x) and damping (-c*v) forces.

    Parameters:
    - x0 (np.ndarray): Position at time t
    - x1 (np.ndarray): Velocity at time t
    - params (np.ndarray): Array of parameters with length 12

    Returns:
    - y (np.ndarray): Acceleration at time t
    """
    
    p = params
    
    y = (
        p[0]                          # constant offset term (bias)
        - p[1] * x0                   # linear restoring force (-k*x)
        - p[2] * x1                   # linear damping force (-c*v)
        + p[3] * x0**2                # quadratic stiffness nonlinearity
        + p[4] * x1**2                # quadratic damping nonlinearity
        + p[5] * x0**3                # cubic stiffness nonlinearity (Duffing)
        + p[6] * x0 * x1              # cross term coupling position & velocity
        - p[7] * x1**3                # cubic damping nonlinearity (note negative sign for physical consistency)
        + p[8] * (x0**2) * x1         # mixed cubic term: position^2 * velocity
        + p[9] * x0 * (x1**2)         # mixed cubic term: position * velocity^2
        - p[10]* x0**4                # quartic pure stiffness nonlinearity (negative for stiffening spring)
        + p[11]* np.sign(x1)          # friction-like discontinuous damping effect depending on sign of velocity
    )
    
    return y
