def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Calculates acceleration for a nonlinear harmonic oscillator given position (x0)
    and velocity (x1), using polynomial terms up to cubic order including cross terms.

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length at least 12.
    
    Returns:
    - y (np.ndarray): Calculated acceleration.
    """
    return (
        params[0]  # constant term
        + params[1] * x0  # linear position term
        + params[2] * np.power(x0, 3)  # cubic position term (nonlinear stiffness)
        + params[3] * x1  # linear velocity term (damping)
