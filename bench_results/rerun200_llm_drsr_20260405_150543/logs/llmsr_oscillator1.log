def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` with additional nonlinear damping and forcing terms.
    
    Model form:
    y = p0 
        + p1*x0 
        + p2*x1 
        + p3*x0**2 
        + p4*x0*x1 
        + p5*x1**2 
        + p6*x0**3 
        + p7*(x0**2)*x1 
        + p8*x0*(x1**2) 
        + p9*x1**3
        + p10*np.sign(x1)*np.abs(x1)**(3/2)  # fractional power nonlinear damping
        + p11*np.sign(x0)*np.abs(x0)**(5/2)  # fractional power nonlinear restoring force
    
    Parameters:
    - params: array of length at least 12
    
    Returns:
    - y: acceleration values as numpy array
    """
    
    p = params
    
    y = (
          p[0]
          + p[1]*x0
          + p[2]*x1
          + p[3]*x0**2
          + p[4]*x0*x1
          + p[5]*x1**2
          + p[6]*x0**3
          + p[7]*(x0**2)*x1
          + p[8]*x0*(x1**2)
          + p[9]*x1**3
          # Nonlinear fractional powers to capture complex damping/restoring effects:
          # Use sign to keep function differentiable and defined for negative inputs.
          # These are optional but can improve fit for some physical systems.
          # If not desired, these two terms can be removed.
          # Make sure params length >= 12 before using these.
          +
          (p[10] * np.sign(x1) * np.abs(x1)**(3/2))
          +
          (p[11] * np.sign(x0) * np.abs(x0)**(5/2))
         )
    
    return y
