def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version extends the polynomial basis with more mixed nonlinear terms,
    including cubic velocity terms and combined powers of position and velocity,
    to better capture complex nonlinear oscillator dynamics.

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of coefficients with length MAX_NPARAMS=12

    Returns:
    - y: Acceleration at time t
    """
    p = params

    y = (
        p[0]                      # constant term
        + p[1] * x0               # linear position (restoring force)
        + p[2] * x1               # linear velocity (damping)
        + p[3] * x0**2            # quadratic position nonlinearity
        + p[4] * x1**2            # quadratic velocity nonlinearity (nonlinear damping)
        + p[5] * x0**3            # cubic position nonlinearity (Duffing type)
        + p[6] * x0 * x1          # cross term between position and velocity
        + p[7] * x0**2 * x1       # higher order mixed term
        + p[8] * x0 * x1**2       # another mixed term
