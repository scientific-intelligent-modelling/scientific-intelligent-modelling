        + p[9] * (x0 * (x1 ** 2)) # mixed linear position & quadratic velocity term
        + p[10] * (x0 ** 4)       # quartic stiffness nonlinearity for stronger anharmonicity
        + p[11] * ((x0 ** 3) * x1)# mixed cubic position & linear velocity interaction
    )
