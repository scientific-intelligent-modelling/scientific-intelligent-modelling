    - params: array of 12 coefficients:
        params[0]: constant offset (usually zero)
        params[1]: linear stiffness coefficient (-alpha)
        params[2]: cubic stiffness coefficient (-beta)
        params[3]: linear damping coefficient (-gamma)
        params[4]: quadratic position term coefficient
        params[5]: quadratic velocity term coefficient
        params[6]: cross term coefficient (x0 * x1)
        params[7]: quartic position term coefficient (x0^4)
        params[8]: cubic velocity term coefficient (x1^3)
        params[9]: mixed nonlinear coupling term (x0^2 * x1)
        params[10]: mixed nonlinear coupling term (x0 * x1^2)
        params[11]: extra constant or bias if needed

    Returns:
    - y: acceleration values as np.ndarray.
    """

    c = params[0]       # constant offset
    k1 = params[1]      # linear stiffness (-alpha), restoring force ~ -k*x
    k3 = params[2]      # cubic stiffness (-beta), Duffing nonlinearity ~ -beta*x^3
    d = params[3]       # linear damping (-gamma), force ~ -gamma*v
    qx = params[4]      # quadratic position nonlinearity
    qv = params[5]      # quadratic velocity nonlinearity (nonlinear damping)
    cross = params[6]   # cross term between position and velocity, e.g. x*v coupling
    k4 = params[7]      # quartic stiffness nonlinearity (~x^4) for stronger anharmonicity 
    v3 = params[8]      # cubic velocity nonlinearity (~v^3) for stronger nonlinear damping 
    mix1 = params[9]     # mixed nonlinear coupling term x0^2 * x1 
    mix2 = params[10]     # mixed nonlinear coupling term x0 * x1^2 
    c_extra = params[11]  # extra constant or bias if needed

    
    y = (
          c + c_extra 
          + k1 * x0 
          + k3 * x0**3 
          + k4 * x0**4 
          + d * x1 
          + qx * x0**2 
          + qv * x1**2 
          + v3 * x1**3 
          + cross * x0 * x1 
          + mix1 * (x0**2) * x1 
          + mix2 * x0 * (x1**2)
       )
    
    return y
