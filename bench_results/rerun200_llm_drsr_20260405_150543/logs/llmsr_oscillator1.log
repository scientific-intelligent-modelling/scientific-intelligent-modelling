def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Models acceleration as a polynomial function of position (x0) and velocity (x1),
    including higher-order nonlinear terms to better capture complex dynamics of 
    a nonlinear harmonic oscillator with nonlinear damping and stiffness.

    The model includes:
    - constant term
    - linear terms in position and velocity
    - quadratic terms in position and velocity and their cross product
    - cubic terms in position and velocity and their cross products
    - quartic terms involving powers up to 4 in x0 and x1
    - quintic term in position to capture strong stiffness nonlinearity

    y = params[0]
        + params[1]*x0
        + params[2]*x1
        + params[3]*x0**2
        + params[4]*x0*x1
        + params[5]*x1**2
        + params[6]*x0**3
        + params[7]*(x0**2)*x1
        + params[8]*x0*(x1**2)
        + params[9]*(x1**3)
        + params[10]*x0**5   # quintic stiffness nonlinearity (important for nonlinear oscillators)
        + params[11]*(x1**4) # higher order damping effect

    Parameters:
    - x0 (np.ndarray): Position at time t.
    - x1 (np.ndarray): Velocity at time t.
    - params (np.ndarray): Trainable coefficients, expected length >= 12.
    
    Returns:
    - y (np.ndarray): Acceleration at time t.
    """
    
    return (
        params[0]
