def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of equation including physically meaningful structure:
    - Linear and nonlinear restoring forces (position terms)
    - Linear and nonlinear damping (velocity terms)
    - Cross coupling terms
    
    Parameters:
    - params: array of 12 parameters
    
    Returns:
    - y: acceleration
    """
    
    # Unpack parameters for clarity (optional)
    c0 = params[0]   # constant offset term
    k1 = params[1]   # linear stiffness coefficient (restoring force)
    c_damp = params[2]  # linear damping coefficient
    
    k2 = params[3]   # quadratic stiffness term coefficient
    c_damp_nl = params[4]  # quadratic damping term coefficient
    
    k3 = params[5]   # cubic stiffness term coefficient
    c_damp_cubic = params[6]  # cubic damping term coefficient
    
    cross_lin = params[7]     # linear cross term coefficient (x0 * x1)
    
    cross_quad_pos_vel = params[8]  # quadratic cross term (x0^2 * x1)
    
    cross_quad_vel_pos = params[9]  # quadratic cross term (x0 * x1^2)
    
    cross_cubic_pos_vel = params[10]  # cubic cross term (x0^3 * x1)
    
    cross_cubic_vel_pos = params[11]  # cubic cross term (x0 * x1^3)

    
    return (
        c0 
        - k1 * x0 
