def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator with:
    - linear and cubic stiffness terms in position,
    - linear damping term in velocity,
    - quadratic, cubic, and quartic nonlinearities in position,
    - quadratic, cubic, and quartic nonlinearities in velocity,
    - mixed cross terms including quadratic, cubic, and quartic interactions.

    Parameters:
    - params (np.ndarray): array of coefficients with length at least 15:
        params[0]: constant offset (usually zero)
        params[1]: linear stiffness coefficient (-alpha)
        params[2]: cubic stiffness coefficient (-beta)
        params[3]: linear damping coefficient (-gamma)
        params[4]: quadratic position term coefficient
        params[5]: quadratic velocity term coefficient
        params[6]: cross term coefficient (x0 * x1)
        params[7]: cubic velocity term coefficient (x1^3)
        params[8]: mixed cubic term coefficient ((x0^2)*x1)
        params[9]: mixed cubic term coefficient (x0*(x1^2))
        params[10]: quartic position term coefficient (x0^4)
        params[11]: quartic velocity term coefficient (x1^4)
        params[12]: mixed quartic term coefficient ((x0^3)*x1)
        params[13]: mixed quartic term coefficient ((x0)*(x1^3))
        params[14]: mixed quartic term coefficient ((x0^2)*(x1^2))

    Returns:
    - y (np.ndarray): acceleration values.
    """
    
    c = params[0]      # constant offset
    k1 = params[1]     # linear stiffness
    k3 = params[2]     # cubic stiffness
    d = params[3]      # linear damping
    qx = params[4]     # quadratic position term
    qv = params[5]     # quadratic velocity term
    cross = params[6]  # cross linear term x0*x1
    v3 = params[7]     # cubic velocity term x1^3
    cx21 = params[8]   # mixed cubic x0^2 * x1
    cx12 = params[9]   # mixed cubic x0 * x1^2
    q4x = params[10]   # quartic position term

    q4v = 0 if len(params) < 12 else params[11]   # quartic velocity term x1^4
    cx31 = 0 if len(params) < 13 else params[12]  # mixed quartic x0^3 * x1 
    cx13 = 0 if len(params) < 14 else params[13]  # mixed quartic x0 * x1^3 
    cx22 = 0 if len(params) < 15 else params[14]  # mixed quartic x0^2 * x1^2 

    
    return (
          c 
        + k1 * x0 
        + k3 * x0**3 
        + d * x1 
        + qx * x0**2 
        + qv * x1**2 
        + cross * x0 * x1 
        + v3 * x1**3 
        + cx21 * (x0**2) * x1 
        + cx12 * x0 * (x1**2) 
        + q4x * (x0**4)
        
        + q4v * (x1**4)
        
        + cx31 * (x0**3) * x1
        
        + cx13 * x0 * (x1**3)

        + cx22 * (x0**2) * (x1**2)
        
       )
