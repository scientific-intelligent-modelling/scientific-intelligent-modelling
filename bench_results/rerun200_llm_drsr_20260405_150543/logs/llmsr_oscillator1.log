    quartic_mixed = p[10]*(x0**3)*x1
    
    # Friction-like effect depending on velocity sign (discontinuous damping)
    friction_like = p[11]*np.sign(x1)
    
    y = linear + quadratic + cubic + quartic_mixed + friction_like
    
