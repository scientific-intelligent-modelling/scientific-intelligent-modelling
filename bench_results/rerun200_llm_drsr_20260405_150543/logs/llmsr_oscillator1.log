def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator as:
    - constant offset term
    - linear restoring force proportional to position (typically negative stiffness)
    - linear damping proportional to velocity (typically negative)
    - polynomial nonlinearities in position and velocity up to cubic order
    - cross terms between position and velocity capturing coupling effects
    - periodic restoring force component (e.g., due to pendulum-like behavior)
    - piecewise damping effect depending on velocity direction

    Parameters:
        x0 (np.ndarray): Position at time t
        x1 (np.ndarray): Velocity at time t
        params (np.ndarray): Coefficients array with length 12

    Returns:
        y (np.ndarray): Acceleration at time t
    """
    
    # Unpack parameters for clarity (optional)
    c0 = params[0]   # constant offset
    k1 = params[1]   # linear stiffness coefficient (-k)
    c1 = params[2]   # linear damping coefficient (-c)
    
    k2 = params[3]   # quadratic stiffness nonlinearity
    c2 = params[4]   # quadratic damping nonlinearity
    
    k3 = params[5]   # cubic stiffness nonlinearity
    c3 = params[6]   # cubic damping nonlinearity
    
    cross1 = params[7]  # cross term: x0 * x1
    cross2 = params[8]  # cross term: x0^2 * x1
    cross3 = params[9]  # cross term: x0 * x1^2
    
    periodic_k = params[10]  # amplitude of sinusoidal restoring force component
    
    friction_c = params[11]  # piecewise friction/damping depending on sign(velocity)

    
    y = (
        c0 
        + k1 * x0 
        + c1 * x1 
        + k2 * (x0 ** 2) 
        + c2 * (x1 ** 2) 
        + k3 * (x0 ** 3) 
        + c3 * (x1 ** 3) 
        + cross1 * (x0 * x1) 
        + cross2 * ((x0 ** 2) * x1) 
        + cross3 * (x0 * (x1 ** 2)) 
        + periodic_k * np.sin(x0) 
        + friction_c * np.sign(x1)
     )
    
    return y
