def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v0`.

    Includes nonlinear polynomial terms up to cubic order in position and velocity.
    """
    # Unpack parameters for clarity
    p = params
    # Terms:
    # p[0]: constant
    # p[1]*x0 + p[2]*x1 : linear terms
    # p[3]*x0^2 + p[4]*x1^2 : quadratic pure terms
    # p[5]*x0*x1 : quadratic mixed term
    # p[6]*x0^3 + p[7]*x1^3 : cubic pure terms
    # p[8]*x0^2*x1 + p[9]*x0*x1^2 : cubic mixed terms
    # Additional linear or nonlinear if needed:
    # p[10]*np.sign(x1)*np.abs(x1)**2 (nonlinear damping-like term)
    # p[11]*np.sign(x0)*np.abs(x0)**2 (nonlinear restoring force-like term)

    return (
        p[0]
        + p[1] * x0
        + p[2] * x1
        + p[3] * x0**2
        + p[4] * x1**2
        + p[5] * x0 * x1
        + p[6] * x0**3
        + p[7] * x1**3
        + p[8] * (x0**2) * x1
        + p[9] * x0 * (x1**2)
        + p[10] * np.sign(x1) * np.abs(x1)**2  # optional nonlinear damping-like term 
        + p[11] * np.sign(x0) * np.abs(x0)**2  # optional nonlinear restoring force-like term 
    )
