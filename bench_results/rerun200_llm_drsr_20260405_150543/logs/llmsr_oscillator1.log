        + params[12] * (x0 ** 6)         # sextic stiffness nonlinearity

        + params[13] * ((x0 ** 3) * x1)   # cubic position times linear velocity

        + params[14] * (x0 * (x1 ** 3))   # linear position times cubic velocity

        + params[15] * ((x0 ** 2) * (x1 ** 2))   # quadratic pos. times quadratic vel.
        
    )
