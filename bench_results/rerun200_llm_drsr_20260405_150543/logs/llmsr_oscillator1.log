def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Calculate acceleration for a nonlinear harmonic oscillator with polynomial nonlinearities.

    Parameters:
    - x0: Position at time t
    - x1: Velocity at time t
    - params: Array of 12 parameters corresponding to coefficients of polynomial terms

    Returns:
    - y: Acceleration at time t
    """
    # Constant term (bias)
    term0 = params[0]

    # Linear terms
    term_x = params[1] * x0          # linear restoring force ~ position
    term_v = params[2] * x1          # linear damping force ~ velocity

    # Quadratic terms
    term_x2 = params[3] * (x0 ** 2)
    term_v2 = params[4] * (x1 ** 2)

    # Cubic terms
    term_x3 = params[5] * (x0 ** 3)
    term_v3 = params[6] * (x1 ** 3)

    # Cross terms between position and velocity
    term_xv = params[7] * (x0 * x1)
    
    # Higher order cross terms capturing nonlinear coupling effects
    term_x2v = params[8] * ((x0 ** 2) * x1)
    term_xv2 = params[9] * (x0 * (x1 ** 2))
    
    term_x3v = params[10] * ((x0 ** 3) * x1)
    term_xv3 = params[11] * (x0 * (x1 ** 3))

    
    y = (
        term0 + 
        term_x + 
        term_v + 
        term_x2 + 
        term_v2 + 
        term_x3 + 
        term_v3 +
        term_xv +
        term_x2v +
        term_xv2 +
        term_x3v +
        term_xv3
     )
    
    return y
