def equation(x0: np.ndarray, x1: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Physically motivated polynomial model for acceleration in a nonlinear harmonic oscillator,
    including linear, quadratic, cubic, quintic stiffness terms and linear, quadratic, cubic damping terms,
    as well as cross terms between position and velocity to capture nonlinear coupling effects.

    Parameters indices:
    0: bias (should be zero or near zero physically)
    1: linear coefficient for position (x0)
    2: cubic coefficient for position (x0^3)
    3: linear coefficient for velocity (x1)
    4: quadratic coefficient for position (x0^2)
    5: quadratic coefficient for velocity (x1^2)
    6: cross term coefficient for x0 * x1
    7: quintic coefficient for position (x0^5)
    8: cubic coefficient for velocity (x1^3)
    9: cross term coefficient for x0^2 * x1
    10: cross term coefficient for x0 * x1^2
    11: quartic coefficient for position (x0^4)

    Returns:
        y (np.ndarray): Acceleration values.
    """
    
    return (
        params[0] +                                # bias term
        params[1] * x0 +                           # linear stiffness
        params[4] * np.power(x0, 2) +             # quadratic stiffness
        params[11] * np.power(x0,4) +              # quartic stiffness
        params[2] * np.power(x0, 3) +             # cubic stiffness
        params[7] * np.power(x0,5) +              # quintic stiffness

        params[3] * x1 +                           # linear damping
        params[5] * np.power(x1, 2) +             # quadratic damping
        params[8] * np.power(x1,3) +              # cubic damping

        params[6] * x0 * x1 +                      # cross term linear*linear
        params[9] * np.power(x0,2) * x1 +         # cross term quadratic pos times vel 
        params[10] * x0 * np.power(x1,2)          # cross term pos times quadratic vel 
    )
