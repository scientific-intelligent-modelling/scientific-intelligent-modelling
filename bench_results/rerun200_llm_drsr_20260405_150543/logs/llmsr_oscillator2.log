def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Further improved version of the nonlinear harmonic oscillator acceleration model.

    Model includes:
    - Constant offset
    - Linear and quadratic time dependence
    - Linear stiffness (-k*x), cubic stiffness (-alpha*x^3)
    - Linear damping (-c*v), quadratic & cubic damping nonlinearities
    - Cross terms between position and velocity (x*v)
    - Additional nonlinear cross term (x^2 * v)
    - Sinusoidal forcing with sine and cosine components modulated by time
    - Parametric excitation via time-modulated forcing t*sin(t), t*cos(t)

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array-like with 12 parameters

    Returns:
        acceleration array at time t
    """

    p0 = params[0]   # constant offset / bias acceleration term
    p1 = params[1]   # linear in time term (e.g., secular trend)
    p11 = params[11] # quadratic in time term (t^2)

    p2 = params[2]   # linear stiffness coefficient (-k)
    p4 = params[4]   # cubic stiffness nonlinearity (-alpha * x^3)

    p3 = params[3]   # linear damping coefficient (-c)
    p7 = params[7]   # quadratic damping nonlinearity (v^2 term)

    p8 = params[8]   # cross term between position and velocity (x*v)
    
    p12_cross_nonlinear = 0.5 * p7  # Use half of quadratic damping param for cubic damping v^3
    
    p5 = params[5]   # amplitude of sinusoidal forcing sin(t)
    p6 = params[6]   # amplitude of sinusoidal forcing cos(t)

    p9  = params[9]  # modulated sinusoidal forcing t*sin(t)
    
    p10 = params[10] # modulated sinusoidal forcing t*cos(t)

    
    omega = 2 * np.pi

    
    return (
        p0 
        + p1 * x0 
        + p11 * (x0 ** 2) 

        + p2 * x1 
        + p4 * (x1 ** 3) 

        + p3 * x2 
        + p7 * (x2 ** 2) 
        + p12_cross_nonlinear * (x2 ** 3) 

        + p8 * (x1 * x2) 
        + 0.5 * p8 * ((x1 ** 2) * x2)     # additional nonlinear cross term involving position squared times velocity

        + p5 * np.sin(omega * x0) 
        + p6 * np.cos(omega * x0) 

        + p9 * (x0 * np.sin(omega * x0)) 
        + p10* (x0 * np.cos(omega * x0))
       )
