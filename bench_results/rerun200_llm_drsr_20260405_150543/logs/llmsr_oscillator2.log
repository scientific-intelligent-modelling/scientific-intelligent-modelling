        + p9 * (x0 * np.sin(x0)) 
        + p10 * (x0 * np.cos(x0))

        # Additional mixed nonlinear parametric excitation terms for richer dynamics:

        + 0.1*p4*p8*(x1**2)*x2           # coupling cubic stiffness & cross term
        
        - 0.05*p7*p8*x1*(x2**3)          # higher order mixed damping-cross term
        
        + 0.02*p9*(x1*np.sin(x0))         # modulation of forcing by position
        
        - 0.02*p10*(x2*np.cos(x0))         # modulation of forcing by velocity

