def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0` that includes nonlinear terms relevant to 
    a nonlinear harmonic oscillator acceleration model.
    
    y ≈ p0 + p1 * t + p2 * x + p3 * x^3 + p4 * v
    
    where:
    - t: time
    - x: position
    - v: velocity
    """
    return (
        params[0]  # constant term
        + params[1] * x0  # linear in time (optional forcing)
        + params[2] * x1  # linear position term (-alpha*x)
        + params[3] * np.power(x1, 3)  # cubic nonlinearity (-beta*x^3)
        + params[4] * x2  # linear velocity term (-gamma*v)
    )
