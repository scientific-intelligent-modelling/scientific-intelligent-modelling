def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version enforces physically meaningful signs on key parameters to ensure stability and 
    correct physical behavior of the nonlinear oscillator acceleration model.

    Model structure:
    y = constant forcing + time-dependent forcing terms
        - linear restoring force (negative stiffness)
        - linear damping (negative damping)
        + nonlinear polynomial terms (quadratic and cubic in position and velocity)
        + cross terms between position, velocity, and time

    Parameters:
    - x0: time array (independent variable)
    - x1: position array at time t
    - x2: velocity array at time t
    - params: array of 12 trainable coefficients

    Returns:
    - y: acceleration array corresponding to inputs
    """

    # Enforce negative signs on physically dissipative/restoring terms for stability:
    k = abs(params[2])      # linear restoring force coefficient magnitude
    c = abs(params[3])      # linear damping coefficient magnitude
    k3 = abs(params[6])     # cubic restoring force coefficient magnitude

    return (
          params[0]                      # constant forcing / bias term
        + params[1] * x0                # linear in time forcing modulation
        
        - k * x1                       # linear restoring force (-k*x), stable if k>0
        
        - c * x2                       # linear damping (-c*v), dissipative if c>0
        
        + params[4] * (x1 ** 2)         # quadratic position nonlinearity (can be positive or negative)
        
        + params[5] * (x2 ** 2)         # quadratic velocity nonlinearity
        
        - k3 * (x1 ** 3)                # cubic restoring force (-k3*x^3), typically stiffening
        
        + params[7] * (x2 ** 3)         # cubic velocity nonlinearity (nonlinear damping)
        
        + params[8] * (x1 * x2)         # cross term between position and velocity
        
        + params[9] * (x0 * x1)         # cross term between time and position
        
        + params[10]* (x0 * x2)         # cross term between time and velocity
        
        + params[11]* ((x1 ** 2) * x2)  # higher order mixed nonlinearity (cubic type)
     )
