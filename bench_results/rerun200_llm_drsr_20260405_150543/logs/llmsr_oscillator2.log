def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Adds additional nonlinear terms involving time and cross-terms to better capture complex dynamics.

    Equation form:
        y = a0 + a1*t + a2*x + a3*x^2 + a4*x^3 + a5*v + a6*v^2 + a7*v^3 +
            a8*x*v + a9*x^2*v + a10*x*v^2 +
            a11*t*x +
            a12*t*v

    Parameters mapping:
        params[0] = a0   # constant offset
        params[1] = a1   # coefficient for time t
        params[2] = a2   # linear stiffness coefficient (-omega^2)
        params[3] = a3   # quadratic stiffness coefficient
        params[4] = a4   # cubic stiffness coefficient (-alpha)
        params[5] = a5   # linear damping coefficient (-beta)
        params[6] = a6   # nonlinear damping coefficient for v^2
        params[7] = a7   # cubic velocity term coefficient
        params[8] = a8   # coupling coefficient for x*v
        params[9] = a9   # coupling coefficient for x^2 * v
        params[10]=a10  # coupling coefficient for x * v^2
        params[11]=a11  # coupling term t * x (time-position interaction)
        params[12]=a12  # coupling term t * v (time-velocity interaction)

    Note:
      This uses up to 13 parameters (params[:13]).
      If fewer parameters are provided, the extra terms can be omitted or zeroed.

    Inputs:
        x0 : time t
        x1 : position x(t)
        x2 : velocity v(t)

    Returns:
        y : acceleration at time t
    """
    
    (
      a0,
      a1,
      a2,
      a3,
      a4,
      a5,
      a6,
      a7,
      a8,
      a9,
      a10,
      a11,
      *rest
    ) = (params[i] if i < len(params) else 0.0 for i in range(13))
    
    # For safety in case only 12 parameters are given, set last param zero if missing.
    if len(params) < 13:
        rest.append(0.0)
    
    return (
          a0 +
          a1 * x0 +
          a2 * x1 +
          a3 * np.power(x1, 2) +
          a4 * np.power(x1, 3) +
          a5 * x2 +
          a6 * np.power(x2, 2) +
          a7 * np.power(x2, 3) +
          a8 * x1 * x2 +
         	a9 * np.power(x1, 2) * x2 +
        	a10* x1 * np.power(x2, 2) +
        	a11* x0 * x1 +
        	rest[0]*x0*x2     # corresponds to param index 12 (a12)
     )
