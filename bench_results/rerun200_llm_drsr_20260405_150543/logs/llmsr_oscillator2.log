def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of a nonlinear harmonic oscillator with polynomial nonlinearities 
    up to cubic order including cross terms between position, velocity, and time.

    Parameters:
    - x0: time array (can be used for forcing or modulation)
    - x1: position array
    - x2: velocity array
    - params: array of 12 parameters

    Returns:
    - y: acceleration array
    """

    # Physically meaningful grouping of parameters:
    # params[0]: constant forcing term (bias)
    # params[1]: linear time-dependent forcing coefficient
    # params[2]: linear restoring force coefficient (-k)
    # params[3]: linear damping coefficient (-c)
    
    # Nonlinear position terms:
    # params[4]: cubic restoring force coefficient (-k3)
    # params[5]: quadratic position nonlinearity
    
    # Velocity nonlinearities:
    # params[6]: quadratic velocity term (e.g., drag)
    
    # Cross terms between position and velocity:
    # params[7]: linear cross term x1*x2
    
    # Time dependent nonlinearities:
    # params[8]: quadratic time dependence
    
