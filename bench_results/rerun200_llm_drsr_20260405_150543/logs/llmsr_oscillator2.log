def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator with time-dependent forcing,
    nonlinear stiffness and damping terms, and mixed nonlinearities.

    The model includes:
    - constant offset
    - linear and quadratic time dependence (forcing/drift)
    - linear restoring force (Hooke's law)
    - linear damping
    - cubic stiffness nonlinearity (Duffing term)
    - quadratic and cubic velocity nonlinearities (nonlinear damping)
    - cross terms between position and velocity
    - quadratic position term (asymmetry/nonlinearity)
    - mixed nonlinear terms involving powers of position and velocity

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of 12 parameters controlling each term

    Returns:
        acceleration array modeled by the above equation.
    """
    
    return (
        params[0]                       # constant offset
        + params[1] * x0               # linear in time (forcing/drift)
        + params[2] * x1               # linear restoring force (-k*x)
        + params[3] * x2               # linear damping (-c*v)
        + params[4] * x1**3            # cubic stiffness nonlinearity (-k3*x^3)
        + params[5] * x2**2            # quadratic velocity term (nonlinear damping effect)
        + params[6] * x1 * x2          # cross term between position and velocity
        + params[7] * x1**2            # quadratic position term (asymmetry/nonlinearity)
        + params[8] * x0**2            # quadratic time dependence (slow forcing/drift)
        + params[9] * x2**3            # cubic velocity nonlinearity (higher order damping)
        + params[10] * (x1**2) * x2     # mixed nonlinear term involving squared position and velocity
        + params[11] * x1 * (x2**2)     # mixed nonlinear term involving position and squared velocity
    )
