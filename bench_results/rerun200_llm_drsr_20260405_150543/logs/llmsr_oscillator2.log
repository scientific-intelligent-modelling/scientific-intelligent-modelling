        + params[4]*(x1**3)

        # Linear damping modulated by linear trend in time:
        + (params[3] + 0.3*params[1]*x0)*x2

        # Quadratic and cubic velocity nonlinearities:
        + params[7]*(x2**2)
        + params[10]*(x2**3)

        # Cross terms between position & velocity:
        + params[8]*(x1*x2)
        
        # Higher order cross term ((x^2)*v):
        + params[9]*((x1**2)*x2)

         # Sinusoidal external forcing components:
         # Note: no separate modulated sin/cos by t*sin or t*cos here due to param limit.
         # Could be added if param count increased.
         
         # Pure sinusoidal forcing terms:
         +
         (
             params[5]*np.sin(omega*x0) +
