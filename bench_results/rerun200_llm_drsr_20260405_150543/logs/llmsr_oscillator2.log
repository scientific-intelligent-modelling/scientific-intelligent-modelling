def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Extends the nonlinear harmonic oscillator model by including:
    - Quintic nonlinearity in position and velocity
    - Mixed nonlinear terms involving higher powers of position and velocity
    - Additional trigonometric forcing terms at triple frequency
    - Time-modulated nonlinear coefficients to capture parametric excitation effects
    - Non-smooth friction-like terms involving abs and sign functions

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of 12 parameters [p0 ... p11]

    Returns:
        Acceleration array y corresponding to inputs.
    """
    
    p = params
    
    # Base linear terms (constant, linear in time, linear in position and velocity)
    linear = (
        p[0] +          # constant offset / bias
        p[1] * x0 +     # linear in time (forcing frequency component)
        p[2] * x1 +     # linear restoring force term (-k*x)
        p[3] * x2       # linear damping term (-c*v)
    )
    
    # Higher order nonlinearities in position (cubic, quartic, quintic)
    pos_nonlinear = (
        p[4] * (x1 ** 3) +
        p[5] * (x1 ** 4) +
        p[6] * (x1 ** 5)
    )
    
    # Velocity nonlinearities including quadratic, cubic with sign, quintic with sign 
    vel_nonlinear = (
