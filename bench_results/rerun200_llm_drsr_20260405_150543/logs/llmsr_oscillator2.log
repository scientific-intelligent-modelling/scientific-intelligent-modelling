        params[7] * (x2 ** 2) +            # quadratic velocity term for nonlinear damping/effects
        params[8] * (x1 * x2) +            # cross term between position and velocity
        params[9] * (x0 * np.sin(x0)) +   # modulated sinusoidal forcing by time
        params[10] * (x0 * np.cos(x0)) +  # modulated cosine forcing by time
        params[11] * (x0 ** 2)             # quadratic time dependence for possible secular trends
    )
