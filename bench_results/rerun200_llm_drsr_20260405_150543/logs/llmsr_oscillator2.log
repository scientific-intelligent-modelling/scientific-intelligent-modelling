def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further extends the nonlinear harmonic oscillator acceleration model by:
    - Including higher-order nonlinearities in position and velocity
    - Adding mixed polynomial terms involving time, position, and velocity
    - Incorporating trigonometric modulation terms to capture periodic forcing effects
    - Maintaining physical interpretability consistent with nonlinear oscillator dynamics

    Parameters:
    - params (np.ndarray): array of length at least 12

    Returns:
    - y (np.ndarray): predicted acceleration
    """
    p = params  # shorthand

    # Base linear terms: constant offset, linear in time (forcing), linear restoring force (position),
    # linear damping (velocity)
    y = (
        p[0]                      # constant bias term
        + p[1] * x0               # linear time-dependent forcing/drift
        + p[2] * x1               # linear restoring force ~ position
        + p[3] * x2               # linear damping ~ velocity
    )

    # Nonlinear stiffness and damping terms:
    y += (
        p[4] * x1**3              # cubic stiffness nonlinearity (Duffing-type)
        + p[5] * x2**3            # cubic nonlinear damping
        + p[9] * x2**2            # quadratic velocity nonlinearity (nonlinear damping)
        + p[8] * x1**5            # quintic stiffness nonlinearity for stronger anharmonicity
        + 0.5 * p[4] * x1**4      # quartic stiffness term for asymmetry/nonlinearity enhancement
        - 0.3 * p[5] * x2**4      # quartic damping term for complex dissipation behavior
    )

    # Mixed polynomial interaction terms between position and velocity:
    y += (
        p[6] * (x1**2) * x2       # quadratic position times velocity interaction term
        + p[7] * x1 * (x2**2)     # position times quadratic velocity interaction term
        
        + 0.6 * p[8] * (x1**3)*x2   # mixed cubic/quadratic interaction capturing complex coupling
        
        - 0.5 * p[9] * x1*(x2**3)   # asymmetric mixed interaction affecting damping/stiffness balance
    )

    # Time-dependent modulations including parametric excitation and coupling with state variables:
    y += (
        0.7 * p[6] * x0**2         # parametric excitation via quadratic time dependence
        
        - 0.4 * p[7] * x0*x2       # coupling between time and velocity for modulation effects
        
        + p[10]*np.sin(x0)         # sinusoidal forcing dependent on time
        
        + p[11]*x0*x1              # linear coupling between time and position
        
        + 0.3*p[11]*np.cos(x0)*x1   # additional trigonometric modulation on position-time coupling
        
        - 0.25*p[10]*np.sin(2*x0)*x2   # higher harmonic forcing modulated by velocity for richer dynamics
    )

    return y
