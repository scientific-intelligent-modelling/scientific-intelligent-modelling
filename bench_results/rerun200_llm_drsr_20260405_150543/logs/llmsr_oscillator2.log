def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further extends the nonlinear harmonic oscillator model by including:
    - Quartic nonlinearity in position and velocity
    - Mixed nonlinear terms involving products of time, position, and velocity powers
    - Additional trigonometric forcing terms with fundamental and doubled frequency
    - Non-smooth friction-like terms involving absolute value and sign of velocity

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of 12 parameters

    Returns:
        Acceleration array y corresponding to inputs.
    """
    
    p = params
    
    return (
        p[0] +                          # constant offset / bias
        
        p[1] * x0 +                     # linear in time (forcing frequency component)
        
        p[2] * x1 +                     # linear restoring force term (-k*x)
        
        p[3] * x2 +                     # linear damping term (-c*v)
        
        p[4] * (x1 ** 3) +              # cubic nonlinearity in position
        
        p[5] * np.sin(x0) +             # sinusoidal forcing term (fundamental frequency)
        
        p[6] * (x1 ** 4) +              # quartic nonlinearity in position
        
        p[7] * (x2 ** 2) +              # quadratic velocity term
        
        p[8] * (x1 ** 2) * x2 +         # mixed nonlinear term (position squared times velocity)
        
        p[9] * np.abs(x2) +             # friction-like effect proportional to speed
        
        p[10] * np.sign(x2) * (x2 ** 3) +   # cubic velocity times sign for complex friction/damping
        
        p[11] * np.cos(2*x0)            # additional periodic forcing component with doubled frequency
    )
