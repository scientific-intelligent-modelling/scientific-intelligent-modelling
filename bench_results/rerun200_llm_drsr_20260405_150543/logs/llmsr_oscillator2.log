def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration of nonlinear harmonic oscillator as:
        a = params[0]                  # constant forcing or bias term
            + params[1]*x0             # linear time-dependent forcing modulation
            + params[2]*x1             # linear restoring force (-k * x)
            + params[3]*x2             # linear damping (-c * v)
            + params[4]*x1**3          # cubic restoring force (-k3 * x^3)
            + params[5]*x2**3          # cubic velocity nonlinearity (nonlinear damping)
            + params[6]*(x1 * x2)      # cross term between position and velocity

    Parameters:
        - x0: time array (independent variable)
        - x1: position array at time t
        - x2: velocity array at time t
        - params: array of 7 parameters controlling each term

    Returns:
        - y: acceleration array modeled by the nonlinear oscillator equation skeleton.
    """
    return (
        params[0] +
        params[1] * x0 +
        params[2] * x1 +
        params[3] * x2 +
        params[4] * x1**3 +
        params[5] * x2**3 +
        params[6] * (x1 * x2)
    )
