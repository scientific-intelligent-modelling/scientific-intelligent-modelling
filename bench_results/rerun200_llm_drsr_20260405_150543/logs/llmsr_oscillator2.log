def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Adds higher order nonlinear terms and cross terms to better capture complex dynamics
    of a nonlinear harmonic oscillator.

    Variables:
    - x0: time t
    - x1: position at time t
    - x2: velocity at time t

    Parameters:
    - params: array of coefficients with length >= 12

    Returns:
    - y: acceleration at time t
    """
    
    # Linear terms
    y = params[0]  # constant offset / bias term
    y += params[1] * x0  # linear in time (forcing)
    y += params[2] * x1  # linear in position (restoring force)
    y += params[3] * x2  # linear in velocity (damping)
    
    # Nonlinear terms (cubic)
    y += params[4] * (x1 ** 3)      # cubic nonlinearity in position
    y += params[5] * (x2 ** 3)      # cubic nonlinearity in velocity
    
    # Cross-terms nonlinearities (quadratic and cubic mixed terms)
    y += params[6] * (x1 ** 2) * x2   # quadratic position times velocity term
    y += params[7] * x1 * (x2 ** 2)   # position times quadratic velocity term
    
    # Higher order nonlinearities and cross-terms
    y += params[8] * (x1 ** 5)         # quintic nonlinearity in position
    y += params[9] * (x2 ** 5)         # quintic nonlinearity in velocity
    
    y += params[10] * (x1 ** 3) * x2   # cubic position times velocity term
    y += params[11] * x1 * (x2 ** 3)   # position times cubic velocity term
    
    return y
