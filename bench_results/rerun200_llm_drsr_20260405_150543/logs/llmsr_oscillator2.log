def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Includes nonlinear restoring force (cubic in position),
    linear and nonlinear damping terms,
    and possible periodic forcing term depending on time.
    
    Parameters:
    - params: array of 12 coefficients
        params[0]: constant offset
        params[1]: linear in time (x0)
        params[2]: linear in position (x1)
        params[3]: linear in velocity (x2)
        params[4]: cubic in position (x1^3)
        params[5]: quadratic in velocity (x2^2)
        params[6]: velocity * |velocity| term for nonlinear damping
        params[7]: sin(time) forcing amplitude
        params[8]: cos(time) forcing amplitude
        params[9], [10], [11]: cross or higher order terms as needed

    Returns:
    - y: acceleration array
    """
    
    # Basic linear terms
    y = (
        params[0] +
        params[1] * x0 +
        params[2] * x1 +
        params[3] * x2 +
        
        # Nonlinear restoring force term ~ cubic in position
        params[4] * (x1 ** 3) +
        
        # Quadratic velocity term for nonlinear damping or other effects
        params[5] * (x2 ** 2) +
        
        # Nonlinear damping proportional to velocity magnitude times velocity sign
