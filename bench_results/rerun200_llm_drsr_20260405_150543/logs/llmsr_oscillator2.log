        + params[6]*x1*x2               # cross term between position and velocity
        + params[7]*x1**2               # quadratic stiffness nonlinearity
        + params[8]*x2**3               # cubic velocity nonlinearity (damping)
        + params[9]*x0**2               # quadratic time dependence (forcing effect)
