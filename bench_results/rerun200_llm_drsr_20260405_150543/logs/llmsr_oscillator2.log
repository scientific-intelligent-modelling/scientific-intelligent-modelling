def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Models acceleration in a nonlinear harmonic oscillator as a combination of polynomial,
    trigonometric, exponential, hyperbolic tangent (smooth sign), and mixed nonlinear terms:

        a = p0 
            + p1*t 
            + p2*x 
            + p3*v 
            + p4*x^3 
            + p5*x^2*v 
            + p6*x*v^2 
            + p7*v^3
            + p8*sin(t)           
            + p9*cos(t)           
            + p10*exp(-abs(v))    
            + p11*tanh(v)*x       
            
    Extended with additional terms:
    
        + p12 * t * x * v       (mixed time-position-velocity interaction)
        + p13 * tanh(x) * v     (smooth sign of position times velocity)
        - ... but since MAX_NPARAMS=12, we keep 12 params total.

    Since MAX_NPARAMS=12, we replace some terms with more expressive ones or combine them.

    Parameters:
    - params (np.ndarray): array of parameters [p0,...,p11]

    Returns:
    - acceleration (np.ndarray)
    """

    # To keep within 12 parameters, replace some less physically meaningful terms from v1 with new ones.
    
    return (
        params[0]                          # constant offset
        + params[1] * x0                  # linear in time (external forcing or drift)
        + params[2] * x1                  # linear stiffness term (-k*x)
        + params[3] * x2                  # linear damping term (-c*v)
        + params[4] * (x1 ** 3)           # cubic stiffness nonlinearity (-k3*x^3)
        + params[5] * (x1 ** 2) * x2      # quadratic position times velocity term
        + params[6] * x1 * (x2 ** 2)      # position times squared velocity term
        + params[7] * (x2 ** 3)           # cubic velocity term (nonlinear damping)
        + params[8] * np.sin(x0)          # sinusoidal forcing term in time
        + params[9] * np.cos(x0)          # cosine forcing term in time
        + params[10] * np.exp(-np.abs(x2))# exponential decay damping based on speed magnitude
        + params[11] * np.tanh(x0) * x1 * x2   # smooth nonlinear coupling of time-position-velocity triple product
    )
