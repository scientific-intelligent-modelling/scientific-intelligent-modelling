    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Extended nonlinear harmonic oscillator acceleration model.

    Model includes:
    - Constant offset
    - Linear and quadratic time dependence
    - Linear stiffness (-k * x) with time modulation
    - Cubic stiffness nonlinearity (-alpha * x^3)
    - Linear damping (-c * v) with time modulation
    - Quadratic and cubic damping nonlinearities
    - Cross terms between position and velocity (x*v), including higher order ((x^2)*v)
    - Sinusoidal forcing with sine and cosine components modulated by time

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of 12 parameters

    Returns:
        acceleration array at time t
    """

    p0 = params[0]   # constant offset / bias acceleration term
    p1 = params[1]   # linear in time term (for secular trends or forcing modulation)
    
    p2 = params[2]   # linear stiffness coefficient (-k)
    p3 = params[3]   # linear damping coefficient (-c)

    p4 = params[4]   # cubic stiffness nonlinearity (-alpha * x^3)

    p5 = params[5]   # amplitude of sinusoidal forcing term sin(omega*t)
    p6 = params[6]   # amplitude of sinusoidal forcing term cos(omega*t)

    p7 = params[7]   # quadratic damping nonlinearity (v^2 term)
    
    p8 = params[8]   # cross term between position and velocity (x*v)

    p9  = params[9]  # modulated sinusoidal forcing by t*sin(omega*t)

    p10 = params[10]  # modulated sinusoidal forcing by t*cos(omega*t)

    p11 = params[11]  # quadratic in time term for secular trends or slow modulation

    
    omega = 2 * np.pi  # fundamental frequency for sinusoidal forcing
    
  
    return (
        p0 
        + p1 * x0 
        + (p2 + 0.5 * p1 * x0) * x1           # linear stiffness modulated by linear time trend 
        + p4 * (x1 ** 3)                       # cubic stiffness nonlinearity 
        + (p3 + 0.3 * p1 * x0) * x2           # linear damping modulated by linear time trend 
        + p7 * (x2 ** 2)                       # quadratic damping nonlinearity 
        + p8 * (x1 * x2)                       # cross term between position & velocity 
        + p5 * np.sin(omega * x0)              # sinusoidal external forcing sin component 
        + p6 * np.cos(omega * x0)              # sinusoidal external forcing cos component 
        + p9  * (x0 * np.sin(omega*x0))       # modulated sin forcing by t*sin(t*omega)
        + p10 * (x0 * np.cos(omega*x0))       # modulated cos forcing by t*cos(t*omega)
        + p11 * (x0 ** 2)                      # quadratic secular trend in time 
     )
