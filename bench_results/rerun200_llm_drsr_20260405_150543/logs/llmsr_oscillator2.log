def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Calculates acceleration for a nonlinear harmonic oscillator with additional nonlinear
    and coupling terms:

        y = a0 
            + a1 * t 
            + a7 * t^2 
            + a2 * x 
            + a3 * x^3 
            + a8 * x^5 
            + a4 * v 
            + a5 * v^2 
            + a9 * v^3
            + a6 * x*v
            + a10 * t*v
            + a11 * t*x
            + (reuse param[9]) x²*v

    Parameters mapping:
        params[0]  = a0   # constant offset
        params[1]  = a1   # linear time coefficient
        params[2]  = a2   # linear stiffness coefficient (-omega²)
        params[3]  = a3   # cubic stiffness coefficient (-alpha)
        params[4]  = a4   # linear damping coefficient (-beta)
        params[5]  = a5   # quadratic velocity damping coefficient
        params[6]  = a6   # coupling term between position and velocity (x*v)
        params[7]  = a7   # quadratic time term (t²)
        params[8]  = a8   # quintic stiffness term (x⁵)
        params[9]  = a9   # cubic velocity damping term (v³) AND reused for x²*v coupling
       params[10] =a10   # time-velocity coupling term (t*v)
       params[11] =a11   # time-position coupling term (t*x)

    Inputs:
      - x0 : time t
      - x1 : position x(t)
      - x2 : velocity v(t)

    Returns:
      - y : acceleration at time t
    """

    (
