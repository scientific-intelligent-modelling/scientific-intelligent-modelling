def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Adds:
    - Separate parameters for quintic stiffness and quadratic time term
    - Additional cubic time term for parametric excitation
    - More balanced distribution of nonlinear terms
    - Keeps MAX_NPARAMS=12

    Parameters mapping (MAX_NPARAMS=12):
        params[0]  = a0   # constant offset
        params[1]  = a1   # linear time coefficient (t)
        params[2]  = a2   # linear stiffness coefficient (-omega^2)
        params[3]  = a3   # cubic stiffness coefficient (-alpha)
        params[4]  = a4   # linear damping coefficient (-beta)
        params[5]  = a5   # quadratic velocity damping coefficient (v^2)
        params[6]  = a6   # coupling x*v coefficient
        params[7]  = a7   # quadratic time coefficient (t^2)
        params[8]  = a8   # cubic velocity damping term (v^3)
        params[9]  = a9   # quadratic position-velocity coupling (x^2 * v)
        params[10] =a10   # quintic stiffness term (x^5)
        params[11] =a11   # cross term t*x

    Inputs:
      - x0 : time t
      - x1 : position x(t)
      - x2 : velocity v(t)

    Returns:
      - y : acceleration at time t
    """

    (
      a0,  a1,  a2,  a3,
      a4,  a5,  a6,  a7,
      a8,  a9,  a10,a11,
    ) = params[:12]

    return (
          +a0                              # constant offset
