    # Linear position coefficient (restoring force)
    c_x = params[2]
    
    # Linear velocity coefficient (damping)
    c_v = params[3]
    
    # Cubic position coefficient (nonlinear restoring force)
    c_x3 = params[4]
    
    return c + c_t * x0 + c_x * x1 + c_v * x2 + c_x3 * (x1 ** 3)
