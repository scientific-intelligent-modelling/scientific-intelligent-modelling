def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version includes:
    - linear terms (time, position, velocity)
    - nonlinear stiffness terms (cubic, quartic, quintic in position)
    - nonlinear damping terms (cubic and quartic in velocity)
    - mixed nonlinear interaction terms between position and velocity
    - time-dependent forcing including sinusoidal modulation
    - higher order time-position and time-velocity interactions

    Parameters:
    - params (np.ndarray): array of length at least 12

    Returns:
    - y (np.ndarray): predicted acceleration
    """
    
    p = params
    
    # Linear terms
    linear = p[0] + p[1]*x0 + p[2]*x1 + p[3]*x2
    
    # Nonlinear stiffness terms (restoring force)
    stiffness = (
        p[4]*(x1**3)           # cubic Duffing nonlinearity
        + 0.5*p[4]*(x1**4)     # quartic asymmetry term scaled from cubic param
        + p[8]*(x1**5)         # quintic anharmonicity
        - 0.05*p[6]*(x1**3)     # higher order mixed term involving position cubic 
                              # scaled from interaction param to keep param count fixed
    )
    
    # Nonlinear damping terms
    damping = (
        p[3]*x2               # linear damping
        + p[5]*(x2**3)         # cubic nonlinear damping
        + p[9]*(x2**4)         # quartic nonlinear damping for stronger effects
        - 0.3*p[3]*(x2**2)     # quadratic damping energy dissipation term scaled from linear damping param 
                              # to reduce free parameters but keep physical meaning.
        
    )
    
    # Mixed interaction terms between position and velocity
    mixed = (
        p[6]*(x1**2)*x2       # quadratic position times velocity interaction 
        + p[7]*x1*(x2**2)      # linear position times quadratic velocity interaction 
                              #- 0.05*p[6]*(x1**3) included above as higher order correction 
                              #(to avoid using extra params)
        
                              )
    
    # Time-dependent forcing / modulation terms including sinusoidal forcing on time,
    forcing = (
        p[10]* x0 * x1          # time-position interaction term (parametric modulation)
        + 0.1 * p[10] * (x0 ** 2)   # quadratic time modulation of forcing scaled from same param
        
        + p[11] * np.sin(x0)     # sinusoidal forcing dependent on time
        
        + p[11] * 0.05 * x0      # small linear-in-time correction scaled from sinusoidal forcing param
        
                                )
