def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` with physically meaningful nonlinear oscillator structure.

    y = params[0]                      # constant offset
        + params[1]*x0                # linear time dependence (optional)
        + params[2]*x1                # linear restoring force term
        + params[3]*x2                # linear damping term
        + params[4]*x1**3             # cubic nonlinearity in position
        + params[5]*x2**2             # quadratic velocity term (nonlinear damping)
        + params[6]*x1*x2             # coupling between position and velocity
        + params[7]*x0*x1             # interaction between time and position
        + params[8]*x0*x2             # interaction between time and velocity
        + params[9]*(x1**2)*x2        # higher order nonlinear coupling
        + params[10]*(x1)*(x2**2)     # another higher order nonlinear coupling
        + params[11]*(x0**2)          # quadratic time dependence (optional)
    """
    return (
        params[0]
        + params[1] * x0
        + params[2] * x1
        + params[3] * x2
        + params[4] * (x1 ** 3)
        + params[5] * (x2 ** 2)
        + params[6] * (x1 * x2)
        + params[7] * (x0 * x1)
        + params[8] * (x0 * x2)
        + params[9] * ((x1 ** 2) * x2)
        + params[10] * (x1 * (x2 ** 2))
        + params[11] * (x0 ** 2)
    )
