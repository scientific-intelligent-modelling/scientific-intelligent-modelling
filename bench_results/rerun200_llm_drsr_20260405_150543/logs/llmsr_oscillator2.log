def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` that includes additional nonlinear terms relevant for a nonlinear harmonic oscillator.

    Models acceleration as:
    a = param0 
        + param1 * t 
        + param2 * x 
        + param3 * v 
        + param4 * x^3
        + param5 * v^2
        + param6 * x * v
        + param7 * x^2
        + param8 * v^3

    where:
    - t = time (x0)
    - x = position (x1)
    - v = velocity (x2)

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
      Expected length >= 9.
    """
    
    return (
