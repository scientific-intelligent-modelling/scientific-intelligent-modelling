def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further extends the nonlinear harmonic oscillator model by including:
    - Quintic nonlinearity in position (x1^5)
    - Velocity cubed term for advanced damping modeling
    - Mixed nonlinear terms involving velocity cubed times position squared
    - Higher harmonics in forcing terms (sin(3*x0), cos(3*x0))
    - Non-smooth friction-like terms involving velocity absolute and sign functions combined
    - Interaction terms combining velocity magnitude and position powers

    Parameters:
        x0: time array
        x1: position array at time t
        x2: velocity array at time t
        params: array of 12 parameters

    Returns:
        Acceleration array y corresponding to inputs.
    """
    
    p = params
    
    return (
        p[0] +                          # constant offset / bias
        p[1] * x0 +                     # linear in time (forcing frequency component)
        p[2] * x1 +                     # linear restoring force term (-k*x)
        p[3] * x2 +                     # damping term (-c*v)
        
        p[4] * (x1 ** 3) +              # cubic nonlinearity in position
        
        p[5] * np.sin(x0) +             # sinusoidal forcing term
        
        p[6] * (x1 ** 4) +              # quartic nonlinearity in position
        
        p[7] * (x2 ** 2) * x1 +         # mixed nonlinear term velocity squared times position
        
        p[8] * (x1 * x2) +              # cross product nonlinearity
        
        p[9] * np.abs(x2) +             # absolute value of velocity for friction-like effect
        
        p[10] * np.sign(x2) * (x2 ** 3) +   # cubic velocity with sign for complex friction effect
        
        p[11] * np.cos(2*x0)            # higher harmonic periodic forcing component
    )
