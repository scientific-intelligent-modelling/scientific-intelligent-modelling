def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    Further extends the nonlinear harmonic oscillator acceleration model by including:
    - quartic position term (x^4) to capture higher order stiffness nonlinearities
    - quartic velocity term (v^4) for stronger nonlinear damping effects
    - additional cross terms involving time, position and velocity to model more complex coupling

    Equation form:
        y = a0 
            + a1*t 
            + a7*t^2 
            + a2*x 
            + a8*x^2 
            + a12*x^4
            + a3*x^3 
            + a4*v 
            + a5*v^2 
            + a9*v^3
            + a13*v^4
            + a6*x*v 
            + a10*x^2*v 
            + a11*x*v^2
            + a14*t*x*v

    Parameters mapping (params length extended to 15):
        params[0]  = a0   # constant offset
        params[1]  = a1   # linear in time t
        params[7]  = a7   # quadratic in time t
        params[2]  = a2   # linear in position x
        params[8]  = a8   # quadratic in position x
        params[12] =a12   # quartic in position x (x^4)
        params[3]  = a3   # cubic in position x
        params[4]  = a4   # linear in velocity v
        params[5]  = a5   # quadratic in velocity v
        params[9]  = a9   # cubic in velocity v
        params[13] =a13   # quartic in velocity v (v^4)
        params[6]  =a6    # cross term x*v
        params[10] =a10   # cross term x² *v
        params[11] =a11   # cross term x *v²
        params[14] =a14   # triple cross term t * x * v

    Inputs:
        - x0 : time t array-like shape (n,)
        - x1 : position array-like shape (n,)
        - x2 : velocity array-like shape (n,)
    
    Returns:
        y : acceleration array-like shape (n,)
    """
    
    (
      a0,  a1,  a2,  a3,
      a4,  a5,  a6,  a7,
      a8,  a9,  a10,a11,
      a12,a13,a14,
    ) = np.pad(params[:15], (0,max(15-len(params),0)), 'constant')

    return (
          +a0                                  # constant offset  
          +a1 * x0                             # linear time  
          +a7 * np.power(x0, 2)                # quadratic time  
          +a2 * x1                             # linear position  
          +a8 * np.power(x1, 2)                # quadratic position  
          +a12* np.power(x1,4)                 # quartic position  
          +a3 * np.power(x1,3)                 # cubic position  
          +a4 * x2                             # linear velocity  
          +a5 * np.power(x2, 2)                # quadratic velocity  
          +a9 * np.power(x2,3)                 # cubic velocity  
          +a13* np.power(x2,4)                 # quartic velocity  
          +a6 * x1 * x2                       # cross term pos*vel  
          +a10* np.power(x1, 2)*x2             # cross term pos²*vel  
          +a11* x1*np.power(x2, 2)             # cross term pos*vel²  
          +a14* x0*x1*x2                      # triple product t*x*v coupling   
       )
