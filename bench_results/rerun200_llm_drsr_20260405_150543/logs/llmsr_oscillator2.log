def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v0`.

    Model acceleration as a nonlinear function of time (x0), position (x1), and velocity (x2).
    Includes linear and cubic terms for position, linear and quadratic terms for velocity.
    
    Parameters:
    - params (np.ndarray): array of length at least 12
    
    Returns:
    - y (np.ndarray): predicted acceleration
    """
    # Unpack parameters for clarity
    c0 = params[0]   # constant term
    c_t = params[1]  # linear time term
    c_x = params[2]  # linear position term
    c_v = params[3]  # linear velocity term
    c_x3 = params[4] # cubic position term
    c_v2 = params[5] # quadratic velocity term (e.g. v * |v|)
    
    # Additional cross or higher order terms if desired:
    c_tx = params[6]   # time * position
    c_tv = params[7]   # time * velocity
    c_xv = params[8]   # position * velocity
    
    c_x2 = params[9]   # quadratic position term
    c_v3 = params[10]  # cubic velocity term
    
    c_t2 = params[11]  # quadratic time term

    return (
        c0 +
        c_t * x0 +
        c_x * x1 +
        c_v * x2 +
        c_x3 * (x1 ** 3) +
        c_v2 * (x2 * np.abs(x2)) +
        c_tx * (x0 * x1) +
        c_tv * (x0 * x2) +
        c_xv * (x1 * x2) +
        c_x2 * (x1 ** 2) +
        c_v3 * (x2 ** 3) +
        c_t2 * (x0 ** 2)
     )
