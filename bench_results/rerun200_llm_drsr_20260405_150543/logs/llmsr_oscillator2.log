def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further extends the nonlinear oscillator model by including:
    - Additional higher order nonlinearities in position and velocity
    - More cross terms involving time, position, and velocity
    - Parametric excitation with cubic and quartic time dependencies
    - Mixed polynomial-trigonometric-hyperbolic terms for richer dynamics

    Parameters:
    - params (np.ndarray): array of length at least 12

    Returns:
    - y (np.ndarray): predicted acceleration
    """
    p = params  # shorthand

    # Base linear + cubic + quintic + quadratic terms similar to v1
    y = (
