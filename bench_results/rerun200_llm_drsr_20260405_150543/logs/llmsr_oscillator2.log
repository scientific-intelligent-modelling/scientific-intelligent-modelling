def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1`.

    Includes higher order nonlinearities and nonlinear damping consistent with a 
    nonlinear harmonic oscillator model.
    
    Variables:
    - x0: time t
    - x1: position at time t
    - x2: velocity at time t
    
    Parameters:
    - params: array of coefficients [p0 ... p11]
    
    Returns:
    - acceleration y at time t
    """
    
    # Linear terms
    linear = params[0] + params[1]*x0 + params[2]*x1 + params[3]*x2
    
    # Nonlinear stiffness terms (position powers)
    nonlinear_stiffness = (
        params[4]*(x1**2) +
        params[5]*(x1**3) +
        params[6]*(x1**4)
    )
    
    # Nonlinear damping terms (velocity powers and abs)
    nonlinear_damping = (
        params[7]*(x2**2) +
        params[8]*np.abs(x2)*x2  # sign-sensitive quadratic damping
    )
    
    # Cross terms between position and velocity
    cross_terms = (
        params[9]*x1*x2 +
        params[10]*x0*x1 +
        params[11]*x0*x2
    )
    
    return linear + nonlinear_stiffness + nonlinear_damping + cross_terms
