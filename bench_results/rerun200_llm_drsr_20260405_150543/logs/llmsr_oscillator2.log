def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Further improved model for acceleration in a nonlinear harmonic oscillator.

    Mathematical form:

        a = p0 
          + p1*t 
          + p2*x 
          + p3*v 
          + p4*x^2 
          + p5*v^2 
          + p6*x^3 
          + p7*x*v 
          + p8*sin(t) 
          + p9*cos(t) 
          + p10*exp(-abs(v)) 
          + p11*tanh(v)*x

    where:
      t = time (x0)
      x = position (x1)
      v = velocity (x2)

    Parameters:
        params (np.ndarray): array of parameters [p0,...,p11]

    Returns:
        acceleration (np.ndarray)
    """
    
    return (
        params[0]                          # constant offset
        + params[1] * x0                  # linear in time
        + params[2] * x1                  # linear stiffness term (-k*x)
        + params[3] * x2                  # linear damping term (-c*v)
        + params[4] * (x1 ** 2)           # quadratic stiffness nonlinearity
        + params[5] * (x2 ** 2)           # quadratic damping nonlinearity
        + params[6] * (x1 ** 3)           # cubic stiffness nonlinearity (-k3*x^3)
        + params[7] * x1 * x2             # bilinear coupling between position and velocity
        + params[8] * np.sin(x0)          # sinusoidal forcing term in time
        + params[9] * np.cos(x0)          # cosine forcing term in time
        + params[10] * np.exp(-np.abs(x2))# exponential decay damping based on speed magnitude
        + params[11] * np.tanh(x2) * x1   # nonlinear coupling with smoothed sign of velocity and position
    )
