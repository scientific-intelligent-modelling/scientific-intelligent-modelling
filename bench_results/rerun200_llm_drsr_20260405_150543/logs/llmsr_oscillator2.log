    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` including sinusoidal forcing term,
    physically meaningful nonlinearities and interactions.
    
    Parameters:
    - params (np.ndarray): array of length 12
    
    Returns:
    - y (np.ndarray): predicted acceleration
    """
    # Unpack parameters for clarity
    c0 = params[0]      # constant offset
    c1 = params[1]      # linear in time t
    c2 = params[2]      # linear in position x (restoring force)
    c3 = params[3]      # linear in velocity v (damping)
    c4 = params[4]      # cubic nonlinearity in position x^3
    c5 = params[5]      # cubic nonlinearity in velocity v^3 (nonlinear damping)
    c6 = params[6]      # quadratic time term t^2
    c7 = params[7]      # interaction t*x
    c8 = params[8]      # interaction t*v
    
    # Use param 9 as amplitude of sinusoidal forcing 
    A_force = params[9]
    
    # Use param 10 as angular frequency of forcing omega (>0 ideally)
    omega_force = abs(params[10]) + 1e-5  # avoid zero frequency
    
    c11 = params[11]     # quadratic position term x^2
    
    forcing_term = A_force * np.cos(omega_force * x0)
    
    return (
        c0 
        + c1 * x0 
        + c2 * x1 
        + c3 * x2 
        + c4 * (x1 ** 3) 
        + c5 * (x2 ** 3) 
        + c6 * (x0 ** 2) 
        + c7 * (x0 * x1) 
        + c8 * (x0 * x2) 
