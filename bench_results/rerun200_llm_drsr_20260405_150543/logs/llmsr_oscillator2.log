def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` including:
    - Linear restoring force (-k * x1)
    - Cubic nonlinearity (-alpha * x1^3)
    - Linear damping (-c * x2)
    - Sinusoidal forcing terms (A*sin(omega*t), B*cos(omega*t))
    - Interaction terms
    
    Parameters:
    - params (np.ndarray): array of length 12
    
    Returns:
    - y (np.ndarray): predicted acceleration
    """
    
    # Unpack parameters for clarity
    c0 = params[0]       # constant offset
    c_t = params[1]      # linear in time t
    k = params[2]        # linear in position (restoring force coefficient)
    c = params[3]        # linear damping coefficient
    alpha = params[4]     # cubic nonlinearity coefficient in position
    beta = params[5]      # cubic nonlinearity coefficient in velocity (less common physically but kept for flexibility)
    
    c_t2 = params[6]     # quadratic term in time
    
    c_t_x = params[7]     # interaction between time and position
    c_t_v = params[8]     # interaction between time and velocity
    
    c_xxv = params[9]     # squared-position times velocity interaction
    c_xvv = params[10]     # position times squared velocity interaction
    
    c_xx = params[11]     # quadratic term in position

    
    omega = 1.0  # angular frequency for forcing; could be parameterized or fixed
    
    return (
        c0 
        + c_t * x0 
        + k * x1 
        + c * x2 
        + alpha * (x1 ** 3) 
        + beta * (x2 ** 3) 
        + c_t2 * (x0 ** 2) 
        + c_t_x * (x0 * x1) 
        + c_t_v * (x0 * x2) 
        + c_xxv * ((x1 ** 2) * x2) 
        + c_xvv * (x1 * (x2 ** 2)) 
        + c_xx * (x1 ** 2) 
        
        # Add sinusoidal forcing terms with parameters as amplitudes:
        + params[-4] * np.sin(omega * x0)  
        + params[-3] * np.cos(omega * x0)
        
        # Optional additional nonlinear interactions if desired:
        + params[-2] * np.sin(omega * x0) * x1  
        + params[-1] * np.cos(omega * x0) * x2  
        
       )
