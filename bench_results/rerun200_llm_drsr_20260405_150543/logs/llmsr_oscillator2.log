def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version further refines the nonlinear harmonic oscillator acceleration model by including:
    - Time-dependent polynomial terms up to cubic in time (x0, x0^2, x0^3)
    - Linear and nonlinear restoring force terms (x1, x1^3)
    - Velocity damping terms including linear velocity dependence (x2)
    - Mixed nonlinear terms involving position and velocity powers (x1*x2)
    - External periodic forcing via sinusoids and cosinusoids at fundamental and second harmonics (sin(x0), cos(x0), sin(2*x0), cos(2*x0))
    - Cross terms between time and state variables to capture parametric excitation effects

    Physical motivation:
    The acceleration depends on restoring forces with nonlinear stiffness,
    damping forces with linear velocity dependence,
    external periodic forcing at multiple harmonics,
    parametric excitation effects modeled by polynomial time terms,
    and cross coupling between time and state variables.

    Parameters:
        - x0: time t
        - x1: position at time t
        - x2: velocity at time t
        - params: array of 12 trainable coefficients

    Returns:
        Acceleration y as a numpy array.
    """

    return (
          params[0]                         # constant offset / bias term
        + params[1] * x0                    # linear in time forcing / parametric excitation
        + params[2] * (x0 ** 2)             # quadratic in time term for slow modulation effects
        + params[3] * (x0 ** 3)             # cubic in time term for higher order modulation
        + params[4] * x1                    # linear restoring force (-k*x)
        + params[5] * (x1 ** 3)              # cubic stiffness nonlinearity (-α*x³)
        + params[6] * x2                    # linear damping (-c*v)
        + params[7] * (x1 * x2)               # coupling between position and velocity 
        + params[8] * np.sin(x0)           # fundamental harmonic forcing term
        + params[9] * np.cos(x0)           # fundamental harmonic cosine forcing term for phase shift effects
        + params[10] * np.sin(2*x0)         # second harmonic sine forcing term for richer external excitation
        + params[11] * np.cos(2*x0)         # second harmonic cosine forcing term for phase shift effects at second harmonic
    )
