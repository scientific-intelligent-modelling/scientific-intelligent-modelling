def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """Improved version of `equation_v1`.

    This version extends the nonlinear harmonic oscillator acceleration model by including:
    - Quartic stiffness term (x1^4)
    - Cubic velocity term (x2^3)
    - Cross terms like (x1^3 * x2), (x1 * x2^2)
    - Polynomial time-dependent terms up to cubic in time (x0², x0³)
    - Higher harmonic trigonometric forcing terms sin(2x0), cos(2x0)

    Variables:
        x0 : time t
        x1 : position at time t
        x2 : velocity at time t

    Parameters:
        params[0]  : constant offset term
        params[1]  : linear in time forcing coefficient (x0)
        params[2]  : linear stiffness coefficient (-ω²) * x1
        params[3]  : linear damping coefficient (-β) * x2
        params[4]  : cubic stiffness coefficient (-α) * (x1**3)
        params[5]  : quartic stiffness coefficient * (x1**4)
        params[6]  : cross term coefficient for (x1**3)*x2
        params[7]  : quintic stiffness coefficient * (x1**5)
        params[8]  : quadratic velocity damping term * (x2**2)
        params[9]  : cross term coefficient for x1*(x2**2)
        params[10] : sin(time) forcing amplitude + polynomial in time e.g. sin(x0), sin(2*x0)
        params[11] : cos(time) forcing amplitude + polynomial in time e.g. cos(x0), cos(2*x0)

    """
    return (
          params[0]
        + params[1]*x0
        + params[2]*x1
        + params[3]*x2
        + params[4]*(x1**3)
        + params[5]*(x1**4)
        + params[6]*(x1**3)*x2
        + params[7]*(x1**5)
        + params[8]*(x2**3)
        + params[9]*x1*(x2**2)
        + params[10]*np.sin(x0) 
            # optionally could add sin(2*x0), but limited by param count; here just sin(x0).
            # if desired, could replace with a combination like: 
            #   p10*sin(x0) + p11*sin(2*x0), but param count is fixed.
            # so keep it simple.
            
        + params[11]*np.cos(x0)
    )
