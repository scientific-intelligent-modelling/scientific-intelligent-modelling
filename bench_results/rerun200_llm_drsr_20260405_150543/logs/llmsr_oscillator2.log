        p[8] * (x1 * x2) +            # cross product nonlinearity
        
        p[9] * np.abs(x2) +           # absolute value of velocity for friction-like effect
        
        p[10] * np.sign(x2) +         # sign function for dry friction effect
        
        p[11] * np.cos(x0)            # another periodic forcing component
    )
