def equation(x0: np.ndarray, x1: np.ndarray, x2: np.ndarray, params: np.ndarray) -> np.ndarray:
    """Equation to be evolved.

    Background:
    Calculate Acceleration in Nonl-linear Harmonic Oscillator given Time, Position at time t and Velocity at time t

    Variables:
    - Independents: x0, x1, x2
- Dependent: y

    Parameters:
    - params (np.ndarray): Trainable coefficients used by the equation skeleton.
    """
    """
    Improved version of `equation_v1` with additional nonlinear interaction terms 
    and explicit periodic forcing terms.

    Background:
    Calculate Acceleration in Nonlinear Harmonic Oscillator given Time (x0), Position (x1), and Velocity (x2).

    Variables:
    - Independents: x0 (time), x1 (position), x2 (velocity)
    - Dependent: y (acceleration)

    Parameters:
    - params (np.ndarray): Trainable coefficients [p0,...p15]

    Model form:
        y ≈ p0 
          + p1 * t 
          + p11 * t^2
          + p12 * sin(t)
          + p13 * cos(t)
          + p14 * v * sin(t)
          + p15 * v * cos(t)
          + p2 * x 
          + p4 * x^3 
          + p7 * x^5
          + p3 * v 
          + p5 * v^2 
          + p8 * v^3
          + p6 * x*v 
          + p9 * x^2*v
          + p10* x*v^2
          + p16* x^3*v  # optional if param available
          
    Note: If fewer parameters are provided, the last terms can be omitted accordingly.
    
    """
    
    # Ensure params length for optional terms
    n = len(params)
    
    # Base terms from equation_v1 plus new ones:
    
    result = (
        params[0]  # constant term
        + params[1] * x0  # linear time dependence
        + params[11] * (x0 ** 2)  # quadratic time dependence
        
        + params[2] * x1  # linear position term (restoring force)
        + params[4] * (x1 ** 3)  # cubic position nonlinearity
        + params[7] * (x1 ** 5)  # quintic position nonlinearity
        
        + params[3] * x2  # linear velocity term (damping)
        + params[5] * (x2 ** 2)  # quadratic velocity nonlinearity
        + params[8] * (x2 ** 3)  # cubic velocity nonlinearity
        
        + params[6] * (x1 * x2)  # cross term between position and velocity
        + params[9] * ((x1 ** 2) * x2)  # mixed nonlinear term: position squared times velocity
        + params[10] *(x1 *(x2 ** 2))   # mixed nonlinear term: position times velocity squared
    )
    
    if n > 12:
        result += params[12]*np.sin(x0)   # sinusoidal forcing in time
    
    if n >13:
        result += params[13]*np.cos(x0)   # cosine forcing in time
    
    if n >14:
        result += params[14]*x2*np.sin(x0)   # velocity modulated by sine(time)
        
    if n >15:
        result += params[15]*x2*np.cos(x0)   # velocity modulated by cosine(time)

    if n >16:
        result += params[16]*(x1**3)*x2      # higher order mixed nonlinearity

    return result
