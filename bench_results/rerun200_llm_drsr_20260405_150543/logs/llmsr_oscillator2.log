          +a9 * np.power(x2,3)               # cubic velocity damping effect on acceleration
          +a6 * x1*x2                       # coupling between position and velocity terms
          +a10* x0*x2                       # coupling between time and velocity terms
          +a11* x0*x1                       # coupling between time and position terms
